#!/usr/bin/env bash
# Git pre-push hook — 圖譜健康同步把關(push 前最後一道,同步可見)
#
# 為什麼需要:
#   L2 pre-commit 只擋「污染指紋 + code 無圖譜」,不跑完整 doctor。
#   壞圖譜狀態(斷連結 / orphan / verified_by 漏寫 / plan_refs 斷鏈)能 commit 過。
#   CI push 觸發雖會抓,但**非同步、終端看不到、擋不了**(push 已發生)。
#   pre-push 在 push 前**同步**跑 lumos doctor:Claude Code / 終端當場看到輸出,
#   有問題擋下 push,壞圖譜出不了本機。self-contained(lumos 零 Obsidian 依賴)。
#
# Bypass: git push --no-verify(業界標準,code review / CI 仍會抓)
#
# 安裝: scripts/install-hooks.sh 已設 core.hooksPath=scripts/hooks,此檔放進去即生效

set -u

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$REPO_ROOT" || exit 0

# ── stdin 必須最先讀(prepush範圍修法 #1)──
# githooks(5):每行 "<local_ref> <local_sha> <remote_ref> <remote_sha>"。
# 先整批讀進陣列——後段的 anchor verify/測試/doctor 都是 subprocess,會繼承並吃掉 fd0,
# 若不先讀,推送範圍就丟了。無 stdin 行(如手動測試)=空陣列,代碼風險段自然跳過。
_PP_LINES=()
while IFS= read -r _line; do
  [[ -n "$_line" ]] && _PP_LINES+=("$_line")
done

# 無 lumos / python3 → 降級放行(不為缺環境 brick push,CI 兜底)
GRAPHCTL="$REPO_ROOT/scripts/lumos"
PY="$(command -v python3 || command -v python || true)"
if [[ -z "$PY" || ! -f "$GRAPHCTL" ]]; then
  echo "pre-push: 無 python3 或 lumos,跳過圖譜巡檢(CI 仍會抓)" >&2
  exit 0
fi

# 錨點完整性:驗證器(runner/hooks)沒被動過,後面的「doctor 過/測試綠」才可信(repo 層,vault 無關)
if ! "$PY" "$GRAPHCTL" anchor verify; then
  {
    echo ""
    echo "🚫 pre-push: anchor verify 失敗——驗證器檔案與 baseline 不符,push 已擋下"
    echo ""
    echo "請選一條:"
    echo "  1. 非刻意改動 → git checkout 還原錨點檔後重 push"
    echo "  2. 刻意改錨點 → lumos anchor approve --note \"理由\" 後重 push"
    echo "  3. 確屬可接受 → git push --no-verify(留 PR diff 與缺 approve 事件的對帳痕)"
    echo ""
  } >&2
  exit 1
fi

# 測試套件閘(僅 Lumos 源 repo;2026-07-07):紅測試兩度溜進 main(pre-push 原只跑 doctor 不跑測試)。
# 事件點修法:push 前全量跑一次(實測 ~32s)。消費專案不跑——skills/ 只存在於源 repo(不 vendor),
# 消費端自己的測試歸自己的 CI/hooks 管,lumos 不越俎。逃生:git push --no-verify(自負)。
if [[ -d "$REPO_ROOT/skills/lumos-project-notes" && -f "$REPO_ROOT/scripts/test_lumos.py" ]]; then
  echo "pre-push: 跑 test_lumos.py 全量(源 repo 測試閘,~32s)…" >&2
  if ! "$PY" "$REPO_ROOT/scripts/test_lumos.py" >/tmp/lumos-prepush-tests.log 2>&1; then
    {
      echo ""
      echo "🚫 pre-push: test_lumos.py 有紅——push 已擋下(完整輸出: /tmp/lumos-prepush-tests.log)"
      tail -15 /tmp/lumos-prepush-tests.log | sed 's/^/    /'
      echo ""
      echo "請選一條:"
      echo "  1. 修到綠再 push(正途)"
      echo "  2. 確屬可接受(如 flaky/環境因素) → git push --no-verify(自負)"
      echo ""
    } >&2
    exit 1
  fi
  tail -1 /tmp/lumos-prepush-tests.log >&2
fi

# 代碼偏科 + code-loop 必用守衛(tier=high):push 前把 diff 的代碼形態風險攤在眼前。
# prepush範圍修法(2026-07-21):改讀 stdin 推送範圍逐 ref 判,取代 merge-base——分支與
# main-direct 同軌;無基準(新 ref/缺物件)倒向保守掃 empty-tree..local_sha(非 fail-open,
# 否則守衛升格成穩定繞法);留痕綁 remote_ref 目的地(非 checkout);逐 ref 獨立判,某 ref
# high 未過即擋。fail-open 僅剩:pitfalls 本身出錯 / empty-tree 都跑不動。
_ZERO="0000000000000000000000000000000000000000"
_EMPTY_TREE="$(git hash-object -t tree /dev/null 2>/dev/null || true)"
for _ppl in ${_PP_LINES+"${_PP_LINES[@]}"}; do
  read -r _lref _lsha _rref _rsha <<< "$_ppl"
  # 刪除遠端 ref(local_sha 全零)→ 無代碼推送,跳過
  [[ "$_lsha" == "$_ZERO" ]] && continue
  # 推導檢查範圍
  _range=""
  if [[ "$_rsha" == "$_ZERO" ]]; then
    # 新 ref(含首推 main:遠端無此 ref)→ 保守掃全部引入內容
    _range="$_EMPTY_TREE..$_lsha"
  elif ! git cat-file -e "$_rsha" 2>/dev/null; then
    # remote_sha 本地無此物件(shallow/force-push 分岔未 fetch)→ 保守掃
    _range="$_EMPTY_TREE..$_lsha"
  else
    # 一般情形:增量 endpoint diff
    _range="$_rsha..$_lsha"
  fi
  [[ -z "$_EMPTY_TREE" ]] && continue   # 連空樹都算不出=git 環境壞,advisory 放行

  pf_json="$("$PY" "$GRAPHCTL" pitfalls --diff "$_range" --no-lint --json --repo "$REPO_ROOT" 2>/dev/null || true)"
  if printf '%s' "$pf_json" | grep -q '"tier": *"high"'; then
    {
      echo ""
      echo "⚠ pre-push:$_rref tier=high(代碼形態風險命中 $_range,見下)"
      "$PY" "$GRAPHCTL" pitfalls --diff "$_range" --no-lint --repo "$REPO_ROOT" 2>/dev/null | sed 's/^/    /'
      echo ""
    } >&2
    # 留痕座標綁 remote_ref 目的地:refs/heads/* → 分支硬擋+skip 逃生;非 heads → advisory
    if [[ "$_rref" == refs/heads/* ]]; then
      _rbranch="${_rref#refs/heads/}"
      cl_rc=0
      "$PY" "$GRAPHCTL" code-loop check --diff "$_range" --at-sha "$_lsha" --branch "$_rbranch" \
        --repo "$REPO_ROOT" >/dev/null 2>&1 || cl_rc=$?
      if [[ "$cl_rc" -eq 1 ]]; then
        {
          echo "🚫 pre-push: $_rref tier=high 代碼未過 code-loop → push 已擋下"
          echo ""
          echo "請選一條:"
          echo "  1. 跑 lumos-code-loop 終審 → 收斂後重 push"
          echo "  2. 確屬可接受(假陽/刻意略過) → lumos code-loop skip --note \"<理由>\" → 重 push(留痕)"
          echo "  3. 緊急繞過 → git push --no-verify(自負、無痕)"
          echo ""
        } >&2
        exit 1
      fi
      # rc=0(已收斂/skip):放行;rc≠0/1(異常):fail-open 放行
    else
      # 非分支 remote_ref(tag/其他 namespace):無 branch marker 通道,high 亦 advisory
      echo "💡 pre-push: $_rref 非分支 ref、tier=high——advisory 放行(tag 內容 gate 另訂策略)" >&2
    fi
  elif printf '%s' "$pf_json" | grep -q '"stack_questions": *{"'; then
    {
      echo ""
      echo "💡 pre-push:$_rref 棧別效能檢核(advisory,不擋;終審留痕請含答案)"
      "$PY" "$GRAPHCTL" pitfalls --diff "$_range" --no-lint --repo "$REPO_ROOT" 2>/dev/null | sed 's/^/    /'
      echo ""
    } >&2 || true
  fi
  # test-layers 軟提醒(advisory,恆不影響 rc;無 .lumos/test-layers.json 靜默)
  "$PY" "$GRAPHCTL" test-layers --diff "$_range" --repo "$REPO_ROOT" 2>/dev/null || true
done

# 只在 vault 存在時跑
have_vault=0
for d in docs/*-knowledge docs/knowledge; do
  [[ -d "$d" ]] && have_vault=1 && break
done
[[ $have_vault -eq 0 ]] && exit 0

if "$PY" "$GRAPHCTL" doctor --ci; then
  exit 0
fi

{
  echo ""
  echo "🚫 pre-push: lumos doctor 發現圖譜問題(見上方),push 已擋下"
  echo ""
  echo "請選一條:"
  echo "  1. 修圖譜(補連結 / verified_by / plan_refs…)後重 push"
  echo "  2. 確認非真問題(疑 lumos bug)→ 走並跑期裁決協議"
  echo "     (lumos_計劃 §11:本地重現 → 讀 finding → Check1-3 可用 bash 裁決)"
  echo "  3. 確屬可接受 → git push --no-verify(CI 仍會抓,留審計)"
  echo ""
} >&2
exit 1
