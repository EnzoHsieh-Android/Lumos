  if(playTimer){ clearInterval(playTimer); playTimer=null; tp.textContent='▶'; return; }
  tp.textContent='⏸'; let i=(+tr.value>=dates.length-1)?0:+tr.value;
  tr.value=i; setCut(i);
  playTimer=setInterval(()=>{
    i++; if(i>=dates.length){ clearInterval(playTimer); playTimer=null; tp.textContent='▶'; return; }
    tr.value=i; setCut(i);
  }, 380);
};

// ---- legend ----
