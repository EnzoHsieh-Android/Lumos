    p = sub.add_parser("bootstrap", help="一鍵裝好一切(自動 clone Lumos + skills + 全域 + repo hooks)")
    p.add_argument("--lumos-url", help="Lumos repo URL(預設公開 repo / $LUMOS_URL)")
    p.add_argument("--lumos-home", help="Lumos clone 目標(預設 ~/harness/lumos-toolchain / $LUMOS_HOME)")
    p.add_argument("--pull", action="store_true", help="既有 Lumos clone 也 git pull 拉最新(預設沿用)")
    p = sub.add_parser("init", help="在當前 repo 初始化圖譜(建資料夾+.gitignore,預設並裝 pre-commit/pre-push 閘)")
    p.add_argument("--name", help="vault slug(預設 = repo 資料夾名小寫)")
    p.add_argument("--force", action="store_true", help="既有 vault 也重裝/更新 hooks 與工具組(vault 內容不動)")
    p.add_argument("--no-hooks", action="store_true", help="只建圖譜,不 vendor 工具/不裝 hooks(輕量版)")
    p.add_argument("--no-pull", action="store_true", help="vendor 工具時不 git pull 來源")
    p = sub.add_parser("deinit", help="專案層反安裝(對稱 init):拆本 repo 的 hooks/工具組/CLAUDE.md 注入/圖譜")
    p.add_argument("--keep-graph", action="store_true", help="保留圖譜 vault,其餘照拆")
    p.add_argument("--dry-run", action="store_true", help="只印會動到什麼,不實際改動")
    p.add_argument("-y", "--yes", action="store_true", help="跳過互動確認(CI/非互動用)")
    p.add_argument("--source", help="Lumos 來源 repo 路徑(僅供自我保護比對)")

    p = sub.add_parser("fold-check", help="折入後一致性複查(vault-free):列舉鏡像段 + value-drift/reverse-omission flag")
    p.add_argument("path", help="要核對的 markdown 檔路徑")
    p.add_argument("--json", dest="as_json", action="store_true", help="JSON 輸出(供機器讀)")

    p = sub.add_parser("refcheck", help="spec 指涉宣稱確定性核對(vault-free):inline-code 路徑/行號 → 存在性 manifest")
    p.add_argument("md", help="要核對的 markdown 檔")
    p.add_argument("--repo", dest="refcheck_repo", help="repo root(預設 cwd 逐層向上找 .git)")
    p.add_argument("--json", dest="as_json", action="store_true", help="輸出 JSON manifest")

    p = sub.add_parser("impact", help="動手前算出哪些知識圖譜節點會被 code 改動波及")
    p.add_argument("--file", dest="impact_file", help="被改動的 code 檔路徑(單檔模式;與 --diff/--node 三擇一)")
    p.add_argument("--node", dest="impact_node", help="[M4/S2] typed hop-1 第三模式:列「誰以 verified_by/plan_refs 指向該節點」(單層;與 --depth 互斥)")
    p.add_argument("--diff", dest="impact_diff", help="diff range(如 main..HEAD):聚合各改動檔的 ranked impact 成受影響功能面 manifest(code-loop 審計鏡頭)")
    p.add_argument("--sync-check", action="store_true", dest="impact_sync",
                   help="落成核對(配 --diff):預期受影響節點 vs 分支實際動過節點 → 未同步清單(advisory)")
    p.add_argument("--repo", dest="impact_repo", help="repo root(缺則退回 find_vault;hook 必傳)")
    p.add_argument("--depth", dest="impact_depth", type=int, default=None, help="BFS 展開深度(缺省讀 .lumos/impact.json;最終預設 2)")
    p.add_argument("--json", dest="impact_json", action="store_true", help="JSON 輸出(機器可讀)")
    p.add_argument("--ranked", action="store_true", dest="impact_ranked", help="融合排序+固定席+降噪(dormant v1)")
    p.add_argument("--top", type=int, dest="impact_top", default=8, help="--ranked 非固定項上限")
    p.add_argument("--min-score", type=float, dest="impact_min", default=0.20, help="--ranked 分數底線")
    p.add_argument("--stdin-payload", action="store_true", dest="impact_stdin", help="stdin 讀 {query,prospective}")
    p.add_argument("--incidents-only", action="store_true", dest="impact_inc_only", help="只跑事故比對(不反查/BFS)")

    p = sub.add_parser("pitfalls", help="實務隱患提問(vault-free):spec 逼答隱患 / --diff 攤代碼風險位置")
    p.add_argument("md", nargs="?", help="spec md 檔(spec 模式)")
    p.add_argument("--diff", dest="pf_diff", help="diff range(如 main..HEAD;diff 模式)")
    p.add_argument("--repo", dest="pf_repo", help="repo root(預設 cwd 向上找 .git)")
    p.add_argument("--check", action="store_true", help="命中風險類且無「## 實務隱患」節 → rc 1")
    p.add_argument("--json", dest="pf_json", action="store_true", help="JSON 輸出")
    p.add_argument("--no-lint", dest="pf_no_lint", action="store_true", help="--diff 只跑 regex 層、不跑專案 lint 指令(快,給 pre-push advisory)")

    p = sub.add_parser("test-layers", help="測試層軟提醒(vault-free,恆 rc0):diff 命中 .lumos/test-layers.json 宣告棧 → 提醒該跑的測試層")
    p.add_argument("--diff", dest="tl_diff", help="diff range(如 main..HEAD)")
    p.add_argument("--repo", dest="tl_repo", help="repo root(預設 cwd 向上找 .git)")
    p.add_argument("--json", dest="tl_json", action="store_true", help="JSON 輸出")

    p = sub.add_parser("lint-check", help="檢查 .lumos/lint.json 宣告健康度(收『宣告了跑不動的東西』破口):靜態格式校驗 + --smoke 真跑冒煙")
    p.add_argument("--repo", dest="lc_repo", help="repo root(預設 cwd 向上找 .git)")
    p.add_argument("--smoke", dest="lc_smoke", action="store_true", help="真跑每條宣告命令、驗有無產出可解析 SARIF(抓 task 不存在/工具沒裝的空殼)")
    p.add_argument("--json", dest="lc_json", action="store_true", help="JSON 輸出")

    p = sub.add_parser("sqlfluff-sarif", help="sqlfluff --format json(stdin)→ SARIF v2.1(橋接 SQL linter 進 lint-adapter)")
    p.add_argument("--out", dest="sqlfluff_out", help="輸出 SARIF 檔路徑(預設 stdout)")

    p = sub.add_parser("stylelint-sarif", help="stylelint --formatter json(stdin)→ SARIF v2.1(橋接 CSS/SCSS linter 進 lint-adapter)")
    p.add_argument("--out", dest="stylelint_out", help="輸出 SARIF 檔路徑(預設 stdout)")

    p = sub.add_parser("anchor", help="錨點完整性(vault-free):測試 runner/把關 hooks 的 sha256 baseline")
    asub = p.add_subparsers(dest="anchor_cmd", required=True)
    av = asub.add_parser("verify", help="比對錨點 sha256 vs baseline;不符 rc=1(baseline 不存在 rc=0+警示)")
    av.add_argument("--repo", dest="anchor_repo", help="repo root(預設 cwd 逐層向上找 .git)")
    av.add_argument("--json", dest="as_json", action="store_true", help="輸出 JSON")
    aa = asub.add_parser("approve", help="重算錨點 hash 寫回 baseline + governance-log 留痕(改錨點的合法路徑)")
    aa.add_argument("--repo", dest="anchor_repo", help="repo root(預設 cwd 逐層向上找 .git)")
    aa.add_argument("--note", required=True, help="一句話理由(必填,進留痕)")

    p = sub.add_parser("lint-watch", help="依賴版本落差掃描(vault-free):讀 .lumos/lint-watch.json 對比 registry 最新版")
    p.add_argument("--repo", dest="lint_watch_repo", default=".", help="repo root(含 .lumos/lint-watch.json 的資料夾,預設 .)")
    p.add_argument("--json", action="store_true", dest="as_json", help="輸出 JSON manifest")

    p = sub.add_parser("compose-metrics", help="Compose 可組合指標回歸掃描(vault-free):讀 .lumos/compose-metrics.json 比對 baseline")
    p.add_argument("--repo", dest="compose_metrics_repo", default=".", help="repo root(含 .lumos/compose-metrics.json 的資料夾,預設 .)")
    p.add_argument("--json", action="store_true", dest="as_json", help="輸出 JSON manifest")
    p.add_argument("--update-baseline", action="store_true", help="以現況更新 baseline(跳過解析失敗模組)")
    p.add_argument("--audit", action="store_true", help="無視 baseline,盤點當下全部 non-skippable composable(初次採用/現況全景)")

    cc = sub.add_parser("cochange", help="co-change 漏改守衛(vault-free):git 歷史挖共改規則,commit 時警告漏改夥伴(advisory)")
    ccsub = cc.add_subparsers(dest="cccmd", required=True)
    ccr = ccsub.add_parser("rules", help="列告警規則集(預設套 config 門檻;--all 解除 confidence 門檻)")
    ccr.add_argument("--all", action="store_true", dest="coch_all",
                     help="解除 confidence 門檻(support 硬底線 2 仍全域生效)")
    ccr.add_argument("--repo", dest="coch_repo", default=None, help="repo root(預設 cwd 逐層向上找 .git)")
    ccr.add_argument("--json", action="store_true", dest="coch_json", help="輸出 JSON manifest")
    ccc = ccsub.add_parser("check", help="對變更集比對規則列漏改警告(advisory rc0;git 失敗 rc2)")
    ccc.add_argument("--staged", action="store_true", dest="coch_staged", help="變更集=git staged")
    ccc.add_argument("--diff", dest="coch_diff", default=None, metavar="A..B",
                     help="變更集=diff range(pre-resolved 兩點如 main..HEAD;與 --staged 同給時 --diff 優先)")
    ccc.add_argument("--repo", dest="coch_repo", default=None, help="repo root(預設 cwd 逐層向上找 .git)")
    ccc.add_argument("--json", action="store_true", dest="coch_json", help="輸出 JSON manifest")

    cl = sub.add_parser("code-loop", help="code-loop 留痕(vault-free):pass/skip 收斂紀錄 + check 查詢")
    clsub = cl.add_subparsers(dest="clcmd", required=True)
    for _clname, _clhelp in (
        ("pass", "記錄本分支 HEAD 已過 code-loop 收斂(status=passed)"),
        ("skip", "顯式跳過 code-loop 並留痕(status=skipped;同 bypass 哲學)"),
        ("check", "跑判定式:tier=high∧無有效留痕→rc1 blocked;--json 輸出 verdict dict"),
    ):
        _clp = clsub.add_parser(_clname, help=_clhelp)
        if _clname in ("pass", "skip"):
            _clp.add_argument("--note", default="", help="理由(pass/skip 必填習慣;進治理帳)")
        if _clname == "check":
            _clp.add_argument("--json", dest="cl_json", action="store_true",
                              help="以 JSON 輸出 verdict dict{blocked,reason,tier}")
        _clp.add_argument("--repo", dest="cl_repo", default=None,
                          help="repo root(預設 cwd 逐層向上找 .git)")

    args = ap.parse_args()

    # install/uninstall/update/bootstrap 不需要 Env(vault),先處理
    if args.cmd == "install":
        return cmd_install(force=args.force)
    if args.cmd == "uninstall":
        return cmd_uninstall()
    if args.cmd == "update":
        return cmd_update(source=args.source, no_pull=args.no_pull)
    if args.cmd == "bootstrap":
        return cmd_bootstrap(lumos_url=args.lumos_url, lumos_home=args.lumos_home, pull=args.pull)
    if args.cmd == "init":
        return cmd_init(name=args.name, force=args.force,
                        with_hooks=not args.no_hooks, no_pull=args.no_pull)
    if args.cmd == "deinit":
        return cmd_deinit(keep_graph=args.keep_graph, dry_run=args.dry_run,
                          yes=args.yes, source=args.source)
    if args.cmd == "fold-check":
        return cmd_fold_check(args.path, as_json=args.as_json)
    if args.cmd == "refcheck":
        return cmd_refcheck(args.md, repo=args.refcheck_repo, as_json=args.as_json)
    if args.cmd == "pitfalls":
        return cmd_pitfalls(md=args.md, diff=args.pf_diff, repo=args.pf_repo,
                            check=args.check, as_json=args.pf_json, no_lint=args.pf_no_lint)
    if args.cmd == "test-layers":
        return cmd_test_layers(diff=args.tl_diff, repo=args.tl_repo, as_json=args.tl_json)
    if args.cmd == "lint-check":
        return cmd_lint_check(repo=args.lc_repo, smoke=args.lc_smoke, as_json=args.lc_json)
    if args.cmd == "impact":
        if sum(1 for x in (args.impact_file, args.impact_diff, args.impact_node) if x) > 1:
            print("ERROR: --file/--diff/--node 三擇一,不可同給", file=sys.stderr)
            return 2
        if args.impact_node:
            if args.impact_depth is not None:
                print("ERROR: --node 為單層 typed 列舉,與 --depth 互斥(無深度語意)", file=sys.stderr)
                return 2
            return cmd_impact_node(args.impact_node, repo=args.impact_repo, as_json=args.impact_json)
        if args.impact_diff:
            return cmd_impact_diff(args.impact_diff, repo=args.impact_repo,
                                   depth=args.impact_depth, top=args.impact_top,
                                   min_score=args.impact_min, as_json=args.impact_json,
                                   sync_check=args.impact_sync)
        if not args.impact_file:
            print("ERROR: impact 需要 --file <檔> 或 --diff <range>", file=sys.stderr)
            return 2
        return cmd_impact(args.impact_file, repo=args.impact_repo,
                          depth=args.impact_depth, as_json=args.impact_json,
                          ranked=args.impact_ranked, top=args.impact_top,
                          min_score=args.impact_min, stdin_payload=args.impact_stdin,
                          incidents_only=args.impact_inc_only)
    if args.cmd == "sqlfluff-sarif":
        return cmd_sqlfluff_sarif(out=args.sqlfluff_out)
    if args.cmd == "stylelint-sarif":
        return cmd_stylelint_sarif(out=args.stylelint_out)
    if args.cmd == "anchor":
        if args.anchor_cmd == "verify":
            return cmd_anchor_verify(repo=args.anchor_repo, as_json=args.as_json)
        return cmd_anchor_approve(repo=args.anchor_repo, note=args.note, vault=args.vault)
    if args.cmd == "lint-watch":
        return _lint_watch_mode(args.lint_watch_repo, args.as_json)
    if args.cmd == "compose-metrics":
        return _compose_metrics_mode(args.compose_metrics_repo, args.as_json, args.update_baseline, args.audit)
    if args.cmd == "cochange":
        if args.cccmd == "rules":
            return cmd_cochange_rules(repo=args.coch_repo, show_all=args.coch_all,
                                      as_json=args.coch_json)
        return cmd_cochange_check(repo=args.coch_repo, staged=args.coch_staged,
                                  diff_range=args.coch_diff, as_json=args.coch_json)
    if args.cmd == "code-loop":
        note = getattr(args, "note", None) or ""
        cl_json = getattr(args, "cl_json", False)
        return cmd_code_loop(args.clcmd, note=note, repo=args.cl_repo, as_json=cl_json)
    if args.cmd == "loop" and args.lcmd == "capture-counts":
        # 純機械原語(不碰圖譜):跨異質 finder 算 capture-recapture 重疊,vault-free
        return cmd_loop_capture_counts(None, args.finders,
                                       from_pitfalls=args.cc_pitfalls, repo=args.cc_repo)

    vault = args.vault or find_vault(Path.cwd())
    if vault is None or not vault.is_dir():
        print("ERROR: 找不到 vault (docs/*-knowledge),可用 --vault 指定", file=sys.stderr)
        return 2
    env = Env(vault)

    if args.cmd == "doctor":
        color = sys.stdout.isatty() and not args.ci
        return run_doctor(env, strict=(args.strict or args.ci), color=color, suggest=args.suggest, ci=args.ci)

    if args.cmd in ("links", "backlinks", "context", "map") or \
       (args.cmd == "decisions" and not args.superseded):
        rel = env.find(getattr(args, "note", None) or "")
        if rel is None:
            print(f"ERROR: 找不到筆記: {args.note}", file=sys.stderr)
            return 2
        if args.cmd == "links":
            return cmd_links(env, rel)
        if args.cmd == "backlinks":
            return cmd_links(env, rel, reverse=True)
        if args.cmd == "context":
            return cmd_context(env, rel, brief=args.brief, recommend=args.recommend, top=args.ctx_top, min_score=args.ctx_min, as_json=args.ctx_json)
        if args.cmd == "map":
            return cmd_map(env, rel, args.depth)
        return cmd_decisions(env, rel)

    if args.cmd == "search":
        # 2026-07-11 轉正:相關性排序為預設(goldset 評測 §6 search 面全過);
        # --legacy 逃生;--regex 自動走舊路(候選語意不同,靜默、不印 fallback note)
        _use_ranked = not args.search_legacy and not args.regex
        if args.ranked and args.regex:
            print("(--ranked 不適用 --regex 模式,照舊輸出)", file=sys.stderr)
        return cmd_search(env, args.term, path_prefix=args.path_prefix,
                          regex=args.regex, files_only=args.files_only,
                          include_code=args.code, ranked=_use_ranked, top=args.top,
                          as_json=args.search_json)

    if args.cmd == "contracts":
        rel = None
        if args.note:
            rel = env.find(args.note)
            if rel is None:
                print(f"ERROR: 找不到筆記: {args.note}", file=sys.stderr)
                return 2
        return cmd_contracts(env, rel)

    if args.cmd == "lint":
        return cmd_lint(env, args.note)

    if args.cmd == "spec-trace":
        return cmd_spec_trace(env, args.node, as_json=args.st_json)
    if args.cmd == "signoff":
        return cmd_signoff(env, args.node, note=args.note, by=args.by)
    if args.cmd == "gov":
        return cmd_gov(env, args.node, args.since)

    if args.cmd == "canary":
        return cmd_canary(env, args.kind, args.auditor, args.token, args.note, args.loop,
                          args.severity, findings=args.findings, round_id=args.round_id,
                          capture_counts=args.capture_counts, clusters=args.clusters)

    if args.cmd == "loop":
        if args.lcmd == "status":
            return cmd_loop_status(env, args.loop_id, args.need,
                                   gate=args.gate, spec=args.gate_spec, repo=args.gate_repo,
                                   panel=args.panel)
        # capture-counts 已在 vault-free 段提前處理(見上)

    if args.cmd == "guard":
        if args.gcmd == "list":
            return cmd_guard_list(env, unbound_only=args.unbound)
        if args.gcmd == "scaffold":
            return cmd_guard_scaffold(env, args.node, args.invariant, args.method,
                                      args.type, args.claim, out_dir=args.out,
                                      template=args.template, klass=args.klass,
                                      platform=args.platform)
        if args.gcmd == "bind":
            return cmd_guard_bind(env, args.node, args.invariant, args.method,
                                  platform=args.platform)
        if args.gcmd == "audit":
            return cmd_guard_audit(env, args.node, args.invariant, args.model, args.date)
        if args.gcmd == "kill-add":
            return cmd_guard_kill_add(env, args.node, args.invariant, file=args.file,
                                      old=args.old, new=args.new, test=args.test,
                                      platform=args.gk_platform, note=args.note)
        if args.gcmd == "kill":
            return cmd_guard_kill(env, args.node, invariant_substr=args.invariant,
                                  platform_override=args.gk_platform,
                                  as_json=args.gk_json, keep_worktree=args.keep_worktree)
        if args.gcmd == "trace":
            return cmd_guard_trace(env, args.node)

    if args.cmd == "sync-verified-by":
        return cmd_sync_verified_by(env, apply=args.apply)

    if args.cmd == "decisions":
        return cmd_decisions(env, superseded=True)
    if args.cmd == "stale":
        return cmd_stale(env, match=args.match, candidate=args.candidate)
    if args.cmd == "recent":
        return cmd_recent(env, args.days)
    if args.cmd == "stats":
        return cmd_stats(env)
    if args.cmd == "export":
        if args.format == "html":
            return cmd_export_html(env, args.output, standalone=args.standalone)
        return cmd_export(env, args.format, set(args.folders))

    if args.cmd == "self-audit":
        rel = env.find(args.node)
        if rel is None:
            print(f"ERROR: 找不到筆記: {args.node}", file=sys.stderr)
            return 2
        try:
            return cmd_self_audit(env, rel, args.model, args.date)
        except (ValueError, RuntimeError) as e:
            print(f"ERROR: {e}", file=sys.stderr)
            return 2

    # T1 寫側
    if args.cmd in ("set", "append"):
        rel = env.find(args.note)
        if rel is None:
            print(f"ERROR: 找不到筆記: {args.note}", file=sys.stderr)
            return 2
        try:
            if args.cmd == "set":
                return cmd_set(env, rel, args.key, args.value)
            return cmd_append(env, rel, args.key, args.value)
        except (ValueError, RuntimeError) as e:
            print(f"ERROR: {e}", file=sys.stderr)
            return 2
    if args.cmd == "new":
        import datetime
        try:
            return cmd_new(env, args.type, args.name, datetime.date.today().isoformat())
        except (ValueError, RuntimeError) as e:
            print(f"ERROR: {e}", file=sys.stderr)
            return 2
    if args.cmd == "rel-cascade":
        try:
            if args.verb in ("confirm", "prune"):
                missing = [f for f, v in (("<鄰居>", args.arg), ("--cascade-id", args.rc_cid),
                                          ("--from", args.rc_from), ("--edge", args.rc_edge),
                                          ("--by", args.rc_by)) if not v]
                if missing:
                    print(f"ERROR: rel-cascade {args.verb} 缺參數: {' '.join(missing)}", file=sys.stderr)
                    return 2
                return cmd_rel_cascade_write(env, args.verb, args.arg, args.rc_cid,
                                             args.rc_from, args.rc_edge, args.rc_by)
            if args.verb == "resume":
                if not args.arg:
                    print("ERROR: rel-cascade resume 需 <cascade-id>", file=sys.stderr)
                    return 2
                return cmd_rel_cascade_resume(env, args.arg)
            return cmd_rel_cascade_list(env, stale_days=args.rc_stale)
        except (ValueError, RuntimeError, OSError) as e:
            # [code-loop r1 B3] 含 OSError:磁碟滿/權限/TOCTOU 檔案消失/O_NOFOLLOW 拒 symlink
            #   ——帳本走檔案系統,IO 例外是本分支常態失敗面,裸 traceback 會破壞 rc=2 行式協議
            print(f"ERROR: {e}", file=sys.stderr)
            return 2

    if args.cmd == "decision-reindex" and getattr(args, "reindex_all", False):
        try:
            return cmd_decision_reindex(env, all_mode=True)
        except (ValueError, RuntimeError, OSError) as e:   # [code-loop r1 A] 寫檔面 IO 例外 → rc=2 非裸 traceback
            print(f"ERROR: {e}", file=sys.stderr)
            return 2

    if args.cmd in ("decision-supersede", "decision-add", "decision-reindex"):
        if args.cmd == "decision-reindex" and not args.note:
            print("ERROR: decision-reindex 需 <節點> 或 --all", file=sys.stderr)
            return 2
        rel = env.find(args.note)
        if rel is None:
            print(f"ERROR: 找不到筆記: {args.note}", file=sys.stderr)
            return 2
        try:
            # [M1/P2] 兩函式回 (rc, 全域決策id);dispatcher 解包,CLI 對外仍只回整數 rc
            #   (M4 [S1] 觸發端將在此用 decision_id 呼 cascade_surface——屆時包獨立 try/except)
            if args.cmd == "decision-reindex":
                return cmd_decision_reindex(env, rel)
            if args.cmd == "decision-supersede":
                rc, _decision_id = cmd_decision_supersede(env, rel, args.match, args.by, ended=args.ended)
                # [M4/S1] 觸發:supersede 成功→②建檔+③surfacing。②③同包獨立 try(不放上層
                #   atomic try 內——否則例外被 except 吞成 rc=2 違反 rc=0 合約,R8/T6)。
                #   輸出協議:supersede stdout 首行已印且逐字不變;cascade 面全走 stderr;
                #   失敗 fail-open(stderr 記 CASCADE-ERROR、rc 仍 0、補網 E2 兜底)。
                if rc == 0:
                    try:
                        if _decision_id:
                            _cid = rel_cascade_create(env, _decision_id, rel)
                            print(f"CASCADE {_cid} ROOT {_decision_id}", file=sys.stderr)
                            _n = cascade_surface(env, rel, _decision_id, stream=sys.stderr)
                            if not _n:
                                print("CASCADE-EMPTY 無 typed 連入鄰居(本次翻案無已知依賴面)", file=sys.stderr)
                        else:
                            print("CASCADE-SKIP 決策無 id(節點未 reindex),本次不開 cascade;補網 E2 兜底", file=sys.stderr)
                    except Exception as _e:   # fail-open:決策寫入已 atomic 完成,不回滾
                        print(f"CASCADE-ERROR {_e}", file=sys.stderr)
                return rc
            rc, _decision_id = cmd_decision_add(env, rel, args.content, args.decided,
                                                context=args.context, why=args.why)
            return rc
        except (ValueError, RuntimeError, OSError) as e:   # [code-loop 最終 delta A] 補 OSError:
            # 單節點 decision-supersede/add/reindex 皆走 atomic_write_verify 寫檔,IO 例外(磁碟滿/
            # 權限/BrokenPipe)本該 rc=2 非裸 traceback——與 --all/rel-cascade dispatcher 一致
            print(f"ERROR: {e}", file=sys.stderr)
            return 2
    if args.cmd == "archive":
        import datetime
        return cmd_archive(env, args.days, args.apply, datetime.date.today().isoformat())
    return 2


if __name__ == "__main__":
    sys.exit(main())
