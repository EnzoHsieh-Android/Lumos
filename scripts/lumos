    p = sub.add_parser("search", help="全文搜尋(frontmatter+body);取代 obsidian search")
    p.add_argument("term")
    p.add_argument("--path", dest="path_prefix", help="限資料夾前綴(如 Systems)")
    p.add_argument("--regex", action="store_true", help="term 當正則(預設 substring 大小寫不敏感)")
    p.add_argument("--files-only", action="store_true", help="只列檔名+命中數")
    p.add_argument("--code", action="store_true", help="含 code block(預設排除,對齊 doctor)")
    p.add_argument("--ranked", action="store_true", help="BM25F 相關性排序(2026-07-11 起已是預設,旗標保留相容)")
    p.add_argument("--legacy", action="store_true", dest="search_legacy",
                   help="舊行為:字母序+全量輸出(轉正前預設;--regex 自動走此路)")
    p.add_argument("--top", type=int, default=0, help="相關性排序輸出上限(0=全量,預設;圖譜先行不靜默截斷)")
    p.add_argument("--json", dest="search_json", action="store_true", help="相關性排序 JSON manifest")

    p = sub.add_parser("map", help="鄰域樹狀展開")
