  +'<div class="row"><span class="ed" style="border-color:#4fd6a8"></span>verified_by</div>';
setTimeout(()=>{const h=document.getElementById('hint');if(h)h.style.opacity=0;},7000);
</script>
</body>
</html>"""


def _html_model(env):
    """蒐集語意模型給 HTML 視圖:nodes(含 type/status/合約/stale/raw)+ typed edges。"""
    out_e, in_e = env.edges
    nodes, edges, seen = [], [], set()
    for rel, n in env.notes.items():
        inv, debt = extract_contracts(n)
        summ = n.fields.get("summary")
        summ = summ if isinstance(summ, str) else ""
        status = status_of(env, rel)
        ntype = n.fields.get("type")
        ntype = ntype if isinstance(ntype, str) and ntype else rel.split("/")[0].lower()
        try:
            raw = (env.vault / rel).read_text(encoding="utf-8-sig")
        except Exception:
            raw = ""
        _dt = n.fields.get("date") or n.fields.get("created")
        nodes.append({
            "id": rel, "label": n.stem, "rel": rel, "type": ntype, "status": status,
            "folder": rel.split("/")[0], "inv": inv, "debt": debt,
            "date": str(_dt) if _dt else "",
            "indeg": len(set(in_e.get(rel, []))),
            "summary": [l.strip() for l in summ.split("\n") if l.strip()][:6],
            "raw": raw,
        })
    # typed edges: plan_refs / verified_by / link
    for rel, n in env.notes.items():
        plan = {env.resolve(link_target(x)) for x in as_list(n.fields.get("plan_refs"))}
        verify = {env.resolve(link_target(x)) for x in as_list(n.fields.get("verified_by"))}
        plan.discard(None); verify.discard(None)
        for d in set(out_e.get(rel, [])):
            kind = "plan" if d in plan else "verify" if d in verify else "link"
            key = (rel, d, kind)
            if key not in seen:
                seen.add(key)
                edges.append({"source": rel, "target": d, "kind": kind})
    return {"nodes": nodes, "edges": edges}


_VIZ_LIBS = {
    "3d-force-graph": ("https://cdn.jsdelivr.net/npm/3d-force-graph",
                       '<script src="https://cdn.jsdelivr.net/npm/3d-force-graph"></script>'),
    "marked": ("https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js",
               '<script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>'),
}
_FONT_LINKS = ('<link rel="preconnect" href="https://fonts.googleapis.com">\n'
               '<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>\n'
               '<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">')


def _fetch_text(url, cache):
    """下載文字資源並快取(scripts/vendor/)。離線重複 export 不再抓。
    用 curl(走系統憑證;macOS python urllib 常無 cert store 致 SSL verify 失敗)。"""
    import subprocess
    if cache.exists():
        return cache.read_text(encoding="utf-8")
    cache.parent.mkdir(parents=True, exist_ok=True)
    txt = subprocess.run(["curl", "-fsSL", url], capture_output=True, text=True,
                         timeout=60, check=True).stdout
    if not txt:
        raise RuntimeError("空回應")
    cache.write_text(txt, encoding="utf-8")
    return txt


def cmd_export_html(env, out_path, standalone=False):
    import json
    import datetime
    model = _html_model(env)
    # </script> 在嵌入 JSON 裡會提早關閉 <script> 標籤破壞整頁 → 轉義 </(標準作法)
    data = json.dumps(model, ensure_ascii=False).replace("</", "<\\/")
    stamp = datetime.date.today().isoformat()
    html = _HTML_TEMPLATE.replace("__DATA__", data).replace("__STAMP__", stamp) \
                         .replace("__VAULT__", env.vault.name) \
                         .replace("__NC__", str(len(model["nodes"]))) \
                         .replace("__EC__", str(len(model["edges"])))
    if standalone:
        # inline cytoscape/marked(去 CDN,防火牆/離線可開);字體退化系統字(移除 google link)
        vendor = Path(__file__).resolve().parent / "vendor"
        for name, (url, tag) in _VIZ_LIBS.items():
            try:
                src = _fetch_text(url, vendor / f"{name}.min.js").replace("</script", "<\\/script")
            except Exception as e:
                print(f"ERROR: --standalone 需抓 {name}(此機需一次網路): {e}", file=sys.stderr)
                return 2
            html = html.replace(tag, f"<script>{src}</script>")
        html = html.replace(_FONT_LINKS, "<!-- standalone: 字體退化系統字(無外部 CDN) -->")
    Path(out_path).write_text(html, encoding="utf-8")
    mode = "standalone(自包含/離線可開)" if standalone else "CDN"
    print(f"✓ export html [{mode}]: {out_path}  ({len(model['nodes'])} 節點 / {len(model['edges'])} 邊)")
    return 0


# ═══════════════════════ 階段三: 寫側 T1(行級手術) ═══════════════════════

SCALAR_KEYS = {"status", "updated", "created", "type", "self_audit", "signed_off", "regen"}
LIST_KEYS = {"verified_by", "plan_refs", "related", "tags"}
DATE_KEYS = {"updated", "created", "date", "decided", "ended"}
DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")


def fm_structure(fm_lines):
    """回傳 ordered [(key, start, end, kind)]，kind ∈ scalar/list/block。
    end = 該 key 區塊最後一行的 index(含)。"""
    out = []
    i, n = 0, len(fm_lines)
    while i < n:
        m = TOP_KEY_RE.match(fm_lines[i])
        if not m:
            i += 1
            continue
        key, val = m.group(1), m.group(2).strip()
        start = i
        if val in ("|", "|-", ">", ">-"):
            i += 1
            while i < n and (fm_lines[i].startswith("  ") or not fm_lines[i].strip()):
                i += 1
            out.append((key, start, i - 1, "block"))
        elif val == "":
            # 消費所有縮排行(含 list item 的 sub-mapping,如 decisions 的 content/decided),
            # 與 parse_frontmatter 一致 → fm_structure 算出的 end 涵蓋整個區塊(BUG-5 對齊)
            i += 1
            while i < n and (fm_lines[i].startswith(" ") or not fm_lines[i].strip()):
                i += 1
            out.append((key, start, i - 1, "list"))
        else:
            out.append((key, start, start, "scalar"))
            i += 1
    return out


def fmt_scalar(key, value):
    """純量值格式化。日期 bare(不加引號避污染指紋);含 ': ' 或特殊字元才引號。"""
    v = value.strip()
    if key in DATE_KEYS:
        if not DATE_RE.match(v):
            raise ValueError(f"{key} 需 YYYY-MM-DD,得到: {v}")
        return v  # bare,絕不加引號
    # YAML 型別劫持守衛: true/false/null/yes/no/~ 與純數字當 status 會被解析成 bool/num/null
    if v.lower() in ("true", "false", "null", "yes", "no", "on", "off", "~") or \
       re.fullmatch(r"-?\d+(\.\d+)?", v):
        return '"' + v + '"'
    if re.search(r":\s|^[\[\{>|*&!#@`]|^\s|\s$", v) or v == "":
        return '"' + v.replace('"', '\\"') + '"'
    return v


def fmt_list_item(value):
    """list 項格式化。wikilink / 含特殊字元 → 引號(鐵則1 安全:一項一行)。"""
    v = value.strip()
    if v.startswith("[[") or re.search(r":\s|^[\[\{]", v):
        return '"' + v.replace('"', '\\"') + '"'
    return v


def edit_fm_scalar(fm_lines, key, value):
    fm = list(fm_lines)
    formatted = fmt_scalar(key, value)
    struct = {k: (s, e, kind) for k, s, e, kind in fm_structure(fm)}
    if key in struct:
        s, e, kind = struct[key]
        if kind != "scalar":
            raise ValueError(f"{key} 是 {kind} 型,set 只改純量(list 用 append,巢狀用 T3)")
        fm[s] = f"{key}: {formatted}"
    else:
        # 插在開頭純量區之後(第一個 list/block key 之前,否則末尾)
        ins = len(fm)
        for k, s, e, kind in fm_structure(fm):
            if kind in ("list", "block"):
                ins = s
                break
        fm.insert(ins, f"{key}: {formatted}")
    return fm


def edit_fm_append(fm_lines, key, value):
    fm = list(fm_lines)
    item = fmt_list_item(value)
    tgt = link_target(value)
    struct = {k: (s, e, kind) for k, s, e, kind in fm_structure(fm)}
    if key in struct:
        s, e, kind = struct[key]
        if kind != "list":
            raise ValueError(f"{key} 是 {kind} 型,append 只加 list 項")
        # dedup: 精確 full-target 比對(保留路徑;非子字串、非 basename-only)
        for j in range(s + 1, e + 1):
            existing = fm[j].strip()
            if existing.startswith("-") and link_target(existing[1:]) == tgt:
                return fm  # 已存在,no-op
        # 偵測現有項縮排,否則預設 2 空格
        indent = "  "
        for j in range(s + 1, e + 1):
            if fm[j].lstrip().startswith("-"):
                indent = fm[j][:len(fm[j]) - len(fm[j].lstrip())]
                break
        # 插在最後一個非空行之後(避開區塊尾部空行,免在 list 中插出空行)
        last = e
        while last > s and not fm[last].strip():
            last -= 1
        fm.insert(last + 1, f"{indent}- {item}")
    else:
        ins = len(fm)
        fm.insert(ins, key + ":")
        fm.insert(ins + 1, f"  - {item}")
    return fm


def decisions_items(fm_lines):
    """surgical 定位 decisions[] 的每個項目行範圍(不重序列化,延伸 T1 到巢狀)。
    回傳 (block_start, block_end, [(item_start, item_end)], item_indent, sub_indent)
    或 None(無 decisions)。item_end 含,已去尾部空行。處理項目內含 nested 子清單。"""
    block = None
    for k, s, e, kind in fm_structure(fm_lines):
        if k == "decisions" and kind == "list":
            block = (s, e)
            break
    if block is None:
        return None
    s, e = block
    item_indent = None
    starts = []
    for i in range(s + 1, e + 1):
        ln = fm_lines[i]
        if not ln.strip():
            continue
        m = re.match(r"^(\s*)-\s", ln)
        if m:
            ind = len(m.group(1))
            if item_indent is None:
                item_indent = ind
            if ind == item_indent:  # 只認最淺層 dash(子清單的 dash 更深,不算項目)
                starts.append(i)
    items = []
    for idx, st in enumerate(starts):
        en = (starts[idx + 1] - 1) if idx + 1 < len(starts) else e
        while en > st and not fm_lines[en].strip():
            en -= 1
        items.append((st, en))
    sub_indent = (item_indent + 2) if item_indent is not None else 4
    return s, e, items, (item_indent or 2), sub_indent


def load_raw_for_edit(path: Path):
    """讀 raw,拒 BOM/CRLF(本 vault 慣例 LF/no-BOM,異常不靜默正規化)。
    回傳 (all_lines, fm_start, fm_end_exclusive)。fm = all_lines[1:fm_end]。"""
    raw = path.read_bytes()
    if raw.startswith(b"\xef\xbb\xbf"):
        raise ValueError("T1 不寫 BOM 檔(慣例外),請用 obsidian CLI / 先正規化")
    if b"\r\n" in raw:
        raise ValueError("此檔是 CRLF(慣例要求 LF)。Windows 常見=git autocrlf;"
                         "修:確認 .gitattributes 已套用(vault 標 eol=lf)+ `git add --renormalize .`,"
                         "或單檔 `dos2unix`。lumos 不靜默改行尾。")
    lines = raw.decode("utf-8").split("\n")
    if not lines or lines[0].strip() != "---":
        raise ValueError("無 frontmatter,T1 不處理")
    fm_end = None
    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            fm_end = i
            break
    if fm_end is None:
        raise ValueError("frontmatter 未閉合")
    return lines, 1, fm_end


def _write_lf(path: Path, text: str):
    """寫 UTF-8 / LF / no-BOM,平台無關(不靠 text mode)。vault 唯一寫入原語。
    用 write_bytes:write_text(newline=) 要 Python 3.10,違反本專案 ≥3.8。"""
    path.write_bytes(text.encode("utf-8"))


def atomic_write_verify(path: Path, new_lines, key, expected_check):
    """寫 tmp → re-parse 自驗 + lint 無新指紋 → atomic rename。任一步敗:tmp 丟棄,原檔不動。"""
    orig_fm = load_raw_for_edit(path)
    orig_lint = set(parse_frontmatter(orig_fm[0][1:orig_fm[2]])[2])
    text = "\n".join(new_lines)
    new_fm_lines = new_lines[1:]
    for i in range(1, len(new_lines)):
        if new_lines[i].strip() == "---":
            new_fm_lines = new_lines[1:i]
            break
    fields, _, new_lint = parse_frontmatter(new_fm_lines)
    if not expected_check(fields):
        raise RuntimeError(f"自驗失敗:{key} 寫入後值不符預期")
    introduced = set(new_lint) - orig_lint
    if introduced:
        raise RuntimeError("自驗失敗:引入新 frontmatter 指紋:" + "; ".join(sorted(introduced)))
    import os
    tmp = path.with_suffix(path.suffix + ".lumos-tmp")
    try:
        _write_lf(tmp, text)
        os.replace(tmp, path)
    finally:
        if tmp.exists():
            tmp.unlink()


def cmd_set(env, rel, key, value):
    if key not in SCALAR_KEYS:
        print(f"ERROR: set 白名單={sorted(SCALAR_KEYS)};{key} 不在內"
              f"(list 用 append;decisions 翻盤/新增用 decision-supersede / decision-add)", file=sys.stderr)
        return 2
    path = env.vault / rel
    lines, s, e = load_raw_for_edit(path)
    new_fm = edit_fm_scalar(lines[1:e], key, value)
    new_lines = lines[:1] + new_fm + lines[e:]
    exp = fmt_scalar(key, value)
    exp_val = strip_quotes(exp)
    atomic_write_verify(path, new_lines, key,
                        lambda f: str(f.get(key, "")) == exp_val)
    print(f"✓ set {rel}: {key} = {exp}")
    return 0


def cmd_self_audit(env, rel, model="sonnet", date=None):
    """L4 自足性審計留痕:寫 self_audit: <model>/<date> 到節點 frontmatter。
    語意:這整篇節點的「自足性」(無主對話脈絡的乾淨 agent 只讀圖譜能不能還原
    專案現況)已由一個獨立 agent 審過並通過。對應 guard audit 的角色(乾淨 agent
    審後蓋戳),但程式路徑獨立——這是節點級戳記,guard audit 是行級 [audit:]。
    工具只記留痕,不證明審計真乾淨——派 agent 的乾淨脈絡/中立 prompt 靠主對話誠實。"""
    import datetime
    if date is None:
        date = datetime.date.today().isoformat()
    else:
        try:
            datetime.date.fromisoformat(date)
        except ValueError:
            print(f"ERROR: --date 須為 YYYY-MM-DD:{date!r}", file=sys.stderr)
            return 2
    return cmd_set(env, rel, "self_audit", f"{model}/{date}")


def cmd_append(env, rel, key, value):
    if key not in LIST_KEYS:
        print(f"ERROR: append 白名單={sorted(LIST_KEYS)};{key} 不在內", file=sys.stderr)
        return 2
    path = env.vault / rel
    lines, s, e = load_raw_for_edit(path)
    new_fm = edit_fm_append(lines[1:e], key, value)
    new_lines = lines[:1] + new_fm + lines[e:]
    tgt = link_target(value)
    atomic_write_verify(path, new_lines, key,
                        lambda f: any(link_target(x) == tgt for x in as_list(f.get(key))))
    print(f"✓ append {rel}: {key} += {value}")
    return 0


def _fm_of(all_lines):
    """從完整檔行抽 frontmatter 行(供 decision 自驗用 parse_decisions 重解)。"""
    for i in range(1, len(all_lines)):
        if all_lines[i].strip() == "---":
            return all_lines[1:i]
    return all_lines[1:]


def _fmt_decision_value(v):
    """decision 子欄位值格式化(含 ': ' 或特殊字元 → 引號,避鐵則 3)。"""
    v = v.strip()
    if re.search(r":\s|^[\[\{>|*&!#@`\"']|^\s|\s$", v) or v == "":
        return '"' + v.replace('"', '\\"') + '"'
    return v


def cmd_decision_supersede(env, rel, match, by, ended=None):
    """T3 巢狀手術:把 decisions[] 中 content 含 match 的決策標 valid:false + 補
    superseded_by/ended。surgical line-based(不重序列化,最小 diff;優於 ruamel reflow)。
    [P1]:ended 缺則自動補今日 + 同步 bump 頂層 updated(單次 atomic,供 E2 時序法)。"""
    import datetime
    if ended and not DATE_RE.match(ended):
        raise ValueError(f"--ended 需 YYYY-MM-DD,得到: {ended}")
    path = env.vault / rel
    lines, s_fm, e_fm = load_raw_for_edit(path)
    fm = lines[1:e_fm]
    loc = decisions_items(fm)
    if loc is None:
        raise ValueError("此筆記無 decisions")
    if not loc[2]:  # block 存在但解析不到項目(Bug2:0-indent / 非標準縮排)
        raise ValueError("decisions 區塊解析不到項目(本工具要求 2-space 縮排,不支援 0-indent/tab)")
    _, _, items, _, sub = loc
    pad = " " * sub
    needle = nfc(match)
    id_mode = re.fullmatch(r"#d\d+", match.strip())
    if id_mode:
        # [M1/R12] #dN 精確定址:比對項內 id 行
        want = match.strip()[1:]
        hits = [(st, en) for (st, en) in items
                if any(re.match(rf"^{pad}id:\s*{re.escape(want)}\s*$", fm[i])
                       for i in range(st, en + 1))]
        if not hits:
            raise ValueError(f"以 {match} 定址查無決策——該節點決策可能尚無 id,先跑 lumos decision-reindex {rel}")
    else:
        hits = [(st, en) for (st, en) in items
                if needle in nfc("\n".join(fm[st:en + 1]))]
        if not hits:
            raise ValueError(f"找不到 content 含「{match}」的決策")
        if len(hits) > 1:
            # [M1/R12] 選擇端唯一命中:first-match 會「先改錯項、再用錯項 id 精確驗證它改成功」
            cands = "; ".join(first_line(fm[st].split("content:", 1)[-1].strip(), 40)
                              for (st, _) in hits[:5])
            raise ValueError(f"「{match}」命中 {len(hits)} 條決策,拒絕 first-match(防改錯項)。"
                             f"候選: {cands} …改用更長子字串或 --match \"#dN\" 精確定址")
    st, en = hits[0]
    valid_line = None
    for i in range(st, en + 1):
        if re.match(rf"^{pad}valid:\s", fm[i]):   # 只認精確 sub_indent(Bug5:移除過寬 fallback,免誤命中子清單)
            valid_line = i
            break
    if valid_line is None:
        raise ValueError("該決策無 valid 欄位(或縮排非標準 2-space),T3 不自動 supersede(請手動 / 確認結構)")
    # Bug3: 已 superseded 不重插(免重複鍵)。同 sub_indent 已有 superseded_by → 拒
    for i in range(st, en + 1):
        if re.match(rf"^{pad}superseded_by:\s", fm[i]):
            raise ValueError("該決策已有 superseded_by(已翻盤過),不重複 supersede;要改取代者請手動編輯")
    fm[valid_line] = f"{pad}valid: false"
    # [P1] ended 選填 → 缺則自動補今日(E2 時序法要 ended 才判得了「鄰居晚於翻案沒?」)
    if not ended:
        ended = datetime.date.today().isoformat()
    ins = [f"{pad}superseded_by: {_fmt_decision_value(by)}", f"{pad}ended: {ended}"]
    fm[valid_line + 1:valid_line + 1] = ins
    # [P1] supersede = 對本節點的實質編輯 → 同步 bump 頂層 updated(單次 atomic,同一份 fm;
    #   不串第二個寫命令避免半完成)。有則就地換、無則插在 decisions: 前(不動決策區索引)。
    today = datetime.date.today().isoformat()
    upd_i = next((k for k, ln in enumerate(fm) if re.match(r"^updated:\s", ln)), None)
    if upd_i is not None:
        fm[upd_i] = f"updated: {today}"
    else:
        dec_i = next((k for k, ln in enumerate(fm) if re.match(r"^decisions:\s*$", ln)), len(fm))
        fm[dec_i:dec_i] = [f"updated: {today}"]
    new_lines = lines[:1] + fm + lines[e_fm:]
    # [M1/P2] 讀 target 的 id → 組全域格式 <rel>#d<N> 回傳(下游 header/CASCADE/--from 同格式,無裸碼流出)
    did = None
    for i in range(st, en + 1):
        m = re.match(rf"^{pad}id:\s*(d\d+)\s*$", fm[i])
        if m:
            did = m.group(1)
            break
    gid = f"{rel}#{did}" if did else None

    def _check(_fields):
        for d in parse_decisions(_fm_of(new_lines)):
            # [M1] 有 id → ID 精確驗證(content 子字串重疊會驗錯項);無 id(未 reindex 舊節點)→ 退回 content 驗證
            hit = (str(d.get("id", "")).strip() == did) if did \
                else (needle in nfc(str(d.get("content", ""))))
            if hit:
                return str(d.get("valid", "")).lower() == "false" and "superseded_by" in d
        return False
    atomic_write_verify(path, new_lines, "decisions", _check)
    _tag = f" [{gid}]" if gid else ""
    print(f"✓ supersede {rel}: 決策「{match[:30]}」→ valid:false + superseded_by + ended={ended} (updated bump {today}){_tag}")
    return 0, gid


def _max_decision_id(fm_lines):
    """[M1/P2] 掃 decisions[] 既有 id: d<N>,回最大 N(無則 0)。新號=max+1(不重排既有、
    不回收缺號——ID 穩定性合約:翻案後永不重用)。"""
    mx = 0
    for d in parse_decisions(fm_lines):
        m = re.fullmatch(r"d(\d+)", str(d.get("id", "")).strip())
        if m:
            mx = max(mx, int(m.group(1)))
    return mx


def cmd_decision_add(env, rel, content, decided, context=None, why=None):
    """T3 巢狀手術:append 一條新 ADR 決策到 decisions[](無則建)。surgical line-based。
    [M1/P2]:指派穩定 id d<max+1> 並回傳 (rc, 全域決策id <rel>#d<N>);dispatcher 解包後
    CLI 對外仍只回整數 rc。"""
    if not DATE_RE.match(decided):
        raise ValueError(f"--decided 需 YYYY-MM-DD,得到: {decided}")
    path = env.vault / rel
    lines, s_fm, e_fm = load_raw_for_edit(path)
    fm = lines[1:e_fm]
    loc = decisions_items(fm)
    new_id = f"d{_max_decision_id(fm) + 1}"
    if loc is None:
        # 無 decisions key → 在 fm 末尾建
        item_indent, sub = 2, 4
        block = [f'{" "*item_indent}- content: {_fmt_decision_value(content)}',
                 f"{' '*sub}id: {new_id}"]
        if context:
            block.append(f'{" "*sub}context: {_fmt_decision_value(context)}')
        if why:
            block.append(f'{" "*sub}why_chosen: {_fmt_decision_value(why)}')
        block += [f"{' '*sub}decided: {decided}", f"{' '*sub}valid: true"]
        fm = fm + ["decisions:"] + block
    else:
        _, e_block, items, item_indent, sub = loc
        ip, sp = " " * item_indent, " " * sub
        block = [f"{ip}- content: {_fmt_decision_value(content)}", f"{sp}id: {new_id}"]
        if context:
            block.append(f"{sp}context: {_fmt_decision_value(context)}")
        if why:
            block.append(f"{sp}why_chosen: {_fmt_decision_value(why)}")
        block += [f"{sp}decided: {decided}", f"{sp}valid: true"]
        last = items[-1][1] if items else e_block
        fm[last + 1:last + 1] = block
    new_lines = lines[:1] + fm + lines[e_fm:]
    needle = nfc(content)

    def _check(_fields):
        # [M1] ID 精確驗證:新 id 那條存在且 content 相符(取代純 content 子字串——重疊時驗錯項)
        return any(str(d.get("id", "")).strip() == new_id
                   and needle in nfc(str(d.get("content", "")))
                   for d in parse_decisions(_fm_of(new_lines)))
    atomic_write_verify(path, new_lines, "decisions", _check)
    print(f"✓ decision-add {rel}: 「{content[:30]}」(id={new_id}, valid:true)")
    return 0, f"{rel}#{new_id}"


def cmd_decision_reindex(env, rel=None, all_mode=False):
    """[M1/P2] 回填遷移:對既有無 id 決策依文件順序、從既有最大 id+1 接續編號(不重排既有、
    不回收缺號——混合狀態絕不撞既有 id);冪等(已有 id 跳過)。單節點一次一篇;--all 批次套用
    到所有有 decisions 的節點(decision_refs 自動養成前置 P;顯式指令、非隱式改)。
    解析不到的決策項明確拒絕(同 supersede 0-indent/tab 語意),不靜默跳過造成缺洞。"""
    if all_mode:
        targets = sorted(r for r, n in env.notes.items() if decisions_items(n.fm_lines) is not None)
        done = errs = 0
        for r in targets:
            try:
                cmd_decision_reindex(env, r)
                done += 1
            except (ValueError, RuntimeError, OSError) as e:   # [code-loop r1 A] 補 OSError:寫檔面(磁碟滿/權限)
                print(f"  ✗ {r}: {e}", file=sys.stderr)
                errs += 1
        print(f"✓ reindex --all: 掃 {len(targets)} 個決策節點,{done} 處理 / {errs} 拒絕(格式不合)")
        return 2 if errs else 0
    path = env.vault / rel
    lines, s_fm, e_fm = load_raw_for_edit(path)
    fm = lines[1:e_fm]
    loc = decisions_items(fm)
    if loc is None:
        raise ValueError("此筆記無 decisions")
    if not loc[2]:
        raise ValueError("decisions 區塊解析不到項目(本工具要求 2-space 縮排,不支援 0-indent/tab)")
    _, _, items, _, sub = loc
    pad = " " * sub
    nxt = _max_decision_id(fm) + 1
    # 先依文件順序算好指派,再由下而上插入(插入不位移未處理的上方索引)
    plan = []
    for (st, en) in items:
        if not any(re.match(rf"^{pad}id:\s*d\d+\s*$", fm[i]) for i in range(st, en + 1)):
            plan.append((st, f"d{nxt}"))
            nxt += 1
    if not plan:
        print(f"✓ reindex {rel}: 全部決策已有 id,無需回填(冪等)")
        return 0
    pre_ids = {str(d.get("id", "")).strip() for d in parse_decisions(fm) if d.get("id")}
    for st, did in reversed(plan):
        fm[st + 1:st + 1] = [f"{pad}id: {did}"]   # 插在 dash(content)行之後
    new_lines = lines[:1] + fm + lines[e_fm:]

    def _check(_fields):
        ds = parse_decisions(_fm_of(new_lines))
        ids = [str(d.get("id", "")).strip() for d in ds]
        return (all(re.fullmatch(r"d\d+", i) for i in ids)          # 全數有 id
                and len(ids) == len(set(ids))                        # 唯一
                and pre_ids <= set(ids))                             # 既有 id 未被動
    atomic_write_verify(path, new_lines, "decisions", _check)
    print(f"✓ reindex {rel}: 回填 {len(plan)} 條 id({plan[0][1]}..{plan[-1][1]});既有 {len(pre_ids)} 條跳過")
    return 0


# ── [M3/S5b] rel-cascade ledger:連鎖判定的 append-only 帳本 ──
# 設計/合約見 Projects/關係層主網_實作計畫 M3(3 輪 design-loop 釘死):
# 每 cascade 一檔 governance/rel-cascade/<cascade-id>.jsonl;行帶 event 判別欄
# (header|transition);重放折疊=只折 transition、同粒度鍵取檔內物理序最後一筆(沿
# canary-log 慣例:讀 append 序、不 ts-sort);torn 行(壞 JSON)=未提交,跳過。

CASCADE_ID_RE = re.compile(r"^[A-Za-z0-9._-]+$")
REL_CASCADE_EDGES = ("verified_by", "plan_refs")   # 方向語意明確的邊(related 弱,v1 恆不展)


def _rel_cascade_dir(env):
    """帳本目錄=<repo root>/governance/rel-cascade(可追蹤逐 cascade 檔,非 vault-parent 隱藏帳慣例——
    刻意設計)。repo root:docs/<slug>-knowledge 型= docs 的上層;standalone vault=vault 自身
    (絕不往系統 temp 等共用父層爬;.jsonl 非 .md,load_vault 不掃、無污染)。"""
    root = env.vault.parent.parent if env.vault.parent.name == "docs" else env.vault
    return root / "governance" / "rel-cascade"


def _utc_ts():
    import datetime
    return datetime.datetime.now(datetime.timezone.utc).isoformat(timespec="seconds")


def _ledger_append(path, obj):
    """[M3 並行合約] O_APPEND fd + 單次 os.write() 整行 bytes(≤4KB 寫前拒,不截斷)。
    POSIX regular file 實務原子;Windows/跨平台 best-effort、預期單寫者(誠實降級,r1 D10)。
    無 O_CREAT——confirm/prune 永不建檔(建檔只屬觸發端 rel_cascade_create,r2 R4)。
    [code-loop r1] O_NOFOLLOW 拒 symlink 終點(字元白名單擋不住,CX1);os.write 回傳驗滿寫
    (ENOSPC 短寫會留中段殘行且 rc=0 假成功,B1)——短寫即 RuntimeError,呼叫端 rc=2。"""
    import json
    data = (json.dumps(obj, ensure_ascii=False) + "\n").encode("utf-8")
    if len(data) > 4096:
        raise ValueError(f"事件行 {len(data)}B 超過 4KB 上限,寫前拒絕(不截斷、不靜默破壞原子假設)")
    fd = os.open(str(path), os.O_WRONLY | os.O_APPEND | getattr(os, "O_NOFOLLOW", 0))
    try:
        written = os.write(fd, data)
        if written != len(data):
            raise RuntimeError(f"帳本短寫({written}/{len(data)}B,疑磁碟滿)——本筆事件未完整落盤,重試前先查空間")
    finally:
        os.close(fd)


def rel_cascade_create(env, root_gid, node_rel):
    """[M3 定址合約] 觸發端唯一鑄造者:mint cascade-id=c-<UTC秒ts>-<sha1(root全域id)[:8]>(-<n>)?
    + O_CREAT|O_EXCL 建檔寫 header。同秒撞名遞增序號(不等下秒;上限 99 防異常迴圈)。
    純生成、不含節點名——中文 rel 無淨化問題(r1 D5 消解)。回 cascade_id。"""
    import datetime, hashlib, json
    d = _rel_cascade_dir(env)
    d.mkdir(parents=True, exist_ok=True)
    ts = datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%d%H%M%S")
    base = f"c-{ts}-{hashlib.sha1(root_gid.encode('utf-8')).hexdigest()[:8]}"
    for suffix in [""] + [f"-{i}" for i in range(1, 100)]:
        cid = base + suffix
        p = d / (cid + ".jsonl")
        try:
            fd = os.open(str(p), os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o644)
        except FileExistsError:
            continue
        try:
            hdr = json.dumps({"event": "header", "ts": _utc_ts(),
                              "root_decision_id": root_gid, "node": node_rel},
                             ensure_ascii=False) + "\n"
            os.write(fd, hdr.encode("utf-8"))
        finally:
            os.close(fd)
        return cid
    raise RuntimeError("cascade-id 同名重試逾上限(99)——目錄異常?")


def _ledger_read(path):
    """重放讀取:append 序逐行 parse;壞 JSON 行跳過(torn=未提交事件,丟棄正確)。
    header=首行且 event:header 才算(torn header → None,root 不可恢復)。回 (header|None, transitions)。"""
    import json
    try:
        raw = path.read_text(encoding="utf-8")
    except (FileNotFoundError, OSError):
        return None, []
    header, trans = None, []
    for i, line in enumerate(raw.splitlines()):
        try:
            o = json.loads(line)
        except ValueError:
            continue
        if i == 0 and o.get("event") == "header" \
                and str(o.get("root_decision_id", "")).strip() and str(o.get("node", "")).strip():
            # [code-loop r1 CX2] 必要欄位齊才算合法 header——空殼 {"event":"header"} 會讓
            #   resume 拿空 root 靜默 rc=0 裝成功,而非走「不可恢復 rc=1」救援語意
            header = o
        elif o.get("event") == "transition":
            trans.append(o)
    return header, trans


def _ledger_fold(transitions):
    """狀態折疊:同 (neighbor×edge_type×from_decision_id) 取物理序最後一筆。"""
    state = {}
    for t in transitions:
        k = (t.get("neighbor"), t.get("edge_type"), t.get("from_decision_id"))
        if all(k):
            state[k] = t
    return state


def _validate_cascade_id(cid):
    # [code-loop r1 A3] fullmatch 非 match——match+$ 會放過尾端換行(re 的 $ 容忍結尾 \n)
    if not CASCADE_ID_RE.fullmatch(cid) or ".." in cid:
        raise ValueError(f"cascade-id 含非法字元(限 [A-Za-z0-9._-],擋 ../): {cid}")


def _validate_from_gid(from_id):
    if re.fullmatch(r"d\d+", from_id.strip()):
        raise ValueError(f"--from 需全域格式 <節點rel>#d<N>,裸 {from_id} 拒收(裸格式會讓折疊鍵跨節點誤合)")
    if not re.fullmatch(r".+#d\d+", from_id.strip()):
        raise ValueError(f"--from 格式非 <節點rel>#d<N>: {from_id}")


def _append_decision_ref(env, rel, field, ref):
    """[decision_refs 自動養成 T1] 把精確 decision_ref(<rel>#dN)append 到 field
    (decision_refs=human/cascade-confirmed | decision_refs_ai=AI 填)。**exact-string dedup**
    ——不用 link_target(它 split('#') 會把 #dN 剝掉,導致同節點不同決策誤 dedup 成一條)。
    值一律引號化(含 #// 安全)。走 atomic_write_verify。回 True=新增 / False=已存在。"""
    ref = ref.strip()
    # [code-loop r1 CX3/B + delta] 顯式拒 " / \ / 任何 C0 控制字元(<0x20,含裸 \r/\n/\t)——
    #   strip_quotes 不反跳脫、CRLF 檔案守衛只認 \r\n 序列認不出裸 CR;合法 <rel>#dN 永不含這些。
    #   「凡控制字元一律拒」比枚舉個案完整(delta reviewer:漏 \r)。
    if '"' in ref or '\\' in ref or any(ord(c) < 0x20 for c in ref):
        raise ValueError(f"decision_ref 含不可序列化字元(\"/\\/控制字元): {ref!r}")
    path = env.vault / rel
    lines, s_fm, e_fm = load_raw_for_edit(path)
    fm = lines[1:e_fm]
    struct = {k: (s, e, kind) for k, s, e, kind in fm_structure(fm)}
    quoted = '"' + ref + '"'   # ref 已排除 "/\ → 純引號包裹即安全 round-trip(含 #// 無虞)
    if field in struct:
        s, e, kind = struct[field]
        if kind != "list":
            raise ValueError(f"{field} 是 {kind} 型,不可 append decision_ref")
        for j in range(s + 1, e + 1):
            if fm[j].lstrip().startswith("-") and strip_quotes(fm[j].lstrip()[1:].strip()) == ref:
                return False   # exact 已存在
        indent = "  "
        for j in range(s + 1, e + 1):
            if fm[j].lstrip().startswith("-"):
                indent = fm[j][:len(fm[j]) - len(fm[j].lstrip())]
                break
        last = e
        while last > s and not fm[last].strip():
            last -= 1
        fm.insert(last + 1, f"{indent}- {quoted}")
    else:
        fm.append(field + ":")
        fm.append(f"  - {quoted}")
    new_lines = lines[:1] + fm + lines[e_fm:]
    atomic_write_verify(path, new_lines, field,
                        lambda f: any(str(x).strip() == ref for x in as_list(f.get(field))))
    return True


def cmd_rel_cascade_write(env, verb, neighbor, cascade_id, from_id, edge, by):
    """[M3] confirm|prune:append 一筆 transition。寫前驗證(R4):檔存在(不存在→拒,建檔只屬觸發端)、
    header 合法(torn→拒,與 resume rc=1 救援語意按指令類別分流)、--from==header root(全鏈同源)。"""
    _validate_cascade_id(cascade_id)
    _validate_from_gid(from_id)
    nrel = env.find(neighbor)
    if nrel is None:
        raise ValueError(f"找不到鄰居節點: {neighbor}")
    p = _rel_cascade_dir(env) / (cascade_id + ".jsonl")
    if not p.exists():
        raise ValueError(f"cascade 檔不存在: {cascade_id}——帳本由 decision-supersede 觸發端建立,confirm/prune 永不建檔")
    header, _ = _ledger_read(p)
    if header is None:
        raise ValueError("header 損毀/不合法,寫前驗證拒(該 cascade 交 resume 標不可恢復+補網 E2 兜底)")
    if header.get("root_decision_id") != from_id.strip():
        raise ValueError(f"--from 不屬本 cascade(header root={header.get('root_decision_id')});v1 全鏈同源")
    state = "confirmed" if verb == "confirm" else "pruned"
    _ledger_append(p, {"event": "transition", "ts": _utc_ts(), "neighbor": nrel,
                       "edge_type": edge, "from_decision_id": from_id.strip(),
                       "state": state, "by": by})
    print(f"✓ rel-cascade {verb} {nrel} --edge {edge} ({cascade_id}, by={by})")
    # [decision_refs 自動養成 T1] confirm = 地面真相「鄰居依賴這條決策」→ 回寫 decision_ref。
    #   provenance 雙欄不對稱信任:by ai → decision_refs_ai(E3 firing 生效、E2 抑制碰不到);
    #   by human → decision_refs(可抑制 E2)。prune 不回寫(判無關=不記依賴)。
    #   回寫失敗=軟警告不回滾(帳本才是地面真相,decision_refs 是衍生、可從帳本重建)。
    if verb == "confirm":
        # [code-loop r1 C-medium] fail-**safe**:只有明確 by==human 才落可信正欄;非 ai/human
        #   (None/打錯/未來新值)一律落不可信 ai 欄——安全守門不靠上游 argparse 撐(誤落正欄=可抑制 E2)
        field = "decision_refs" if by == "human" else "decision_refs_ai"
        try:
            if _append_decision_ref(env, nrel, field, from_id.strip()):
                print(f"  ↳ decision_refs 養成: {nrel}.{field} += {from_id.strip()}")
        except Exception as _e:
            # [code-loop r1 CX2] 不過度承諾:reconcile 命令尚未實作(列 future),此處僅記帳本已提交
            print(f"  ⚠ decision_ref 回寫失敗(帳本已記為地面真相;節點欄位本次未同步): {_e}", file=sys.stderr)
    return 0


def cmd_rel_cascade_list(env, stale_days=None):
    """[M3] 以活動齡列 cascade(--stale N=最後事件 ts 早於 N 天;不判開放/完成精確分類——
    活動齡才是可算的 crash/失敗偵測器)。stdout、查無 rc=0 空輸出。"""
    import datetime
    d = _rel_cascade_dir(env)
    if not d.exists():
        return 0
    now = datetime.datetime.now(datetime.timezone.utc)
    for p in sorted(d.glob("*.jsonl")):
        header, trans = _ledger_read(p)
        cid = p.stem
        root = header.get("root_decision_id") if header else "(header 損毀,root 不可恢復)"
        all_ts = [o.get("ts", "") for o in ([header] if header else []) + trans if o.get("ts")]
        last = max(all_ts) if all_ts else ""
        if stale_days is not None and last:
            try:
                age = (now - datetime.datetime.fromisoformat(last)).days
            except ValueError:
                age = None
            if age is not None and age < stale_days:
                continue
        folded = _ledger_fold(trans)
        n_c = sum(1 for t in folded.values() if t.get("state") == "confirmed")
        n_p = sum(1 for t in folded.values() if t.get("state") == "pruned")
        print(f"{cid}  root={root}  last={last or '?'}  confirmed={n_c} pruned={n_p}")
    return 0


def _typed_hop1(env, node_rel, idx=None):
    """[M4/S2] typed hop-1 原語:在 [P0] typed 索引上列「誰以方向語意明確的邊指向 node」單層鄰居。
    多跳/visited 交 [S4] 編排(resume/判斷閘)。回 (neighbors=[(src,etype,invariant數)], ambigs=[(字面,候選數)])。"""
    if idx is None:
        idx = build_typed_index(env)
    neighbors, ambigs = [], []
    for (src, etype) in idx["rev"].get(node_rel, []):
        if etype not in REL_CASCADE_EDGES:
            continue
        inv_n = len(extract_contracts(env.notes[src])[0]) if src in env.notes else 0
        neighbors.append((src, etype, inv_n))
    for (asrc, lit, aetype, cands) in idx["ambiguous"]:
        if node_rel in cands and aetype in REL_CASCADE_EDGES:
            ambigs.append((lit, len(cands)))
    return neighbors, ambigs


def cascade_surface(env, node_rel, root_decision_id, stream=None):
    """[M4/S1] surfacing 印行器:對 ledger 唯讀、不叫 AI(判斷閘=外部 agent 步驟)。
    NEIGHBOR 行由本函式印(dispatcher 印 CASCADE 行——它持有 mint 的 id 與 root id,T2 職責切分)。
    行式 schema=交接通道(編排者從此組 confirm/prune 參數)。回攤出的鄰居數。"""
    out = stream if stream is not None else sys.stderr
    neighbors, ambigs = _typed_hop1(env, node_rel)
    for (src, etype, inv_n) in neighbors:
        tag = f" INVARIANT_COUNT {inv_n}" if inv_n else ""
        print(f"NEIGHBOR {src} EDGE {etype}{tag}", file=out)
    for (lit, n) in ambigs:
        print(f"NEIGHBOR-AMBIG {lit} CANDIDATES {n}", file=out)
    return len(neighbors) + len(ambigs)


def cmd_impact_node(node_arg, repo=None, as_json=False):
    """[M4/S2] impact 第三模式 CLI 皮(供人手動查;自動迴圈走進程內原語不 shell-out):
    typed hop-1 列「誰依賴我」。與 --file/--diff 互斥、與 --depth 互斥(單層列舉無深度語意)。"""
    import json
    start = Path(repo).resolve() if repo else Path.cwd()
    vault = find_vault(start)
    if vault is None:
        print("ERROR: 找不到 vault(docs/*-knowledge)", file=sys.stderr)
        return 2
    env = Env(vault)
    rel = env.find(node_arg)
    if rel is None:
        print(f"ERROR: 找不到節點: {node_arg}", file=sys.stderr)
        return 2
    neighbors, ambigs = _typed_hop1(env, rel)
    if as_json:
        print(json.dumps({"node": rel,
                          "neighbors": [{"rel": s, "edge": e, "invariant_count": n}
                                        for (s, e, n) in neighbors],
                          "ambiguous": [{"literal": l, "candidates": n} for (l, n) in ambigs]},
                         ensure_ascii=False))
        return 0
    print(f"NODE {rel}  typed-hop1 連入(verified_by/plan_refs;related 弱恆不展):")
    for (src, etype, inv_n) in neighbors:
        tag = f" INVARIANT_COUNT {inv_n}" if inv_n else ""
        print(f"  NEIGHBOR {src} EDGE {etype}{tag}")
    for (lit, n) in ambigs:
        print(f"  NEIGHBOR-AMBIG {lit} CANDIDATES {n}")
    if not neighbors and not ambigs:
        print("  (無 typed 連入鄰居)")
    return 0


def cmd_rel_cascade_resume(env, cascade_id):
    """[M3] 「續」的交付項(D16):重放折疊→取 header root→重展 root+最終態 confirmed 鄰居
    (先 confirm 後 prune 不重展)→對粒度鍵差集→列剩餘待判。decision_id=root 全鏈攜帶(R3)。
    輸出:首行 CASCADE 行(編排者跨 session 拿 --from 不需讀檔)+NEIGHBOR 行 schema。
    中斷接續/escalate 待人項/誤 prune 翻案補跑下游 三場景共用。torn header → rc=1。"""
    _validate_cascade_id(cascade_id)
    p = _rel_cascade_dir(env) / (cascade_id + ".jsonl")
    if not p.exists():
        raise ValueError(f"cascade 檔不存在: {cascade_id}")
    header, trans = _ledger_read(p)
    if header is None:
        print(f"✗ {cascade_id}: header 損毀,root 不可恢復——本 cascade 放棄,交補網 E2 兜底", file=sys.stderr)
        return 1
    root_gid = header.get("root_decision_id", "")
    node = header.get("node", "")
    state = _ledger_fold(trans)
    confirmed = sorted({k[0] for k, t in state.items() if t.get("state") == "confirmed"})
    seeds = [node] + [c for c in confirmed if c != node]
    idx = build_typed_index(env)
    print(f"CASCADE {cascade_id} ROOT {root_gid}")
    pending = []
    seen = set()
    expanded = set()
    for s in seeds:   # visited=root∪最終態 confirmed;粒度鍵冪等,重複展開無害只多列
        if s in expanded:   # 菱形:同節點經兩路抵達 → 不再展,stderr 留痕(反靜默紀律)
            print(f"CASCADE-SKIP 已展過不重展: {s}", file=sys.stderr)
            continue
        expanded.add(s)
        neighbors, ambigs = _typed_hop1(env, s, idx=idx)
        for (src, etype, inv_n) in neighbors:
            k = (src, etype, root_gid)
            if k in state or k in seen:
                continue
            seen.add(k)
            tag = f" INVARIANT_COUNT {inv_n}" if inv_n else ""
            pending.append(f"NEIGHBOR {src} EDGE {etype}{tag}")
        for (lit, n) in ambigs:
            if (s, lit) not in seen:
                seen.add((s, lit))
                pending.append(f"NEIGHBOR-AMBIG {lit} CANDIDATES {n}")
    for line in pending:
        print(line)
    return 0


TEMPLATES = {
    "system": ("Systems", "type: system\nstatus: doing\ncreated: {today}\nupdated: {today}\n"
               "tags:\n  - type/system\n  - status/doing\nsummary: |-\n  FLOW:\n  KEY:\n  DEP:\n  TEST:"),
    "verification": ("Verification", "type: verification\nstatus: pass\ndate: {today}\n"
                     "valid_under:\nrevalidate_when:\ntags:\n  - type/verification\n  - status/pass"),
    "issue": ("Issues", "type: issue\nstatus: open\ncreated: {today}\nupdated: {today}\n"
              "tags:\n  - type/issue\n  - status/open\nsummary: |-\n  FLAG:\n  DECISION:\n  KEY:"),
    "project": ("Projects", "type: project\nstatus: doing\ncreated: {today}\nupdated: {today}\n"
                "tags:\n  - type/project\n  - status/doing"),
}

# new 後印出的「寫入當下教學」:符號行怎麼填 + 合約鏈,讓正確格式在執行 CLI 的此刻就在 context。
NEW_HINT = {
    "system": [
        "填 summary 符號行: FLOW:<流程 a→b→c>  KEY:<關鍵概念/欄位>  DEP:[[依賴模組]]  TEST:<測試狀態>",
        "合約用 KEY 行前綴: ★INVARIANT★=業務合約(改=breaking),必綁 [test:測試名] 再經獨立 [audit:];★DEBT★=偶然可改",
        "  └ 綁定別手寫: lumos guard bind <node> \"<KEY子字串>\" <測試名> / guard audit <node> \"<KEY子字串>\"",
        "可逆性: 不可逆動作(prod遷移/上架)標 ★IRREVERSIBLE★ + [rollback:decisions];改了難救標 ★CHECKPOINT★;外部不可逆(信已送/下游已消費)改用 [guard:decisions] 記冪等鍵/核可閘([guard:] 僅對 ★IRREVERSIBLE★ 生效;屬可逆性軸,與 lumos guard bind 的合約軸正交)",
        "組合覆蓋: 最重的鐵則(金額/權限/不可逆)在 ★INVARIANT★ 之後標 ★COMBO★ → doctor Check K 軟提醒補組合測試(別只測 happy-path)",
    ],
    "issue": [
        "填 summary 符號行: FLAG:<TECHNICAL/DECISION/ORIGIN>  DECISION:<決策簡述>  KEY:<關鍵發現>",
    ],
    "verification": [
        "填 valid_under:<此驗證在什麼前提下成立>  revalidate_when:<改到什麼時該重驗>",
        "從對應 Systems 用 verified_by 回掛本篇(或 lumos sync-verified-by 補);summary 可選 TEST:/VERIFY:",
    ],
    "project": [
        "計劃節點: 落地的 Verification 用 plan_refs 回指本節點(意圖鏈,doctor Check 4 把關)",
    ],
}


def cmd_new(env, ntype, name, today):
    if ntype not in TEMPLATES:
        print(f"ERROR: type 須為 {sorted(TEMPLATES)}", file=sys.stderr)
        return 2
    if "/" in name or "\\" in name or ".." in name or name.startswith("."):
        print(f"ERROR: name 不得含路徑分隔符 / .. / 開頭點(防路徑逃脫): {name}", file=sys.stderr)
        return 2
    folder, tmpl = TEMPLATES[ntype]
    path = env.vault / folder / f"{name}.md"
    if path.exists():
        print(f"ERROR: 已存在: {path}", file=sys.stderr)
        return 2
    path.parent.mkdir(parents=True, exist_ok=True)
    fm = tmpl.format(today=today)
    _write_lf(path, f"---\n{fm}\n---\n# {name}\n")
    print(f"✓ new {ntype}: {path.relative_to(env.vault)}")
    for line in NEW_HINT.get(ntype, []):
        print(f"  {line}")
    print(f"  寫完跑 lumos lint {name}(單檔快檢標籤/格式)→ 全圖再 lumos doctor;完整規範見 lumos-project-notes skill")
    return 0


# ═══════════════════════ 階段三: archive(lumos 自做,單遍) ═══════════════════════

ARCHIVABLE = {"pass", "done", "superseded"}


def cmd_archive(env, days, apply, today):
    import os
    import datetime
    cutoff = (datetime.date.fromisoformat(today) - datetime.timedelta(days=days)).isoformat()

    # 「活守衛護欄」:一份 Verification 若還在提到某條 ★INVARIANT★ 綁定、且該測試仍存在於 code 的守衛,
    # 它的有效性是 CI 每次真機跑出來證明的、不是日曆決定的 → 不按年齡歸檔(否則把還在跑綠的守衛證據
    # 降級進 Archive,等於歸檔規則[天數]凌駕有效性規則[CI 綠燈])。守衛若被刪(測試不在 code)則照舊可歸檔。
    repo_root = None
    for p in env.vault.parents:
        if p.name == "docs":
            repo_root = p.parent
            break
    live_guard_tests = set()
    guard_re = None
    if repo_root is not None:
        # 多平台感知:每 invariant 依平台前綴解析,對其平台 root+profile 的 method set 判存活。
        # 收「存活的裸方法名」(非帶前綴的 ref)——guard_re 要在 Verification 文字裡搜方法名。
        _, split, default, methods_for, _hay = _platform_test_index(repo_root)
        for _n in env.notes.values():
            invs, _ = extract_contracts(_n)
            for inv in invs:
                try:
                    for plat, name in resolve_test_refs(inv, split, default):
                        if name in methods_for(plat):
                            live_guard_tests.add(name)
                except ValueError:
                    continue   # 未定義平台前綴:非有效綁定,不護
        if live_guard_tests:
            # 精確度對齊 Check T:用【詞界】比對方法名,不是 raw 子字串。
            # 否則短/前綴名(live `Pay` 命中散文 "Payment"、`Foo` 命中 `FooBar`)會
            # 假性護住無關 Verification → 它們永遠不歸檔(歸檔靜默失效)。
            # re.ASCII:方法名是 ASCII 識別字;否則 Python \b 視 CJK 為 \w,
            # 「守衛Pay跑」(中文緊貼方法名無空格)→ \b 不成立 → 漏護(under-protection,更危險)。
            guard_re = re.compile(r"\b(?:" + "|".join(map(re.escape, live_guard_tests)) + r")\b",
                                  re.ASCII)
    guards_all_dead = repo_root is not None and not live_guard_tests and any(
        invariant_test_refs(inv)
        for _n in env.notes.values() for inv in extract_contracts(_n)[0])

    cands = []       # (rel, stem, ym)
    protected = []   # (rel, [backs...]):早於 cutoff 但仍背書存活守衛
    for rel, n in sorted(env.notes.items()):
        if not rel.startswith("Verification/") or "/Archive/" in rel:
            continue
        if str(n.fields.get("status", "")) not in ARCHIVABLE:
            continue
        datestr = str(n.fields.get("created") or n.fields.get("date") or "")[:10]
        if not DATE_RE.match(datestr) or datestr > cutoff:
            continue
        # 活守衛護欄:這篇是否【詞界】提到任一條「測試仍存在」的綁定名 → 是則保留不歸檔
        if guard_re is not None:
            try:
                raw = (env.vault / rel).read_text(encoding="utf-8-sig")
            except Exception:
                raw = ""
            backs = sorted(set(guard_re.findall(raw)))
            if backs:
                protected.append((rel, backs))
                continue
        cands.append((rel, n.stem, datestr[:7]))

    print(f"lumos archive — vault: {env.vault}")
    print(f"  cutoff: {cutoff} (--days {days})  mode: {'APPLY' if apply else 'DRY-RUN(--apply 真執行)'}")
    if repo_root is None:
        print("  ⚠ 無法定位 repo root → 活守衛護欄停用(本次純按年齡歸檔)")
    if guards_all_dead:
        print("  ⚠ ★INVARIANT★ 綁定的測試都不在 code(守衛已刪/裸合約)→ 活守衛護欄本次停用"
              "(0 受護 ≠ 全部都能放心歸檔)")
    if protected:
        print(f"  活守衛護欄:{len(protected)} 篇早於 cutoff 但仍背書存活守衛(綁定測試還在 code)→ 保留不歸檔")
        for rel, backs in protected:
            print(f"      • {rel}  (backs: {', '.join(backs)})")
    print()
    if not cands:
        print("  無符合條件的 Verification(status∈{pass,done,superseded} 且早於 cutoff;已扣除活守衛護欄保留者)")
        return 0

    moved_stems = {stem for _, stem, _ in cands}
    # 計算每個被移檔的 path 式入連結(body + frontmatter 字串一起,raw text 掃)
    rewrite_plan = defaultdict(list)  # rel → [stem,...] 該檔內要正規化的 path 式連結
    for rel, n in env.notes.items():
        try:
            text = (env.vault / rel).read_text(encoding="utf-8-sig")
        except Exception:
            continue
        for stem in moved_stems:
            if re.search(r"\[\[Verification/" + re.escape(stem) + r"(?=[\]|#])", text):
                rewrite_plan[rel].append(stem)

    print(f"  將歸檔 {len(cands)} 篇:")
    for rel, stem, ym in cands:
        print(f"    • {rel} → Verification/Archive/{ym}/{stem}.md")
    n_links = sum(len(v) for v in rewrite_plan.values())
    print(f"\n  path 式入連結正規化(→ basename): {n_links} 處,分佈 {len(rewrite_plan)} 檔")
    for rel, stems in sorted(rewrite_plan.items()):
        print(f"    • {rel}: {', '.join(stems)}")
    if not apply:
        print("\n  (DRY-RUN,未動檔。basename 式入連結不受影響=移檔不斷)")
        return 0

    # 1) 先正規化連結(檔案還在原位)。順序=先 rewrite 後移檔:若中途失敗,
    #    已 rewrite 未移檔的檔其 basename 連結仍解析得到(檔還在 Verification/),狀態良性;
    #    且 re-run archive 會跳過已正規化的(無 path 式可改)只補移檔 → 可重入恢復。
    rewritten = 0  # 實際改寫處數(非計畫數;CRLF 跳過時不灌水,GAP-4)
    for rel, stems in sorted(rewrite_plan.items()):
        p = env.vault / rel
        raw = p.read_bytes()
        if raw.startswith(b"\xef\xbb\xbf") or b"\r\n" in raw:
            print(f"  ⚠ 跳過 rewrite(BOM/CRLF 慣例外,不靜默正規化): {rel}", file=sys.stderr)
            continue
        text = raw.decode("utf-8")
        for stem in stems:
            text, n_sub = re.subn(r"\[\[Verification/" + re.escape(stem) + r"(?=[\]|#])",
                                  "[[" + stem, text)
            rewritten += n_sub
        tmp = p.with_suffix(p.suffix + ".lumos-tmp")
        try:
            _write_lf(tmp, text)
            os.replace(tmp, p)
        finally:
            if tmp.exists():
                tmp.unlink()
    # 2) 移檔
    moved = 0
    for rel, stem, ym in cands:
        src = env.vault / rel
        dst_dir = env.vault / "Verification" / "Archive" / ym
        dst_dir.mkdir(parents=True, exist_ok=True)
        dst = dst_dir / f"{stem}.md"
        if dst.exists():
            print(f"  ⚠ 跳過(目標已存在): {dst}", file=sys.stderr)
            continue
        os.replace(src, dst)
        moved += 1
    print(f"\n  ✓ 歸檔 {moved} 篇,正規化 {rewritten} 處連結(計畫 {n_links})")
    return 0


# ═══════════════════════ main ═══════════════════════

def cmd_install(force=False):
    """全域 lumos + user-scope skills(機器層一鍵)。Unix=symlink、Win=.cmd shim。"""
    import os
    src = Path(__file__).resolve()
    bindir = Path.home() / ".local" / "bin"
    bindir.mkdir(parents=True, exist_ok=True)
    if _IS_WIN:
        shim = bindir / "lumos.cmd"
        shim.write_text(f'@echo off\r\npython "{src}" %*\r\n', encoding="utf-8")
        print(f"✓ 安裝: {shim} → python {src}")
    else:
        dst = bindir / "lumos"
        if dst.is_symlink() and dst.resolve() == src:
            print(f"✓ 已安裝(symlink 正確): {dst} → {src}")
        elif dst.exists() or dst.is_symlink():
            if not force:
                cur = str(dst.resolve()) if dst.is_symlink() else "(一般檔案)"
                print(f"⚠ {dst} 已存在(→ {cur}),加 --force 覆寫", file=sys.stderr)
                return 2
            dst.unlink(); dst.symlink_to(src); print(f"✓ 覆寫安裝: {dst} → {src}")
        else:
            dst.symlink_to(src); print(f"✓ 安裝: {dst} → {src}")
    # 連帶裝 skills(r2-F1:機器層一鍵)
    print("裝 user-scope skills…")
    _install_skills()
    # PATH 檢查(r1-F7:用 os.pathsep,Windows 是 ;)
    if str(bindir) not in os.environ.get("PATH", "").split(os.pathsep):
        hint = (f'  Windows:把 {bindir} 加進使用者 PATH(系統環境變數)'
                if _IS_WIN else f'  export PATH="$HOME/.local/bin:$PATH"')
        print(f"⚠ {bindir} 不在當前 PATH —\n{hint}", file=sys.stderr)
    else:
        print(f"  {bindir} 已在 PATH — 任何專案打 `lumos doctor` 即可")
    return 0


def cmd_uninstall():
    """對稱移除 cmd_install 裝的東西:全域指令(Unix symlink / Win lumos.cmd)+ user-scope skills。"""
    import os, shutil
    removed = []
    bindir = Path.home() / ".local" / "bin"
    for name in ("lumos.cmd", "lumos"):          # Win shim + Unix symlink
        g = bindir / name
        if g.is_symlink():
            removed.append(f"{g}(symlink → {g.resolve()})"); g.unlink()
        elif g.exists():
            removed.append(str(g)); g.unlink()
    sk = Path.home() / ".claude" / "skills"      # 對稱 _install_skills:junction/symlink/複製夾都清
    for s in _SKILLS:
        d = sk / s
        if d.is_symlink():
            d.unlink(); removed.append(str(d))
        elif d.is_dir():
            try:
                os.rmdir(d)                       # junction/空夾:只移連結本身,不跟進 target(同 W4)
            except OSError:
                shutil.rmtree(d, ignore_errors=True)
            removed.append(str(d))
    if removed:
        print("✓ 移除:\n  " + "\n  ".join(removed))
    else:
        print("✓ 未安裝(無全域 lumos / skills)")
    return 0


def cmd_deinit(keep_graph=False, dry_run=False, yes=False, source=None):
    """專案層反安裝(對稱 cmd_init):拆本 repo 的 pre-commit 閘 / vendored 工具組 /
    CLAUDE.md 注入區塊 /(預設)圖譜 vault。不碰機器共用項(~/.claude)。不自動 commit。"""
    import subprocess
    # root 走 git toplevel;非 git 目錄中止(不 fallback cwd——deinit 會刪檔)
    try:
        root = Path(subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], text=True,
            stderr=subprocess.DEVNULL).strip())
    except Exception:
        print("ERROR: 非 git 目錄,deinit 需可靠 repo root(不 fallback cwd)", file=sys.stderr)
        return 2
    # pre-flight 守衛①:來源 repo 自我保護(對齊 cmd_update 的 root==src → return 2)
    src = _lumos_src(source)
    if root.resolve() == src.resolve():
        print("ERROR: 當前就是 Lumos 來源本身,deinit 拒絕執行", file=sys.stderr)
        return 2
    vault = _vault_in(root)
    # pre-flight 守衛②:vault == root 鐵閘(防 rmtree 整個 repo)
    if vault is not None and vault.resolve() == root.resolve() and not keep_graph:
        keep_graph = True
        print("⚠ 偵測到 standalone vault(圖譜=repo 根):強制保留圖譜,只拆其餘專案層。",
              file=sys.stderr)
    will_delete_vault = (vault is not None) and (not keep_graph)
    installed = _deinit_detect_installed(root)
    has_claude = _claude_block_present(root)
    if not installed and not will_delete_vault and not has_claude:
        print("✓ 未安裝(此 repo 無 Lumos 專案層)")
        return 0
    if dry_run:
        print("lumos deinit --dry-run(僅預演,不改動):")
        print(f"  root: {root}")
        print("  拆閘: git config --unset core.hooksPath" if installed
              else "  拆閘: (core.hooksPath 未設,略)")
        if has_claude:
            print("  剝 CLAUDE.md graph-discipline 區塊")
        if will_delete_vault:
            n = len([f for f in vault.rglob("*") if f.is_file()])
            print(f"  刪圖譜 vault: {vault}({n} 檔)")
        elif vault is not None:
            print(f"  保留圖譜 vault: {vault}")
        print("  移除 vendored 工具組(白名單:5 檔 + hooks/templates 兩夾)")
        return 0
    if will_delete_vault and not yes:
        if not sys.stdin.isatty():
            print("ERROR: 非互動環境(stdin 非 tty)且未加 --yes,拒絕刪圖譜。加 --yes 確認。",
                  file=sys.stderr)
            return 2
        files = [f for f in vault.rglob("*") if f.is_file()]
        dirty = subprocess.run(["git", "-C", str(root), "status", "--porcelain", str(vault)],
                               capture_output=True, text=True).stdout
        n_dirty = len([ln for ln in dirty.splitlines() if ln.strip()])
        print(f"將刪除圖譜 vault: {vault}({len(files)} 檔)")
        if n_dirty:
            print(f"  ⚠ 其中 {n_dirty} 個未 commit — 刪了 git 救不回!")
        try:
            ans = input("確定刪除?輸入 y 繼續、其他取消: ").strip().lower()
        except EOFError:
            # isatty() 在某些終端/Windows 回 True 但 stdin 其實 EOF → 讀不到確認。
            # 破壞性操作安全預設:拒刪(對齊上面非互動 rc2)。
            print("ERROR: 讀不到確認輸入(stdin EOF),拒絕刪圖譜。加 --yes 確認。", file=sys.stderr)
            return 2
        if ans != "y":
            print("已取消。")
            return 1
    # ── 固定順序執行(pre-flight 已過)──
    _deinit_unbar_gate(root)                 # step 1 先拆閘
    _deinit_strip_claude(root)               # step 2 剝 CLAUDE.md 區塊
    if will_delete_vault:                    # step 3 刪圖譜(pre-flight + 安全網已過)
        import shutil
        shutil.rmtree(vault)
    _deinit_remove_vendored(root)            # step 4 最後移 vendored(可能含自己)
    print("✓ deinit 完成(專案層已移除)。檢視 `git diff` 後自行 commit。")
    return 0


def _deinit_unbar_gate(root: Path) -> int:
    """拆 pre-commit 閘:git -C root config --unset core.hooksPath。
    rc 0(已 unset)/ rc 5(key 本不存在)皆成功;其他 rc 印 warning 但不中止
    (真正保險是 step 4 會把 scripts/hooks/ 整夾刪掉,缺 hook 檔 git 自會放行)。"""
    import subprocess
    r = subprocess.run(["git", "-C", str(root), "config", "--unset", "core.hooksPath"],
                       capture_output=True, text=True)
    if r.returncode not in (0, 5):
        print(f"  ⚠ git config --unset core.hooksPath rc={r.returncode}(續行)", file=sys.stderr)
    return r.returncode


def _extract_claude_block_span(text: str):
    """定位 CLAUDE.md 中的 LUMOS:GRAPH-DISCIPLINE sentinel 區塊,回傳三態。

    回傳 (state, span):
      "found"  → span 是 BlockSpan(body, body_start, body_end);
                 body = START 行結尾 \\n 之後、END 行開頭之前的子字串,strip 首尾空行;
                 保證 text[body_start:body_end] == body。
      "absent" → (START 前綴出現 0 次 且 END 出現 0 次) → ("absent", None)
                 乾淨「沒這塊」,T2 可安全附加。
      "broken" → 只 START 沒 END / 只 END 沒 START / END 在 START 前 /
                 START 前綴出現 > 1 次 → ("broken", None)
                 有殘跡但壞了,不可盲改。
    """
    start_count = 0
    idx = 0
    si = -1
    # 計算 START 前綴出現次數,同時記第一次位置
    while True:
        pos = text.find(_CLAUDE_START_PREFIX, idx)
        if pos == -1:
            break
        start_count += 1
        if start_count == 1:
            si = pos
        idx = pos + 1

    ei = text.find(_CLAUDE_END)

    has_start = start_count > 0
    has_end = ei != -1

    # absent: 兩者皆無
    if not has_start and not has_end:
        return ("absent", None)

    # broken: 只有其中一個 / 重複 START / END 在 START 前
    if start_count > 1:
        return ("broken", None)
    if has_start and not has_end:
        return ("broken", None)
    if has_end and not has_start:
        return ("broken", None)
    if ei < si:
        return ("broken", None)

    # found: si = START 行首字元;找該行結尾(含 \n)
    nl_after_start = text.find("\n", si)
    if nl_after_start == -1:
        # START 行是檔案最後一行,無換行 → 無 body
        body_raw_start = len(text)
    else:
        body_raw_start = nl_after_start + 1  # body 從 START 行下一字元開始

    # body 結束 = END 行開頭字元
    body_raw_end = ei  # text[body_raw_start:body_raw_end] 是未 strip 的 body

    raw_body = text[body_raw_start:body_raw_end]

    # strip 首尾空白行(只去掉 \n,保留內部縮排)
    stripped = raw_body.strip("\n")

    if stripped:
        # 在 raw_body 中找 stripped 的真實位移
        inner_start = raw_body.find(stripped)
        body_start = body_raw_start + inner_start
        body_end = body_start + len(stripped)
    else:
        # body 全是空白行:body 設為空字串,位移指向 body_raw_start
        body_start = body_raw_start
        body_end = body_raw_start
        stripped = ""

    return ("found", BlockSpan(body=stripped, body_start=body_start, body_end=body_end))


# Task 2 ─────────────────────────────────────────────────────────────────────
# START 行(本 task 無版本戳;T5 會在此字串中插入版本號——形式保留易替換)


def _expected_claude_body(root: Path, slug: str) -> "str | None":
    """讀 scripts/templates/graph-discipline.md,{{KG}} 替換後 strip 首尾空行 → 預期 body 字串。
    範本不存在 → None(呼叫端 skip Check D)。
    strip 用 `.strip("\\n")`(只去首尾空行、保留內縮排),與 _extract_claude_block_span 的 body
    取法一致——reinject 寫入、extract 讀回、Check D 比對三處同一算法,版本差不觸發(版本在 body 外)。"""
    tpl_path = root / "scripts" / "templates" / "graph-discipline.md"
    if not tpl_path.exists():
        return None
    return tpl_path.read_text(encoding="utf-8").replace("{{KG}}", f"docs/{slug}-knowledge/").strip("\n")



def _reinject_claude_block(root: Path, slug: str) -> "ReInjectResult":
    """讀 vendored 範本 → {{KG}} 替換 → 組 sentinel block → 依三態更新 CLAUDE.md。

    status ∈ created|updated|unchanged|appended|sentinel_broken|no_template。
    diff:僅 updated 帶 difflib.unified_diff 字串,其餘 None。
    讀入時正規化 CRLF→LF 並去 BOM;寫入一律 _write_lf(強制 LF / 無 BOM)。
    """
    import difflib

    # 1. 範本 + body(共用 _expected_claude_body 確保 Check D 比對算法一致)
    body = _expected_claude_body(root, slug)
    if body is None:
        return ReInjectResult("no_template", None)

    # 3. 組 block(START 行帶當前版本戳,機械插值——版本在 body 外,不影響 Check D 比對)
    start_line = _START_TEMPLATE.format(version=LUMOS_VERSION)
    block = start_line + "\n" + body + "\n" + _CLAUDE_END

    # 4. 讀 CLAUDE.md(去 BOM + CRLF 正規化)
    cm = root / "CLAUDE.md"
    if cm.exists():
        raw = cm.read_bytes()
        # 去 UTF-8 BOM
        if raw.startswith(b"\xef\xbb\xbf"):
            raw = raw[3:]
        claude_text = raw.decode("utf-8").replace("\r\n", "\n").replace("\r", "\n")
    else:
        claude_text = None

    # 5. 三態分派
    if claude_text is None:
        # CLAUDE.md 不存在 → created
        _write_lf(cm, "# CLAUDE.md\n\n" + block + "\n")
        return ReInjectResult("created", None)

    state, span = _extract_claude_block_span(claude_text)

    if state == "broken":
        return ReInjectResult("sentinel_broken", None)

    if state == "absent":
        # 有 CLAUDE.md 但無 sentinel → appended
        new_text = claude_text.rstrip() + "\n\n" + block + "\n"
        _write_lf(cm, new_text)
        return ReInjectResult("appended", None)

    # state == "found": splice body + 同步刷新 START 行(版本戳落在存量戶的唯一路徑——
    # 只換 body 會讓 updated 路徑永遠拿不到版本戳,標籤機制對存量安裝戶形同虛設。
    # START 行在管理區塊「內」,★INVARIANT★ 只保護 sentinel 之外,刷新它不違約)。
    old_body = span.body
    new_body = body
    si = claude_text.find(_CLAUDE_START_PREFIX)
    sl_begin = claude_text.rfind("\n", 0, si) + 1
    sl_end = claude_text.find("\n", si)
    old_start_line = claude_text[sl_begin:sl_end] if sl_end != -1 else claude_text[sl_begin:]

    if old_body == new_body and old_start_line == start_line:
        return ReInjectResult("unchanged", None)

    # 有差 → 先換 body(高位移),再換 START 行(低位移,原始位移仍有效);兩 splice 之間
    # 的原始空白行區逐字保留。
    new_text = claude_text[:span.body_start] + new_body + claude_text[span.body_end:]
    if sl_end != -1 and old_start_line != start_line:
        new_text = new_text[:sl_begin] + start_line + new_text[sl_end:]
    _write_lf(cm, new_text)

    diff = "".join(difflib.unified_diff(
        (old_start_line + "\n" + old_body).splitlines(keepends=True),
        (start_line + "\n" + new_body).splitlines(keepends=True),
        fromfile="old block",
        tofile="new block",
    ))
    return ReInjectResult("updated", diff)


def _deinit_strip_claude(root: Path) -> bool:
    """剝 CLAUDE.md 的 LUMOS:GRAPH-DISCIPLINE 區塊;其餘內容/整個檔都留。
    無檔或無 START 標記 → no-op 回 False(對稱注入端 scripts/lumos:3175 的存在性 gating)。"""
    cm = root / "CLAUDE.md"
    if not cm.exists():
        return False
    text = cm.read_text(encoding="utf-8")
    start_marker = "<!-- LUMOS:GRAPH-DISCIPLINE:START"
    end_marker = "LUMOS:GRAPH-DISCIPLINE:END -->"
    si = text.find(start_marker)
    ei = text.find(end_marker)
    if si == -1 or ei == -1 or ei < si:
        return False
    ei += len(end_marker)
    new = (text[:si].rstrip() + "\n" + text[ei:].lstrip()).strip()
    _write_lf(cm, (new + "\n") if new else "")
    return True


def _deinit_remove_vendored(root: Path) -> list:
    """白名單移除 vendored 工具組:① _VENDORED_TOOLKIT 固定 5 檔;
    ② scripts/hooks/、scripts/templates/ 整夾遞迴刪(Lumos-owned,不靠 src 列舉)。
    scripts/ 底下使用者自有檔不碰;scripts/ 空了才 rmdir。回傳已移除相對路徑列表。"""
    import shutil
    removed = []
    for rel in _VENDORED_TOOLKIT:
        p = root / rel
        if p.exists():
            p.unlink(); removed.append(rel)
    for d in ("scripts/hooks", "scripts/templates"):
        p = root / d
        if p.is_dir():
            shutil.rmtree(p); removed.append(d + "/")
    sc = root / "scripts"
    if sc.is_dir() and not any(sc.iterdir()):
        sc.rmdir(); removed.append("scripts/")
    return removed


def _deinit_detect_installed(root: Path) -> bool:
    """target repo root 是否有專案層安裝痕跡:core.hooksPath 有值 或 scripts/hooks/ 存在。
    不靠 scripts/lumos 自身存在(執行檔與'此 repo 是否裝過'無關)。"""
    import subprocess
    hp = subprocess.run(["git", "-C", str(root), "config", "core.hooksPath"],
                        capture_output=True, text=True)
    if hp.returncode == 0 and hp.stdout.strip():
        return True
    return (root / "scripts" / "hooks").is_dir()


def _claude_block_present(root: Path) -> bool:
    cm = root / "CLAUDE.md"
    return cm.exists() and "LUMOS:GRAPH-DISCIPLINE:START" in cm.read_text(encoding="utf-8")


def _lumos_src(source=None):
    """解析 Lumos 唯一源 repo 路徑:--source > $LUMOS_HOME > ~/harness/lumos-toolchain。"""
    import os
    return Path(source or os.environ.get("LUMOS_HOME")
                or (Path.home() / "harness" / "lumos-toolchain")).expanduser()


# ── Task 5: 版本 parse + nudge ───────────────────────────────────────────────

def _parse_sentinel_version(claude_text: str) -> "str | None":
    """從 CLAUDE.md 文字中找 START sentinel 行,空格切分取形如 vX.Y 的欄位。
    取不到(無 START / START 行無版本欄位) → None;不 crash。"""
    _ver_re = re.compile(r"\bv\d+\.\d+\b")
    for line in claude_text.splitlines():
        if _CLAUDE_START_PREFIX in line:
            # START 行存在,掃各 token 找 vX.Y
            for token in line.split():
                if _ver_re.fullmatch(token):
                    return token
            # START 行存在但無版本欄位 → None
            return None
    return None


def _version_nudge(root: Path) -> "str | None":
    """比對本專案 CLAUDE.md sentinel 版本 vs 來源 clone 的 LUMOS_VERSION。

    - 來源 clone 不存在/不可達 → None(靜默 skip;CI 無來源 clone 不誤報)。
    - CLAUDE 版本 < 來源版本(字串不等且 CLAUDE 較舊) → 軟提示字串。
    - 相等 / CLAUDE 較新 / 任一取不到 → None。
    """
    # 1. 讀 CLAUDE.md sentinel 版本
    cm = root / "CLAUDE.md"
    if not cm.exists():
        return None
    try:
        claude_text = cm.read_bytes()
        if claude_text.startswith(b"\xef\xbb\xbf"):
            claude_text = claude_text[3:]
        claude_text = claude_text.decode("utf-8").replace("\r\n", "\n").replace("\r", "\n")
    except OSError:
        return None
    claude_ver = _parse_sentinel_version(claude_text)
    if claude_ver is None:
        return None

    # 2. 讀來源 clone 的 LUMOS_VERSION(文字 grep,不 import 避免副作用)
    src = _lumos_src()
    src_lumos = src / "scripts" / "lumos"
    if not src_lumos.exists():
        return None  # 來源不可達 → 靜默 skip
    try:
        _ver_pat = re.compile(r'^LUMOS_VERSION\s*=\s*"(v\d+\.\d+)"', re.MULTILINE)
        src_text = src_lumos.read_text(encoding="utf-8", errors="replace")
        m = _ver_pat.search(src_text)
        if not m:
            return None
        src_ver = m.group(1)
    except OSError:
        return None

    # 3. 比對:CLAUDE 版本 < 來源版本 → nudge(簡單字串不等判準;版本是 advisory)
    if claude_ver == src_ver:
        return None
    # 嘗試 tuple 比對(vMAJOR.MINOR → (MAJOR, MINOR));取不到就用字串不等
    def _ver_tuple(s):
        try:
            parts = s.lstrip("v").split(".")
            return tuple(int(x) for x in parts)
        except (ValueError, AttributeError):
            return None
    ct = _ver_tuple(claude_ver)
    st = _ver_tuple(src_ver)
    if ct is not None and st is not None and ct >= st:
        return None  # CLAUDE 版本 ≥ 來源,不 nudge
    # CLAUDE 落後(或無法比較)→ 提示
    return (
        f"本專案紀律區塊版本 {claude_ver} 落後來源 {src_ver},"
        f" 可跑 lumos update 刷新"
    )


# vendored 工具組白名單(固定 5 檔,scripts/ 前綴;hooks/templates 兩夾另走整夾刪)。
# _vendor_toolchain 安裝端與 cmd_deinit 移除端共用,避免漂移。
_VENDORED_TOOLKIT = ("scripts/lumos", "scripts/test_lumos.py",
                     "scripts/merge-claude-settings.py", "scripts/graph-rename.sh",
                     "scripts/fetch-notesmd.sh")


def _vendor_toolchain(src, root, slug, no_pull=False):
    """從 Lumos 來源 src vendor 工具組到專案 root(python 單一源 scaffold + hooks + 結尾自癒)。
    回傳 0;來源無效回傳 None。圖譜資料受 _scaffold_project 的 skip 保護不被動。
    cmd_update / cmd_init(--with-hooks) 共用。"""
    import subprocess, shutil, filecmp
    installer = src / "scripts" / "install-graph-toolchain.sh"  # 仍作來源有效性探針(薄殼亦在)
    if not installer.exists():
        print(f"ERROR: 找不到 Lumos 來源 {src}（無 scripts/install-graph-toolchain.sh）\n"
              f"  用 --source <path> 指定、設 $LUMOS_HOME、或 clone 到 ~/harness/lumos-toolchain",
              file=sys.stderr)
        return None
    if not no_pull:
        if (src / ".git").is_dir():
            print("  git pull 來源(取最新工具組)…")
            if subprocess.run(["git", "-C", str(src), "pull", "--ff-only"]).returncode != 0:
                print("  ⚠ git pull 失敗(無 remote / 非 ff),用現有來源繼續", file=sys.stderr)
        else:
            print("  (來源非 git repo,跳過 pull)")
    # 安裝邏輯收進 python 單一源(scaffold + hooks);bash 安裝器僅留薄殼。
    _scaffold_project(root, slug)
    _install_hooks_py(root)
    rc = 0
    # 結尾 diff 自癒:python 端逐檔比對 src↔target,差異即補(可安全覆寫)。
    toolkit = list(_VENDORED_TOOLKIT)
    for sub in ("scripts/hooks", "scripts/templates"):
        base = src / sub
        if base.is_dir():
            toolkit += [str(p.relative_to(src)) for p in base.rglob("*") if p.is_file()]
    healed = []
    for rel in toolkit:
        s, t = src / rel, root / rel
        if not s.exists():
            continue
        if (not t.exists()) or not filecmp.cmp(s, t, shallow=False):
            t.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(s, t)
            if s.stat().st_mode & 0o111:
                t.chmod(t.stat().st_mode | 0o111)
            healed.append(rel)
    if healed:
        print(f"  結尾自癒:補齊 installer 漏的 {len(healed)} 檔 → {', '.join(healed)}")
    else:
        print("  ✓ 結尾自癒檢查:工具組完全對齊(無漏)")
    # 範本已是最新(copy2 迴圈完成) → reinject CLAUDE.md 紀律區塊
    ri = _reinject_claude_block(root, slug)
    if ri.status == "updated":
        print("  CLAUDE.md 紀律區塊已更新")
        if ri.diff:
            for line in ri.diff.splitlines()[:20]:  # 最多印 20 行 diff 摘要
                print(f"    {line}")
    elif ri.status in ("created", "appended"):
        print(f"  CLAUDE.md 紀律區塊已注入({ri.status})")
    elif ri.status == "sentinel_broken":
        print("  ⚠ CLAUDE.md sentinel 半壞,未自動覆蓋,請檢查", file=sys.stderr)
    # unchanged / no_template → 靜默
    return rc


def cmd_update(source=None, no_pull=False):
    """從 Lumos 唯一源 repo 更新「本專案」vendored 的工具組。
    = (git pull Lumos) + install-graph-toolchain --target <本專案> --slug <自動偵測>。
    圖譜資料受 install-graph-toolchain 的 scaffold-skip 保護,不會被動。"""
    src = _lumos_src(source)
    vault = find_vault(Path.cwd())
    if vault is None:
        print("ERROR: 當前目錄找不到 docs/*-knowledge 專案 vault", file=sys.stderr)
        return 2
    root = vault.parent.parent  # docs/<slug>-knowledge → docs → 專案 root
    slug = vault.name[:-len("-knowledge")] if vault.name.endswith("-knowledge") else vault.name
    if root.resolve() == src.resolve():
        print("ERROR: 當前就是 Lumos 來源本身,不需 update", file=sys.stderr)
        return 2
    print(f"lumos update — 來源 {src} → 本專案 {root}（slug={slug}）")
    rc = _vendor_toolchain(src, root, slug, no_pull=no_pull)
    return 2 if rc is None else rc


def _skills_list():
    """user-scope skills=repo skills/ 下所有含 SKILL.md 的目錄(掃目錄防清單漂移——
    舊硬編碼 tuple 曾漏 code-loop 等;同步修 install.sh 同款漂移)。"""
    repo = Path(__file__).resolve().parent.parent
    d = repo / "skills"
    if not d.is_dir():
        return ()
    return tuple(sorted(p.name for p in d.iterdir() if (p / "SKILL.md").is_file()))


_SKILLS = _skills_list()


def _link_or_copy(src: Path, dst: Path):
    """src→dst:Unix symlink、Win 目錄 junction、失敗 fallback 複製。src 須為目錄。"""
    import os, shutil, subprocess
    # W4:Windows junction 不被 is_symlink() 認出。舊碼 rmtree(dst) 會「跟進」junction 刪掉
    # 來源 target;且重跑時 junction 殘留 → mklink 報已存在 → 不冪等。改:junction/空夾用
    # os.rmdir(只移連結本身、不碰 target),真實非空夾才 rmtree。
    if dst.is_symlink():
        dst.unlink()                                  # Unix symlink
    elif dst.is_dir():
        try:
            os.rmdir(dst)                             # junction 或空夾:只移連結/夾,不跟進 target
        except OSError:
            shutil.rmtree(dst, ignore_errors=True)    # 真實非空夾(上次 fallback 複製過)
    elif dst.exists():
        dst.unlink()
    dst.parent.mkdir(parents=True, exist_ok=True)
    try:
        if _IS_WIN:
            # W2:mklink 輸出走 OEM 碼頁(繁中=cp950),text=True 預設 UTF-8 解碼會在
            # reader thread 炸 UnicodeDecodeError。errors="replace" 防炸,returncode 仍可靠。
            r = subprocess.run(["cmd", "/c", "mklink", "/J", str(dst), str(src)],
                               capture_output=True, text=True, encoding="utf-8", errors="replace")
            if r.returncode != 0:
                raise OSError(r.stderr)
        else:
            dst.symlink_to(src)
    except OSError:
        shutil.copytree(src, dst, dirs_exist_ok=True)  # Python ≥ 3.8
        print(f"  ⚠ 連結失敗,改複製(失去 git pull 即更新): {dst}")


def _install_skills():
    repo = Path(__file__).resolve().parent.parent
    dest = Path.home() / ".claude" / "skills"
    for s in _SKILLS:
        src = repo / "skills" / s
        if src.is_dir():
            _link_or_copy(src, dest / s)
            print(f"  ✓ skill {s}")


_INIT_SUBDIRS_FULL = ("Systems", "Verification", "Projects", "Issues", "Sessions", "MOC")


def _scaffold_project(root: Path, slug: str):
    kg = root / "docs" / f"{slug}-knowledge"
    if kg.exists():
        print(f"  ✓ vault 已存在,跳過 scaffold(保護資料): {kg}")
        return
    for d in _INIT_SUBDIRS_FULL:
        (kg / d).mkdir(parents=True, exist_ok=True)
    _write_lf(kg / "MOC" / "index.md",
              f"---\ntype: moc\nstatus: doing\n---\n# {slug} 知識圖譜總索引\n")
    _write_lf(kg / ".gitignore",
              ".bypass-log.jsonl\n.rot-queue.jsonl\n.governance-log.jsonl\n.canary-log.jsonl\n.kill-log.jsonl\n.signoff-log.jsonl\n")
    print(f"  ✓ scaffold {kg}")


def _install_hooks_py(root: Path):
    import subprocess, shutil
    # ① git config core.hooksPath
    subprocess.run(["git", "-C", str(root), "config", "core.hooksPath", "scripts/hooks"])
    # ② 複製 Claude hooks 到 ~/.claude/hooks/(個別 .py 一律 copy,不用 junction:mklink /J 只連目錄)
    chooks = Path.home() / ".claude" / "hooks"
    chooks.mkdir(parents=True, exist_ok=True)
    src_dir = root / "scripts" / "hooks" / "claude"
    for f in ("check-graph-sync.py", "verification-rot-check.py", "impact-hook.py"):
        s = src_dir / f
        if s.exists():
            shutil.copy2(s, chooks / f)
    # ③ settings.json 註冊(Task 3 改 merge-claude-settings.py 用 resolved python)
    merge = root / "scripts" / "merge-claude-settings.py"
    if merge.exists():
        subprocess.run([sys.executable, str(merge)])
    print("  ✓ hooks:core.hooksPath + Claude hooks 複製 + settings 註冊")


def cmd_bootstrap(lumos_url=None, lumos_home=None, pull=False):
    """一鍵在專案內裝好一切:自動 clone Lumos(若缺)→ user-scope skills → 全域 lumos → repo hooks。
    給「剛 clone 專案、機器還沒設定」的同事:cd 進專案打 `python3 scripts/lumos bootstrap` 即可,
    連 Lumos 都不用先手動 clone(專案自帶 vendored lumos 來跑這個)。
    --pull:既有 Lumos clone 也 git pull 拉最新(否則已存在就沿用,拿不到 skills 更新)。"""
    import os, subprocess
    home = Path(lumos_home or os.environ.get("LUMOS_HOME")
                or (Path.home() / "harness" / "lumos-toolchain")).expanduser()
    url = lumos_url or os.environ.get("LUMOS_URL") or "https://github.com/EnzoHsieh-Android/Lumos"
    # 1) 確保 Lumos 來源在(缺則自動 clone;--pull 則既有 clone 也拉最新)
    if (home / "install.sh").exists():
        if pull:
            print(f"[1/3] Lumos 來源已在,git pull 更新: {home}")
            if subprocess.run(["git", "-C", str(home), "pull", "--ff-only"]).returncode != 0:
                print(f"WARN: git pull 失敗(來源有本機改動?),沿用現有 clone", file=sys.stderr)
        else:
            print(f"[1/3] Lumos 來源已在: {home}（--pull 可拉最新 skills）")
    else:
        print(f"[1/3] clone Lumos → {home} …")
        home.parent.mkdir(parents=True, exist_ok=True)
        if subprocess.run(["git", "clone", url, str(home)]).returncode != 0:
            print(f"ERROR: clone 失敗。手動 `git clone {url} {home}` 後重試", file=sys.stderr)
            return 2
    # 2) 全域 lumos → 指向 Lumos 來源(非 vendored copy);install --force 已連帶裝 user-scope skills
    print("[2/3] 裝全域 lumos(+ user-scope skills)…")
    subprocess.run([sys.executable, str(home / "scripts" / "lumos"), "install", "--force"])
    # 3) 本 repo hooks(git toplevel)
    try:
        root = Path(subprocess.check_output(["git", "rev-parse", "--show-toplevel"], text=True).strip())
    except Exception:
        root = Path.cwd()
    if (root / "scripts" / "merge-claude-settings.py").exists():
        print(f"[3/3] 裝 repo hooks（{root}）…")
        _install_hooks_py(root)
    else:
        print(f"[3/3] ⚠ {root} 無 vendored 工具組(找不到 scripts/merge-claude-settings.py),跳過 hooks", file=sys.stderr)
    print("\n✓ bootstrap 完成。最後一步:**重啟 Claude Code session**(L1/L3 hooks 要 session start 才載入)。")
    return 0


def _slugify_vault(name: str):
    """repo basename → vault slug:小寫、非英數轉 -、收斂連續 -、去頭尾 -、去既有 -knowledge 尾。"""
    s = re.sub(r"[^a-z0-9]+", "-", name.lower()).strip("-")
    if s.endswith("-knowledge"):
        s = s[:-len("-knowledge")]
    return s or "project"


def cmd_init(name=None, force=False, with_hooks=True, no_pull=False):
    """在當前 repo 初始化知識圖譜:建 docs/<slug>-knowledge/{6 個資料夾} + .gitignore,
    預設並 vendor 工具組 + 裝 pre-commit/pre-push 閘(--no-hooks 只建圖譜輕量版)。
    像 `openspec init`:一行開好就能 `lumos new`。
    分工:init = 專案層(圖譜 + 該 repo 的 hooks);bootstrap = 機器層(clone Lumos/skills/全域 lumos),一輩子一次。
    序列(既有 vault 非 force):只 _reinject_claude_block(讀本機已 vendor 範本,不 pull、不重裝 hooks)→ early-return。
    序列(新 vault 或 --force):_vendor_toolchain(pull + copy2 + hooks + reinject) → scaffold → 完成。
    no_hooks 路徑(不分新/既有):只 _reinject_claude_block(讀本機已 vendor 範本,無則靜默)。"""
    import subprocess
    try:
        root = Path(subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], text=True, stderr=subprocess.DEVNULL).strip())
    except Exception:
        root = Path.cwd()
    existing = _vault_in(root)
    # slug 決定順序:① --name 顯式 ② 既有 vault 的 slug ③ repo basename。
    # ②必須先於③:否則既有 vault 上跑 --force 會用 repo basename 當 slug,
    # 建錯一個空 vault + 把 CLAUDE.md {{KG}} 路徑寫錯(現場事故:basename landmarkmember
    # vs 既有 vault landmark-knowledge)。既有 vault 的資料夾名即權威 slug,不重新 slugify。
    if name:
        slug = _slugify_vault(name)
    elif existing is not None and existing.name.endswith("-knowledge"):
        slug = existing.name[:-len("-knowledge")]
    else:
        slug = _slugify_vault(root.name)

    # ── Step 1: reinject CLAUDE.md(依路徑輕/重分流)─────────────────────
    # 既有 vault 非 force:只 reinject(輕量);不 pull、不重裝 hooks。
    # 新 vault 或 --force:完整 _vendor_toolchain(pull + copy2 + hooks + reinject)。
    # no_hooks 路徑:一律只 reinject(讀本機已 vendor 範本,無則靜默)。
    def _do_reinject():
        ri = _reinject_claude_block(root, slug)
        if ri.status == "updated":
            print("  CLAUDE.md 紀律區塊已更新")
        elif ri.status in ("created", "appended"):
            print(f"  CLAUDE.md 紀律區塊已注入({ri.status})")
        elif ri.status == "sentinel_broken":
            print("  ⚠ CLAUDE.md sentinel 半壞,未自動覆蓋,請檢查", file=sys.stderr)
        # unchanged / no_template → 靜默

    if with_hooks:
        src = _lumos_src()
        if root.resolve() == src.resolve():
            print("\n  (當前就是 Lumos 來源本身,跳過 vendor/hooks)")
        elif existing is not None and not force:
            # 既有 vault 非 force:輕量路徑,只刷新 CLAUDE.md 紀律區塊
            _do_reinject()
        else:
            # 新 vault 或 --force:完整 vendor(pull + copy2 + hooks + reinject)
            print(f"lumos init — 在 {root} 建圖譜 vault: docs/{slug}-knowledge/")
            print("\n裝 hooks:vendor 工具組 + 啟用 pre-commit/pre-push 閘…")
            rc = _vendor_toolchain(src, root, slug, no_pull=no_pull)
            # _vendor_toolchain 已呼叫 _install_hooks_py + _reinject_claude_block;不重複
            if rc is None:
                print("  ⚠ 來源不可用,略過 hooks(圖譜已建好)。日後補裝:lumos update")
    else:
        # no_hooks:讀本機 vendored 範本執行 reinject(無範本 → no_template → 靜默)
        _do_reinject()

    # ── Step 2: existing/force 判定 ───────────────────────────────────
    if existing is not None and not force:
        print(f"✓ 此 repo 已有 vault: {existing.relative_to(root)}")
        print("  (要另建用 --name <slug>;要在既有 vault 上重裝/更新 hooks 與工具組用 --force,vault 內容不動)")
        return 0

    # ── Step 3: scaffold 圖譜資料(新 vault;既有 vault 內部 kg.exists() guard 保護) ──
    if not with_hooks:
        print(f"lumos init — 在 {root} 建圖譜 vault: docs/{slug}-knowledge/")
    _scaffold_project(root, slug)  # 6 夾 + .gitignore + MOC/index.md;既有 vault 自動 skip 保護資料

    print("\n✓ init 完成。開始用:")
    print(f"    cd {root}")
    print("    lumos new system <模組名>     # 建第一個系統節點")
    print("    lumos doctor                  # 健檢")
    if with_hooks:
        print("  (已裝 pre-commit/pre-push 閘:改 code 沒更新圖譜會被擋)")
    return 0


def _vault_in(d: Path):
    """d 之下是否有 vault: docs/*-knowledge 或 docs/knowledge(專案佈局),
    或 d 本身就是 vault root(standalone,如核心 repo:有 MOC/ + Verification|Systems)。"""
    docs = d / "docs"
    if docs.is_dir():
        for sub in sorted(docs.iterdir()):
            if sub.is_dir() and sub.name.endswith("-knowledge"):
                return sub
        if (docs / "knowledge").is_dir():
            return docs / "knowledge"
    # standalone vault root(核心 repo 等):MOC/ + (Verification/ 或 Systems/)
    if (d / "MOC").is_dir() and ((d / "Verification").is_dir() or (d / "Systems").is_dir()):
        return d
    return None


def find_vault(start: Path):
    """從 cwd 往上走找 vault(全域安裝後可從任何專案子目錄跑)。"""
    start = start.resolve()
    for d in [start, *start.parents]:
        v = _vault_in(d)
        if v is not None:
            return v
        if (d / ".git").exists():  # 到 repo 根還沒找到就停(別爬出專案)
            break
    return None



ANCHOR_FILES = [
    "scripts/test_lumos.py",
    "scripts/test_autonomous_loop.py",
    "scripts/hooks/pre-commit",
    "scripts/hooks/pre-push",
    "scripts/hooks/post-commit",
]
_ANCHOR_BASELINE_REL = "governance/anchor-baseline.json"


def _anchor_repo_root(repo):
    """--repo 顯式優先;省略時 cwd 逐層向上找 .git(同 refcheck 慣例)。失敗印錯回 None。"""
    if repo is not None:
        p = Path(repo)
        if not p.is_dir():
            print(f"ERROR: --repo 不是目錄: {repo}", file=sys.stderr)
            return None
        return p
    for cand in (Path.cwd(), *Path.cwd().parents):
        if (cand / ".git").exists():
            return cand
    print("ERROR: cwd 逐層向上找不到 .git repo,請用 --repo 指定", file=sys.stderr)
    return None


def cmd_anchor_verify(repo=None, as_json=False):
    """錨點完整性核對:baseline 內每個錨點檔算 sha256 比對。
    全符 rc=0;mismatch/缺檔 rc=1;baseline 不存在 rc=0+警示(漸進採用);參數錯 rc=2。
    只證「驗證器檔案沒被動過」,不證測試本身寫得對(spec 誠實天花板)。"""
    import json
    import hashlib
    repo_root = _anchor_repo_root(repo)
    if repo_root is None:
        return 2
    bp = repo_root / _ANCHOR_BASELINE_REL
    if not bp.exists():
        print("anchor: baseline 不存在(未啟用)——`lumos anchor approve --note` 建立後生效")
        return 0
    try:
        data = json.loads(bp.read_text(encoding="utf-8"))
    except (OSError, ValueError) as e:
        print(f"ERROR: baseline 讀取失敗: {e}", file=sys.stderr)
        return 2
    mismatches = []
    for rel, expected in sorted(data.get("anchors", {}).items()):
        f = repo_root / rel
        if not f.is_file():
            mismatches.append({"file": rel, "expected": expected, "actual": "(缺檔)"})
            continue
        actual = hashlib.sha256(f.read_bytes()).hexdigest()
        if actual != expected:
            mismatches.append({"file": rel, "expected": expected, "actual": actual})
    if as_json:
        print(json.dumps({"ok": not mismatches, "mismatches": mismatches}, ensure_ascii=False))
    elif mismatches:
        print("✗ anchor verify 失敗——驗證器檔案與 baseline 不符:")
        for m in mismatches:
            act = m["actual"] if m["actual"] == "(缺檔)" else m["actual"][:16] + "…"
            print(f"  {m['file']}(期望 {m['expected'][:16]}… 實際 {act})")
        print("非刻意 → git checkout 還原;刻意改錨點 → lumos anchor approve --note \"理由\"")
    else:
        print(f"✓ anchor verify — {len(data.get('anchors', {}))} 個錨點全符")
    return 1 if mismatches else 0


def cmd_anchor_approve(repo=None, note=None, vault=None):
    """重算全部錨點 sha256 寫回 baseline + governance-log 留痕(anchor-approve 事件)。
    改錨點檔的唯一合法路徑;--note 必填(空理由=無資訊留痕)。"""
    import json
    import hashlib
    import datetime
    if not note or not note.strip():
        print("ERROR: --note 必填(留痕理由)", file=sys.stderr)
        return 2
    repo_root = _anchor_repo_root(repo)
    if repo_root is None:
        return 2
    anchors, absent = {}, []
    for rel in ANCHOR_FILES:
        f = repo_root / rel
        if f.is_file():
            anchors[rel] = hashlib.sha256(f.read_bytes()).hexdigest()
        else:
            absent.append(rel)
    if absent:
        print(f"⚠ 錨點檔缺失(不入 baseline): {', '.join(absent)}")
    bp = repo_root / _ANCHOR_BASELINE_REL
    prev = {}
    if bp.exists():
        try:
            prev = json.loads(bp.read_text(encoding="utf-8")).get("anchors", {})
        except (OSError, ValueError):
            prev = {}
    changed = sorted({k for k in anchors if anchors[k] != prev.get(k)} | (set(prev) - set(anchors)))
    bp.parent.mkdir(parents=True, exist_ok=True)
    payload = {"version": 1, "anchors": anchors,
               "approved_at": datetime.datetime.now().astimezone().isoformat(timespec="seconds"),
               "note": note}
    bp.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    v = vault or find_vault(Path.cwd())
    if v is None:
        print("⚠ 無 vault:baseline 已寫,governance-log 留痕跳過")
    else:
        _append_governance_log(v, [{"gate": "anchor-approve", "kind": "approved",
                                    "hard": False, "nodes": changed, "note": note}])
    print(f"✓ anchor approve — {len(anchors)} 個錨點寫入 baseline({len(changed)} 個變更)")
    return 0


def _validate_repo_ref(repo_root, token, line):
    """驗一條 repo 內檔案指涉:回 (status, excerpt)。status ∈ missing/line_out_of_range/ok。
    _refcheck_scan 與 check_regen_provenance(Check J 的 [src:] 驗證)共用——
    J-c 不得走 _refcheck_scan 抽取入口(inline-code 抽取 + top_dirs 靜默過濾會把假目錄放行,
    正是 J-c 要擋的幻覺;此 helper 直收已解析 path/line,無靜默過濾)。
    token 消毒(code-review blocker 修):空/絕對路徑/含 .. 一律 missing——top_dirs 過濾
    被拆掉時它隱含的安全性(空值/絕對/traversal 天然進不了 top_dirs)必須在此顯式補回,
    否則 [src: ]/[src:/etc/passwd]/[src:../..] 會 resolve 到 repo 外真實存在的路徑而判 ok。"""
    token = token.strip()
    from pathlib import PurePosixPath, PureWindowsPath
    if (not token
            or PurePosixPath(token).is_absolute() or PureWindowsPath(token).is_absolute()
            or ".." in PurePosixPath(token).parts):
        return "missing", ""
    target = repo_root / token
    if not target.exists():
        return "missing", ""
    if target.is_dir() or not line:
        return "ok", ""
    if "-" in line:
        lo, hi = (int(x) for x in line.split("-", 1))
    else:
        lo = hi = int(line)
    try:
        file_lines = target.read_text(encoding="utf-8-sig", errors="replace").splitlines()
    except OSError:
        file_lines = None
    if file_lines is None or lo < 1 or hi > len(file_lines):
        return "line_out_of_range", ""
    if lo == hi:
        return "ok", file_lines[lo - 1]
    return "ok", file_lines[lo - 1] + "\n…\n" + file_lines[hi - 1]


def _refcheck_scan(text, repo_root):
    """refcheck 抽取+核對核心(不列印):回 (claims, n_missing, n_oor, n_ok)。
    cmd_refcheck 與 loop status --gate(G1 錨)共用;抽取規則見 cmd_refcheck docstring。
    核對段走 _validate_repo_ref(與 Check J 共用);抽取段(inline-code+top_dirs 過濾)維持原規則。"""
    top_dirs = {p.name for p in repo_root.iterdir() if p.is_dir() and not p.name.startswith(".")}
    _suffix_re = re.compile(r":([^/]+)$")
    spans = [s.strip("`") for s in INLINE_CODE_RE.findall(FENCE_RE.sub("", text))]
    seen = set()
    claims = []
    for raw in spans:
        if "://" in raw or any(c in raw for c in "*<>?"):
            continue
        m = _suffix_re.search(raw)
        if m:
            token, sfx = raw[:m.start()], m.group(1)
            line = sfx if re.fullmatch(r"\d+(?:-\d+)?", sfx) else ""
        else:
            token, line = raw, ""
        if "/" not in token or (token, line) in seen:
            continue
        if token.split("/")[0] not in top_dirs:
            continue
        seen.add((token, line))
        status, excerpt = _validate_repo_ref(repo_root, token, line)
        claim = {"token": token, "line": line, "status": status, "excerpt": excerpt}
        if status == "ok" and (repo_root / token).is_dir():
            claim["dir"] = True
        claims.append(claim)

    n_missing = sum(1 for c in claims if c["status"] == "missing")
    n_oor = sum(1 for c in claims if c["status"] == "line_out_of_range")
    n_ok = sum(1 for c in claims if c["status"] == "ok")
    return claims, n_missing, n_oor, n_ok


PITFALL_CLASSES = {
    "payment": [r"金流", r"payment", r"stripe", r"billing", r"退款", r"refund", r"扣款"],
    "external-send": [r"寄送", r"送出", r"\bsend\b", r"webhook", r"notify", r"LINE 推送", r"\bmail\b", r"簡訊", r"對外"],
    "prod-irreversible": [r"\bprod\b", r"production", r"遷移", r"migration", r"不可逆", r"DROP TABLE", r"DELETE FROM", r"上架"],
    "self-governance": [r"錨點", r"anchor verify", r"收斂判準", r"canary", r"審計閘", r"pre-push hook"],
}
_PITFALL_COMPILED = {c: [re.compile(p, re.I) for p in pats] for c, pats in PITFALL_CLASSES.items()}
_PITFALL_GENERAL = [
    "併發——同資源兩請求同時進來會怎樣?",
    "效能——這段會進熱路徑/大資料量嗎?",
    "資源——連線/檔案/鎖有沒有確定釋放?",
]
_PITFALL_QUESTIONS = {
    "payment": "冪等鍵怎麼設計?重複扣款如何防?部分失敗怎麼補償/對帳?",
    "external-send": "重試會不會風暴?收端如何去重?超時與速率上限?",
    "prod-irreversible": "回滾路徑?遷移順序與鎖表窗口?",
    "self-governance": "誤擋的逃生口?繞過有沒有留痕?",
}
_PITFALL_BLACKLIST = ("方案評比", "canary 相容性", "誠實天花板", "審計修正紀錄")
# diff 模式:代碼形態 pattern:(regex, 形態類軸, 提問)——類軸限 併發/效能/資源(非四業務類)
_PITFALL_DIFF_PATTERNS = [
    (re.compile(r"requests\.\w+\(|httpx\.\w+\(", re.I), "資源", "HTTP 呼叫有沒有 timeout?"),
    (re.compile(r"\bopen\s*\(", re.I), "資源", "檔案 handle 有沒有 with/確定 close?"),
    (re.compile(r"\bSELECT\b", re.I), "效能", "是否在迴圈內、造成 N+1?"),
    (re.compile(r"\btime\.sleep\s*\(", re.I), "效能", "sleep 在迴圈裡會不會累積延遲?"),
    (re.compile(r"\bthreading\.|\bLock\s*\(|global\s+\w+", re.I), "併發", "共享狀態有沒有鎖保護?"),
    (re.compile(r"\bINSERT\b|\bUPDATE\b|\bDELETE\b", re.I), "併發", "寫入有沒有交易包裹?"),
]
_PITFALL_DIFF_SKIP_EXT = {".md", ".txt", ".rst"}
_PITFALL_DIFF_TEST_PAT = re.compile(r"(test_|_test\.|\.spec\.|/tests?/)", re.I)
LINT_CMD_TIMEOUT = 180


def _diff_added_lines(diff_text):
    """從 git diff -U3 輸出建 {file: set(new_line_numbers)} 對應所有新增行(+ 開頭)。
    使用與 _pitfall_diff_mode 相同的 @@ 標頭推導邏輯。"""
    added = {}
    cur_file, new_ln = "", 0
    for line in diff_text.splitlines():
        if line.startswith("+++ b/"):
            cur_file = line[6:]
            continue
        m = re.match(r"@@ -\d+(?:,\d+)? \+(\d+)", line)
        if m:
            new_ln = int(m.group(1))
            continue
        if line.startswith("+++") or line.startswith("---"):
            continue
        if line.startswith("-"):
            continue                          # 刪除行不推進新檔行號
        if not line.startswith("+"):
            new_ln += 1                       # context 行推進
            continue
        # 這是新增行(+ 開頭)
        if cur_file:
            added.setdefault(cur_file, set()).add(new_ln)
        new_ln += 1                           # 新增行推進新檔行號
    return added


def _lint_aligned(diff_range, repo_root):
    """判斷 diff_range 右端 ref 是否與工作區 HEAD 對齊(座標系一致)。
    右端:先 rsplit('...', 1) 再 rsplit('..', 1);空→HEAD;無 .. → 工作區比較恆 True。
    對齊 = git rev-parse <right> == git rev-parse HEAD 且 git status --porcelain 空。
    任何子程序失敗 → False。"""
    import subprocess
    # 提取右端 ref
    if "..." in diff_range:
        right = diff_range.rsplit("...", 1)[1]
    elif ".." in diff_range:
        right = diff_range.rsplit("..", 1)[1]
    else:
        # 無 .. → 工作區比較,恆對齊
        return True
    if not right:
        right = "HEAD"
    try:
        r_right = subprocess.run(
            ["git", "rev-parse", right],
            capture_output=True, text=True, cwd=str(repo_root))
        r_head = subprocess.run(
            ["git", "rev-parse", "HEAD"],
            capture_output=True, text=True, cwd=str(repo_root))
        r_status = subprocess.run(
            ["git", "status", "--porcelain"],
            capture_output=True, text=True, cwd=str(repo_root))
    except FileNotFoundError:
        return False
    if r_right.returncode != 0 or r_head.returncode != 0 or r_status.returncode != 0:
        return False
    return (r_right.stdout.strip() == r_head.stdout.strip()
            and r_status.stdout.strip() == "")


def _lint_load_config(repo_root):
    """讀取 repo_root/.lumos/lint.json → dict;不存在或解析失敗 → None。"""
    import json
    p = Path(repo_root) / ".lumos" / "lint.json"
    if not p.exists():
        return None
    try:
        with open(p, encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return None


def _lint_stacks_for_diff(added, config):
    """由 added({file: set(line_numbers)}) 與 config(lint.json dict) 推導待執行指令列表。
    每個 added 檔案取副檔名(lstrip('.'))比對 config key;命中則收其指令 list。
    去重保序(first-seen order),同一指令只收一次。"""
    seen = set()
    result = []
    for f in added:
        ext = Path(f).suffix.lstrip(".")
        if ext in config:
            for cmd in config[ext]:
                if cmd not in seen:
                    seen.add(cmd)
                    result.append(cmd)
    return result


def _lintcheck_validate(config):
    """靜態校驗 .lumos/lint.json 宣告格式,回 problems 列表(每項 {stack,issue})。
    正確格式={副檔名: [含 {LINT_SARIF_OUT} 的命令字串,...]}。抓「宣告了明顯壞的東西」:
    非 dict / value 非 list / 命令非字串或空 / 缺 SARIF 輸出佔位符。空 dict=合法無宣告。
    只驗格式不驗命令跑不跑得動(那是 --smoke 冒煙的事)。設計 [[Systems/lint-declaration-health]]。"""
    problems = []
    if not isinstance(config, dict):
        problems.append({"stack": "<root>", "issue": "lint.json 頂層必須是 dict(副檔名→命令列表)"})
        return problems
    for stack, cmds in config.items():
        if not isinstance(cmds, list):
            problems.append({"stack": stack, "issue": f"value 必須是命令列表(list),實得 {type(cmds).__name__}"})
            continue
        if not cmds:
            problems.append({"stack": stack, "issue": "命令列表為空"})
            continue
        for idx, cmd in enumerate(cmds):
            if not isinstance(cmd, str) or not cmd.strip():
                problems.append({"stack": stack, "issue": f"第 {idx} 條命令為空或非字串"})
                continue
            if "{LINT_SARIF_OUT}" not in cmd:
                problems.append({"stack": stack, "issue": f"第 {idx} 條命令缺 {{LINT_SARIF_OUT}} 佔位符(SARIF 無處輸出=不會被消費)"})
    return problems


def cmd_lint_check(repo=None, smoke=False, as_json=False):
    """檢查 .lumos/lint.json 宣告健康度(收「宣告了跑不動的東西」破口)。
    靜態層(恆跑):格式校驗(見 _lintcheck_validate)。--smoke:真跑每條命令、驗有無產出可解析
    SARIF——抓「格式對但 task 不存在/plugin 沒裝」的空殼(如 KDS detektMain)。
    rc:0=健康(含無宣告)/1=有問題/2=lint.json 非 JSON。設計 [[Systems/lint-declaration-health]]。"""
    import json
    repo_root = _anchor_repo_root(repo)
    if repo_root is None:
        print("lint-check: 找不到 repo root", file=sys.stderr)
        return 0
    p = Path(repo_root) / ".lumos" / "lint.json"
    if not p.exists():
        if as_json:
            print(json.dumps({"problems": [], "declared": False}, ensure_ascii=False))
        return 0
    try:
        with open(p, encoding="utf-8") as f:
            config = json.load(f)
    except (OSError, json.JSONDecodeError) as e:
        print(f"✗ lint-check: .lumos/lint.json 不是合法 JSON: {e}", file=sys.stderr)
        return 2
    problems = _lintcheck_validate(config)
    # --smoke:靜態層無格式問題才冒煙(格式壞的命令沒必要跑)
    if smoke and not problems and isinstance(config, dict):
        for stack, cmds in config.items():
            for cmd in (cmds if isinstance(cmds, list) else []):
                _claims, ok = _lint_run_and_parse(cmd, repo_root)
                if not ok:
                    problems.append({"stack": stack, "issue": f"冒煙失敗:命令跑不出可解析 SARIF(task 不存在/工具沒裝?)｜{cmd[:60]}"})
    if as_json:
        print(json.dumps({"problems": problems, "declared": True}, ensure_ascii=False))
        return 1 if problems else 0
    if not problems:
        print(f"✓ lint-check: .lumos/lint.json 宣告健康({'冒煙通過' if smoke else '格式通過,--smoke 可再驗命令'})")
        return 0
    print(f"✗ lint-check: .lumos/lint.json 有 {len(problems)} 個問題:")
    for pr in problems:
        print(f"  [{pr['stack']}] {pr['issue']}")
    return 1


def _testlayers_load_config(repo_root):
    """讀取 repo_root/.lumos/test-layers.json → dict;不存在/解析失敗/非 dict → None(fail-open)。"""
    import json
    p = Path(repo_root) / ".lumos" / "test-layers.json"
    if not p.exists():
        return None
    try:
        with open(p, encoding="utf-8") as f:
            cfg = json.load(f)
        return cfg if isinstance(cfg, dict) else None
    except Exception:
        return None


def _testlayers_hits(files, config):
    """files 副檔名(lstrip '.')比對 config key(語意同 _lint_stacks_for_diff)。
    回傳 [(key, entry, 命中檔數)],key 依首見序去重。"""
    order = []
    counts = {}
    for f in files:
        ext = Path(f).suffix.lstrip(".")
        if ext in config:
            if ext not in counts:
                order.append(ext)
                counts[ext] = 0
            counts[ext] += 1
    return [(k, config[k], counts[k]) for k in order]


def _lint_run_and_parse(cmd, repo_root):
    """執行宣告的 lint 指令並解析 SARIF 輸出為 claims 清單。
    cmd: 含 {LINT_SARIF_OUT} 佔位符的 shell 指令字串。
    repo_root: git repo 根目錄(Path 或 str)。
    回傳 (list[claim], bool)——claim={file,line,source,rule,message};ok=成功產出可解析 SARIF。
    rc≠0 不算失敗,detekt 等工具有問題時仍輸出有效 SARIF。"""
    import json
    import os
    import shlex
    import signal
    import subprocess
    import tempfile
    import urllib.parse

    repo_root = str(repo_root)
    # 生成獨立的臨時檔案路徑
    fd, temp_path = tempfile.mkstemp(suffix=".sarif", prefix="lumos-lint-")
    os.close(fd)
    try:
        # 注入臨時檔路徑到指令
        injected_cmd = cmd.replace("{LINT_SARIF_OUT}", shlex.quote(temp_path))
        # 執行指令:使用 Popen 以便 TimeoutExpired 時能 killpg。
        # stdout/stderr → DEVNULL:linter 的 console 輸出(dotnet 警告走 stdout、detekt 走 stderr)
        # 不可洩漏到 lumos 的 stdout,否則污染 --json 輸出(SARIF 走檔案、console 輸出非契約)。
        proc = subprocess.Popen(
            injected_cmd,
            shell=True,
            cwd=repo_root,
            start_new_session=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        try:
            proc.communicate(timeout=LINT_CMD_TIMEOUT)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(os.getpgid(proc.pid), signal.SIGKILL)
            except (ProcessLookupError, OSError):
                pass
            proc.wait()
            return ([], False)
        # 讀臨時檔:空或 parse 失敗 → ([], False)
        try:
            with open(temp_path, encoding="utf-8") as f:
                content = f.read()
        except OSError:
            return ([], False)
        if not content.strip():
            return ([], False)
        try:
            data = json.loads(content)
        except json.JSONDecodeError:
            return ([], False)
        # 解析 SARIF(支援 v2.1 與 v1.0——dotnet/Roslyn ErrorLog 預設吐 v1,Landmark 真機坐實)
        claims = []
        runs = data.get("runs") or []
        sarif_v1 = str(data.get("version", "")).startswith("1")
        for run in runs:
            # Finding 1: guard run-level structure — malformed run skipped, not crashed
            tool = run.get("tool", {})
            driver_name = tool.get("name") if sarif_v1 else tool.get("driver", {}).get("name")
            if not driver_name:
                continue
            base = run.get("originalUriBaseIds", {})
            for r in (run.get("results") or []):
                try:
                    if sarif_v1:
                        # v1: locations[].resultFile.{uri,region};message 為字串
                        rf = r["locations"][0]["resultFile"]
                        uri = rf["uri"]
                        start_line = rf.get("region", {}).get("startLine", 0)
                        msg = r.get("message")
                        message_text = (msg if isinstance(msg, str) else (msg or {}).get("text", ""))[:120]
                    else:
                        # v2.1: locations[].physicalLocation.artifactLocation;message.text
                        loc = r["locations"][0]["physicalLocation"]
                        art_loc = loc["artifactLocation"]
                        uri = art_loc["uri"]
                        uri_base_id = art_loc.get("uriBaseId")
                        if uri_base_id and uri_base_id in base:
                            uri = base[uri_base_id]["uri"] + uri
                        start_line = loc.get("region", {}).get("startLine", 0)
                        msg = r.get("message") or {}
                        message_text = (msg.get("text", "") if isinstance(msg, dict) else str(msg))[:120]
                    # 共用 uri 正規化:剝 file:// + unquote + 絕對路徑 relpath + 反斜線正規化
                    if uri.startswith("file://"):
                        uri = uri[7:]
                    uri = urllib.parse.unquote(uri)
                    if os.path.isabs(uri):
                        rel = os.path.relpath(uri, repo_root)
                    else:
                        rel = uri
                    rel = rel.replace("\\", "/")
                    rule_id = r.get("ruleId", "")
                    claims.append({
                        "file": rel,
                        "line": start_line,
                        "source": f"lint:{driver_name}",
                        "rule": rule_id,
                        "message": message_text,
                    })
                except (KeyError, IndexError):
                    continue
        return (claims, True)
    finally:
        try:
            os.unlink(temp_path)
        except OSError:
            pass


def _semver_parse(v):
    s = v.strip()
    if s[:1].lower() == "v":
        s = s[1:]
    parts = s.split(".")
    if not parts or not all(p.isdigit() for p in parts):
        return None
    return tuple(int(p) for p in parts)


def _is_prerelease(v):
    import re
    s = v.lower()
    if "-" in s:
        return True
    return re.search(r'(?:\d|[-._])(a|b|c|rc|alpha|beta|dev|pre)\d*(?:$|[-._\d])', s) is not None


def _compare_versions(current, latest):
    if _is_prerelease(current) or _is_prerelease(latest):
        return ("skip", "prerelease")
    cu, la = _semver_parse(current), _semver_parse(latest)
    if cu is None or la is None:
        return ("skip", "unparseable")
    if len(cu) != len(la):
        return ("skip", "segment-count-mismatch")
    return ("behind", "") if la > cu else ("current", "")


def _http_get_text(url):
    """Fetch URL and return raw decoded text (utf-8), or None on any failure.

    If env var LUMOS_LINT_WATCH_FIXTURE is set, reads that JSON file and
    returns fixture.get(url) — the stored value for text-type urls is expected
    to be a STRING (e.g. XML text); if the key is missing, returns None.
    Otherwise uses urllib.request with timeout=10s.
    """
    import os
    fixture_path = os.environ.get("LUMOS_LINT_WATCH_FIXTURE")
    if fixture_path:
        import json
        try:
            with open(fixture_path, encoding="utf-8") as fh:
                fixture = json.load(fh)
            return fixture.get(url)
        except Exception:
            return None
    import urllib.request
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "lumos-lint-watch"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            if resp.status < 200 or resp.status >= 300:
                return None
            return resp.read().decode("utf-8")
    except Exception:
        return None


def _http_get_json(url):
    """Fetch URL and return parsed JSON dict, or None on any failure.

    If env var LUMOS_LINT_WATCH_FIXTURE is set, reads that JSON file (a
    {url: response_dict} map) and returns fixture.get(url) — never hitting
    the network.  Otherwise uses urllib.request with timeout=10s.
    """
    import os
    fixture_path = os.environ.get("LUMOS_LINT_WATCH_FIXTURE")
    if fixture_path:
        import json
        try:
            with open(fixture_path, encoding="utf-8") as fh:
                fixture = json.load(fh)
            return fixture.get(url)
        except Exception:
            return None
    import json
    import urllib.request
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "lumos-lint-watch"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            if resp.status < 200 or resp.status >= 300:
                return None
            return json.loads(resp.read().decode("utf-8"))
    except Exception:
        return None


def _registry_latest(registry, fetch=None):
    """Return (version, None) on success or (None, reason) on failure.

    registry format: "<type>:<coord>"
      pypi:<pkg>
      npm:<pkg>
      github:<owner>/<repo>
      maven:<group>:<artifact>
      google-maven:<group>:<artifact>
      nuget:<PackageId>
    """
    if fetch is None:
        fetch = _http_get_json
    try:
        import urllib.parse
        rtype, _, coord = registry.partition(":")
        if rtype == "pypi":
            url = f"https://pypi.org/pypi/{coord}/json"
            d = fetch(url)
            if d is None:
                return (None, "registry query failed: fetch returned None")
            try:
                version = d["info"]["version"]
            except (KeyError, TypeError) as e:
                return (None, f"registry query failed: {e}")
            if _is_prerelease(version):
                return (None, "latest is prerelease")
            return (version, None)

        elif rtype == "npm":
            url = f"https://registry.npmjs.org/{coord}/latest"
            d = fetch(url)
            if d is None:
                return (None, "registry query failed: fetch returned None")
            try:
                version = d["version"]
            except (KeyError, TypeError) as e:
                return (None, f"registry query failed: {e}")
            if _is_prerelease(version):
                return (None, "latest is prerelease")
            return (version, None)

        elif rtype == "github":
            url = f"https://api.github.com/repos/{coord}/releases/latest"
            d = fetch(url)
            if d is None:
                return (None, "registry query failed: fetch returned None")
            try:
                tag = d["tag_name"]
            except (KeyError, TypeError) as e:
                return (None, f"registry query failed: {e}")
            version = tag.lstrip("v") if tag.startswith("v") else tag
            if _is_prerelease(version):
                return (None, "latest is prerelease")
            return (version, None)

        elif rtype == "maven":
            group, _, artifact = coord.partition(":")
            q = urllib.parse.quote(f'g:"{group}" AND a:"{artifact}"')
            url = (f"https://search.maven.org/solrsearch/select?q={q}"
                   "&core=gav&sort=timestamp+desc&rows=20&wt=json")
            d = fetch(url)
            if d is None:
                return (None, "registry query failed: fetch returned None")
            try:
                docs = (d.get("response") or {}).get("docs") or []
                stable = [x["v"] for x in docs if x.get("v") and not _is_prerelease(x["v"])]
                stable = [v for v in stable if _semver_parse(v)]
            except Exception as e:
                return (None, f"registry query failed: {e}")
            if not stable:
                return (None, "no stable version")
            return (max(stable, key=_semver_parse), None)

        elif rtype == "google-maven":
            # Google Maven (dl.google.com) — returns XML, not JSON.
            # TRAP: <latest>/<release> tags can be prerelease (e.g. AGP 9.4.0-alpha03).
            # Must iterate ALL <version> elements, filter _is_prerelease, take numeric max.
            try:
                group, _, artifact = coord.partition(":")
                url = ("https://dl.google.com/dl/android/maven2/"
                       + group.replace(".", "/") + "/" + artifact + "/maven-metadata.xml")
                xml_text = _http_get_text(url)
                if xml_text is None:
                    return (None, f"registry query failed: fetch returned None for {url}")
                import xml.etree.ElementTree as ET
                root = ET.fromstring(xml_text)
                versions = [e.text for e in root.iter("version") if e.text]
                stable = [v for v in versions if not _is_prerelease(v) and _semver_parse(v) is not None]
                if not stable:
                    return (None, "no stable version")
                return (max(stable, key=_semver_parse), None)
            except Exception as e:
                return (None, f"registry query failed: {e}")

        elif rtype == "nuget":
            # NuGet flatcontainer:index.json 回 {"versions":[...]}(升序,含 prerelease)。
            # id 需小寫(flatcontainer 慣例);過濾 prerelease 後數值 max。
            url = f"https://api.nuget.org/v3-flatcontainer/{coord.lower()}/index.json"
            d = fetch(url)
            if d is None:
                return (None, "registry query failed: fetch returned None")
            try:
                versions = d.get("versions") or []
                stable = [v for v in versions if not _is_prerelease(v) and _semver_parse(v) is not None]
            except Exception as e:
                return (None, f"registry query failed: {e}")
            if not stable:
                return (None, "no stable version")
            return (max(stable, key=_semver_parse), None)

        else:
            return (None, f"registry query failed: unknown type {rtype!r}")
    except Exception as e:
        return (None, f"registry query failed: {e}")


def _compose_read_module(metrics_dir, prefix):
    """Parse <metrics_dir>/<prefix>-module.json; missing file or parse error → None."""
    import json, os
    p = os.path.join(metrics_dir, prefix + "-module.json")
    if not os.path.exists(p):
        return None
    try:
        with open(p, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return None


def _compose_read_composables(reports_dir, prefix):
    """Parse composables CSV + TXT for a given prefix.

    Returns (non_skippable_fqns:set, fqn_to_name:dict, unstable_map:dict).
    Missing CSV → (set(), {}, {}); missing TXT → unstable_map empty.
    """
    import csv, os
    non_skippable_fqns = set()
    fqn_to_name = {}
    unstable_map = {}

    csv_path = os.path.join(reports_dir, prefix + "-composables.csv")
    if not os.path.exists(csv_path):
        return (set(), {}, {})
    with open(csv_path, newline="", encoding="utf-8") as f:
        for row in csv.DictReader(f):
            fqn = row["package"]
            fqn_to_name[fqn] = row["name"]
            if row.get("skippable") == "0" and row.get("restartable") == "1":
                non_skippable_fqns.add(fqn)

    txt_path = os.path.join(reports_dir, prefix + "-composables.txt")
    if os.path.exists(txt_path):
        cur = None
        with open(txt_path, encoding="utf-8") as f:
            for line in f:
                if "fun " in line and "(" in line:
                    # Block start: extract name, strip generics.
                    # Split on first "fun " to handle both col-0 bare `fun Foo(`
                    # and keyword-prefixed `restartable scheme(...) fun Foo(`.
                    name = line.split("fun ", 1)[1].split("(", 1)[0]
                    name = name.split("<", 1)[0]
                    cur = name
                    unstable_map[cur] = []
                elif cur is not None and line.strip().startswith("unstable "):
                    unstable_map[cur].append(line.strip()[len("unstable "):])
                # Empty lines and other lines do not change cur

    return (non_skippable_fqns, fqn_to_name, unstable_map)


COMPOSE_RATIO_EPS = 0.01


def _compose_diff(module, baseline_mod, cur_agg, cur_non_skippable, fqn_to_name, umap):
    """Return list of regression dicts for one module.

    Regression kinds:
    - new_non_skippable: FQN appeared in cur_non_skippable but not in baseline.
    - aggregate/skippable_ratio: ratio dropped by more than COMPOSE_RATIO_EPS.
    - aggregate/knownUnstableArguments|inferredUnstableClasses: count rose.
    Removed composables (in baseline, not in current) are NOT reported.
    """
    regs = []
    base_agg = baseline_mod.get("aggregate") or {}
    base_non = set(baseline_mod.get("non_skippable") or [])

    # new_non_skippable
    for fqn in sorted(cur_non_skippable - base_non):
        name = fqn_to_name.get(fqn, "")
        regs.append({
            "module": module,
            "kind": "new_non_skippable",
            "name": fqn,
            "unstable_params": umap.get(name, []),
        })

    # skippable_ratio drop
    br = base_agg.get("skippableComposables", 0) / max(base_agg.get("totalComposables", 0), 1)
    cr = cur_agg.get("skippableComposables", 0) / max(cur_agg.get("totalComposables", 0), 1)
    if cr < br - COMPOSE_RATIO_EPS:
        regs.append({
            "module": module,
            "kind": "aggregate",
            "metric": "skippable_ratio",
            "baseline": round(br, 3),
            "current": round(cr, 3),
        })

    # count increases (no EPS)
    for k in ("knownUnstableArguments", "inferredUnstableClasses"):
        b = base_agg.get(k, 0)
        c = cur_agg.get(k, 0)
        if c > b:
            regs.append({"module": module, "kind": "aggregate", "metric": k, "baseline": b, "current": c})

    return regs


def _compose_metrics_mode(repo, as_json, update_baseline, audit=False):
    """lumos compose-metrics: 讀 .lumos/compose-metrics.json、逐模組比對 baseline、輸出回歸 manifest。
    --audit: 無視 baseline、盤點當下全部 non-skippable composable(初次採用/現況全景)。
    rc 0 = 成功(含回歸/baseline 缺失); rc 2 = config 格式錯誤。
    """
    import json, glob as _glob, os

    cfg_path = Path(repo) / ".lumos" / "compose-metrics.json"
    if not cfg_path.exists():
        if update_baseline:
            print("compose-metrics: config 不存在,略過 baseline 更新")
        elif audit:
            print(json.dumps({"inventory": [], "aggregate": {}, "checked_modules": 0,
                               "failed": []}, ensure_ascii=False)
                  if as_json else "0 non-skippable composables (audit, modules: 0)")
        else:
            print(json.dumps({"regressions": [], "checked_modules": 0, "new_modules": [],
                               "failed": [], "baseline_missing": False}, ensure_ascii=False)
                  if as_json else "")
        return 0

    try:
        with open(cfg_path, encoding="utf-8") as fh:
            cfg = json.load(fh)
    except Exception as e:
        print(f"ERROR: compose-metrics.json 解析失敗: {e}", file=sys.stderr)
        return 2

    if not isinstance(cfg, dict) or "modules" not in cfg:
        print("ERROR: compose-metrics.json 必須是 dict 且含 modules 鍵", file=sys.stderr)
        return 2

    for entry in cfg["modules"]:
        if not isinstance(entry, dict) or not all(k in entry for k in ("name", "metrics_dir", "reports_dir")):
            print("ERROR: compose-metrics.json 每條 module 必須含 name/metrics_dir/reports_dir", file=sys.stderr)
            return 2

    def _agg_subset(mod):
        return {k: mod.get(k, 0) for k in ("skippableComposables", "restartableComposables",
                                            "totalComposables", "knownUnstableArguments",
                                            "inferredUnstableClasses")}

    failed = []
    parsed = []  # list of (name, mod, non_skippable_fqns, fqn_to_name, unstable_map)

    for entry in cfg["modules"]:
        name = entry["name"]
        metrics_dir = os.path.join(repo, entry["metrics_dir"])
        reports_dir = os.path.join(repo, entry["reports_dir"])

        # resolve prefix
        if "file_prefix" in entry:
            prefix = entry["file_prefix"]
        else:
            pattern = os.path.join(metrics_dir, "*-module.json")
            matches = _glob.glob(pattern)
            if len(matches) == 0:
                failed.append({"name": name, "reason": "no *-module.json found in metrics_dir"})
                continue
            if len(matches) > 1:
                failed.append({"name": name, "reason": f"multiple *-module.json found: {matches}"})
                continue
            basename = os.path.basename(matches[0])
            prefix = basename[:-len("-module.json")]

        mod = _compose_read_module(metrics_dir, prefix)
        if mod is None:
            failed.append({"name": name, "reason": "module.json not found or unparseable"})
            continue

        non_skippable_fqns, fqn_to_name, unstable_map = _compose_read_composables(reports_dir, prefix)
        parsed.append((name, mod, non_skippable_fqns, fqn_to_name, unstable_map))

    if audit:
        # 盤點模式:無視 baseline,列出當下全部 non-skippable composable + 各模組聚合現況
        inventory = []
        aggregate = {}
        for (name, mod, non_skippable_fqns, fqn_to_name, unstable_map) in parsed:
            aggregate[name] = _agg_subset(mod)
            for fqn in sorted(non_skippable_fqns):
                bare = fqn_to_name.get(fqn, "")
                inventory.append({"module": name, "name": fqn,
                                  "unstable_params": unstable_map.get(bare, [])})
        if as_json:
            print(json.dumps({"inventory": inventory, "aggregate": aggregate,
                              "checked_modules": len(parsed), "failed": failed}, ensure_ascii=False))
        else:
            print(f"{len(inventory)} non-skippable composables (audit, modules: {len(parsed)})")
            for it in inventory:
                reason = ("  ← unstable: " + "; ".join(it["unstable_params"])) if it["unstable_params"] else ""
                print(f"  [non-skippable] {it['module']}/{it['name']}{reason}")
            for name, agg in aggregate.items():
                tot = agg.get("totalComposables", 0)
                sk = agg.get("skippableComposables", 0)
                print(f"  [{name}] skippable {sk}/{tot}, knownUnstableArgs {agg.get('knownUnstableArguments',0)}, "
                      f"inferredUnstableClasses {agg.get('inferredUnstableClasses',0)}")
            if failed:
                print(f"notice: {len(failed)} module(s) failed to parse")
        return 0

    if update_baseline:
        if not parsed:
            n_skip = len(failed)
            print(f"baseline NOT updated — 0 modules parsed (build metrics first?)"
                  + (f" ({n_skip} failed)" if n_skip else ""))
            return 0
        baseline = {}
        for (name, mod, non_skippable_fqns, fqn_to_name, unstable_map) in parsed:
            baseline[name] = {
                "aggregate": _agg_subset(mod),
                "non_skippable": sorted(non_skippable_fqns),
            }
        baseline_path = Path(repo) / ".lumos" / "compose-baseline.json"
        with open(baseline_path, "w", encoding="utf-8") as fh:
            json.dump(baseline, fh, indent=2, ensure_ascii=False)
        n_ok = len(parsed)
        n_skip = len(failed)
        print(f"baseline updated ({n_ok} modules, {n_skip} skipped)")
        return 0

    # normal branch: load baseline
    baseline_path = Path(repo) / ".lumos" / "compose-baseline.json"
    baseline_missing = False
    baseline_unreadable = False
    baseline = {}
    if not baseline_path.exists():
        baseline_missing = True
    else:
        try:
            with open(baseline_path, encoding="utf-8") as fh:
                baseline = json.load(fh)
        except Exception:
            baseline_unreadable = True

    if baseline_unreadable:
        if as_json:
            print(json.dumps({
                "regressions": [],
                "checked_modules": 0,
                "new_modules": [],
                "failed": failed,
                "baseline_missing": False,
                "baseline_unreadable": True,
            }, ensure_ascii=False))
        else:
            print("baseline unreadable (not overwriting) — fix or re-run --update-baseline")
        return 0

    regressions = []
    checked_modules = 0
    new_modules = []

    for (name, mod, non_skippable_fqns, fqn_to_name, unstable_map) in parsed:
        if baseline_missing or name not in baseline:
            new_modules.append(name)
            continue
        cur_agg = _agg_subset(mod)
        regressions += _compose_diff(name, baseline[name], cur_agg, non_skippable_fqns, fqn_to_name, unstable_map)
        checked_modules += 1

    if as_json:
        print(json.dumps({
            "regressions": regressions,
            "checked_modules": checked_modules,
            "new_modules": new_modules,
            "failed": failed,
            "baseline_missing": baseline_missing,
        }, ensure_ascii=False))
    else:
        n_reg = len(regressions)
        print(f"{n_reg} regressions (modules: {checked_modules})")
        for r in regressions:
            if r["kind"] == "new_non_skippable":
                print(f"  [new-non-skippable] {r['module']}/{r['name']}")
            else:
                print(f"  [aggregate] {r['module']} {r['metric']} {r['baseline']}→{r['current']}")
        if baseline_missing:
            print("notice: baseline not found — run --update-baseline to establish")
        if new_modules:
            print(f"notice: new modules (not in baseline): {', '.join(new_modules)}")
    return 0


def _lint_watch_mode(repo_root, as_json):
    """lumos lint-watch: 讀 .lumos/lint-watch.json、逐條查 registry、輸出 manifest。
    rc 0 = 成功(含空清單); rc 2 = config 格式錯誤。
    """
    import json
    cfg_path = Path(repo_root) / ".lumos" / "lint-watch.json"
    if not cfg_path.exists():
        entries = []
    else:
        try:
            with open(cfg_path, encoding="utf-8") as fh:
                entries = json.load(fh)
        except Exception as e:
            print(f"ERROR: lint-watch.json 解析失敗: {e}", file=sys.stderr)
            return 2
        if not isinstance(entries, list):
            print("ERROR: lint-watch.json 必須是 JSON 陣列", file=sys.stderr)
            return 2
        for entry in entries:
            if not isinstance(entry, dict) or not all(k in entry for k in ("name", "registry", "current")):
                print("ERROR: lint-watch.json 每條必須含 name/registry/current", file=sys.stderr)
                return 2

    candidates, failed, checked = [], [], 0
    for entry in entries:
        latest, reason = _registry_latest(entry["registry"])
        if latest is None:
            failed.append({"name": entry["name"], "reason": reason})
        else:
            state, r = _compare_versions(entry["current"], latest)
            if state == "behind":
                candidates.append({
                    "name": entry["name"],
                    "registry": entry["registry"],
                    "current": entry["current"],
                    "latest": latest,
                })
                checked += 1
            elif state == "current":
                checked += 1
            else:  # skip
                failed.append({"name": entry["name"], "reason": r})

    if as_json:
        print(json.dumps({"candidates": candidates, "checked": checked, "failed": failed},
                         ensure_ascii=False))
    else:
        for c in candidates:
            print(f"{c['name']} {c['current']} → {c['latest']}")
    return 0


# ── cochange:co-change 漏改守衛(vault-free;borrow-design ROSE error-prevention) ──
# 規則:conf(A⇒B)=shared/freq(A)(非對稱條件機率,ROSE TSE 2005 §5);support=絕對共改次數。
# 設計 spec:docs/lumos-toolchain-knowledge/Projects/cochange守衛_計劃.md

_COCHANGE_DEFAULTS = {"min_support": 3, "min_confidence": 0.8, "max_changeset": 20}
_COCHANGE_DEFAULT_EXCLUDE = [
    "docs/.governance-log.jsonl", "docs/.bypass-log.jsonl",
    "docs/.canary-log.jsonl", "docs/.rot-queue.jsonl", "docs/.kill-log.jsonl",
    "docs/.signoff-log.jsonl", "docs/.usage-log.jsonl",
    "**/*-lock.json", "**/*.lock", "**/node_modules/**", "**/dist/**",
    "**/Migrations/**", "**/*.g.cs", "**/*.Designer.cs",
]


def _cochange_repo_root(repo):
    """repo root:--repo 指定則驗證之,否則 cwd 逐層向上找 .git。找不到回 None。"""
    if repo:
        p = Path(repo).resolve()
        return p if (p / ".git").exists() else None
    p = Path.cwd()
    for cand in (p, *p.parents):
        if (cand / ".git").exists():
            return cand
    return None


def _cochange_load_config(repo_root):
    """讀 .lumos/cochange.json。fail-open(借 impact.json 的 rc 語意+額外一行提示):
    缺檔/壞 JSON → 預設值 + note;min_support 硬底線 2(設 1 視為 2 + note)。
    notes 由呼叫端印到 stdout(走 stderr 會被 pre-commit hook 的 2>/dev/null 吞掉)。"""
    import json
    cfg = dict(_COCHANGE_DEFAULTS)
    exclude = list(_COCHANGE_DEFAULT_EXCLUDE)
    notes = []
    p = Path(repo_root) / ".lumos" / "cochange.json"
    if p.exists():
        try:
            data = json.loads(p.read_text(encoding="utf-8"))
            if not isinstance(data, dict):
                raise ValueError("必須是 JSON object")
            for k in ("min_support", "min_confidence", "max_changeset"):
                if k in data:
                    cfg[k] = data[k]
            if isinstance(data.get("exclude"), list):
                exclude.extend(str(x) for x in data["exclude"])
        except Exception as e:
            notes.append(f"cochange: .lumos/cochange.json 解析失敗({e}),改用預設值")
    # 型別守衛(三個門檻一致 fail-open;code-loop r1:只守 min_support 是不對稱缺口)
    for k in ("min_support", "min_confidence", "max_changeset"):
        if not isinstance(cfg[k], (int, float)) or isinstance(cfg[k], bool):
            notes.append(f"cochange: {k} 非數值({cfg[k]!r}),改用預設 {_COCHANGE_DEFAULTS[k]}")
            cfg[k] = _COCHANGE_DEFAULTS[k]
    if cfg["min_support"] < 2:
        notes.append(f"cochange: min_support={cfg['min_support']} 低於硬底線,視為 2(單次共改=巧合)")
        cfg["min_support"] = 2
    cfg["exclude"] = exclude
    return cfg, notes


def _cochange_excluded(path, patterns):
    """glob 命中判定。雙試補 stdlib fnmatch 的坑:`**/` 的 `/` 被當字面斜線,
    `**/*-lock.json` 比不到根層 package-lock.json → 去掉 `**/` 前綴再試一次。"""
    import fnmatch
    for pat in patterns:
        if fnmatch.fnmatch(path, pat):
            return True
        if pat.startswith("**/") and fnmatch.fnmatch(path, pat[3:]):
            return True
    return False


def _cochange_transactions(repo_root, cfg, upto="HEAD"):
    """git 歷史 → transactions(list of set,repo-relative)。挖掘母體挖到 upto 為止
    (--diff A..B 時 upto=A:規則來自變更之前的歷史,被查 commit 不自我豁免)。
    回 (txns, err):zero-commit 回 ([], None);git 失敗回 (None, msg)。
    排除:merge、raw 檔數 > max_changeset(tangled,以排除前的原始檔數計)、exclude pattern。"""
    import subprocess as sp
    head = sp.run(["git", "-C", str(repo_root), "rev-parse", upto],
                  capture_output=True, text=True)
    if head.returncode != 0:
        gitdir = sp.run(["git", "-C", str(repo_root), "rev-parse", "--git-dir"],
                        capture_output=True, text=True)
        if gitdir.returncode == 0 and upto == "HEAD":
            return [], None  # unborn branch:空歷史是正常空結果
        return None, f"git rev-parse {upto} 失敗(非 git repo 或 rev 不存在)"
    r = sp.run(["git", "-C", str(repo_root), "-c", "core.quotePath=off", "log",
                "--no-merges", "--pretty=format:\x01%H", "--name-only", upto],
               capture_output=True, text=True)
    if r.returncode != 0:
        return None, (r.stderr or "git log 失敗").strip()
    txns, cur = [], None
    for line in r.stdout.splitlines():
        if line.startswith("\x01"):
            if cur is not None:
                txns.append(cur)
            cur = []
        elif line.strip() and cur is not None:
            cur.append(line.strip())
    if cur is not None:
        txns.append(cur)
    out = []
    for t in txns:
        if not t or len(t) > cfg["max_changeset"]:  # tangled 以原始檔數判
            continue
        kept = {f for f in t if not _cochange_excluded(f, cfg["exclude"])}
        if kept:
            out.append(kept)
    return out, None


def _cochange_mine(repo_root, cfg, upto="HEAD"):
    """挖規則。回 (rules, n_txn, n_files, err);rules={(lhs,rhs):(conf,support)}。
    support 硬底線 2 於挖掘層生效(rules/check/--all 一體適用)。"""
    import itertools, collections
    txns, err = _cochange_transactions(repo_root, cfg, upto=upto)
    if txns is None:
        return None, 0, 0, err
    freq = collections.Counter()
    pair = collections.Counter()
    for t in txns:
        for f in t:
            freq[f] += 1
        for a, b in itertools.combinations(sorted(t), 2):
            pair[(a, b)] += 1
    rules = {}
    for (a, b), s in pair.items():
        if s < 2:
            continue
        rules[(a, b)] = (round(s / freq[a], 4), s)
        rules[(b, a)] = (round(s / freq[b], 4), s)
    return rules, len(txns), len(freq), None


def cmd_cochange_rules(repo=None, show_all=False, as_json=False):
    """rc:正常(含空規則集/zero-commit)=0;非 git repo/git 失敗=2。"""
    import json
    root = _cochange_repo_root(repo)
    if root is None:
        print("ERROR: 找不到 git repo(--repo 指定或在 repo 內執行)", file=sys.stderr)
        return 2
    cfg, notes = _cochange_load_config(root)
    for n in notes:
        print(n)
    rules, n_txn, n_files, err = _cochange_mine(root, cfg)
    if rules is None:
        print(f"ERROR: {err}", file=sys.stderr)
        return 2
    out = []
    for (a, b), (conf, sup) in rules.items():
        if not show_all and (conf < cfg["min_confidence"] or sup < cfg["min_support"]):
            continue
        out.append({"lhs": a, "rhs": b, "confidence": conf, "support": sup})
    out.sort(key=lambda x: (-x["confidence"], -x["support"], x["lhs"]))
    if as_json:
        print(json.dumps({"rules": out, "commits": n_txn, "files": n_files},
                         ensure_ascii=False))
    else:
        for x in out:
            print(f"conf={x['confidence']:.2f} support={x['support']}  {x['lhs']} => {x['rhs']}")
        print(f"({len(out)} 條規則 / {n_txn} transactions / {n_files} 檔)")
    return 0


def cmd_cochange_check(repo=None, staged=False, diff_range=None, as_json=False):
    """對變更集比對規則,列漏改警告(advisory)。rc:正常(有無警告皆)=0;
    皆缺 --staged/--diff 或 git 失敗=2。同給時 --diff 優先(同 pitfalls diff>md 慣例)。"""
    import json
    import subprocess as sp
    if not staged and not diff_range:
        print("ERROR: 需指定 --staged 或 --diff <A..B>", file=sys.stderr)
        return 2
    if diff_range and diff_range.startswith("-"):
        # 同 pitfalls/impact-diff:'-' 開頭值會被 git 誤認成選項,查詢命令 rc2 拒收
        print("ERROR: --diff 不接受以 '-' 開頭的值", file=sys.stderr)
        return 2
    root = _cochange_repo_root(repo)
    if root is None:
        print("ERROR: 找不到 git repo(--repo 指定或在 repo 內執行)", file=sys.stderr)
        return 2
    cfg, notes = _cochange_load_config(root)
    for n in notes:
        print(n)
    # 挖掘母體:--diff A..B 挖到 A(規則來自變更之前的歷史);--staged 挖到 HEAD
    upto = "HEAD"
    if diff_range:
        base = diff_range.split("..")[0].strip()
        if base:
            upto = base
    rules, _t, _f, err = _cochange_mine(root, cfg, upto=upto)
    if rules is None:
        print(f"ERROR: {err}", file=sys.stderr)
        return 2
    if diff_range:
        cmd = ["git", "-C", str(root), "-c", "core.quotePath=off",
               "diff", "--name-only", diff_range]
    else:
        cmd = ["git", "-C", str(root), "-c", "core.quotePath=off",
               "diff", "--cached", "--name-only"]
    d = sp.run(cmd, capture_output=True, text=True)
    if d.returncode != 0:
        print(f"ERROR: {(d.stderr or 'git diff 失敗').strip()}", file=sys.stderr)
        return 2
    changed = {ln.strip() for ln in d.stdout.splitlines() if ln.strip()}
    changed = {f for f in changed if not _cochange_excluded(f, cfg["exclude"])}
    by_lhs = {}
    for (a, b), v in rules.items():
        by_lhs.setdefault(a, []).append((b, v))
    warnings = []
    for a in sorted(changed):
        for b, (conf, sup) in by_lhs.get(a, ()):
            if b in changed or conf < cfg["min_confidence"] or sup < cfg["min_support"]:
                continue
            if not (root / b).exists():  # 殭屍規則:右側已刪/改名 → 不告警
                continue
            warnings.append({"changed": a, "missing": b,
                             "confidence": conf, "support": sup})
    warnings.sort(key=lambda w: (-w["confidence"], -w["support"], w["changed"]))
    if as_json:
        print(json.dumps({"warnings": warnings, "checked": len(changed)},
                         ensure_ascii=False))
    else:
        for w in warnings:
            print(f"cochange: 改了 {w['changed']} 但未動 {w['missing']}"
                  f"(歷史 {w['confidence']:.0%} 同改,共 {w['support']} 次)——確認是否漏改")
    return 0


def _pitfall_diff_collect(diff_range, repo_root, no_lint=False):
    """掃 git diff <range> 算代碼形態風險 claims(regex 層 + 選擇性 lint 層)——**純計算、不印**。
    回 dict {"claims", "tier"[, "lint_ran", "lint_skipped", "filtered"]};git 錯回 None(呼叫端印錯)。
    供 _pitfall_diff_mode(印)與 loop capture-counts(收割成異質 finder)共用同一計算。"""
    import subprocess
    try:
        # core.quotePath=false:CJK 檔名不轉義加引號(否則 "+++ b/" 前綴比對全失效,
        # r2 panel major:CJK 檔名 pitfall 命中被靜默漏收/誤歸,同 test-layers/impact-diff 先例)
        r = subprocess.run(["git", "-c", "core.quotePath=false", "diff", "-U3", diff_range],
                           capture_output=True, text=True, cwd=str(repo_root))
    except FileNotFoundError:
        print("ERROR: 無 git", file=sys.stderr)
        return None
    if r.returncode != 0:
        print(f"ERROR: git diff {diff_range} 失敗: {r.stderr.strip()}", file=sys.stderr)
        return None
    added = {}
    claims = []
    cur_file, new_ln = "", 0
    for line in r.stdout.splitlines():
        if line.startswith("+++ b/"):
            cur_file = line[6:]
            continue
        m = re.match(r"@@ -\d+(?:,\d+)? \+(\d+)", line)
        if m:
            new_ln = int(m.group(1))
            continue
        if line.startswith("+++") or line.startswith("---"):
            continue
        if line.startswith("-"):
            continue                          # 刪除行不推進新檔行號
        if not line.startswith("+"):
            new_ln += 1                       # context 行推進
            continue
        # 這是新增行(+ 開頭)
        added.setdefault(cur_file, set()).add(new_ln)
        ext = Path(cur_file).suffix if cur_file else ""
        code = line[1:]
        if (ext not in _PITFALL_DIFF_SKIP_EXT and cur_file
                and not _PITFALL_DIFF_TEST_PAT.search(cur_file)
                and not code.strip().startswith(("#", "//", "--", "/*", "*"))):
            for pat, axis, q in _PITFALL_DIFF_PATTERNS:
                if pat.search(code):
                    claims.append({"file": cur_file, "line": new_ln, "class": axis,
                                   "pattern": pat.pattern, "question": q})
                    break
        new_ln += 1                           # 新增行推進新檔行號

    # ── Task 4: lint 整合 ─────────────────────────────────────────────────
    config = None if no_lint else _lint_load_config(repo_root)
    if config is None:
        # fallback: no_lint 或無 config → 維持 regex-only 輸出(不加 lint_ran/lint_skipped)
        return {"claims": claims, "tier": "high" if claims else "standard"}

    # 有 config: 補 source 到 regex claims
    for c in claims:
        c["source"] = "pitfalls-builtin"

    cmds = _lint_stacks_for_diff(added, config)
    aligned = _lint_aligned(diff_range, repo_root)
    lint_ran = []
    lint_skipped = []
    lint_claims = []

    for cmd in cmds:
        lc, ok = _lint_run_and_parse(cmd, repo_root)
        if ok:
            lint_ran.append(cmd)
            lint_claims.extend(lc)
        else:
            lint_skipped.append(cmd)

    # 過濾 lint claims
    filtered_marker = None
    if aligned:
        lint_claims = [
            c for c in lint_claims
            if c["line"] in added.get(c["file"], set())
        ]
    else:
        filtered_marker = False  # 未對齊 → 全收 + 標記

    all_claims = lint_claims + claims
    out = {"claims": all_claims, "tier": "high" if all_claims else "standard",
           "lint_ran": lint_ran, "lint_skipped": lint_skipped}
    if filtered_marker is not None:
        out["filtered"] = filtered_marker
    return out


def _pitfall_diff_mode(diff_range, repo_root, as_json, no_lint=False):
    """掃 git diff <range> 新增行找代碼形態風險位置。過濾繼承 Check H 全套;line 由 @@ 標頭推導。
    rc 恆 0(提示器非閘)。class 用形態類軸(併發/效能/資源)。
    no_lint=True:只跑快的 regex 層、不跑專案宣告的 lint 指令(給 pre-push advisory 用,免每次 push 跑慢 linter)。"""
    import json
    data = _pitfall_diff_collect(diff_range, repo_root, no_lint)
    if data is None:
        return 2
    if as_json:
        print(json.dumps(data, ensure_ascii=False))
    else:
        for c in data["claims"]:
            src = c.get("source", "")
            if src.startswith("lint:"):
                print(f"  {c['file']}:{c['line']} [{src}] {c.get('message','')}")
            else:
                print(f"  {c['file']}:{c['line']} [{c.get('class','')}] {c.get('question','')}")
        print(f"tier: {data['tier']}")
    return 0


def _pitfall_strip_spec(md_text):
    """spec 模式剝除:## 切分→黑名單剝樣板節(前提節保留)→防呆回退→剝 inline-code/檔名。
    對齊 difficulty.assess_spec 慣例、獨立實作(同 refcheck 對 Check P 不共用)。"""
    parts = re.split(r"(?m)^(## .*)$", md_text)
    kept = [parts[0]] if parts and parts[0].strip() else []
    n_sections = 0
    i = 1
    while i + 1 <= len(parts):
        title, body = parts[i], parts[i + 1]
        if not any(b in title for b in _PITFALL_BLACKLIST):
            kept.append(title + body)
            n_sections += 1
        i += 2
    corpus = "\n".join(kept)
    if n_sections < 2 or len(corpus) < 200:
        print("⚠ pitfalls: 剝除後餘文近空(節數<2 或字元<200),回退全文掃描(偏嚴)")
        corpus = md_text
    corpus = INLINE_CODE_RE.sub(" ", corpus)
    corpus = re.sub(r"[\w\-./]+\.(?:md|py|sh|json|yml|yaml|txt)\b", " ", corpus)
    return corpus


def _pitfall_scan_classes(text):
    """回命中類名 list(每類記首個命中即可)。"""
    hits = []
    for cls, pats in _PITFALL_COMPILED.items():
        if any(p.search(text) for p in pats):
            hits.append(cls)
    return hits


def cmd_sqlfluff_sarif(out=None):
    """sqlfluff --format json(stdin)→ SARIF v2.1(--out 或 stdout)。
    橋接:sqlfluff(主流可攜 T-SQL/SQL linter)無原生 SARIF → 轉成 lint-adapter 吃的 SARIF。
    用法(專案 .lumos/lint.json 的 sql 棧):
      sqlfluff lint <dir> --dialect tsql --format json | python3 scripts/lumos sqlfluff-sarif --out {LINT_SARIF_OUT}
    """
    import json
    try:
        data = json.load(sys.stdin)
    except (json.JSONDecodeError, ValueError):
        data = []
    results = []
    for f in (data or []):
        fp = f.get("filepath", "")
        for v in (f.get("violations") or []):
            results.append({
                "ruleId": v.get("code", ""),
                "message": {"text": v.get("description", "")},
                "locations": [{"physicalLocation": {
                    "artifactLocation": {"uri": fp},
                    "region": {"startLine": v.get("start_line_no", v.get("line_no", 0))},
                }}],
            })
    sarif = {"version": "2.1.0",
             "runs": [{"tool": {"driver": {"name": "sqlfluff"}}, "results": results}]}
    text = json.dumps(sarif, ensure_ascii=False)
    if out:
        with open(out, "w", encoding="utf-8") as fh:
            fh.write(text)
    else:
        print(text)
    return 0


def cmd_stylelint_sarif(out=None):
    """stylelint --formatter json(stdin)→ SARIF v2.1(--out 或 stdout)。
    橋接:stylelint(CSS/SCSS/.vue <style> linter)無原生 SARIF → 轉成 lint-adapter 吃的 SARIF。
    用法(專案 .lumos/lint.json 的 css/scss 棧):
      npx stylelint '**/*.{css,vue}' --formatter json | python3 scripts/lumos stylelint-sarif --out {LINT_SARIF_OUT}
    """
    import json
    try:
        data = json.load(sys.stdin)
    except (json.JSONDecodeError, ValueError):
        data = []
    results = []
    for f in (data or []):
        src = f.get("source", "")
        for w in (f.get("warnings") or []):
            results.append({
                "ruleId": w.get("rule", ""),
                "message": {"text": w.get("text", "")},
                "locations": [{"physicalLocation": {
                    "artifactLocation": {"uri": src},
                    "region": {"startLine": w.get("line", 0)},
                }}],
            })
    sarif = {"version": "2.1.0",
             "runs": [{"tool": {"driver": {"name": "stylelint"}}, "results": results}]}
    text = json.dumps(sarif, ensure_ascii=False)
    if out:
        with open(out, "w", encoding="utf-8") as fh:
            fh.write(text)
    else:
        print(text)
    return 0


def cmd_pitfalls(md=None, diff=None, repo=None, check=False, as_json=False, section_title="實務隱患", no_lint=False):
    """實務隱患提問(vault-free):spec 模式逼答設計決策級隱患;--diff 模式攤代碼級風險位置(Task 2)。
    spec 模式印通用 3 問 + 命中類追問;--check:命中類且無「## <section_title>」節 → rc 1(只驗節存在)。
    --no-lint:--diff 只跑 regex 層(快,給 pre-push advisory)。"""
    import json
    repo_root = _anchor_repo_root(repo)
    if repo_root is None:
        return 2
    if diff is not None:
        if diff.startswith("-"):
            # --diff 值直接進 git 當 positional;'-' 開頭會被 git 誤認成選項(可寫任意檔,
            # 如 --output=<path>——r2 panel major 實測驗證)。查詢命令慣例=usage-error rc2。
            print("ERROR: --diff 不接受以 '-' 開頭的值", file=sys.stderr)
            return 2
        return _pitfall_diff_mode(diff, repo_root, as_json, no_lint)
    if md is None:
        print("ERROR: pitfalls 需 <md檔> 或 --diff <range>", file=sys.stderr)
        return 2
    mp = Path(md)
    if not mp.is_file():
        print(f"ERROR: 找不到檔案: {md}", file=sys.stderr)
        return 2
    text = mp.read_text(encoding="utf-8-sig")
    corpus = _pitfall_strip_spec(text)
    hits = _pitfall_scan_classes(corpus)
    if check:
        has_section = re.search(r"(?m)^##\s+.*" + re.escape(section_title), text) is not None
        if hits and not has_section:
            print(f"✗ pitfalls --check: 命中風險類 {hits} 但無「## {section_title}」節 → 補節(寫『無』也要寫+為什麼無)")
            return 1
        print(f"✓ pitfalls --check: {'有節' if has_section else '零命中'}(命中類={hits})")
        return 0
    if as_json:
        print(json.dumps({"hits": hits, "general": _PITFALL_GENERAL,
                          "class_questions": {c: _PITFALL_QUESTIONS[c] for c in hits}}, ensure_ascii=False))
        return 0
    print("實務隱患提問(通用,恆答):")
    for q in _PITFALL_GENERAL:
        print(f"  - {q}")
    if hits:
        print(f"命中風險類追問({', '.join(hits)}):")
        for c in hits:
            print(f"  - [{c}] {_PITFALL_QUESTIONS[c]}")
    return 0


def cmd_test_layers(diff=None, repo=None, as_json=False):
    """test-layers 軟提醒(vault-free,恆 rc 0):diff 命中 .lumos/test-layers.json 宣告棧
    → 印「該跑的測試層」提醒。無宣告檔靜默;git/解析失敗 fail-open(stderr 診斷+rc 0)。
    唯一 rc 2=缺 --diff(用法錯誤)。設計:[[test-layers軟提醒_計劃]]。"""
    import json
    import subprocess
    if not diff:
        print("ERROR: test-layers 需 --diff <range>", file=sys.stderr)
        return 2
    if diff.startswith("-"):
        # --diff 值直接進 git 當 positional;'-' 開頭會被 git 誤認成選項(可寫檔),
        # fail-open 跳過而非硬擋(advisory 合約不變 rc 恆 0,r1 codex minor)
        print("test-layers: --diff 不接受以 '-' 開頭的值,跳過提醒", file=sys.stderr)
        if as_json:
            print(json.dumps({"hits": []}, ensure_ascii=False))
        return 0
    repo_root = _anchor_repo_root(repo)
    if repo_root is None:
        print("test-layers: 找不到 repo root,跳過提醒", file=sys.stderr)
        if as_json:
            print(json.dumps({"hits": []}, ensure_ascii=False))
        return 0
    cfg = _testlayers_load_config(repo_root)
    if cfg is None:
        if as_json:
            print(json.dumps({"hits": []}, ensure_ascii=False))
        return 0
    try:
        # core.quotePath=false:CJK 檔名不轉義加引號(否則 suffix 判斷全失效,r1 panel major)
        r = subprocess.run(["git", "-c", "core.quotePath=false", "diff", "--name-only", diff],
                           cwd=str(repo_root), capture_output=True, text=True, timeout=30)
        if r.returncode != 0:
            print(f"test-layers: git diff rc={r.returncode},跳過提醒", file=sys.stderr)
            if as_json:
                print(json.dumps({"hits": []}, ensure_ascii=False))
            return 0
        files = [ln.strip() for ln in r.stdout.splitlines() if ln.strip()]
    except Exception as e:
        print(f"test-layers: git diff 失敗({e}),跳過提醒", file=sys.stderr)
        if as_json:
            print(json.dumps({"hits": []}, ensure_ascii=False))
        return 0
    hits = _testlayers_hits(files, cfg)
    norm = []
    for k, e, n in hits:
        e = e if isinstance(e, dict) else {}
        norm.append({"stack": k, "files": n, "layer": e.get("layer", ""),
                     "cmd": e.get("cmd", ""), "when": e.get("when", "")})
    if as_json:
        print(json.dumps({"hits": norm}, ensure_ascii=False))
        return 0
    if not norm:
        return 0
    print("💡 test-layers 軟提醒(不擋):")
    for h in norm:
        line = f"   diff 碰到 {h['stack']}({h['files']} 檔) → 宣告的 {h['layer'] or '?'} 層"
        if h["cmd"]:
            line += f":{h['cmd']}"
        print(line)
        if h["when"]:
            print(f"     時機:{h['when']}")
    print("   跑了嗎?沒跑的話這是 push 前最後一次便宜的提醒點。")
    return 0


_FOLD_MIRROR_HEADING_RE = re.compile(
    r"^##\s+(§\d+\s+)?(審計修正紀錄|誠實天花板)", re.MULTILINE)


def _fold_mirror_sections(text):
    """掃 text 回傳所有「鏡像段」標籤清單,供 fold-check 列舉複查用。

    鏡像段定義(設計 §2.1):
      1. frontmatter summary block → "summary"
      2. body 內每個 ```json fence → "```json fence N"(1-indexed)
      3. ## …審計修正紀錄(含節號前綴如 ## §5 審計修正紀錄)
      4. ## …誠實天花板(含節號前綴如 ## §4 誠實天花板)

    標題比對容節號前綴(r1-F5):regex ^##\\s+(§\\d+\\s+)?(審計修正紀錄|誠實天花板)
    """
    sections = []

    # 1. summary block:frontmatter 有 summary: 鍵
    # Also captures body for steps 2 & 3 — single call, DRY
    fm_lines, body = split_frontmatter(text)
    if fm_lines is not None:
        for line in fm_lines:
            if re.match(r"^summary\s*:", line):
                sections.append("summary")
                break

    # 2. ```json fences in body — body from split_frontmatter (correct offset, DRY)
    # Match ```json ... ``` fences
    json_fence_re = re.compile(r"^```json\b", re.MULTILINE)
    json_count = 0
    for m in json_fence_re.finditer(body):
        json_count += 1
        sections.append(f"```json fence {json_count}")

    # 3 & 4. ## …審計修正紀錄 / ## …誠實天花板 headings (with optional §N prefix)
    # Scan body only (consistent with json fence scan above)
    for m in _FOLD_MIRROR_HEADING_RE.finditer(body):
        # Use the full matched heading text (strip leading ##\s+)
        heading = m.group(0).lstrip("#").strip()
        sections.append(heading)

    return sections


# Regex to strip ## …審計修正紀錄 section (and everything after it until next ## heading or EOF)
_FOLD_AUDIT_RECORD_RE = re.compile(
    r"^##\s+(§\d+\s+)?審計修正紀錄.*", re.MULTILINE)

# Module-level compiled regexes for _fold_value_drift (I1)
_FOLD_DRIFT_FOLD_CHECK_RE = re.compile(r'\bfold-check\s+(\S+)')
_FOLD_DRIFT_DOTDOT_RE = re.compile(r'\d+\.\.\w+')

# Regex to find the next ## heading after a given position (used in audit-section stripping)
_FOLD_NEXT_H2_RE = re.compile(r'^##\s', re.MULTILINE)


def _fold_value_drift(text):
    """偵測「同識別詞在不同處出現不同值」的漂移(全文域)。

    掃描域排除 ## …審計修正紀錄 段(含節號前綴),該段刻意引用歷史/舊值,掃它必假陽。
    單一抽取法:掃符合值 pattern 的「識別詞+值」字串——
      - fold-check <value>  (識別詞=fold-check, value=\S+)
      - \d+\.\.\w+          (整串當 key, 如 2..depth,key 為後綴詞 e.g. depth,value 為前導數字)

    同一識別詞出現不同值 → 一筆 {key, a, b}。
    Returns list[dict] with keys: key, a, b.
    """
    # Step 1: 排除審計修正紀錄段(從標題行到下個 ## 標題或 EOF)
    # C2 fix: only strip the audit section itself, not everything after it.
    m = _FOLD_AUDIT_RECORD_RE.search(text)
    if m:
        audit_start = m.start()
        # Find the next ## heading *after* the audit heading
        next_h2 = _FOLD_NEXT_H2_RE.search(text, m.end())
        if next_h2:
            # Keep text before audit section + text from next heading onward
            scan_text = text[:audit_start] + text[next_h2.start():]
        else:
            # Audit section is the last section — truncate to before it
            scan_text = text[:audit_start]
    else:
        scan_text = text

    # Step 2: 單一抽取法 — 掃值 pattern,抽取「識別詞+值」對
    # fold-check \S+ : identifier="fold-check", value=next non-whitespace token
    # \d+\.\.\w+ : e.g. "2..depth", "1..depth"
    seen = defaultdict(set)

    for m2 in _FOLD_DRIFT_FOLD_CHECK_RE.finditer(scan_text):
        val = m2.group(1)
        seen["fold-check"].add(val)

    for m2 in _FOLD_DRIFT_DOTDOT_RE.finditer(scan_text):
        token = m2.group(0)
        # The suffix (\w+) is the concept identifier; the prefix (\d+) is the value.
        # e.g. "2..depth" → key="depth", val="2"
        parts = token.split("..")
        if len(parts) == 2:
            key = parts[1]   # e.g. "depth"
            val = parts[0]   # e.g. "2" or "1"
            seen[key].add(val)

    # Step 3: flag any key that has more than one distinct value
    drifts = []
    for key, vals in seen.items():
        if len(vals) > 1:
            val_list = sorted(vals)
            drifts.append({"key": key, "a": val_list[0], "b": val_list[1]})

    return drifts


# Module-level compiled regexes for _fold_reverse_omission
_FOLD_RO_PLACEHOLDER_RE = re.compile(r'<[^>]+>')
_FOLD_RO_DDFLAG_RE = re.compile(r'--\w[\w-]*')
_FOLD_RO_MARKER_RE = re.compile(r'★\w+★')
# 帶已知副檔名的檔名(避開純版本號如 1.0);路徑允許中間有 . / -
_FOLD_RO_FILENAME_RE = re.compile(
    r'\w[\w./-]*\.(?:json|py|md|sh|txt|kt|cs|vue|js|ts|yml|yaml)\b'
)


def _fold_reverse_omission(text):
    """偵測「body 有的顯著 token,summary 沒有」的反向遺漏(全文域)。

    掃描域排除 ## …審計修正紀錄 段(複用 _FOLD_AUDIT_RECORD_RE/_FOLD_NEXT_H2_RE)。
    排除 <…> placeholder(r2-F5)。
    抽顯著 token(high-signal 三類):
      1. --flag(--\w[\w-]*)
      2. ★MARKER★(★...★)
      3. 帶已知副檔名的檔名(\w[\w./-]*\.{ext})
    不抽 backtick 內容與裸 CamelCase(技術 spec 噪音主源)。
    主軸:body 有、summary 無 → 一筆 {token, present_in, missing_in}。

    Returns list[dict] with keys: token, present_in, missing_in.
    """
    # Step 1: 排除審計修正紀錄段(從標題行到下個 ## 標題或 EOF),複用 T2 邏輯
    m = _FOLD_AUDIT_RECORD_RE.search(text)
    if m:
        audit_start = m.start()
        next_h2 = _FOLD_NEXT_H2_RE.search(text, m.end())
        if next_h2:
            scan_text = text[:audit_start] + text[next_h2.start():]
        else:
            scan_text = text[:audit_start]
    else:
        scan_text = text

    # Step 2: 拆 frontmatter/body,抽 summary 文字
    fm_lines, body = split_frontmatter(scan_text)

    # Extract summary block from frontmatter: lines under "summary: |-" or "summary: |"
    summary_text = ""
    in_summary = False
    summary_lines = []
    for line in (fm_lines or []):
        stripped = line.strip()
        if re.match(r'^summary\s*:\s*\|[-]?\s*$', stripped):
            in_summary = True
            continue
        if in_summary:
            # Indented lines belong to the summary block; bare key: ends it
            if line.startswith(" ") or line.startswith("\t"):
                summary_lines.append(line)
            else:
                in_summary = False
    summary_text = "\n".join(summary_lines)

    # Step 3: 抽顯著 token helper
    def _strip_placeholders(s):
        return _FOLD_RO_PLACEHOLDER_RE.sub(' ', s)

    def _extract_tokens(s):
        """Extract high-signal tokens from string s, excluding <...> placeholders.

        Three token classes:
          1. --flag (--\w[\w-]*)
          2. ★MARKER★
          3. Filenames with known extensions (\w[\w./-]*\.{known_ext})
        Backtick content and bare CamelCase are intentionally excluded (noise sources).
        """
        s = FENCE_RE.sub("", s)
        s = _strip_placeholders(s)
        tokens = set()
        # --flags
        for m2 in _FOLD_RO_DDFLAG_RE.finditer(s):
            tokens.add(m2.group(0))
        # ★MARKER★
        for m2 in _FOLD_RO_MARKER_RE.finditer(s):
            tokens.add(m2.group(0))
        # filenames with known extensions
        for m2 in _FOLD_RO_FILENAME_RE.finditer(s):
            tokens.add(m2.group(0))
        return tokens

    summary_tokens = _extract_tokens(summary_text)
    body_tokens = _extract_tokens(body)

    # Step 4: body 有、summary 無 → flag
    omissions = []
    for tok in sorted(body_tokens - summary_tokens):
        omissions.append({
            "token": tok,
            "present_in": "body",
            "missing_in": "summary",
        })

    return omissions


def cmd_fold_check(path, as_json=False):
    """折入後一致性複查輔助:列舉鏡像段 + value-drift + reverse-omission flag。

    rc = (value_drift 或 reverse_omission 非空) ? 1 : 0
    --json schema: {path, mirror_sections, value_drift, reverse_omission}
    """
    import json
    md = Path(path)
    if not md.is_file():
        print(f"ERROR: 找不到檔案: {path}", file=sys.stderr)
        return 2
    try:
        text = md.read_text(encoding="utf-8-sig")
    except OSError as e:
        print(f"ERROR: 讀不到 {path}: {e}", file=sys.stderr)
        return 2

    mirror_sections = _fold_mirror_sections(text)
    value_drift = _fold_value_drift(text)
    reverse_omission = _fold_reverse_omission(text)

    has_flag = bool(value_drift or reverse_omission)

    if as_json:
        print(json.dumps({
            "path": str(md),
            "mirror_sections": mirror_sections,
            "value_drift": value_drift,
            "reverse_omission": reverse_omission,
        }, ensure_ascii=False))
    else:
        print(f"fold-check {md}")
        print("── 鏡像段(逐段確認與 body 一致)──")
        for s in mirror_sections:
            print(f"  ☐ 複查 {s}:與 body 一致?")
        if not mirror_sections:
            print("  (無鏡像段)")
        if value_drift:
            print("── value-drift ──")
            for item in value_drift:
                print(f"  ⚠ value-drift: 「{item['key']} {item['a']}」vs 「{item['key']} {item['b']}」")
        if reverse_omission:
            print("── reverse-omission ──")
            for item in reverse_omission:
                print(f"  ⚠ reverse-omission: {item['present_in']} 有「{item['token']}」{item['missing_in']} 無")
        if not has_flag:
            print("✓ 無 flag")

    return 1 if has_flag else 0


def cmd_refcheck(md_path, repo=None, as_json=False):
    """spec 指涉宣稱確定性核對(vault-free):inline-code 檔路徑/行號 → 存在性 manifest。
    抽取規則同 doctor Check P step 1-2(刻意複製、不共用——去重粒度不同:
    Check P 是 token 級,這裡是 (token, line);同檔多行號各自成 claim)。
    只驗 spec→repo 指涉,不驗 spec 內部一致性(canary 保留地)。"""
    import json
    md = Path(md_path)
    if not md.is_file():
        print(f"ERROR: 找不到檔案: {md_path}", file=sys.stderr)
        return 2
    if repo is not None:
        repo_root = Path(repo)
        if not repo_root.is_dir():
            print(f"ERROR: --repo 不是目錄: {repo}", file=sys.stderr)
            return 2
    else:
        repo_root = None
        for cand in (Path.cwd(), *Path.cwd().parents):
            if (cand / ".git").exists():
                repo_root = cand
                break
        if repo_root is None:
            print("ERROR: cwd 逐層向上找不到 .git repo,請用 --repo 指定", file=sys.stderr)
            return 2
    try:
        text = md.read_text(encoding="utf-8-sig")
    except OSError as e:
        print(f"ERROR: 讀不到 {md_path}: {e}", file=sys.stderr)
        return 2

    claims, n_missing, n_oor, n_ok = _refcheck_scan(text, repo_root)
    if as_json:
        print(json.dumps({"claims": claims, "missing": n_missing,
                          "out_of_range": n_oor, "ok": n_ok}, ensure_ascii=False))
    else:
        print(f"refcheck {md} (repo={repo_root})")
        for c in claims:
            loc = f"{c['token']}:{c['line']}" if c["line"] else c["token"]
            mark = "✓" if c["status"] == "ok" else "✗"
            tail = f" | {c['excerpt']}" if c["excerpt"] and "\n" not in c["excerpt"] else ""
            print(f"  {mark} {c['status']:<17} {loc}{tail}")
        print(f"統計: ok {n_ok} / missing {n_missing} / out_of_range {n_oor}")
    return 1 if (n_missing or n_oor) else 0


def _impact_reverse_lookup(rel_code_path, env, repo_root):
    """給一支 code 路徑,反查「哪些圖譜節點的 body inline-code 引用了它」。

    設計要點(Task 2):
    - 只掃 body inline-code,絕不掃 core_refs(r7-F2)。
    - 複用 _refcheck_scan(text, repo_root) 抽取 body inline-code 路徑;
      Note 不存 body → 重讀盤每個 .md 餵它(r1-F1)。
    - 路徑規範化(r3-F5):輸入若為絕對路徑先轉 repo-relative 再比對。
    - _refcheck_scan 的 top_dirs 靜默過濾照舊(§4 天花板 5)。

    回傳: list[node_rel] — body inline-code 命中 rel_code_path 的節點清單。
    """
    import os

    repo_root = Path(repo_root)

    # 路徑規範化:絕對路徑 → repo-relative
    rp = str(rel_code_path)
    if os.path.isabs(rp):
        rp = os.path.relpath(rp, str(repo_root))

    hits = []
    for node_rel, note in env.notes.items():
        # 重讀盤:Note 不存 body,直接讀原始 .md 文字
        md_path = env.vault / node_rel
        try:
            text = md_path.read_text(encoding="utf-8-sig", errors="replace")
        except OSError:
            continue
        claims, _n_missing, _n_oor, _n_ok = _refcheck_scan(text, repo_root)
        for claim in claims:
            if claim["token"] == rp:
                hits.append(node_rel)
                break  # 同一節點只算一次
    return hits


def _impact_contract(note):
    """Task 3: 偵測節點的合約標記,回傳 (contract: str|None, combo: bool)。

    兩軸設計(r6-F3):
    - INVARIANT/DEBT 軸: extract_contracts(note) → inv list。DEBT → None(r9-F7)。
    - IRREVERSIBLE 軸: 獨立 IRREVERSIBLE_RE 掃 summary(extract_contracts 不含此)。
    取最高: IRREVERSIBLE > INVARIANT > None。
    combo(r6-F6): ★COMBO★ 是 ★INVARIANT★ 同行後綴修飾,偵測 INVARIANT 行含 ★COMBO★
                 (參 scripts/lumos:725 的 '★COMBO★' not in inv);不入 contract enum,走獨立布林。
    """
    invs, _debts = extract_contracts(note)  # 只掃 INVARIANT/DEBT

    # combo: 任一 INVARIANT 行含 ★COMBO★ 即為 True
    combo = any("★COMBO★" in inv for inv in invs)

    # INVARIANT 軸: 有 inv 則 contract="INVARIANT"(DEBT 已被 extract_contracts 分到 _debts,不入此路)
    contract = "INVARIANT" if invs else None

    # IRREVERSIBLE 軸: 獨立掃 summary(extract_contracts 不含 IRREVERSIBLE)
    summ = note.fields.get("summary")
    if isinstance(summ, str):
        for line in summ.split("\n"):
            if IRREVERSIBLE_RE.match(line.strip()):
                contract = "IRREVERSIBLE"  # 最高優先,覆蓋 INVARIANT
                break

    return contract, combo


def _impact_bfs(direct_nodes, env, depth):
    """Task 4: 從直接節點集沿 env.edges 雙向 BFS 展開間接關聯。

    設計要點:
    - hop 語意(r8-F5): hop = 距最近直接節點的 BFS 距離,hop ∈ 1..depth。
    - visited/cycle guard(r8-F4): seen 先種入全部直接節點,直接節點沿環不重入 indirect
      (參 cmd_map 的 seen 模式 scripts/lumos:908-923)。
    - 雙向邊: out_e(outlink)+in_e(backlink) 都走;每筆記 is_backlink。
    - 雙向 direction 衝突(r8-F7): 若 dest 同時可從 out_e 與 in_e 到達 → 標 backlink 優先。
    - 不含直接節點本身。

    回傳: list[(node, hop, from_node, is_backlink)]
    """
    out_e, in_e = env.edges

    # pending 機制正確處理同一 hop 內雙向衝突(backlink 優先,r8-F7)
    seen = set(direct_nodes)
    queue = deque()

    # 每一輪 frontier 的 pending: dest -> (hop, from_node, is_backlink)
    # backlink 優先:若 dest 先被 outlink 加,後被 backlink 命中 → 覆蓋為 backlink
    for direct in direct_nodes:
        pending = {}  # dest -> (from_node, is_backlink)
        for dest in out_e.get(direct, []):
            if dest not in seen:
                if dest not in pending:
                    pending[dest] = (direct, False)
                # outlink 不覆蓋已有的 backlink
        for dest in in_e.get(direct, []):
            if dest not in seen:
                # backlink 優先:無論如何覆蓋
                pending[dest] = (direct, True)
        for dest, (from_node, is_bl) in pending.items():
            if dest not in seen:
                seen.add(dest)
                queue.append((dest, 1, from_node, is_bl))

    result = []

    while queue:
        node, hop, from_node, is_backlink = queue.popleft()
        result.append((node, hop, from_node, is_backlink))

        if hop < depth:
            # 展開下一層,同樣用 pending 處理雙向衝突
            pending = {}
            for dest in out_e.get(node, []):
                if dest not in seen:
                    if dest not in pending:
                        pending[dest] = (node, False)
            for dest in in_e.get(node, []):
                if dest not in seen:
                    pending[dest] = (node, True)
            for dest, (fn, is_bl) in pending.items():
                if dest not in seen:
                    seen.add(dest)
                    queue.append((dest, hop + 1, fn, is_bl))

    return result


def _impact_via(frontier, dest, is_backlink, env):
    """Task 5: 判斷 BFS 一條邊的 via(沿哪個 frontmatter 欄位到達)。

    設計要點(§2.3,r9-F1):
    - env.edges 是 out_e[a].append(b) / in_e[b].append(a) ——
      wikilink **永遠寫在「連出去」那一端**。
    - outlink(is_backlink=False): wikilink 在 frontier → 讀 frontier.fields,
      找含指向 dest 的 wikilink 欄位。
    - backlink(is_backlink=True): wikilink 在 dest(dest 連向 frontier) →
      讀 dest.fields(不是 frontier!),找含指向 frontier 的 wikilink 欄位。
      **讀錯端(frontier)會全 miss → 全 body-wikilink fallback(r9-F1 的 bug)。**
    - 比對:欄位值是 "[[stem]]" 字串,目標是 rel 路徑 →
      用 link_target()+env.resolve() 轉 rel 再比。
    - body-wikilink fallback(r5-F3):n.fields 只有 frontmatter;
      若「wikilink 所在端」任何 frontmatter 欄位都找不到 → via="body-wikilink"。

    via 枚舉: related / verified_by / plan_refs / body-wikilink。
    direction = "backlink" if is_backlink else "outlink"(由呼叫端 is_backlink 決定)。
    """
    # 決定「wikilink 所在端」和「被指向的目標 rel」
    if is_backlink:
        # backlink: dest 連向 frontier → wikilink 在 dest,目標是 frontier
        wikilink_node = dest
        target_rel = frontier
    else:
        # outlink: frontier 連向 dest → wikilink 在 frontier,目標是 dest
        wikilink_node = frontier
        target_rel = dest

    note = env.notes.get(wikilink_node)
    if note is None:
        return "body-wikilink"

    # 掃 frontmatter 欄位(跳過 block scalar;只看 list/str wikilink 欄位)
    for field_key in ("related", "verified_by", "plan_refs"):
        vals = as_list(note.fields.get(field_key))
        for val in vals:
            resolved = env.resolve(link_target(val))
            if resolved == target_rel:
                return field_key

    # 任何 frontmatter 欄位都找不到 → 邊來自 body([[..]])
    return "body-wikilink"


def _impact_collect(direct_node_rel, env, depth=2):
    """Task 6: 組裝單一直接節點的影響清單(直接 + 間接)。

    設計要點:
    - direct_node_rel: vault-relative 路徑(如 "Systems/A.md")。
    - 直接節點: direct_node_rel 本身,補齊 {node, hit, contract, combo}。
    - 間接關聯:
        1. core_refs 跨 repo 葉(r7-F2): 直接節點若有 core_refs,把每條值當
           「不可展開跨 repo 葉」輸出,標 via:"core_refs",cross_repo:True,
           no_expand:True,**不試圖 BFS 進它**。
           讀法: as_list(n.fields.get("core_refs"))(r3-F8:值可能 str/list)。
        2. BFS 間接關聯(via env.edges 雙向)→ 由 _impact_bfs 出結果,
           再用 _impact_via 補 via/direction。
           (BFS 項目的 cross_repo/no_expand 不存在——下游用 .get 取 false。)

    回傳: {"direct": [...], "indirect": [...]}
    格式:
      direct 每筆: {node, hit:"body-inline-code", contract, combo}
      indirect 每筆(core_refs 葉):
        {node, hop:1, via:"core_refs", direction:"outlink",
         from:<直接節點>, cross_repo:True, no_expand:True,
         contract:None, combo:False}
      indirect 每筆(BFS):
        {node, hop, via, direction, from, contract, combo}
    """
    direct_list = []
    indirect_list = []

    # 直接節點資料
    direct_note = env.notes.get(direct_node_rel)
    contract, combo = _impact_contract(direct_note) if direct_note else (None, False)
    direct_list.append({
        "node": direct_node_rel,
        "hit": "body-inline-code",
        "contract": contract,
        "combo": combo,
    })

    # 1. core_refs 跨 repo 葉(r7-F2):不 BFS 進、不查 env.notes[dest]
    if direct_note is not None:
        for core_ref in as_list(direct_note.fields.get("core_refs")):
            indirect_list.append({
                "node": core_ref,
                "hop": 1,
                "via": "core_refs",
                "direction": "outlink",
                "from": direct_node_rel,
                "cross_repo": True,
                "no_expand": True,
                "contract": None,
                "combo": False,
            })

    # 2. BFS 間接關聯(via env.edges)
    bfs_results = _impact_bfs([direct_node_rel], env, depth=depth)
    for (node, hop, from_node, is_backlink) in bfs_results:
        bfs_note = env.notes.get(node)
        bfs_contract, bfs_combo = _impact_contract(bfs_note) if bfs_note else (None, False)
        via = _impact_via(from_node, node, is_backlink, env)
        direction = "backlink" if is_backlink else "outlink"
        indirect_list.append({
            "node": node,
            "hop": hop,
            "via": via,
            "direction": direction,
            "from": from_node,
            "contract": bfs_contract,
            "combo": bfs_combo,
        })

    return {"direct": direct_list, "indirect": indirect_list}


def _impact_knob(name, default):
    """hook 面調參旋鈕:預設=凍結常數;LUMOS_IMPACT_* env 僅供 goldset 網格消融,非使用者旗標。"""
    try:
        return float(os.environ.get(name, default))
    except ValueError:
        return default


def _match_incident_triggers(file_rel, file_content, env):
    """給被碰 code 檔(路徑 + 內容),掃全圖有 pitfall_when 的事故節點,比對觸發條件。

    觸發條件格式(§2):
    - "glob:<pattern>"  — 比 file_rel 路徑(fnmatch/PurePath.match)。
    - "content:<regex>" — 比 file_content 內容(re.search)。新建檔空字串 → content 全 miss。

    回傳: list[dict]  每筆 {"node": node_rel, "matched_by": "<trigger 字串>"}。
    """
    import re
    import fnmatch
    from pathlib import PurePath

    results = []
    for node_rel, note in env.notes.items():
        triggers = as_list(note.fields.get("pitfall_when"))
        if not triggers:
            continue
        for trigger in triggers:
            if trigger.startswith("glob:"):
                pat = trigger[len("glob:"):]
                # PurePath.match 支援 ** 遞迴匹配(Python 3.12+);
                # 對舊版用 fnmatch.fnmatch 作後備以支援基本 * 通配。
                try:
                    hit = PurePath(file_rel).match(pat)
                except Exception:
                    hit = False
                if not hit:
                    # fnmatch 後備:支援 **/*Repository*.py 型 pattern
                    hit = fnmatch.fnmatch(file_rel, pat)
                if hit:
                    results.append({"node": node_rel, "matched_by": trigger})
                    break  # 同節點只計一次
            elif trigger.startswith("content:"):
                pat = trigger[len("content:"):]
                if not file_content:  # 新建檔無內容 → content 全 miss
                    continue
                try:
                    if re.search(pat, file_content):
                        results.append({"node": node_rel, "matched_by": trigger})
                        break  # 同節點只計一次
                except re.error:
                    continue  # 無效 regex 靜默跳過
    return results


def _impact_load_config(repo_root):
    """讀取 repo_root/.lumos/impact.json → {"depth":int,"ttl_min":int}。
    缺檔或解析失敗 → fail-open 回預設 {"depth":2,"ttl_min":20}。
    同 .lumos per-feature 檔慣例,但缺檔回 merged 預設(非 None)以 fail-open
    (注意:_lint_load_config 缺檔回 None,語意不同)。
    bool 值不被視為合法 int(isinstance(True, int) 在 Python 為 True,故明確排除)。
    """
    import json
    _DEFAULTS = {"depth": 2, "ttl_min": 20}
    p = Path(repo_root) / ".lumos" / "impact.json"
    if not p.exists():
        return dict(_DEFAULTS)
    try:
        with open(p, encoding="utf-8") as f:
            raw = json.load(f)
        result = dict(_DEFAULTS)
        depth_val = raw.get("depth")
        if isinstance(depth_val, int) and not isinstance(depth_val, bool):
            result["depth"] = depth_val
        ttl_val = raw.get("ttl_min")
        if isinstance(ttl_val, int) and not isinstance(ttl_val, bool):
            result["ttl_min"] = ttl_val
        return result
    except Exception:
        return dict(_DEFAULTS)


def cmd_impact(file, repo=None, depth=None, as_json=False,
               ranked=False, top=8, min_score=0.20, stdin_payload=False, incidents_only=False,
               payload=None, preloaded=None):
    """動手前算出哪些知識圖譜節點會被 code 改動波及。
    rc 協定: 0=成功(有/無影響集都算) / 3=vault 找不到 / 其他非 0=內部錯。
    Task 7: 排序 + --json schema + 人讀輸出。
    """
    import json

    # 1. 解析 repo root
    if repo is not None:
        repo_root = Path(repo)
        if not repo_root.is_dir():
            print(f"ERROR: --repo 不是目錄: {repo}", file=sys.stderr)
            return 2
    else:
        repo_root = None
        for cand in (Path.cwd(), *Path.cwd().parents):
            if (cand / ".git").exists():
                repo_root = cand
                break

    # 2. 找 vault(rc 3 = vault 找不到)
    if repo_root is not None:
        vault = _vault_in(repo_root)
    else:
        vault = find_vault(Path.cwd())
    if vault is None:
        print("IMPACT-DEBUG: vault 找不到(rc3)——非圖譜專案或 --repo 未指向含 vault 的目錄", file=sys.stderr)
        return 3

    # 3. 解析 depth:CLI(顯式 --depth) > .lumos/impact.json config > 預設 2
    _cfg_root = repo_root if repo_root is not None else vault.parent.parent
    _impact_cfg = _impact_load_config(_cfg_root)
    if depth is None:
        depth = _impact_cfg["depth"]

    # 4. 載入圖譜環境(preloaded=(vault,env) 由 --diff 聚合復用,避免逐檔重建 N+1)
    if preloaded is not None and preloaded[0] == vault:
        env = preloaded[1]
    else:
        env = Env(vault)
    repo_root_for_lookup = repo_root if repo_root is not None else vault.parent.parent

    # 5. code → node 反查(只認 body inline-code,r7-F2)
    # incidents_only 真快速路(r1 終審親驗修正:原實作僅「不顯示」,反查/BFS 照跑——宣稱落空):
    # 事故比對只需 rel_file+內容,不需 direct/BFS → 整段跳過,冷卻窗成本回到近零。
    if incidents_only:
        direct_rels = []
    else:
        direct_rels = _impact_reverse_lookup(file, env, repo_root_for_lookup)

    # 6. 組裝影響清單:single multi-source BFS 保證 hop = 距最近直接節點的 min 距離(I1)。
    #
    # 舊做法(per-node loop)問題:各直接節點各跑一次 BFS → first-wins 去重 → 若節點 N
    # 從 D1 hop=2、從 D2 hop=1,但 D1 先迭代,N 以 hop=2 進 indirect_seen → D2 的 hop=1
    # 被跳過,違反設計 §2 indirect.hop=距最近直接節點。
    #
    # 新做法:
    #   ① direct 資料:逐一收(hit/contract/combo 是 per-node 屬性)。
    #   ② core_refs 葉:逐一從各直接節點抽(也是 per-node 屬性,hop=1 固定)。
    #   ③ BFS 間接:single multi-source BFS(全部直接節點一起當種子)→ hop 自然是 min。
    #
    # 直接節點預種 direct_seen 確保:BFS 不把另一直接節點誤加進 indirect。
    all_direct = []
    all_indirect = []
    direct_seen = set(direct_rels)  # ← 預種全量,BFS seen 初始集 + dedup guard
    indirect_seen = set()  # 去重:core_refs 葉 + BFS 間接
    processed_direct = set()  # 避免同一 direct 重複展開 direct/core_refs

    # ① 直接節點資料 + ② core_refs 葉(per-node,保留原 _impact_collect 語意)
    # (incidents_only 時 direct_rels 為空,以下兩段自然零工作——BFS multi-source 種子空集即不擴散)
    for d_rel in direct_rels:
        if d_rel in processed_direct:
            continue
        processed_direct.add(d_rel)
        direct_note = env.notes.get(d_rel)
        contract, combo = _impact_contract(direct_note) if direct_note else (None, False)
        all_direct.append({"node": d_rel, "hit": "body-inline-code",
                           "contract": contract, "combo": combo})
        # core_refs 跨 repo 葉(r7-F2):hop=1 固定,不入 BFS
        if direct_note is not None:
            for core_ref in as_list(direct_note.fields.get("core_refs")):
                if core_ref not in direct_seen and core_ref not in indirect_seen:
                    indirect_seen.add(core_ref)
                    all_indirect.append({
                        "node": core_ref, "hop": 1, "via": "core_refs",
                        "direction": "outlink", "from": d_rel,
                        "cross_repo": True, "no_expand": True,
                        "contract": None, "combo": False,
                    })

    # ③ 單次 multi-source BFS:全部直接節點為種子,hop = min 距離
    unique_direct_rels = list(processed_direct)
    bfs_results = _impact_bfs(unique_direct_rels, env, depth=depth)
    for (node, hop, from_node, is_backlink) in bfs_results:
        if node in direct_seen or node in indirect_seen:
            continue
        indirect_seen.add(node)
        bfs_note = env.notes.get(node)
        bfs_contract, bfs_combo = _impact_contract(bfs_note) if bfs_note else (None, False)
        via = _impact_via(from_node, node, is_backlink, env)
        direction = "backlink" if is_backlink else "outlink"
        all_indirect.append({
            "node": node, "hop": hop, "via": via, "direction": direction,
            "from": from_node, "contract": bfs_contract, "combo": bfs_combo,
        })

    # 6. 排序(§2.4):合約節點優先 → 直接優先於間接(已分層) → 同層 hop 升序
    # 合約優先權:IRREVERSIBLE=2, INVARIANT=1, None=0
    def contract_priority(contract):
        if contract == "IRREVERSIBLE":
            return 2
        if contract == "INVARIANT":
            return 1
        return 0

    all_direct.sort(key=lambda x: -contract_priority(x.get("contract")))
    all_indirect.sort(key=lambda x: (x.get("hop", 999), -contract_priority(x.get("contract"))))

    # 7. 路徑規範化(用於輸出 + _match_incident_triggers 的 file_rel)
    rel_file = str(file)
    if os.path.isabs(rel_file) and repo_root is not None:
        rel_file = os.path.relpath(rel_file, str(repo_root))

    # 8. stdin payload(階段三):{"query","prospective":{rel:content}}——prospective 供事故比對(套 delta 後),query 供詞彙融合。
    _payload = {}
    if payload is not None:          # 內部呼叫(--diff 聚合)直接給 dict,不經 stdin
        _payload = payload
        stdin_payload = True         # query/prospective 語意與 stdin 模式一致
    elif stdin_payload:
        try:
            _payload = json.loads(sys.stdin.read() or "{}")
        except ValueError:
            _payload = {}
    # incidents 段:掃全圖 pitfall_when trigger,比對被碰檔。
    # 內容來源:stdin prospective(套 delta 後,優先)> 磁碟現況。
    _abs_file = str(file)
    if not os.path.isabs(_abs_file) and repo_root is not None:
        _abs_file = str(repo_root / _abs_file)
    _prosp = _payload.get("prospective") or {}
    file_content = _prosp.get(rel_file)   # key 一律 repo-relative(spec §3;單一查找,無 fallback 歧義)
    if file_content is None:
        try:
            file_content = Path(_abs_file).read_text(encoding="utf-8-sig", errors="replace")
        except OSError:
            file_content = ""

    # 呼叫 _match_incident_triggers,取得原始命中列表(含 node, matched_by)
    # content trigger 的比對對象(v1.1 精度修):有 delta(payload.query)→ 比對「這次改動的內容」;
    # 無 delta(legacy 呼叫)→ 比整檔現況。理由:整檔比對對單體大檔恆誤觸發
    # (scripts/lumos 本身定義 HOOK_ENTRIES 等符號,改任何一行都命中)——goldset 實測 3/9 固定席噪音源自此。
    # glob trigger(比路徑)不受影響。
    _delta_q = (_payload.get("query") or "") if stdin_payload else ""
    # 探測範圍 = delta + 鄰域窗(r1 終審折入):純 delta 會漏「改在危險函式內部、
    # 但編輯片段不含函式名」的真陰性;整檔比對又對單體檔恆誤觸發。
    # 折衷:在整檔內定位 delta 開頭片段,取 ±600 字元鄰域一起探測(窗寬 goldset 調參:2000 會把單體檔遠處符號掃回)——
    # 函式名通常在鄰域內(覆蓋回來),遠處無關符號仍在窗外(噪音不回來)。定位失敗=退回純 delta。
    _content_probe = file_content
    if _delta_q:
        _content_probe = _delta_q
        _seek = _delta_q[:80].strip()
        if _seek and file_content:
            _pos = file_content.find(_seek)
            _win = int(_impact_knob("LUMOS_IMPACT_TRIG_WIN", 600))
            if _pos >= 0 and _win > 0:
                _content_probe = _delta_q + "\n" + file_content[max(0, _pos - _win):_pos + _win]
    _raw_incidents = _match_incident_triggers(rel_file, _content_probe, env)

    # 補 contract/combo(復用 _impact_contract);建 all_incidents list
    all_incidents = []
    for inc in _raw_incidents:
        inc_note = env.notes.get(inc["node"])
        inc_contract, inc_combo = _impact_contract(inc_note) if inc_note else (None, False)
        all_incidents.append({
            "node": inc["node"],
            "matched_by": inc["matched_by"],
            "contract": inc_contract,
            "combo": inc_combo,
        })

    # 去重(§4):某節點既在 incidents 又在 direct/indirect → 從 direct/indirect 移除
    incident_node_set = {x["node"] for x in all_incidents}
    if incident_node_set:
        all_direct = [x for x in all_direct if x["node"] not in incident_node_set]
        all_indirect = [x for x in all_indirect if x["node"] not in incident_node_set]

    # 8.5 ranked 融合(階段三,spec §3):固定席(事故+含合約 direct+深度內合約 indirect)不占 top_k;
    # 非固定按 R=0.6L+0.4G 排,過 max(min_score, 0.25×最高非固定分) 閾;姐妹去冗餘於顯示層。
    if ranked or incidents_only:
        query = (_payload.get("query") or "") if stdin_payload else ""
        results = []
        # 固定席:事故(kind=incident)恆固定
        for x in all_incidents:
            results.append({"node": x["node"], "kind": "incident", "pinned": True,
                            "score": 1.0, "matched_by": x.get("matched_by"),
                            "contract": x.get("contract")})
        if not incidents_only:
            # 詞彙分:對 direct+indirect 候選跑 BM25F(query 為空則全 0)
            cand = [x["node"] for x in all_direct] + [x["node"] for x in all_indirect]
            lex = {}
            if query and cand:
                _mx = None
                raw = _rank_score_candidates(env, query, cand)
                _mx = max((s for _r, s, _h in raw), default=0.0)
                for _r, s, _h in raw:
                    lex[_r] = (s / _mx) if _mx > 0 else 0.0
            eff_depth = depth if depth is not None else 2
            _dbase = _impact_knob("LUMOS_IMPACT_DIRECT_BASE", 0.30)
            for x in all_direct:
                L = lex.get(x["node"], 0.0)
                pinned = bool(x.get("contract"))   # 含合約的 direct 固定
                results.append({"node": x["node"], "kind": "direct", "pinned": pinned,
                                "score": round(_dbase + (1.0 - _dbase) * L, 4), "L": round(L, 4),
                                "contract": x.get("contract")})
            _pin_hop = int(_impact_knob("LUMOS_IMPACT_PIN_HOP", 1))
            for x in all_indirect:
                L = lex.get(x["node"], 0.0)
                hop = x.get("hop", 2)
                contract = x.get("contract")
                # 合約固定席 hop 上限(v1.2 旋鈕):合約密集圖(Landmark 考卷實證)hop2 合約
                # 搭便車氾濫(51 席噪音)——收窄後 hop2 合約降入自由席按分數競爭(L≈0 者被閾殺)
                if contract and hop <= min(eff_depth, _pin_hop):
                    results.append({"node": x["node"], "kind": "indirect", "pinned": True,
                                    "score": round(0.40 + 0.30, 4), "L": round(L, 4),
                                    "hop": hop, "contract": contract})
                    continue
                # hop≥2 需 L>底線(遠端節點要足夠詞彙證據背書)
                if hop >= 2 and L <= _impact_knob("LUMOS_IMPACT_LMIN_HOP2", 0.0):
                    continue
                G = 0.60 * min(1.0, 2.0 / (2 ** hop))
                R = round(0.60 * L + 0.40 * G, 4)
                results.append({"node": x["node"], "kind": "indirect", "pinned": False,
                                "score": R, "L": round(L, 4), "hop": hop, "contract": contract})
        # 分固定/非固定;非固定過閾+排序+補到 top_k
        pins = [r for r in results if r["pinned"]]
        free = [r for r in results if not r["pinned"]]
        max_free = max((r["score"] for r in free), default=0.0)
        thresh = max(float(min_score), _impact_knob("LUMOS_IMPACT_DYN_COEF", 0.65) * max_free)
        free = [r for r in free if r["score"] >= thresh]
        free.sort(key=lambda r: (-r["score"], r.get("hop", 0), r["node"]))
        # 名額制(v1.1):單體檔洪水按排名剪尾——閾值管品質、名額管上限(gate 對齊 top_k+2=10);
        # 剪的是 11 名以後,不動前 8 的視野(精度/必看召回不受影響)
        _quota = int(_impact_knob("LUMOS_IMPACT_FREE_QUOTA", 10))
        truncated = max(0, len(free) - min(int(top), _quota))
        free = free[:min(int(top), _quota)]
        # 姐妹去冗餘(顯示層,--json 全量不折)
        final = pins + free
        meta = {"candidates": len(all_direct) + len(all_indirect) + len(all_incidents),
                "pinned": len(pins), "truncated": truncated,
                "safety_overflow": max(0, len(pins) - int(top))}
        if as_json:
            print(json.dumps({"file": rel_file, "results": final, "meta": meta},
                             ensure_ascii=False))
        else:
            print(f"改動 {rel_file} — 相關 top(固定席 {len(pins)}):")
            for r in final:
                mk = {"incident": "⚠事故", "direct": "直接", "indirect": f"hop{r.get('hop','?')}"}.get(r["kind"], "")
                ct = f" ★{r['contract']}★" if r.get("contract") else ""
                pin = " [固定]" if r["pinned"] else ""
                print(f"  {r['score']:5.2f} {mk} {r['node']}{ct}{pin}")
            if meta["truncated"]:
                print(f"  (+{meta['truncated']} 條低分截斷;--json 全量)")
            if meta["safety_overflow"]:
                print(f"  safety overflow: {meta['safety_overflow']}")
        return 0

    # 9. 輸出
    if as_json:
        print(json.dumps(
            {"file": rel_file, "direct": all_direct, "indirect": all_indirect,
             "incidents": all_incidents},
            ensure_ascii=False,
        ))
    else:
        # 人讀輸出
        print(f"改動 {rel_file} (由讀盤 refcheck 抽取)")
        print(f"── 直接關聯 ({len(all_direct)}) ──")
        for x in all_direct:
            contract_tag = f" ★{x['contract']}★" if x.get("contract") else ""
            combo_tag = "★COMBO★" if x.get("combo") else ""
            tags = (contract_tag + (" " + combo_tag if combo_tag else "")).rstrip()
            print(f"  {'⚠合約 ' if x.get('contract') else ''}{x['node']}{tags}  ({x['hit']})")
        print(f"── 間接關聯 ({len(all_indirect)}) ──")
        for x in all_indirect:
            cross = " [跨repo葉,不展開]" if x.get("cross_repo") else ""
            print(f"  hop{x['hop']}  {x['node']}  {x['direction']} ← via {x['via']} ← {x['from']}{cross}")
        if all_incidents:
            print(f"── 相關事故 ({len(all_incidents)}) ──")
            for x in all_incidents:
                contract_tag = f" ★{x['contract']}★" if x.get("contract") else ""
                print(f"  {x['node']}{contract_tag}  (trigger: {x['matched_by']})")

    return 0


_IMPACT_DIFF_SKIP = ("docs/", "governance/golden/")   # 圖譜/凍結快照非 code,不當 impact 種子


def _impact_diff_seed_ok(f):
    """--diff 種子過濾:只收 code 檔。剔除圖譜/凍結快照/帳檔(.jsonl)/文檔(.md)/
    governance 資料 .json(goldset/裁決紀錄內嵌歷史 code 片段,會偽觸發事故 pin——r1 panel 實證)。"""
    if not f or any(f.startswith(p) for p in _IMPACT_DIFF_SKIP):
        return False
    if f.endswith((".jsonl", ".md")):
        return False
    if f.endswith(".json") and f.startswith("governance/"):
        return False
    return True


def cmd_impact_diff(diff_range, repo=None, depth=None, top=8, min_score=0.20, as_json=False,
                    sync_check=False):
    """code-loop 橋接:對整段 diff 的每支改動 code 檔跑 ranked impact(query=該檔 hunk 文字),
    聚合成「受影響功能面」manifest——固定席(合約/事故)全保、非固定取跨檔最高分 top-N。
    定位=審計員鏡頭(advisory,人判),非自動推播(hook 面 goldset 評測未過線,故不接 hook)。
    rc: 0=成功 / 2=git 失敗 / 3=vault 缺。"""
    import json as _json
    import subprocess as _sp
    if diff_range.startswith("-"):
        # 同 pitfalls/cochange-check:'-' 開頭值會被 git 誤認成選項,查詢命令 rc2 拒收
        print("ERROR: --diff 不接受以 '-' 開頭的值", file=sys.stderr)
        return 2
    repo_root = Path(repo) if repo else None
    if repo_root is None:
        for cand in (Path.cwd(), *Path.cwd().parents):
            if (cand / ".git").exists():
                repo_root = cand
                break
    if repo_root is None or not (repo_root / ".git").exists():
        print("ERROR: 找不到 git repo(--repo 指定)", file=sys.stderr)
        return 2
    # core.quotePath=false:CJK 檔名不轉義加引號(否則 startswith/endswith 過濾全失效,r2 panel major)
    r = _sp.run(["git", "-C", str(repo_root), "-c", "core.quotePath=false",
                 "diff", "--name-only", diff_range], capture_output=True, text=True)
    if r.returncode != 0:
        print(f"ERROR: git diff 失敗: {r.stderr.strip()[:200]}", file=sys.stderr)
        return 2
    files = []
    for f in r.stdout.splitlines():
        f = f.strip()
        if not _impact_diff_seed_ok(f):
            continue
        # 已刪檔不跳過:反查靠「節點 body 引用該路徑」而非檔案存在——
        # 刪除/改名正是合約節點最該被推到審計員眼前的時刻(r1 codex major)
        files.append(f)
    merged = {}          # node -> entry(跨檔取最高分;pinned 任一檔 pinned 即 pinned)
    per_file_meta = []
    import io, contextlib
    _vault = _vault_in(repo_root)
    _env_shared = Env(_vault) if _vault is not None else None   # 建一次,逐檔復用(r1 N+1)
    for f in files:
        d = _sp.run(["git", "-C", str(repo_root), "-c", "core.quotePath=false",
                     "diff", diff_range, "--", f], capture_output=True, text=True)
        hunk = " ".join(l[1:].strip() for l in d.stdout.splitlines()
                        if l[:1] in "+-" and not l.startswith(("+++", "---")))[:4000]
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            rc = cmd_impact(f, repo=str(repo_root), depth=depth, as_json=True,
                            ranked=True, top=top, min_score=min_score,
                            payload={"query": hunk, "prospective": {}},
                            preloaded=(_vault, _env_shared) if _env_shared is not None else None)
        if rc == 3:
            print("IMPACT-DEBUG: vault 找不到(rc3)", file=sys.stderr)
            return 3
        if rc != 0:
            continue
        try:
            data = _json.loads(buf.getvalue().strip().splitlines()[-1])
        except (ValueError, IndexError):
            continue
        per_file_meta.append({"file": f, **data.get("meta", {})})
        for x in data.get("results", []):
            cur = merged.get(x["node"])
            if cur is None:
                merged[x["node"]] = {**x, "files": [f]}
            else:
                if f not in cur["files"]:
                    cur["files"].append(f)
                pinned = cur["pinned"] or x.get("pinned", False)
                if x["score"] > cur["score"]:
                    # 整項以勝出結果重建(避免 hop/L 舊值殘留成幽靈欄位,r1 s4 minor)
                    merged[x["node"]] = {**x, "files": cur["files"], "pinned": pinned}
                else:
                    cur["pinned"] = pinned
    pins = sorted([v for v in merged.values() if v["pinned"]],
                  key=lambda v: (-v["score"], v["node"]))
    free = sorted([v for v in merged.values() if not v["pinned"]],
                  key=lambda v: (-v["score"], v["node"]))[:int(top)]
    # 落成位置閉環(sync-check):預期受影響節點 ∩ 分支實際動過的圖譜節點——
    # 「這功能被改了,它的節點卻沒動」= 受影響未同步清單(advisory,人判;固定席可信度高、自由席≈P@8 .70)
    sync = None
    if sync_check:
        _vault_name = _vault.name if _vault is not None else None
        touched = set()
        if _vault_name:
            _prefix = f"docs/{_vault_name}/"
            for f2 in r.stdout.splitlines():
                f2 = f2.strip().strip('"')
                if f2.startswith(_prefix) and f2.endswith(".md"):
                    touched.add(f2[len(_prefix):])
        missing = [v for v in (pins + free) if v["node"] not in touched]
        sync = {"touched_nodes": sorted(touched),
                "missing": [{"node": v["node"], "pinned": v["pinned"],
                             "score": v["score"], "files": v["files"]} for v in missing]}
    if as_json:
        print(_json.dumps({"range": diff_range, "files": files,
                           "results": pins + free,
                           **({"sync": sync} if sync is not None else {}),
                           "meta": {"files": len(files), "pinned": len(pins),
                                    "free_kept": len(free),
                                    "free_total": sum(1 for v in merged.values() if not v["pinned"]),
                                    "per_file": per_file_meta}}, ensure_ascii=False))
        return 0
    print(f"受影響功能面({diff_range};{len(files)} 檔;固定席 {len(pins)}+top {len(free)}——審計鏡頭,人判):")
    for v in pins + free:
        mk = {"incident": "⚠事故", "direct": "直接", "indirect": f"hop{v.get('hop','?')}"}.get(v["kind"], "")
        ct = f" ★{v['contract']}★" if v.get("contract") else ""
        pin = " [固定]" if v["pinned"] else ""
        print(f"  {v['score']:5.2f} {mk} {v['node']}{ct}{pin}  ←{','.join(v['files'][:3])}")
    if not merged:
        print("  (無節點引用這些檔——圖譜對此 diff 無覆蓋)")
    if sync is not None:
        print(f"\n落成核對(分支動過 {len(sync['touched_nodes'])} 個節點):")
        if not sync["missing"]:
            print("  ✓ 預期受影響節點全數已同步")
        else:
            for v in sync["missing"]:
                mark = "⚠必看" if v["pinned"] else "  "
                print(f"  {mark} 未同步 {v['node']}  ←{','.join(v['files'][:2])}")
            print("  (advisory:漏了還是不用?逐條判;固定席可信度高,自由席人判)")
    return 0


# ── code-loop 留痕(Task 1) ────────────────────────────────────────────────────

def _codeloop_git_branch(repo_root):
    """取 HEAD branch 名(detached HEAD 回 HEAD)。"""
    import subprocess
    r = subprocess.run(["git", "rev-parse", "--abbrev-ref", "HEAD"],
                       capture_output=True, text=True, cwd=str(repo_root))
    return r.stdout.strip() or "HEAD"


def _codeloop_git_head(repo_root):
    """取 HEAD full sha。"""
    import subprocess
    r = subprocess.run(["git", "rev-parse", "HEAD"],
                       capture_output=True, text=True, cwd=str(repo_root))
    return r.stdout.strip()


def _codeloop_git_ts(repo_root):
    """取 HEAD committer date(ISO 8601);失敗回空字串。"""
    import subprocess
    r = subprocess.run(["git", "show", "-s", "--format=%cI", "HEAD"],
                       capture_output=True, text=True, cwd=str(repo_root))
    return r.stdout.strip().splitlines()[0] if r.stdout.strip() else ""


def _codeloop_branch_filename(branch):
    """把 branch 名扁平化(/ → __)避免建子目錄。"""
    return branch.replace("/", "__")


def _codeloop_read(repo_root, branch):
    """讀 governance/code-loop/<branch>.json;不存在回 None。"""
    import json
    safe = _codeloop_branch_filename(branch)
    p = Path(repo_root) / "governance" / "code-loop" / f"{safe}.json"
    if not p.exists():
        return None
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return None


def _codeloop_write(repo_root, branch, status, note, head_sha, ts):
    """寫 governance/code-loop/<branch>.json。"""
    import json
    safe = _codeloop_branch_filename(branch)
    d = Path(repo_root) / "governance" / "code-loop"
    d.mkdir(parents=True, exist_ok=True)
    rec = {"head_sha": head_sha, "status": status, "note": note, "ts": ts}
    (d / f"{safe}.json").write_text(
        json.dumps(rec, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def _codeloop_gov_log(repo_root, branch, status, note, head_sha, ts):
    """把 code-loop 事件 append 到 docs/.governance-log.jsonl(同 bypass-log 哲學)。
    vault 找不到 / 非 git repo → 靜默跳過。"""
    import json
    import subprocess
    # 找 docs 目錄(repo root 下的 docs/)
    docs = Path(repo_root) / "docs"
    if not docs.is_dir():
        return
    if not head_sha:
        return
    path = docs / ".governance-log.jsonl"
    try:
        commit_short = head_sha[:7]
        event = {
            "ts": ts, "commit": commit_short,
            "gate": "code-loop", "kind": status,
            "hard": False, "nodes": [],
            "detail": note, "branch": branch, "head_sha": head_sha,
        }
        with open(path, "a", encoding="utf-8") as f:
            f.write(json.dumps(event, ensure_ascii=False) + "\n")
    except OSError:
        pass


def _codeloop_guard_verdict(repo_root):
    """判定式:tier=high(pitfalls --diff merge-base..HEAD --no-lint --json)
    AND 無有效 pass/skip 留痕(head_sha 綁 HEAD) → blocked=True。
    fail-open:pitfalls 出錯 / 非 git / 無 merge-base → tier 視作非 high(不 blocked)。
    回傳 dict{blocked:bool, reason:str, tier:str}。
    """
    import json as _json
    import subprocess as _sp

    # 1. 取 HEAD sha
    head_sha = _codeloop_git_head(repo_root)
    if not head_sha:
        return {"blocked": False, "reason": "無法取得 HEAD sha(fail-open)", "tier": "unknown"}

    # 2. 取 merge-base(fail-open)
    mb = None
    for base_branch in ("main", "master"):
        r = _sp.run(["git", "merge-base", "HEAD", base_branch],
                    capture_output=True, text=True, cwd=str(repo_root))
        if r.returncode == 0 and r.stdout.strip():
            mb = r.stdout.strip()
            # 若 merge-base == HEAD(在 base branch 上),表示未出 branch,tier 非 high
            if mb == head_sha:
                return {"blocked": False, "reason": "merge-base == HEAD(無 branch diff)", "tier": "standard"}
            break

    if not mb:
        return {"blocked": False, "reason": "無 merge-base(fail-open)", "tier": "unknown"}

    # 3. 跑 pitfalls --diff merge-base..HEAD --no-lint --json 取 tier
    diff_range = f"{mb}..HEAD"
    try:
        import sys as _sys
        graphctl = Path(__file__).resolve()
        r = _sp.run([_sys.executable, str(graphctl), "pitfalls",
                     "--diff", diff_range, "--no-lint", "--json",
                     "--repo", str(repo_root)],
                    capture_output=True, text=True, cwd=str(repo_root))
        if r.returncode != 0:
            return {"blocked": False, "reason": f"pitfalls 失敗(fail-open): {r.stderr.strip()[:120]}", "tier": "unknown"}
        lines = [l for l in r.stdout.splitlines() if l.strip().startswith("{")]
        if not lines:
            return {"blocked": False, "reason": "pitfalls 無 JSON 輸出(fail-open)", "tier": "unknown"}
        data = _json.loads(lines[0])
        tier = data.get("tier", "standard")
    except Exception as e:
        return {"blocked": False, "reason": f"pitfalls 例外(fail-open): {e}", "tier": "unknown"}

    if tier != "high":
        return {"blocked": False, "reason": f"tier={tier}(非 high)", "tier": tier}

    # 4. 讀留痕,pass/skip 且 head_sha == HEAD → 有效
    branch = _codeloop_git_branch(repo_root)
    rec = _codeloop_read(repo_root, branch)
    if rec is not None:
        rec_sha = rec.get("head_sha", "")
        rec_status = rec.get("status", "")
        if rec_sha == head_sha and rec_status in ("passed", "skipped"):
            return {"blocked": False, "reason": f"有效留痕({rec_status}@{head_sha[:8]})", "tier": tier}
        # 留痕存在但 sha 不符或狀態不對
        if rec_sha != head_sha:
            reason = f"tier=high 且留痕 sha 過時(留痕={rec_sha[:8]} HEAD={head_sha[:8]})"
        else:
            reason = f"tier=high 且留痕狀態無效({rec_status!r})"
        return {"blocked": True, "reason": reason, "tier": tier}

    # 5. 無留痕
    return {"blocked": True, "reason": "tier=high 且無留痕(尚未跑 code-loop pass/skip)", "tier": tier}


def cmd_code_loop(subcmd, note=None, repo=None, as_json=False):
    """code-loop 留痕讀寫。
    pass  → status=passed(綁 HEAD sha);
    skip  → status=skipped(綁 HEAD sha,留逃生痕);
    check → 跑判定式回報 verdict(blocked=tier=high∧無有效留痕);--json 輸出 verdict dict。
    rc: 0=OK / 1=check:blocked / 2=參數錯。
    """
    # resolve repo root
    if repo is not None:
        repo_root = Path(repo)
        if not repo_root.is_dir():
            print(f"ERROR: --repo 不是目錄: {repo}", file=sys.stderr)
            return 2
    else:
        repo_root = None
        for cand in (Path.cwd(), *Path.cwd().parents):
            if (cand / ".git").exists():
                repo_root = cand
                break
        if repo_root is None:
            print("ERROR: 找不到 git repo root(.git),請用 --repo 指定", file=sys.stderr)
            return 2

    branch = _codeloop_git_branch(repo_root)
    head_sha = _codeloop_git_head(repo_root)
    if not head_sha:
        print("ERROR: 無法取得 HEAD sha(git 指令失敗?)", file=sys.stderr)
        return 2
    ts = _codeloop_git_ts(repo_root)

    if subcmd in ("pass", "skip"):
        status = "passed" if subcmd == "pass" else "skipped"
        _codeloop_write(repo_root, branch, status, note or "", head_sha, ts)
        _codeloop_gov_log(repo_root, branch, status, note or "", head_sha, ts)
        label = "✅" if status == "passed" else "⏭"
        print(f"{label} code-loop {status} [{branch}@{head_sha[:8]}] {note or ''}")
        return 0

    if subcmd == "check":
        # Task 2: 完整判定式(tier-high∧無有效留痕 → blocked)
        import json as _cljson
        verdict = _codeloop_guard_verdict(repo_root)
        blocked = verdict["blocked"]
        reason = verdict["reason"]
        tier = verdict["tier"]
        if as_json:
            print(_cljson.dumps(verdict, ensure_ascii=False))
        else:
            if blocked:
                print(f"⚠ code-loop check: BLOCKED [{branch}@{head_sha[:8]}] {reason}",
                      file=sys.stderr)
            else:
                print(f"✅ code-loop check: OK [{branch}@{head_sha[:8]}] tier={tier} {reason}")
        return 1 if blocked else 0

    print(f"ERROR: 未知子命令 {subcmd!r}", file=sys.stderr)
    return 2


def main():
    ap = argparse.ArgumentParser(prog="lumos", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("--vault", type=Path, default=None,
                    help="vault 路徑 (預設自動找 docs/*-knowledge)")
    sub = ap.add_subparsers(dest="cmd", required=True)

    d = sub.add_parser("doctor", help="圖譜健康巡檢")
    d.add_argument("--strict", action="store_true", help="有 finding 即 exit 1 (CI 用)")
    d.add_argument("--ci", action="store_true", help="CI 模式 = --strict + 無色彩")
    d.add_argument("--suggest", action="store_true",
                   help="orphan Verification 附推薦掛載 Systems(從正文連結/plan_refs/feature 推斷,供人確認)")

    for name, hlp in (("links", "連出的節點"), ("backlinks", "連入的節點")):
        p = sub.add_parser(name, help=hlp)
        p.add_argument("note")

    p = sub.add_parser("context", help="節點+鄰居壓縮索引")
    p.add_argument("note")
    p.add_argument("--brief", action="store_true", help="壓縮版(meta+summary 首兩行+鄰居名單)")
    p.add_argument("--recommend", action="store_true", help="尾列相關節點推薦(圖分×詞彙融合;dormant v1)")
    p.add_argument("--top", type=int, default=8, dest="ctx_top", help="--recommend 輸出上限")
    p.add_argument("--min-score", type=float, default=0.20, dest="ctx_min", help="--recommend 分數底線")
    p.add_argument("--json", action="store_true", dest="ctx_json", help="--recommend JSON 輸出")

    p = sub.add_parser("contracts", help="合約登記簿 ★INVARIANT★/★DEBT★(全 vault 或單節點)")
    p.add_argument("note", nargs="?")

    p = sub.add_parser("lint", help="單檔快檢:寫完一個節點立刻自驗標籤/格式(比 doctor 快,只看這篇)")
    p.add_argument("note")

    p = sub.add_parser("gov", help="唯讀治理事件帳:時間軸 / 某節點歷來被哪幾道閘攔過")
    p.add_argument("node", nargs="?")
    p.add_argument("--since", type=int, default=90, help="近 N 天(預設 90)")

    cp = sub.add_parser("canary", help="審計員 canary 留痕(test-the-tester):某輪對抗審計有沒有抓到植入瑕疵")
    csub = cp.add_subparsers(dest="ccmd", required=True)
    cr = csub.add_parser("record", help="記一筆 caught|missed")
    cr.add_argument("kind", choices=("caught", "missed"))
    cr.add_argument("--auditor", help="審計用的模型(如 sonnet)")
    cr.add_argument("--token", help="canary token(不給則自動鑄 CANARY-<隨機>)")
    cr.add_argument("--note", help="備註")
    cr.add_argument("--loop", help="把這輪歸進某設計 loop(供 lumos loop status 算收斂)")
    cr.add_argument("--severity", choices=("clean", "minor", "major", "blocker"),
                    help="這輪審計員找到的最嚴重 finding(忠實轉錄)")
    cr.add_argument("--findings", type=int,
                    help="該輪辯方裁決後存活折入的真 findings 數(canary 不計;供 loop status --gate 枯竭錨)")
    cr.add_argument("--round", dest="round_id",
                    help="panel 輪 id(一輪 W 個平行審計員的記錄共享;供 loop status --panel 分組)")
    cr.add_argument("--capture-counts", dest="capture_counts",
                    help="panel 輪的 capture-recapture 輸入:各 distinct 缺陷被幾個審計員找到,逗號分隔(如 '2,2,1');供殘餘估計")
    cr.add_argument("--clusters",
                    help="M2 risk-cluster 三態帳:'名=狀態,...'(resolved/accepted-minor:理由/disputed-major);每輪至多一筆帶,loop status --panel 消費")

    lp = sub.add_parser("loop", help="審計 loop 收斂查詢(消費 canary-log 的 --loop 記錄)")
    lsub = lp.add_subparsers(dest="lcmd", required=True)
    ls = lsub.add_parser("status", help="算某 loop 收斂:連 K 輪 caught 且無 blocker/major")
    ls.add_argument("loop_id")
    ls.add_argument("--need", type=int, default=2, help="連續乾淨輪數 K(預設 2)")
    ls.add_argument("--gate", action="store_true",
                    help="證據閘:K-streak(必要)∧ G1 refcheck 引用座標 ∧ G2 發現枯竭,全過才 rc 0")
    ls.add_argument("--spec", dest="gate_spec", help="--gate 必填:要核對引用座標的最終 spec md")
    ls.add_argument("--repo", dest="gate_repo", help="repo root(預設 cwd 逐層向上找 .git)")
    ls.add_argument("--panel", action="store_true",
                    help="平行 panel 模式:按 round-id 分組。無-cluster 舊帳=三條合取(輪有效∧存活max≤minor∧capture-recapture殘餘,fail-closed);cluster 帳(M2,首個有效輪帶 --clusters 定錨)=兩條合取(輪有效∧fold後無disputed-major),新生cluster/capture-recapture 降 advisory。--gate 對 panel 為相容 no-op(panel 判準恆生效)")
    lcc = lsub.add_parser("capture-counts",
                          help="異質 finder 接線:多 --finder 的 finding-key → capture_counts + 殘餘估計(餵 canary record --capture-counts)")
    lcc.add_argument("--finder", dest="finders", action="append", default=[],
                     help="一個 finder 找到的 finding-key 逗號串(LLM reviewer / SARIF linter / 測試失敗 / mutation 存活各給一個)")
    lcc.add_argument("--from-pitfalls", dest="cc_pitfalls",
                     help="自動收割 pitfalls --diff <range> 命中成確定性 finder(按 source 分組,免手貼)")
    lcc.add_argument("--repo", dest="cc_repo", help="repo root(--from-pitfalls 用;預設 cwd 向上找 .git)")

    g = sub.add_parser("guard", help="合約守衛 scaffold(對談驅動):列出未綁 / 套範本產 stub / 綁定")
    gsub = g.add_subparsers(dest="gcmd", required=True)
    gl = gsub.add_parser("list", help="列 ★INVARIANT★ 綁定狀態(real/dangling/fake/naked)")
    gl.add_argument("--unbound", action="store_true", help="只列未綁(懸空/偽證據/裸)")
    gs = gsub.add_parser("scaffold", help="套範本產測試 stub(預設紅燈,斷言留 TODO)")
    gs.add_argument("--node", required=True, help="守衛的 Systems 節點")
    gs.add_argument("--invariant", required=True, help="KEY 行子字串(定位該合約)")
    gs.add_argument("--method", required=True, help="測試方法名(= [test:] 認領名)")
    gs.add_argument("--type", required=True, choices=list(GUARD_TYPES))
    gs.add_argument("--claim", required=True, help="向人確認過的可測斷言(白話,寫進 stub 註解)")
    gs.add_argument("--out", help="測試專案目錄(預設自動偵測 *Tests / *IntegrationTests)")
    gs.add_argument("--template", help="範本路徑(預設 .lumos/guard-templates/<type>.tmpl)")
    gs.add_argument("--class", dest="klass", help="測試類別名(預設 <method>Tests)")
    gs.add_argument("--platform", help="多平台 config 下指定平台(決定 root/profile/範本落點);"
                                       "省略且單一平台時自動選,多平台則必填")
    gb = gsub.add_parser("bind", help="把 [test:方法] 綁回 KEY 行(寫後自驗)")
    gb.add_argument("node")
    gb.add_argument("invariant", help="KEY 行子字串")
    gb.add_argument("method")
    gb.add_argument("--platform", help="多平台 config 下寫成 [test:平台:方法](method 維持識別字)")
    ga = gsub.add_parser("audit", help="留痕 [audit:模型/日期]:合法性經無脈絡獨立 agent 審計過(maker≠checker)")
    ga.add_argument("node")
    ga.add_argument("invariant", help="KEY 行子字串")
    ga.add_argument("--model", default="sonnet", help="審計用的模型(預設 sonnet — 刻意較弱,不腦補補洞)")
    ga.add_argument("--date", help="審計日期 YYYY-MM-DD(預設今天)")
    gt = gsub.add_parser("trace", help="合約→守衛測試→Verification 證據鏈(reverse:爆炸半徑可查)")
    gt.add_argument("node", nargs="?", help="限單節點(預設全 vault)")
    gka = gsub.add_parser("kill-add", help="宣告壞法配方(kill_recipes+[kill:recipes],同檔原子寫)")
    gka.add_argument("node")
    gka.add_argument("invariant", help="KEY 行子字串")
    gka.add_argument("--file", required=True, help="要弄壞的檔(相對配方平台 root)")
    gka.add_argument("--old", required=True, help="literal 原文(須唯一命中)")
    gka.add_argument("--new", required=True, help="壞版本")
    gka.add_argument("--test", help="綁定測試名(缺省=KEY 行唯一 [test:] ref)")
    gka.add_argument("--platform", dest="gk_platform", help="配方所屬平台(多平台 config)")
    gka.add_argument("--note", default="", help="業務上壞了什麼(人話)")
    gk = gsub.add_parser("kill", help="跑殺傷力驗證:worktree 隔離→baseline 綠→套壞法→綁定測試必須翻紅")
    gk.add_argument("node")
    gk.add_argument("invariant", nargs="?", help="限某合約(KEY 行子字串;預設全部配方)")
