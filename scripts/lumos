    gk.add_argument("--keep-worktree", action="store_true", help="保留沙盒現場(除錯)")

    p = sub.add_parser("spec-trace", help="條款級追溯(RTM 輕量):計劃 [SN] 條款 × 回指 Verification 認領;未認領 rc1")
    p.add_argument("node", help="計劃節點")
    p.add_argument("--json", dest="st_json", action="store_true")

    p = sub.add_parser("signoff", help="業務簽核留痕(validation):人點頭 → .signoff-log.jsonl + frontmatter signed_off")
    p.add_argument("node")
    p.add_argument("--note", required=True, help="確認了什麼(必填,給未來的人看)")
