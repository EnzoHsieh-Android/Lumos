#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""Lumos — 知識圖譜的控制台(graph-as-contract control plane)

每一次全 AI 迭代是一條線,Lumos 把它織進「已理解的布」:巡檢 / 寫入 / 強制 / 視覺化。
self-contained,無 Obsidian app / obsidian CLI 依賴,CI 可跑。
設計與驗收標準: docs/<project>-knowledge/Projects/lumos_計劃.md

子命令:
  doctor      圖譜健康巡檢(四檢查 + 同名守衛 + frontmatter lint)
  links       某筆記連出去的節點
  backlinks   連到某筆記的節點
  map         鄰域樹狀展開(--depth)
  context     節點 + 鄰居 summary 壓縮索引(MemPalace closet 具象化)
  decisions   讀取 ADR 決策(單篇,或 --superseded 全 vault 掃被推翻決策)
  stale       status=stale 的驗證;--match 掃 valid_under/revalidate_when 命中條件
  recent      最近 N 天修改的筆記
  stats       資料夾統計
  export      輸出 mermaid / dot 圖

解析範圍(對齊 Obsidian 行為與 skill 鐵則):
  - body 的 [[wikilink]],排除 fenced code block 與 inline code(Obsidian 不索引)
  - frontmatter: 整個值恰為一個 wikilink 才索引(散文中夾帶的 [[..]] 不算;
    2026-06-13 並跑首日 parity diff 修正)
  - block scalar(summary: |- 等)內的 [[..]] 不算連結(鐵則 2)
  - 連結解析: 路徑優先,fallback basename,大小寫不敏感,NFC 正規化
"""
import argparse
import os
import re
import sys
import time
import unicodedata
from collections import defaultdict, deque, namedtuple
from pathlib import Path

_IS_WIN = os.name == "nt"

# ── Task 5: 版本標籤(人可讀;advisory nudge 用;非正確性 oracle) ───────────────
LUMOS_VERSION = "v1.0"  # release 手動 bump;允許粗——它是標籤,不是內容指紋

# ── CLAUDE.md sentinel 常數(Task 1: reinject)────────────────────────────────
# START 行後面可能帶版本戳與說明(e.g. " v1.2 — 勿手改 -->"),故用前綴 find。
_CLAUDE_START_PREFIX = "<!-- LUMOS:GRAPH-DISCIPLINE:START"
_CLAUDE_END = "<!-- LUMOS:GRAPH-DISCIPLINE:END -->"
# Task 5: START 行模板(含版本佔位符);reinject 時 .format(version=LUMOS_VERSION)。
# 範本 graph-discipline.md 保持無版本戳(canonical prefix 形式);
# 版本由 reinject 當下插值——單一源 = LUMOS_VERSION 常數,無「改範本忘 bump」風險。
_START_TEMPLATE = (
    "<!-- LUMOS:GRAPH-DISCIPLINE:START {version}"
    " — 自動注入/更新,勿手改本區塊;"
    "改範本 scripts/templates/graph-discipline.md -->"
)
# BlockSpan: body=兩 sentinel 之間的內容(strip 首尾空行),
#            body_start/body_end=body 在原 text 中的字元位移,
#            保證 text[body_start:body_end] == body。
BlockSpan = namedtuple("BlockSpan", "body body_start body_end")
# Task 2: ReInjectResult ─ status ∈ created|updated|unchanged|appended|sentinel_broken|no_template
ReInjectResult = namedtuple("ReInjectResult", "status diff")

FENCE_RE = re.compile(r"^```.*?^```", re.S | re.M)
INLINE_CODE_RE = re.compile(r"`[^`\n]*`")
WIKILINK_RE = re.compile(r"\[\[([^\[\]]+?)\]\]")
DATE_PREFIX_RE = re.compile(r"^(\d{4}-\d{2}-\d{2})")
TOP_KEY_RE = re.compile(r"^([A-Za-z_][\w-]*):\s*(.*)$")
LIST_ITEM_RE = re.compile(r"^\s+-\s+(.*)$")
QUOTED_DATE_RE = re.compile(
    r'^\s*(?:-\s+)?(?:date|created|updated|decided|ended):\s*"\d{4}-\d{2}-\d{2}"')
RULE3_RE = re.compile(r"^\s+-\s+\w+: [^\"'|>\s][^\"']*: \S")  # 未引號值含 ": "


def nfc(s):
    return unicodedata.normalize("NFC", s)


def strip_quotes(s):
    if len(s) >= 2 and s[0] == s[-1] and s[0] in "\"'":
        return s[1:-1]
    return s


def link_target(s):
    """從 wikilink 字串/list 項抽**完整 target**(去 [[]]、alias、heading、引號;**保留路徑**)。
    `[[Verification/X|y]]` → `Verification/X`。寫側 dedup 用它做精確比對:
    既修子字串誤判(A vs A_v2 不同),又不像 basename-only 把跨資料夾 Systems/X vs
    Verification/X 誤判相同(2026-06-13 第二輪審計 NEW-A)。"""
    t = strip_quotes(str(s).strip())
    t = t.replace("[[", "").replace("]]", "")
    t = t.split("|")[0].split("#")[0].strip()
    if t.lower().endswith(".md"):
        t = t[:-3]
    return nfc(t)


def split_frontmatter(text):
    """回傳 (fm_lines or None, body)"""
    if not text.startswith("---"):
        return None, text
    lines = text.split("\n")
    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            return lines[1:i], "\n".join(lines[i + 1:])
    return None, text


def parse_frontmatter(fm_lines):
    """極簡 parser(本 vault 慣例範圍): top-level 純量 + 字串 list + block scalar 內文。
    回傳 (fields, block_keys, lint)
      fields: dict[key] = str | list[str];block scalar 的 key 也存內文(供 context 用)
      block_keys: block scalar 的 key 集合(其值內的 [[..]] 不得索引,鐵則 2)
      lint: 鐵則指紋發現
    """
    fields, block_keys, lint = {}, set(), []
    seen = set()
    i, n = 0, len(fm_lines)
    while i < n:
        line = fm_lines[i]
        m = TOP_KEY_RE.match(line)
        if not m:
            i += 1
            continue
        key, val = m.group(1), m.group(2).strip()
        if key in seen:
            lint.append(f"鐵則4 同層重複鍵: {key}")
        seen.add(key)
        if val in ("|", "|-", ">", ">-"):
            block = []
            i += 1
            while i < n and (fm_lines[i].startswith("  ") or not fm_lines[i].strip()):
                if fm_lines[i].strip():
                    block.append(fm_lines[i].strip())
                i += 1
            fields[key] = "\n".join(block)
            block_keys.add(key)
            continue
        if val == "":
            items = []
            i += 1
            while i < n:
                l2 = fm_lines[i]
                if not l2.strip():
                    i += 1
                    continue
                if not l2.startswith(" "):
                    break
                ms = LIST_ITEM_RE.match(l2)
                if ms:
                    item = strip_quotes(ms.group(1).strip())
                    items.append(item)
                    if "]], [[" in item or "]],[[" in item:
                        lint.append(f"鐵則1 單字串多 wikilink: {key} 項 → ghost 節點風險")
                if RULE3_RE.match(l2):
                    lint.append(f"鐵則3 未引號值含「: 」: {l2.strip()[:60]}")
                i += 1
            fields[key] = items
            continue
        sval = strip_quotes(val)
        if sval == "[]":  # 行內空列表(YAML flow style)
            fields[key] = []
            i += 1
            continue
        fields[key] = sval
        if "]], [[" in sval or "]],[[" in sval:
            lint.append(f"鐵則1 單字串多 wikilink: {key} → ghost 節點風險")
        i += 1
    for line in fm_lines:
        if QUOTED_DATE_RE.match(line):
            lint.append(f"污染指紋 日期加引號(property 型別損傷): {line.strip()}")
    return fields, block_keys, lint


def extract_targets(text):
    out = []
    for raw in WIKILINK_RE.findall(text):
        t = raw.split("|")[0].split("#")[0].strip()
        if t:
            out.append(nfc(t))
    return out


class Note:
    __slots__ = ("rel", "stem", "fields", "block_keys", "fm_lines",
                 "targets", "lint", "mtime")


def load_vault(vault: Path):
    notes = {}
    for p in sorted(vault.rglob("*.md")):
        rel = nfc(p.relative_to(vault).as_posix())
        n = Note()
        n.rel = rel
        n.stem = nfc(p.stem)
        try:
            n.mtime = p.stat().st_mtime
            text = p.read_text(encoding="utf-8-sig")  # -sig: BOM 檔也偵測得到 frontmatter
        except Exception as e:
            n.fields, n.block_keys, n.fm_lines = {}, set(), []
            n.targets, n.lint, n.mtime = [], [f"讀檔失敗: {e}"], 0
            notes[rel] = n
            continue
        fm_lines, body = split_frontmatter(text)
        if fm_lines is not None:
            fields, block_keys, lint = parse_frontmatter(fm_lines)
        else:
            fm_lines, fields, block_keys, lint = [], {}, set(), []
        body_clean = INLINE_CODE_RE.sub("", FENCE_RE.sub("", body))
        # frontmatter 連結規則(對齊 Obsidian): 整個值恰為一個 wikilink 才索引,
        # 夾在散文中間的 [[..]] 不算;block scalar 整段排除(鐵則 2)
        fm_targets = []
        for key, v in fields.items():
            if key in block_keys:
                continue
            for item in (v if isinstance(v, list) else [v]):
                s = str(item).strip()
                fm = re.fullmatch(r"\[\[([^\[\]]+?)\]\]", s)
                if fm:
                    t = fm.group(1).split("|")[0].split("#")[0].strip()
                    if t:
                        fm_targets.append(nfc(t))
        n.fields = fields
        n.block_keys = block_keys
        n.fm_lines = fm_lines
        n.targets = extract_targets(body_clean) + fm_targets
        n.lint = lint
        notes[rel] = n
    return notes


def build_index(notes):
    by_stem = defaultdict(list)
    for rel, n in notes.items():
        by_stem[n.stem.lower()].append(rel)
    return by_stem


def make_resolver(notes, by_stem):
    rels = set(notes)

    def resolve(target):
        t = target
        if t.lower().endswith(".md"):
            t = t[:-3]
        if "/" in t:
            cand = t + ".md"
            if cand in rels:
                return cand
            t = t.rsplit("/", 1)[1]
        hits = by_stem.get(t.lower())
        if hits:
            return hits[0]
        return None

    return resolve


def as_list(v):
    if v is None:
        return []
    if isinstance(v, list):
        return [str(x) for x in v]
    return [str(v)]


class Env:
    def __init__(self, vault):
        self.vault = vault
        self.notes = load_vault(vault)
        self.by_stem = build_index(self.notes)
        self.resolve = make_resolver(self.notes, self.by_stem)
        self._edges = None

    @property
    def edges(self):
        if self._edges is None:
            out_e, in_e = defaultdict(list), defaultdict(list)
            for rel, n in self.notes.items():
                seen = set()
                for t in n.targets:
                    d = self.resolve(t)
                    if d and d != rel and d not in seen:
                        seen.add(d)
                        out_e[rel].append(d)
                        in_e[d].append(rel)
            self._edges = (out_e, in_e)
        return self._edges

    def find(self, arg):
        """以 stem 或相對路徑找筆記,回傳 rel 或 None"""
        a = nfc(arg.strip())
        if a.lower().endswith(".md"):
            a = a[:-3]
        if "/" in a and (a + ".md") in self.notes:
            return a + ".md"
        hits = self.by_stem.get(a.rsplit("/", 1)[-1].lower())
        if hits:
            if len(hits) > 1:
                print(f"⚠ 同名筆記 {len(hits)} 個,取第一個: {hits[0]}", file=sys.stderr)
            return hits[0]
        return None


def first_line(s, width=72):
    s = (s or "").strip().split("\n")[0]
    return s if len(s) <= width else s[:width] + "…"


def status_of(env, rel):
    v = env.notes[rel].fields.get("status", "")
    return v if isinstance(v, str) else ""


TYPED_EDGE_FIELDS = ("verified_by", "plan_refs", "related")


def build_typed_index(env):
    """[M2/P0] typed-edge 反向索引——從 frontmatter 具名欄位(verified_by/plan_refs/related)建
    「每節點 ← 誰、以哪種邊型指向我」。補 Env.edges 無型別的洞(建圖層以 target 去重丟來源欄位)。
    每次呼叫現建現用(天生新鮮、無持久化=無腐爛)。合約(關係層主網 M2):
    - 只索引「整個值恰為一個 wikilink」(沿 load_vault fm_targets 規則);殘留 scalar → scalars
      warnings、不進索引(不靜默納入)。block scalar 欄位整段排除(鐵則 2)。
    - ghost(unresolved)→ ghosts 清單(不靜默丟);path 式不 fallback 到 stem(那是靜默猜)。
    - 同名無路徑 [[X]] 多篇候選 → ambiguous + 候選清單(嚴禁靜默指第一篇——不走 env.resolve,
      直接查 by_stem 候選數)。
    - 去重鍵 (source, target字面, type);ambiguous 條目 target=原 wikilink 字面。
    回傳 dict: rev={target_rel:[(source_rel,etype)]} fwd={source_rel:{etype:[target_rel]}}
              ghosts=[(src,字面,etype)] ambiguous=[(src,字面,etype,[候選])] scalars=[(src,etype,值)]"""
    rev = defaultdict(list)
    fwd = defaultdict(lambda: defaultdict(list))
    ghosts, ambiguous, scalars = [], [], []
    seen = set()
    for rel, n in sorted(env.notes.items()):
        for etype in TYPED_EDGE_FIELDS:
            if etype in n.block_keys:
                continue
            for item in as_list(n.fields.get(etype)):
                s = str(item).strip()
                if not s:
                    continue
                m = re.fullmatch(r"\[\[([^\[\]]+?)\]\]", s)
                if not m:
                    scalars.append((rel, etype, s))
                    continue
                t = nfc(m.group(1).split("|")[0].split("#")[0].strip())
                if not t:
                    continue
                key = (rel, t, etype)
                if key in seen:
                    continue
                seen.add(key)
                tt = t[:-3] if t.lower().endswith(".md") else t
                if "/" in tt:
                    cand = tt + ".md"
                    if cand in env.notes:
                        rev[cand].append((rel, etype))
                        fwd[rel][etype].append(cand)
                    else:
                        ghosts.append((rel, t, etype))
                else:
                    cands = env.by_stem.get(tt.lower(), [])
                    if len(cands) == 1:
                        rev[cands[0]].append((rel, etype))
                        fwd[rel][etype].append(cands[0])
                    elif not cands:
                        ghosts.append((rel, t, etype))
                    else:
                        ambiguous.append((rel, t, etype, sorted(cands)))
    return {"rev": rev, "fwd": fwd, "ghosts": ghosts, "ambiguous": ambiguous, "scalars": scalars}


# ═══════════════════════ doctor ═══════════════════════

def _stem_hit(stem, text):
    """stem 是否在 text 中作為「整詞」出現。ASCII stem 用詞界(re.ASCII,避 api 命中 pos_api_auth);
    CJK 無詞界 → 子字串比對,靠呼叫端的前綴抑制處理重疊(點數 vs 點數商城)。"""
    if stem.isascii():
        return re.search(r"\b" + re.escape(stem) + r"\b", text, re.ASCII) is not None
    return stem in text


def _suggest_systems_for_orphan(env, rel, n):
    """為 orphan Verification 推薦『最可能該掛哪個 Systems』(非 auto-fix,供人確認)。
    線索強度:本篇正文連向 Systems(3)> 經 plan_refs 計劃連到(2)> feature 提到 stem(1)。
    回傳 [(sys_rel, score, reason), ...] 依 (score, stem 長度) 降序(同分時更具體的 stem 優先)。"""
    cands = {}   # sys_rel -> (score, reason)

    def add(sys_rel, score, reason):
        if sys_rel in env.notes and (sys_rel not in cands or score > cands[sys_rel][0]):
            cands[sys_rel] = (score, reason)

    for t in n.targets:                                  # 1) 本篇正文連向的 Systems
        d = env.resolve(t)
        if d and d.startswith("Systems/"):
            add(d, 3, "本篇正文連向(verified_by 未同步 → 可 sync-verified-by)")
    for pr in as_list(n.fields.get("plan_refs")):        # 2) plan_refs → 計劃 → 計劃連向 Systems
        pd = env.resolve(link_target(pr))
        if pd and pd in env.notes:
            for t in env.notes[pd].targets:
                d = env.resolve(t)
                if d and d.startswith("Systems/"):
                    add(d, 2, f"經 plan_refs [[{env.notes[pd].stem}]] 連到")
    # 3) feature 提到某 Systems stem(只用人寫的 feature,不用自動檔名;整詞 + 前綴重疊抑制)
    feat = " ".join(str(x) for x in as_list(n.fields.get("feature")))
    if feat:
        matched = [(sr, sn.stem) for sr, sn in env.notes.items()
                   if sr.startswith("Systems/") and sn.stem and _stem_hit(sn.stem, feat)]
        stems = [s for _, s in matched]
        for sr, st in matched:
            if any(st != o and st in o for o in stems):   # st 是另一命中 stem 的子字串 → 丟(留更具體者)
                continue
            add(sr, 1, f"feature 提到「{st}」")
    return sorted(((s, sc, r) for s, (sc, r) in cands.items()),
                  key=lambda x: (-x[1], -len(env.notes[x[0]].stem or "")))


def _append_governance_log(vault, events):
    """寫者=doctor --ci + anchor approve:把 gate findings append 到 docs/.governance-log.jsonl。
    非 git / 取不到 HEAD → 跳過(不報錯)。dedup 留給讀時(lumos gov)。"""
    if not events:
        return
    import json
    import datetime
    import subprocess
    try:
        commit = subprocess.run(["git", "rev-parse", "--short", "HEAD"],
                                capture_output=True, text=True, cwd=str(vault)).stdout.strip()
    except Exception:
        commit = ""
    if not commit:
        return
    ts = datetime.datetime.now().astimezone().isoformat(timespec="seconds")
    path = vault.parent / ".governance-log.jsonl"
    try:
        with open(path, "a", encoding="utf-8") as f:
            for e in events:
                f.write(json.dumps({"ts": ts, "commit": commit, **e}, ensure_ascii=False) + "\n")
    except OSError:
        pass


def run_doctor(env: Env, strict: bool, color: bool, suggest=False, ci=False):
    C = {k: (v if color else "") for k, v in
         dict(R="\033[31m", Y="\033[33m", G="\033[32m", B="\033[1m", X="\033[0m").items()}
    notes, by_stem, resolve = env.notes, env.by_stem, env.resolve
    print(f"{C['B']}lumos doctor{C['X']} — vault: {C['B']}{env.vault}{C['X']} (self-contained, no Obsidian)")
    print()
    issues = 0
    gov_events = []          # 本輪 gate findings → governance-log(--ci 才寫)

    def section(idx, title):
        print(f"{C['B']}[{idx}]{C['X']} {title}")

    def ok(msg):
        print(f"  {C['G']}✓{C['X']} {msg}")

    def warn(lines, head, advice=None):
        nonlocal issues
        print(f"  {C['Y']}⚠{C['X']} {head}")
        for l in lines:
            print(f"      • {l}")
        if advice:
            print(f"  {C['B']}建議動作{C['X']}: {advice}")
        issues += len(lines)

    def warn_soft(lines, head, advice=None):
        # 軟提醒:印出但不動 issues → 不影響 rc(R3-MAJOR-3)
        print(f"  {C['Y']}⚠{C['X']} {head}")
        for l in lines:
            print(f"      • {l}")
        if advice:
            print(f"  {C['B']}建議{C['X']}: {advice}")

    collisions = {s: rs for s, rs in by_stem.items() if len(rs) > 1}

    incoming = defaultdict(int)
    unresolved = set()
    for rel, n in notes.items():
        for t in n.targets:
            dest = resolve(t)
            if dest is None:
                unresolved.add(t)
            elif dest != rel:
                incoming[dest] += 1

    section("1/4", "Verification orphans (沒掛進任何 Systems.verified_by / 無 incoming link)")
    orphans = [rel for rel in notes
               if rel.startswith("Verification/") and incoming[rel] == 0]
    if not orphans:
        ok("沒有 Verification orphan")
    elif suggest:
        print(f"  {C['Y']}⚠{C['X']} 發現 {len(orphans)} 個 Verification 沒任何 incoming link(附推薦掛載 Systems):")
        for o in sorted(orphans):
            print(f"      • {o}")
            sug = _suggest_systems_for_orphan(env, o, notes[o])
            if not sug:
                print("          ↳ (feature/plan_refs/連結皆無線索 → 人工判斷)")
            for sys_rel, _sc, reason in sug[:3]:
                print(f"          ↳ 推薦 {sys_rel}  [{reason}]")
            if len(sug) > 3:
                print(f"          ↳ (另有 {len(sug) - 3} 個較弱線索略過)")
        issues += len(orphans)
        print(f"  {C['B']}建議動作{C['X']}: 確認後 `lumos append <Systems> verified_by \"[[<本篇>]]\"`"
              ";若推薦理由是「本篇正文連向」(verified_by 漏寫)→ `lumos sync-verified-by` 可批次補。")
    else:
        warn(sorted(orphans), f"發現 {len(orphans)} 個 Verification 沒任何 incoming link:",
             "找到它驗證的 Systems 並補進 verified_by(`--suggest` 看推薦掛載目標)")
    print()

    section("2/4", "Unresolved wikilinks (破連結)")
    if not unresolved:
        ok("沒有 unresolved wikilink")
    else:
        warn([f"[[{t}]]" for t in sorted(unresolved)],
             f"發現 {len(unresolved)} 個 unresolved wikilink targets:",
             "建立目標筆記 / 修正打錯的名字 / 移除過時引用")
    print()

    section("3/4", "verified_by 雙向同步 (Verification → Systems 漏寫)")
    # 以 resolve 到的 rel 比對:path 式 [[Verification/X]] 與 basename [[X]] 等價(同篇),
    # 但 [[Projects/X]] 與 Verification/X 不同篇(第二輪審計 NEW-B)。存 Verification 的 rel。
    expected = defaultdict(set)
    for rel, n in notes.items():
        if not rel.startswith("Verification/"):
            continue
        # [E1↔Check3 矛盾修,LandmarkMember 實驗場實錘 2026-07-15] stale/fail 驗證跳過——
        # E1 判死背書要拔,Check 3 若仍強索回掛會跟 E1 打架(拔了這邊報漏寫、掛回那邊報死背書)。
        # 失效驗證的內文連結留作歷史導航,不再構成雙向義務。
        if status_of(env, rel).strip() in ("stale", "fail"):
            continue
        for t in n.targets:
            dest = resolve(t)
            if dest and dest.startswith("Systems/"):
                expected[dest].add(rel)
    missing = []
    for sys_rel, verif_rels in sorted(expected.items()):
        actual_rels = {resolve(link_target(a))
                       for a in as_list(notes[sys_rel].fields.get("verified_by"))}
        actual_rels.discard(None)
        missed = sorted(notes[v].stem for v in verif_rels if v not in actual_rels)
        if missed:
            missing.append(f"{sys_rel} 漏: {' | '.join(missed)}")
    if not missing:
        ok("所有 Verification 都已掛進對應 Systems 的 verified_by")
    else:
        warn(missing, f"發現 {len(missing)} 個 Systems 的 verified_by 漏寫:",
             "對每個 Systems 補上漏寫的 verified_by")
    print()

    section("4/4", "plan_refs 意圖鏈 (計劃結案後的迭代驗證,計劃有沒有跟上)")
    chain = []
    for rel, n in notes.items():
        if not rel.startswith("Verification/"):
            continue
        refs = as_list(n.fields.get("plan_refs"))
        if not refs:
            continue
        m = DATE_PREFIX_RE.match(n.stem)
        v_date = m.group(1) if m else None
        for r in refs:
            name = r.replace("[[", "").replace("]]", "").split("|")[0].strip()
            dest = resolve(nfc(name))
            if dest is None:
                chain.append(f"{n.stem} 的 plan_refs 斷鏈: {name}")
                continue
            pf = notes[dest].fields
            status = str(pf.get("status", ""))
            u = pf.get("updated", "")
            u = (u[0] if u else "") if isinstance(u, list) else u  # updated 萬一是 list 取首項(GAP-2)
            p_updated = str(u)[:10] or None
            if status in ("done", "superseded") and v_date and p_updated and v_date > p_updated:
                chain.append(f"{notes[dest].stem} (status:{status}, updated:{p_updated}) "
                             f"結案後有較新驗證: {n.stem}")
    if not chain:
        ok("意圖鏈完整 (無結案計劃漏接迭代驗證、無 plan_refs 斷鏈)")
    else:
        warn(sorted(chain), f"發現 {len(chain)} 個意圖鏈問題:",
             "結案計劃有較新驗證 → 更新計劃本體; 斷鏈 → 修正 plan_refs 路徑")
    print()

    section("G", "同名 basename 守衛 (連結解析歧義)")
    if not collisions:
        ok("無同名筆記,basename 解析無歧義")
    else:
        warn([f"{s}: {' , '.join(sorted(rs))}" for s, rs in sorted(collisions.items())],
             f"發現 {len(collisions)} 組同名 basename — 不帶路徑的 [[連結]] 解析有歧義:",
             "改名其一,或全 vault 引用改用完整路徑形態")
    print()

    section("L", "frontmatter lint (鐵則 1/3/4 指紋 + 污染指紋; python 版加值)")
    lint_lines = []
    for rel, n in sorted(notes.items()):
        for l in n.lint:
            lint_lines.append(f"{rel}: {l}")
    if not lint_lines:
        ok("無鐵則指紋、無污染指紋")
    else:
        warn(lint_lines, f"發現 {len(lint_lines)} 個 frontmatter 指紋:",
             "鐵則修法見 lumos-project-notes skill; 污染指紋見 pre-commit Gate 1 指引")
    print()

    # Check C: core_refs 跨 repo 指針完整性(只在有 core_refs 時跑)
    import os
    section("C", "core_refs 跨 repo 指針 (指向核心知識 repo 的檔案是否存在)")
    repo_root = None
    for p in env.vault.parents:
        if p.name == "docs":
            repo_root = p.parent
            break
    core_env = os.environ.get("CORE_KNOWLEDGE_ROOT")
    core_refs_all = []
    for rel, n in sorted(notes.items()):
        for ref in as_list(n.fields.get("core_refs")):
            r = ref.strip()
            if r:
                core_refs_all.append((rel, r))
    # 核心 repo 根目錄: CORE_KNOWLEDGE_ROOT env 優先,否則 sibling 慣例(<repo>.parent/<repo-dir-name>)
    core_base = None
    if core_env:
        core_base = Path(core_env)
    elif repo_root is not None and core_refs_all:
        first_seg = core_refs_all[0][1].split("/", 1)[0]
        core_base = repo_root.parent / first_seg
    if not core_refs_all:
        ok("無 core_refs 指針")
    elif core_base is None or not core_base.is_dir():
        # 核心 repo 不在此環境(如 CI 未 checkout 跨 repo)→ 跳過,不誤判懸空
        print(f"  {C['Y']}—{C['X']} 核心 repo 不在此環境(CI 未 checkout?),跳過跨 repo 檢查"
              f"(本機設 CORE_KNOWLEDGE_ROOT 或置核心 repo 為 sibling 可驗)")
    else:
        dangling = []
        for rel, ref in core_refs_all:
            if core_env:
                parts = ref.split("/", 1)
                rest = parts[1] if len(parts) == 2 else ref
                target = core_base / rest
            else:
                target = repo_root.parent / ref
            if not target.exists():
                dangling.append(f"{rel} → {ref}")
        if not dangling:
            ok(f"所有 core_refs 指針有效 ({len(core_refs_all)} 條)")
        else:
            warn(dangling, f"發現 {len(dangling)} 條懸空 core_refs (指向核心 repo 不存在的檔):",
                 "核心 repo 改名/移檔 → 修專案 core_refs 路徑(指針紀律不留快照,懸空=權威失聯)")
    print()

    # Check T: ★INVARIANT★ 合約測試綁定(載重宣稱必須認領存在的可執行證據)
    # 「形式 → 真」缺的那一環:doctor 不執行測試,但強制每條 ★INVARIANT★ 指向一個
    # 真實存在的測試 → 杜絕「裸合約」(宣稱無證據)與「懸空 test_ref」(綁了不存在的測試)。
    section("T", "★INVARIANT★ 合約測試綁定 (載重宣稱有沒有綁可執行證據)")
    inv_all = []
    for rel, n in sorted(notes.items()):
        invs, _ = extract_contracts(n)
        for inv in invs:
            inv_all.append((rel, inv))
    if not inv_all:
        ok("無 ★INVARIANT★ 合約 (無載重宣稱需綁測試)")
    else:
        naked, bound, unaudited = [], [], []
        for rel, inv in inv_all:
            clean, refs = strip_test_refs(inv)
            if refs:
                bound.append((rel, clean, refs))
                if not invariant_audit_refs(inv):     # 綁了測試但沒經獨立合法性審計
                    unaudited.append((rel, clean))
            else:
                naked.append((rel, clean, refs))
        dangling, fake, bad_platform = [], [], []
        if bound:
            if repo_root is None:
                print(f"  {C['Y']}—{C['X']} 無法定位 repo root,跳過 test_ref 存在性檢查(裸合約仍檢)")
            else:
                # 多平台感知:每 ref 依平台前綴選對 root+profile 的 method set/haystack(跨 repo)。
                pdata, split, default, methods_for, hay_for = _platform_test_index(repo_root)
                for rel, clean, refs in bound:
                    for seg in refs:
                        if split and ":" in seg:            # 多平台:含冒號 = 平台:名
                            plat, name = seg.split(":", 1)
                            plat, name = plat.strip(), name.strip()
                            if plat not in split:           # 未定義前綴 → 明確報錯(不誤當方法名)
                                bad_platform.append(
                                    f"{rel}: [test:{seg}] 平台前綴 '{plat}' 未定義於 platforms"
                                    f"({', '.join(split)})")
                                continue
                        else:                               # legacy 或無前綴段 → default 平台
                            plat, name = default, seg
                        if name in methods_for(plat):
                            continue  # 真實測試方法(依該平台 profile 認 attr)
                        _attr = pdata["platforms"][plat]["profile"]["attr_hint"]
                        if name in hay_for(plat):
                            # 出現在程式碼但不是測試方法 → 偽證據(子字串巧合/被改名/拼錯屬性)
                            fake.append(f"{rel}: [test:{seg}] 在程式碼出現,但不是 {_attr} 測試方法")
                        else:
                            dangling.append(f"{rel}: [test:{seg}] 在程式碼中找不到")
        if not naked and not dangling and not fake and not unaudited and not bad_platform:
            ok(f"{len(bound)} 條 ★INVARIANT★ 都綁了真實可執行測試方法且經獨立審計 "
               "(0 裸合約 / 0 偽證據 / 0 懸空 / 0 未審 / 0 未定義平台)")
        if bad_platform:
            warn(bad_platform, f"發現 {len(bad_platform)} 條 test_ref 平台前綴未定義於 config platforms:",
                 "config.json 的 platforms 補該平台,或修正 [test:平台:名] 的平台前綴")
        if naked:
            warn([f"{r}: {first_line(c, 70)}" for r, c, _ in naked],
                 f"發現 {len(naked)} 條裸 ★INVARIANT★ (載重宣稱沒綁測試 → 無法機械驗真):",
                 "在 invariant 行尾加 [test:測試名],並寫對應測試")
        if fake:
            warn(fake, f"發現 {len(fake)} 條偽證據 test_ref (綁的名字不是真測試方法 → 無法執行):",
                 "確認 [test:] 名字 = 該平台 profile 認的真測試方法名(別綁到散文/工具方法/拼錯屬性)")
        if dangling:
            warn(dangling, f"發現 {len(dangling)} 條懸空 test_ref (綁的測試在程式碼中不存在):",
                 "建立該測試,或修正 [test:] 名稱")
        if unaudited:
            warn([f"{r}: {first_line(c, 70)}" for r, c in unaudited],
                 f"發現 {len(unaudited)} 條 ★INVARIANT★ 綁了測試但合法性未經獨立審計 "
                 "(『是不是真鐵則 / 綁的測試夠不夠格』仍由提出者自評 → maker/checker 破口):",
                 "派一個無對話脈絡的乾淨 agent 判合法性(別餵你的結論),過了用 "
                 "`lumos guard audit <node> \"<KEY 行子字串>\"` 留痕")
    print()

    # Check R: 可逆性回退綁定(★IRREVERSIBLE★ 動手前要有實質回退;★CHECKPOINT★ 軟提醒)
    section("R", "可逆性回退綁定 (★IRREVERSIBLE★ 動手前要有實質回退)")
    rev_err, rev_soft = [], []
    for rel, nnote in sorted(notes.items()):
        for marker, clean, ref, guard_ref in extract_reversibility(nnote):
            t_ = nnote.fields.get("type")
            if t_ != "system":
                rev_err.append(f"{rel}: {marker} 標在非 Systems(type={t_!r})")
                gov_events.append({"gate": "check-r", "kind": "blocked", "hard": True, "nodes": [nnote.stem]})
            elif marker == "★IRREVERSIBLE★":
                if not (_rollback_resolved(nnote, ref) or _guard_resolved(nnote, guard_ref)):
                    rev_err.append(f"{rel}: {first_line(clean, 60)} (加 [rollback:decisions] 或 [guard:decisions])")
                    gov_events.append({"gate": "check-r", "kind": "blocked", "hard": True, "nodes": [nnote.stem]})
            elif not _rollback_resolved(nnote, ref):  # ★CHECKPOINT★;guard_ref 不讀
                rev_soft.append(f"{rel}: {first_line(clean, 60)}")
                gov_events.append({"gate": "check-r", "kind": "warned", "hard": False, "nodes": [nnote.stem]})
    if not rev_err and not rev_soft:
        ok("無未綁回退的可逆性標記")
    if rev_err:
        warn(rev_err, f"發現 {len(rev_err)} 條 ★IRREVERSIBLE★ 缺實質回退/標錯型別:",
             "標記行加 [rollback:decisions](有回退)或 [guard:decisions](冪等鍵/核可閘),decisions[] 要有非空 rollback/guard;★ 僅用於 Systems")
    if rev_soft:
        warn_soft(rev_soft, f"{len(rev_soft)} 條 ★CHECKPOINT★ 建議補回退(不擋):",
                  "加 [rollback:decisions] + decisions rollback")
    print()

    # Check S: L4 自足性審計提醒(軟,不擋,不計 issues)——type=system 節點:
    #   無 self_audit(或格式非法) = 從未跑 L4;self_audit 日期 < updated = 節點更新後未重審(過期)。
    # 真實性無法機械驗(lumos 不 spawn agent),只給「摩擦地板」提醒派乾淨 agent 跑自足性審計
    # (只讀圖譜還原現況),過了 `lumos self-audit <node>` 留痕。同 maker/checker 誠實天花板。
    section("S", "L4 自足性審計提醒 (Systems 無 self_audit 或已過期 → 派乾淨 agent 還原審)")
    sa_missing, sa_stale = [], []
    for rel, n in sorted(notes.items()):
        if n.fields.get("type") != "system":
            continue
        if str(n.fields.get("status", "")).strip() in ("stale", "superseded"):
            continue
        sa_val = str(n.fields.get("self_audit", "")).strip()
        m = re.search(r"(\d{4}-\d{2}-\d{2})", sa_val) if sa_val else None
        sa_date = m.group(1) if m else None
        if not sa_date:                       # 無 self_audit 或解析不出日期 → 視同未審
            sa_missing.append(rel)
            gov_events.append({"gate": "check-s", "kind": "warned", "hard": False, "nodes": [n.stem]})
            continue
        upd = str(n.fields.get("updated", "")).strip()
        # 缺 updated → 不做過期判定(避免誤報);有則純字串比較(lumos 保證 bare YYYY-MM-DD)
        if upd and sa_date < upd:
            sa_stale.append(f"{rel} (self_audit {sa_date} < updated {upd})")
            gov_events.append({"gate": "check-s", "kind": "warned", "hard": False, "nodes": [n.stem]})

    def _soft_list(items, head, advice):
        shown = items[:8]
        lines = list(shown)
        if len(items) > len(shown):
            lines.append(f"… 還有 {len(items) - len(shown)} 篇")
        warn_soft(lines, head, advice)

    if not sa_missing and not sa_stale:
        ok("所有 Systems 都有 self_audit 且未過期")
    if sa_missing:
        _soft_list(sa_missing,
                   f"{len(sa_missing)} 個 Systems 從未跑 L4 自足性審計(無 self_audit):",
                   "派無脈絡乾淨 agent 只讀圖譜還原現況,過了 `lumos self-audit <node>` 留痕;輕量無需則略過")
    if sa_stale:
        _soft_list(sa_stale,
                   f"{len(sa_stale)} 個 Systems 的 self_audit 已過期(節點更新後未重審):",
                   "重派乾淨 agent 還原審後 `lumos self-audit <node>` 重新留痕")
    print()

    # Check E1: 失效背書(軟,不擋,不計 issues)——關係層語意檢查(補 Check 3 只查邊存不存在、不查
    #   邊還對不對):某節點 verified_by 指向的 Verification 已 stale/fail = 死背書(掛著給人假安心感、
    #   驗證其實已失效)。ghost 目標交既有 ghost 檢查,這裡跳過(不重疊職責)。
    #   設計見 Projects/關係層傳播守衛_計劃 [S6](phase-1 MVP,免前置、純 frontmatter)。
    section("E1", "失效背書 (verified_by 指向的驗證已 stale/fail → 死背書)")
    dead_endorse = []
    for rel, n in sorted(notes.items()):
        for item in as_list(n.fields.get("verified_by")):
            vrel = env.resolve(link_target(item))
            if not vrel:                          # ghost → 交既有 ghost 檢查,跳過
                continue
            vst = status_of(env, vrel).strip()
            if vst in ("stale", "fail"):
                dead_endorse.append(f"{rel} → [[{vrel}]] (status={vst})")
                gov_events.append({"gate": "check-e1", "kind": "warned", "hard": False, "nodes": [n.stem]})
    if not dead_endorse:
        ok("無失效背書 (所有 verified_by 指向的驗證都非 stale/fail)")
    else:
        _soft_list(dead_endorse,
                   f"發現 {len(dead_endorse)} 條失效背書(驗證已 stale/fail 卻還掛著):",
                   "重跑驗證改回 pass、或改標記/移除該 verified_by;死背書給假安心感,是關係層頭號腐爛之一")
    print()

    # Check E2: 建在被推翻決策上(軟,不擋,不計 issues)——關係層時序法(把 Check 4 的時序 proxy 推到「決策
    #   翻案」層):某節點 D 有 valid:false 決策(且有 ended)→ 沿「方向語意明確」的連入邊(verified_by/plan_refs)
    #   找指向 D 的來源節點 A → A.updated 早於該決策 ended = A 可能還建在 D 已被推翻的決策上、沒跟上。時序法是
    #   啟發(可能人早手動確認過但沒動 updated),故 warn_soft。內聯 typed 反查(不建 [P0] 可重用 index——doctor
    #   本就掃全圖,補網不需;主網 proactive 連鎖才需 P0)。設計見 Projects/關係層傳播守衛_計劃 [S7]。
    #   已知限制:無 cascade ledger(主網 future)→ 判過無關卻沒動 A.updated 的會每次重報;量少時手動 bump 消音。
    section("E2", "建在被推翻決策上 (指向某節點的邊,該節點決策已翻案而來源未跟上)")

    import datetime
    def _ymd(s):
        try:
            return datetime.date.fromisoformat(str(s)[:10])
        except (ValueError, TypeError):
            return None
    # [M2] 內聯反查遷移至 build_typed_index 共用(P0);E2 只消費 resolved(ghost/ambiguous
    #   不拿來做時序判定——ghost 交既有 ghost 檢查、ambiguous 由 M4 消費端浮出)。
    #   只收方向語意明確的邊(related 弱、排除)。
    _tidx = build_typed_index(env)
    typed_in = {t: [(s, e) for (s, e) in pairs if e in ("verified_by", "plan_refs")]
                for t, pairs in _tidx["rev"].items()}
    # [M3] ledger 抑制:掃 rel-cascade 帳本折疊出 terminal 事件(判過的粒度鍵)——terminal ts
    #   不早於決策 ended(日級;同日判定=翻案後立即處理的常態)→ 該邊跳過(解「判過無關卻每輪重報」
    #   永久假陽性)。E2 定位帳檔=全目錄掃(復用 list 的讀法),不需重建含秒數的檔名。
    _led_terminal = {}
    _rcd = _rel_cascade_dir(env)
    if _rcd.exists():
        for _p in sorted(_rcd.glob("*.jsonl")):
            _h, _trs = _ledger_read(_p)
            for _k, _t in _ledger_fold(_trs).items():
                _led_terminal[_k] = max(_led_terminal.get(_k, ""), str(_t.get("ts", "")))
    build_on_dead = []
    for drel, dn in sorted(notes.items()):
        for d in parse_decisions(dn.fm_lines):
            if str(d.get("valid", "true")).lower() != "false":
                continue
            ended = _ymd(d.get("ended"))
            if not ended:                        # 無 ended → 無從時序比對(P1 起新翻案自動補),跳過
                continue
            dcontent = first_line(str(d.get("content", "")), 40)
            did = str(d.get("id", "")).strip()
            for arel, etype in typed_in.get(drel, []):
                aupd = _ymd(notes[arel].fields.get("updated"))
                if not (aupd and aupd < ended):
                    continue
                # [M1] E2 首判精化:鄰居有 decision_refs → 只在指到「那條」翻案決策時才標
                #   (指到別條=已聲明依賴面、與本翻案無關,不冤枉);無 refs → 退回節點+ended 級(相容不退化)
                # [自動養成 不對稱信任] 抑制向只讀 decision_refs(human/cascade),**不讀 decision_refs_ai**
                #   ——誤 ai-ref 拿來抑制真落後邊=靜默漏傳播=頭號腐爛;ai-ref 抑制不了 E2(結構保證)
                refs = [str(x).strip() for x in as_list(notes[arel].fields.get("decision_refs"))]
                if refs:
                    def _hits(s):
                        mm = re.fullmatch(r"(.+?)#(d\d+)", s)
                        return bool(mm and did and mm.group(2) == did and env.resolve(mm.group(1)) == drel)
                    if not any(_hits(s) for s in refs):
                        continue
                # [M3] ledger 跳過:這筆 (鄰居×邊型×root決策) 已有 terminal 判定且不早於 ended → 判過,不重報
                if did:
                    _lts = _led_terminal.get((arel, etype, f"{drel}#{did}"), "")
                    if _lts and _lts[:10] >= str(d.get("ended", ""))[:10]:
                        continue
                build_on_dead.append(
                    f"{arel} --{etype}--> {drel}(決策「{dcontent}」{ended} 翻案,來源自 {aupd} 未更新)")
                gov_events.append({"gate": "check-e2", "kind": "warned", "hard": False,
                                   "nodes": [notes[arel].stem]})
    if not build_on_dead:
        ok("無「建在被推翻決策上」的落後邊")
    else:
        _soft_list(build_on_dead,
                   f"發現 {len(build_on_dead)} 條可能建在被推翻決策上的邊(時序法啟發、非定論):",
                   "查該邊是否真受翻案影響:是→更新來源節點跟上新決策;否→已確認無關可 bump 來源 updated 消音;純語意矛盾留 AI 交叉審")
    print()

    # Check E3: 意圖鏈斷義(軟,不擋,不計 issues)——[M1/S8] 精確版:decision_refs(全域格式
    #   <節點rel>#dN,M1/P2 決策穩定 ID)指向的那條決策已 valid:false → 本驗證建在被推翻的意圖上。
    #   dangling ref(格式壞/節點不存在/id 未指派)也浮出——不靜默通過,對齊 M2 反靜默紀律。
    #   設計見 Projects/關係層主網_實作計畫 M1;取代母計劃 [S8] 的高噪音 advisory。
    section("E3", "意圖鏈斷義 (decision_refs 指向的決策已翻案 → 建在被推翻意圖上)")
    e3_broken, e3_dangling = [], []
    for rel, n in sorted(notes.items()):
        # [自動養成 不對稱信任] firing 向讀「聯集」decision_refs + decision_refs_ai(放寬)
        #   ——ai 填的也能觸發提醒;錯了 advisory 級、人一刪,低 harm(對比抑制向的保守)
        # [code-loop r1 A/C-minor] (rel,ref) 去重:過渡態同 ref 可能兩欄都有,避免重複通報虛胖計數
        seen_e3 = set()
        for ref in as_list(n.fields.get("decision_refs")) + as_list(n.fields.get("decision_refs_ai")):
            s = str(ref).strip()
            if s in seen_e3:
                continue
            seen_e3.add(s)
            m = re.fullmatch(r"(.+?)#(d\d+)", s)
            if not m:
                e3_dangling.append(f"{rel} → {s} (格式非 <節點rel>#dN)")
                continue
            trel = env.resolve(m.group(1))
            if not trel:
                e3_dangling.append(f"{rel} → {s} (節點不存在)")
                continue
            d = next((x for x in parse_decisions(notes[trel].fm_lines)
                      if str(x.get("id", "")).strip() == m.group(2)), None)
            if d is None:
                e3_dangling.append(f"{rel} → {s} (該節點無此決策 id,或未 reindex)")
                continue
            if str(d.get("valid", "true")).lower() == "false":
                e3_broken.append(f"{rel} → {s} (決策已翻案 ended={d.get('ended', '?')})")
                gov_events.append({"gate": "check-e3", "kind": "warned", "hard": False, "nodes": [n.stem]})
    if not e3_broken and not e3_dangling:
        ok("無意圖鏈斷義 (decision_refs 指向的決策都仍有效)")
    if e3_broken:
        _soft_list(e3_broken,
                   f"發現 {len(e3_broken)} 條意圖鏈斷義(所指決策已被推翻):",
                   "本驗證實作的意圖已翻案:重驗並更新、或改指新決策、或標 stale")
    if e3_dangling:
        _soft_list(e3_dangling,
                   f"發現 {len(e3_dangling)} 條 dangling decision_ref(指向不存在的決策):",
                   "修正 ref 格式/目標;若目標節點決策未編號先跑 lumos decision-reindex <節點>")
    print()

    # Check H: 漏標可逆性提醒(軟,不擋,不計 issues)——僅 --ci 掃 diff,提示疑似漏標 ★IRREVERSIBLE★
    section("H", "漏標可逆性提醒 (diff 碰 prod/外部 API/寄送 → 是否漏標 ★IRREVERSIBLE★?)")
    if not ci:
        print("  (僅 --ci 模式掃 diff;互動模式略過)")
    else:
        hint_hits = _scan_diff_for_irreversible_hints(str(env.vault))
        if not hint_hits:
            ok("diff 無疑似不可逆操作行(或無 staged/HEAD diff)")
        else:
            warn_soft(
                hint_hits,
                f"diff 發現 {len(hint_hits)} 行疑似碰外部不可逆操作:",
                "確認相關 Systems 節點已標 ★IRREVERSIBLE★ [rollback:decisions] 或 [guard:decisions];若確認可逆可忽略",
            )
    print()

    # Check K: ★COMBO★ 組合覆蓋提醒(軟,不擋,不計 issues)——標了 ★COMBO★ 的最重 ★INVARIANT★
    #   只綁 1 個 [test:] 標記 → 提醒補組合。數 [test:] 標記個數(TEST_REF_RE,非展開名數),免 [test:a,b] 逗號繞過。
    section("K", "★COMBO★ 組合覆蓋提醒 (最重鐵則只綁 1 個 [test:] → 補組合)")
    combo_thin, combo_any = [], False
    for rel, n in sorted(notes.items()):
        invs, _ = extract_contracts(n)
        for inv in invs:
            if "★COMBO★" not in inv:
                continue
            combo_any = True
            if len(TEST_REF_RE.findall(inv)) == 1:
                combo_thin.append(inv.replace("★COMBO★", "").strip())
                gov_events.append({"gate": "check-k", "kind": "warned", "hard": False, "nodes": [n.stem]})
    if not combo_any:
        ok("無 ★COMBO★ 標記 (無鐵則宣告需組合覆蓋)")
    elif combo_thin:
        _soft_list(combo_thin,
                   f"{len(combo_thin)} 條 ★COMBO★ 鐵則只綁 1 個 [test:] happy-path:",
                   "為這條最重鐵則補一條組合情境測試(多條件交叉),別只測 happy-path")
    else:
        ok("★COMBO★ 鐵則都綁了 ≥2 個 [test:] 標記")
    print()

    # Check D: 紀律區塊漂移守衛(內容比對)
    # 範本 scripts/templates/graph-discipline.md ↔ CLAUDE.md sentinel block body。
    # guard: 範本不存在 → skip(不算 issue);CLAUDE.md absent → skip(未注入過的 repo 不罰)。
    # broken → 報漂移(算 issue,但不取 .body 避免 crash)。
    section("D", "紀律區塊漂移守衛 (CLAUDE.md 紀律區塊 ↔ 範本 graph-discipline.md 內容比對)")
    if repo_root is None:
        print("  (無 docs/ 佈局,略過 Check D)")
    else:
        # slug 從 vault 名取(慣例 docs/<slug>-knowledge → vault.name 去尾碼)
        _d_vault_name = env.vault.name
        _d_slug = (_d_vault_name[:-len("-knowledge")]
                   if _d_vault_name.endswith("-knowledge") else _d_vault_name)
        expected_body = _expected_claude_body(repo_root, _d_slug)
        if expected_body is None:
            print("  (無 scripts/templates/graph-discipline.md 範本,略過 Check D)")
        else:
            # 讀 CLAUDE.md
            _d_cm = repo_root / "CLAUDE.md"
            if not _d_cm.exists():
                print("  (無 CLAUDE.md,略過 Check D — 尚未注入無需比對)")
            else:
                _d_text = _d_cm.read_bytes()
                if _d_text.startswith(b"\xef\xbb\xbf"):
                    _d_text = _d_text[3:]
                _d_text = _d_text.decode("utf-8").replace("\r\n", "\n").replace("\r", "\n")
                _d_state, _d_span = _extract_claude_block_span(_d_text)
                if _d_state == "absent":
                    print("  (CLAUDE.md 無 sentinel 區塊,略過 Check D — 尚未注入)")
                elif _d_state == "broken":
                    warn(["CLAUDE.md 紀律區塊 sentinel 損壞(只有 START 或只有 END),跑 lumos init/update 修復"],
                         "CLAUDE.md sentinel 損壞(broken)— 無法比對,視為漂移:",
                         "lumos init --force 或 lumos update 修復 sentinel 再重驗")
                else:
                    # found: 比對 body
                    if _d_span.body == expected_body:
                        ok("CLAUDE.md 紀律區塊與範本同步(0 漂移)")
                    else:
                        warn(["CLAUDE.md 紀律區塊與範本 graph-discipline.md 不同步,跑 lumos update/init 刷新"],
                             "CLAUDE.md 紀律區塊漂移(與範本不一致):",
                             "lumos update 或 lumos init --force 刷新 CLAUDE.md 紀律區塊")
    print()

    section("V", "valid_under 過期率 (進場提示覆蓋 + 日齡 proxy;軟提醒、不擋 CI)")
    vu_total, vu_stale = [], []
    for rel, n in sorted(notes.items()):
        if not _conds(n.fields.get("valid_under")):
            continue
        vu_total.append(rel)
        age = _node_age_days(n)
        if age is not None and age > 90:
            vu_stale.append(f"{rel}(已 {age} 天未更新)")
    if not vu_total:
        ok("無 valid_under 節點 (無進場提示需量)")
    elif vu_stale:
        rate = len(vu_stale) / len(vu_total)
        warn_soft(vu_stale,
                  f"{len(vu_stale)}/{len(vu_total)} ({rate:.0%}) 個 valid_under 節點 >90 天未更新(前提可能失效):",
                  "進場 lumos context 已會警示;>90 天者建議重核 valid_under、必要時標 stale 或建新 Verification")
    else:
        ok(f"0/{len(vu_total)} (0%) — 所有 valid_under 節點 ≤90 天")
    print()

    section("P", "失效檔案認領 (節點正文 inline-code 路徑指向已不存在的檔;軟提醒、不擋 CI)")
    if repo_root is None:
        ok("(無 docs/ 佈局,略過失效認領檢查)")
    else:
        top_dirs = {p.name for p in repo_root.iterdir() if p.is_dir() and not p.name.startswith(".")}
        _suffix_re = re.compile(r":([^/]+)$")
        stale_claims = []
        for rel, n in sorted(notes.items()):
            try:
                text = (env.vault / rel).read_text(encoding="utf-8-sig")
            except OSError:
                continue
            spans = [s.strip("`") for s in INLINE_CODE_RE.findall(FENCE_RE.sub("", text))]
            seen_paths = set()
            for raw in spans:
                if "://" in raw or any(c in raw for c in "*<>?"):
                    continue
                m = _suffix_re.search(raw)
                if m:
                    token, sfx = raw[:m.start()], m.group(1)
                    line = sfx if re.fullmatch(r"\d+(?:-\d+)?", sfx) else ""
                else:
                    token, line = raw, ""
                if "/" not in token or token in seen_paths:
                    continue
                if token.split("/")[0] not in top_dirs:
                    continue
                seen_paths.add(token)
                if not (repo_root / token).exists():
                    loc = f"{rel}:{line}" if line else rel
                    stale_claims.append(f"{loc} → {token}(已不存在)")
        if stale_claims:
            warn_soft(stale_claims,
                      f"{len(stale_claims)} 個節點引用指向已不存在的 repo 路徑(圖譜指向死碼?):",
                      "碼被刪/改名?更新節點正文的路徑引用,或補對應節點")
        else:
            ok("無失效檔案認領 (節點引用的 repo 路徑都存在)")
    print()

    # Check J: regen 重生來源守衛(from-scratch 節點的 provenance 分級+拒絕發明無證據合約)。
    # 與 cmd_lint 共用 check_regen_provenance(防兩入口規則漂移);映射表——
    # errs→warn(hard)計 issues/warns→warn_soft/gov_events→僅 --ci 落帳。
    _regen_rels = [(rel_, n_) for rel_, n_ in sorted(notes.items())
                   if isinstance(n_.fields.get("regen"), str) and n_.fields.get("regen").strip()]
    if _regen_rels:
        section("J", "regen 重生來源守衛 (provenance 分級;J-a 拒發明合約/J-c 證據指針機械驗)")
        _jroot = repo_root if repo_root is not None else _repo_root_from_env(env)
        j_err_lines, j_soft_lines = [], []
        for rel_, n_ in _regen_rels:
            j_errs, j_warns, j_gov = check_regen_provenance(n_, _jroot)
            j_err_lines.extend(f"{rel_}: {e}" for e in j_errs)
            j_soft_lines.extend(f"{rel_}: {w}" for w in j_warns)
            gov_events.extend(j_gov)
            for _e in j_errs:
                gov_events.append({"gate": "check-j", "kind": "blocked", "hard": True,
                                   "nodes": [n_.stem]})
        if j_err_lines:
            warn(j_err_lines, f"{len(j_err_lines)} 條 regen 節點違反重生來源守衛:",
                 "補 [src:路徑(:行號)]/[git:sha] 證據、或改標 推測:/佚失:(合約不能建在推測上)")
        else:
            ok(f"{len(_regen_rels)} 個 regen 節點證據指針全數可驗")
        if j_soft_lines:
            warn_soft(j_soft_lines, f"{len(j_soft_lines)} 條 J-d/降級提醒(軟,不擋):")
        print()

    # Check N: 版本 nudge(軟提醒,dev-machine advisory;不算 issue、不擋 CI)
    if repo_root is not None:
        _nudge = _version_nudge(repo_root)
        if _nudge:
            section("N", "版本更新提示 (dev-machine advisory;不算 issue、不擋 CI)")
            warn_soft([_nudge], _nudge, "跑 lumos update 刷新紀律區塊與工具組版本")
            print()

    if ci:
        _append_governance_log(env.vault, gov_events)

    print(f"{C['B']}─────────────────────────────────{C['X']}")
    if issues == 0:
        print(f"{C['G']}{C['B']}✓ 圖譜健康{C['X']} — 0 issues ({len(notes)} 篇)")
        return 0
    print(f"{C['Y']}{C['B']}⚠ 發現 {issues} 個 issue{C['X']} ({len(notes)} 篇)")
    return 1 if strict else 0


# ═══════════════════════ 階段二: 讀側 ═══════════════════════

SYMBOL_RE = re.compile(r"^(KEY|FLOW|DEP|TEST|AUTH|FLAG|DECISION|VERIFY|CORE):")
FM_KEY_RE = re.compile(r"^\s*([A-Za-z_][\w-]*):")


def _search_region(lineno, line, fm_end):
    """標記命中行所在的結構區域 — 讓「合約行 vs 散文」一眼可辨(尊重標籤哲學)。"""
    s = line.strip()
    if "★INVARIANT★" in s:
        return "★INVARIANT★"
    if "★DEBT★" in s:
        return "★DEBT★"
    if lineno <= fm_end:
        m = SYMBOL_RE.match(s)
        if m:
            return m.group(1)            # summary 符號行: KEY/FLOW/DEP...
        mk = FM_KEY_RE.match(line)
        if mk:
            return f"fm:{mk.group(1)}"    # frontmatter 欄位
        return "fm"
    return "body"


# ── 檢索排序核心(BM25F,borrow Whoosh 公式+Robertson BM25F tf 加權;spec:檢索優化_計劃) ──

_RANK_ASCII_RE = re.compile(r"[a-z0-9][a-z0-9_\-]*")
_RANK_CJK_RE = re.compile(r"[\u4e00-\u9fff\u3400-\u4dbf]+")
_RANK_FIELD_W = {"title": 4.0, "summary": 2.5, "tags": 1.5, "body": 1.0, "type": 0.5}


def _rank_tokenize(text):
    """中文連續段→字元 bigram(單字段→unigram);ASCII→完整 token+snake/kebab/數字拆分;小寫。"""
    out = []
    low = nfc(text or "").lower()
    for m in _RANK_CJK_RE.finditer(low):
        seg = m.group(0)
        if len(seg) == 1:
            out.append(seg)
        else:
            out.extend(seg[i:i + 2] for i in range(len(seg) - 1))
    for m in _RANK_ASCII_RE.finditer(low):
        tok = m.group(0)
        out.append(tok)
        parts = [p for p in re.split(r"[_\-]|(?<=[a-z])(?=[0-9])|(?<=[0-9])(?=[a-z])", tok) if p]
        if len(parts) > 1 or (parts and parts[0] != tok):
            out.extend(p for p in parts if p != tok)
    return out


def _rank_idf(n_docs, df):
    """平滑 IDF(Whoosh/Lucene Classic):log(N/(df+1))+1——小語料全出現詞仍為正。"""
    import math
    return math.log(n_docs / (df + 1)) + 1.0


def _rank_bm25(tf, idf, dl, avgdl, k1=1.2, b=0.75):
    return idf * (tf * (k1 + 1)) / (tf + k1 * ((1 - b) + b * dl / max(avgdl, 1e-9)))


def _rank_fields(env, rel):
    """節點 → 欄位文本 dict(title/summary/tags/body/type)。body 去 frontmatter。"""
    n = env.notes.get(rel)
    try:
        text = (env.vault / rel).read_text(encoding="utf-8-sig")
    except Exception:
        text = ""
    lines = text.split("\n")
    fm_end = 0
    if lines and lines[0].strip() == "---":
        for i in range(1, len(lines)):
            if lines[i].strip() == "---":
                fm_end = i + 1
                break
    body = "\n".join(lines[fm_end:])
    f = n.fields if n else {}
    tags = f.get("tags")
    tags = " ".join(tags) if isinstance(tags, list) else str(tags or "")
    return {"title": (n.stem if n else Path(rel).stem),
            "summary": str(f.get("summary") or ""),
            "tags": tags, "body": body, "type": str(f.get("type") or "")}


_RANK_TYPE_MULT_MOC = 0.4   # A1 型別先驗:MOC=hub 降權(goldset 實證關鍵字磁鐵;train 網格凍結)


_RANK_STATUS_MULT = 1.0   # A1.5 狀態先驗(stale/superseded 降權;goldset 網格後凍結,1.0=關)


def _rank_type_mult(env, rel):
    """型別/狀態先驗乘數(A1/A1.5,節點靜態先驗_調研):moc 降權、stale/superseded 降權、其餘 1.0。
    降權用乘法(比例效果跨 query 一致,企業搜尋標準);LUMOS_RANK_* env 供評測消融覆寫。"""
    n = env.notes.get(rel)
    fields = n.fields if n and isinstance(n.fields, dict) else {}
    t = str((fields.get("type") or "")).strip().lower()
    m = 1.0
    if t == "moc":
        try:
            m *= float(os.environ.get("LUMOS_RANK_MOC_MULT", _RANK_TYPE_MULT_MOC))
        except ValueError:
            m *= _RANK_TYPE_MULT_MOC
    st = str((fields.get("status") or "")).strip().lower()
    if st in ("stale", "superseded"):
        try:
            m *= float(os.environ.get("LUMOS_RANK_STATUS_MULT", _RANK_STATUS_MULT))
        except ValueError:
            m *= _RANK_STATUS_MULT
    return m


def _rank_score_candidates(env, query, candidates):
    """對候選集跑 BM25F(欄位 tf 加權於飽和前,單一虛擬文件)× 型別先驗乘數(A1)。
    回 [(rel, score, hits)]。N/df/avgdl 以候選集為 corpus(排序目的,絕對值不跨查詢比較)。"""
    q_tokens = list(dict.fromkeys(_rank_tokenize(query)))
    if not q_tokens or not candidates:
        return [(r, 0.0, []) for r in candidates]
    docs = {}
    for rel in candidates:
        fields = _rank_fields(env, rel)
        tfs = {}
        dl = 0.0
        for fname, ftext in fields.items():
            w = _RANK_FIELD_W[fname]
            toks = _rank_tokenize(ftext)
            dl += len(toks)          # 長度用未加權 token 數(spec §1)
            for tok in toks:
                if tok in q_tokens:
                    tfs[tok] = tfs.get(tok, 0.0) + w   # tf 加權於飽和前
        docs[rel] = (tfs, dl)
    n_docs = len(docs)
    avgdl = sum(d for _, d in docs.values()) / max(n_docs, 1)
    df = {t: sum(1 for tfs, _ in docs.values() if t in tfs) for t in q_tokens}
    out = []
    for rel, (tfs, dl) in docs.items():
        score = 0.0
        hits = []
        for tok in q_tokens:
            tf = tfs.get(tok, 0.0)
            if tf <= 0:
                continue
            score += _rank_bm25(tf, _rank_idf(n_docs, df[tok]), dl, avgdl)
            hits.append(tok)
        out.append((rel, round(score * _rank_type_mult(env, rel), 4), hits))
    # A3 權威度(in-degree 飽和加分)已試已殺(2026-07-11 goldset 雙面負增益:
    # search 0.875→0.847@w0.2、edit P@8 0.70→0.65@w0.1——本圖的高連結節點=導覽樞紐非答案,
    # 與 MOC 磁鐵實證同構)。詳見 Projects/節點靜態先驗_調研 消融紀錄;勿憑直覺復活。
    out.sort(key=lambda x: (-x[1], x[0]))
    return out


def cmd_search(env, term, path_prefix=None, regex=False, files_only=False, include_code=False,
               ranked=False, top=20, as_json=False):
    """全文搜尋(frontmatter + body)。預設大小寫不敏感 substring;--regex 用正則。
    預設**排除 fenced code 區塊 + inline code**(對齊 doctor 連結抽取的慣例,--code 才含);
    context 標記命中區域(★INVARIANT★/KEY/fm:欄位/body)。職責=自由文字;結構化查詢走
    contracts/decisions/stale/doctor。取代 obsidian search(2026-06-13)。
    2026-07-11 起 ranked(BM25F 相關性排序)為 CLI 預設(goldset 評測 §6 search 面全過,
    數字見 Verification/2026-07-11_檢索goldset評測);只重排既有候選、不擴召回、預設全量;
    --legacy 走舊字母序,--regex 自動走舊路。"""
    if regex:
        try:
            pat = re.compile(term, re.IGNORECASE)
        except re.error as e:
            print(f"ERROR: 正則無效: {e}", file=sys.stderr)
            return 2
        matches = lambda s: pat.search(s) is not None
    else:
        needle = nfc(term).lower()
        matches = lambda s: needle in nfc(s).lower()
    if ranked and regex:
        print("(--ranked 不適用 --regex 模式,照舊輸出)", file=sys.stderr)
        ranked = False
    _cand_hits = {}     # ranked:rel -> hit 行數(候選=legacy 命中集,不擴召回)
    _cand_detail = {}   # ranked:rel -> (hits, fm_end) 供逐檔明細輸出
    total_files = total_hits = 0
    for rel in sorted(env.notes):
        if path_prefix and not rel.startswith(path_prefix):
            continue
        try:
            text = (env.vault / rel).read_text(encoding="utf-8-sig")
        except Exception:
            continue
        lines = text.split("\n")
        fm_end = 0
        if lines and lines[0].strip() == "---":
            for i in range(1, len(lines)):
                if lines[i].strip() == "---":
                    fm_end = i + 1
                    break
        hits, in_fence = [], False
        for i, ln in enumerate(lines):
            if ln.lstrip().startswith("```"):       # fenced code 邊界
                in_fence = not in_fence
                continue
            if in_fence and not include_code:
                continue
            probe = ln if include_code else INLINE_CODE_RE.sub("", ln)
            if matches(probe):
                hits.append((i + 1, ln))
        if not hits:
            continue
        total_files += 1
        total_hits += len(hits)
        if ranked:
            _cand_hits[rel] = len(hits)
            _cand_detail[rel] = (hits, fm_end)
            continue
        if files_only:
            print(f"{rel} ({len(hits)})")
            continue
        print(f"{rel}")
        for lineno, ln in hits[:8]:
            s = ln.strip()
            tag = _search_region(lineno, ln, fm_end)
            disp = s if len(s) <= 90 else s[:90] + "…"
            print(f"  {lineno} [{tag}]: {disp}")
        if len(hits) > 8:
            print(f"  … 還有 {len(hits) - 8} 處")
    if ranked:
        import json as _json
        scored = _rank_score_candidates(env, term, list(_cand_hits))
        if int(top) > 0:
            scored = scored[:int(top)]
        if as_json:
            results = [{"node": rel, "score": score, "hits": hits, "match_lines": _cand_hits[rel]}
                       for rel, score, hits in scored]
            print(_json.dumps({"results": results, "candidates": len(_cand_hits)},
                              ensure_ascii=False))
        elif files_only:
            for rel, score, _h in scored:
                print(f"{rel} ({_cand_hits[rel]})")
        else:
            for rel, score, toks in scored:
                print(f"{score:7.3f}  {rel}  [{','.join(toks[:5])}]")
                d_hits, d_fm = _cand_detail.get(rel, ([], 0))
                for lineno, ln in d_hits[:8]:
                    s = ln.strip()
                    tag = _search_region(lineno, ln, d_fm)
                    disp = s if len(s) <= 90 else s[:90] + "…"
                    print(f"    {lineno} [{tag}]: {disp}")
                if len(d_hits) > 8:
                    print(f"    … 還有 {len(d_hits) - 8} 處")
            trunc = f"top {len(scored)} / " if len(scored) < len(_cand_hits) else ""
            print(f"\n({trunc}候選 {len(_cand_hits)};相關性排序,--legacy 走舊字母序)")
        return 0
    suffix = f"(限 {path_prefix})" if path_prefix else ""
    if not include_code:
        suffix += " [已排除 code block,--code 可含]"
    print(f"\n{total_hits} 處 / {total_files} 篇{suffix}")
    return 0


def cmd_links(env, rel, reverse=False):
    out_e, in_e = env.edges
    rows = (in_e if reverse else out_e).get(rel, [])
    arrow = "←" if reverse else "→"
    print(f"{rel} {arrow} {len(rows)} 個節點:")
    for d in sorted(rows):
        print(f"  • {d} [{status_of(env, d)}]")
    return 0


def cmd_map(env, rel, depth):
    out_e, _ = env.edges
    seen = {rel}

    def walk(cur, d, prefix):
        if d > depth:
            return
        children = [c for c in sorted(out_e.get(cur, []))]
        for i, c in enumerate(children):
            tail = "└─" if i == len(children) - 1 else "├─"
            mark = " (↺)" if c in seen else ""
            print(f"{prefix}{tail} {c} [{status_of(env, c)}]{mark}")
            if c not in seen:
                seen.add(c)
                walk(c, d + 1, prefix + ("   " if i == len(children) - 1 else "│  "))

    print(f"{rel} [{status_of(env, rel)}]  (depth={depth}, ↺=已出現過)")
    walk(rel, 1, "")
    return 0


# 標準格式: KEY 行前綴 ★INVARIANT★ / ★DEBT★(可帶 (日期) 前綴)。
# 錨定 KEY 行起始 → 排除「散文中提到標記」的誤報(如方法論文件講解標記用法)。
INVARIANT_RE = re.compile(r"^KEY:\s*(?:\([^)]*\)\s*)?★INVARIANT★\s*(.*)")
DEBT_RE = re.compile(r"^KEY:\s*(?:\([^)]*\)\s*)?★DEBT★\s*(.*)")


def extract_contracts(note):
    """從 summary block 的 KEY 行抽標準格式 ★INVARIANT★ / ★DEBT★。回傳 (invariants, debts)。
    只認 KEY 行前綴(標準格式),散文中提及不算 — 否則方法論文件會誤報。"""
    summ = note.fields.get("summary")
    inv, debt = [], []
    if isinstance(summ, str):
        for line in summ.split("\n"):
            line = line.strip()
            mi = INVARIANT_RE.match(line)
            if mi:
                inv.append(mi.group(1).strip())
            md = DEBT_RE.match(line)
            if md:
                debt.append(md.group(1).strip())
    return inv, debt


TEST_REF_RE = re.compile(r"\[test:\s*([^\]]+)\]")
# [audit:模型/日期] — ★INVARIANT★ 合法性經「無對話脈絡的獨立 agent」審計過的留痕。
# 與 [test:] 平行:test 證『有沒有照規則做』,audit 證『這規則該不該是鐵則 / 綁的測試夠不夠格』
# (沒標準答案的判斷不得由提出者本人自評 — maker/checker)。doctor Check T 強制。
AUDIT_REF_RE = re.compile(r"\[audit:\s*([^\]]+)\]")
# 抽「乾淨宣稱文字」時 test/audit/kill 與 regen 證據指針(src/git)都要剝掉(否則漏進顯示/子字串比對)。
# src|git 擴充(M1 Check J):影響 11 處行號/8 類呼叫點(Check T 乾淨宣稱/contracts/lint 訊息/
# guard 分類·list·trace/scaffold/kill-add/audit)——行為後果:guard 定位對「正文相同只差指針」
# 的合約改多重命中=要求更精確正文(指針非宣稱正文,符合語意非退化);[test:] 抽取不受影響。
INV_TAG_RE = re.compile(r"\[(?:test|audit|kill|src|git):\s*[^\]]+\]")
KILL_REF_RE = re.compile(r"\[kill:\s*recipes\s*\]")
# 真實可執行測試方法:xUnit 屬性([Fact]/[Theory]/[SkippableFact],含 (Skip=..) 變體)
# + 可選後續屬性(InlineData/MemberData/Trait)→ 存取修飾 → 可選 async → 回傳型別 → 方法名。
# B6 審計:Check T 不能只做子字串比對(會把「散文裡剛好提到的字」當證據);必須認到真方法。
TEST_METHOD_RE = re.compile(
    r"\[(?:Fact|Theory|SkippableFact)\b[^\]]*\]"
    r"(?:\s*\[[^\]]*\])*"
    r"\s*(?:public|internal|protected|private)\s+(?:async\s+)?"
    r"[\w.<>,\[\]\?]+\s+"
    r"([A-Za-z_]\w*)\s*\(",
    re.S)
CODE_EXTS_T = {".cs", ".py", ".js", ".ts", ".tsx", ".jsx", ".vue",
               ".sql", ".kt", ".java", ".go", ".rs"}
CODE_SKIP_DIRS = {".git", "node_modules", "bin", "obj", "dist", "build",
                  "__pycache__", "publish", "vendor", ".vs", ".idea"}

# Kotlin/JUnit 測試方法:@Test/@ParameterizedTest 等註解 → (中間不跨 `{`,即不越過方法體)
# → fun 方法名(允許反引號帶空白的 Kotlin 測試名)。去註解後比對(同 C#)。
KOTLIN_TEST_RE = re.compile(
    r"@(?:Test|ParameterizedTest|RepeatedTest)\b[^{]*?\bfun\s+(`[^`]+`|[A-Za-z_]\w*)\s*\(",
    re.S)

# Maestro(Android E2E)flow 綁 name: 欄位。行尾 \s*$ 錨:多字 name(含空白)NO MATCH
# → 與 playwright 對稱、不製造假陽性(識別字安全的 name 才可綁,設計慣例)。
MAESTRO_NAME_RE = re.compile(r"(?m)^name:\s*[\"']?([A-Za-z_]\w*)[\"']?\s*$")
# file_must_match:只認含 appId: 行首的檔(真 Maestro flow),濾掉 CI 等其他 yaml。
MAESTRO_FLOW_RE = re.compile(r"(?m)^appId:")
# Playwright(web E2E):test('id')/test.describe('id')。capture 識別字後需緊接引號,
# 故含空白 title(如 'should show menu')NO MATCH(設計上不可綁)。
PLAYWRIGHT_TEST_RE = re.compile(r"\btest(?:\.describe)?\(\s*[\"']([A-Za-z_]\w*)[\"']")

# ── 測試棧 profile(語言可插拔;P5 — Android/Kotlin 等也能用 guard + Check T)──
# 每個 profile:exts(discover 掃哪些副檔名)/ method_re(group(1)=方法名)/
# scaffold_ext(產 stub 副檔名)/ dir_mode(suffix=頂層目錄 endswith / rglob=遞迴找目錄名)/
# dirs[gtype]=(include, exclude)。預設 csharp-xunit(向後相容)。
TEST_PROFILES = {
    "csharp-xunit": {
        "exts": {".cs"}, "method_re": TEST_METHOD_RE, "scaffold_ext": ".cs",
        "dir_mode": "suffix", "rglob_under": None,
        "attr_hint": "[Fact]/[Theory]/[SkippableFact]", "fail_hint": "Assert.Fail",
        "dirs": {"pure": (["Tests"], ["IntegrationTests"]),
                 "behavioral": (["IntegrationTests"], []),
                 "state": (["IntegrationTests"], [])},
    },
    "kotlin-junit": {
        "exts": {".kt"}, "method_re": KOTLIN_TEST_RE, "scaffold_ext": ".kt",
        "dir_mode": "rglob", "rglob_under": "src",   # 限 Gradle/Maven src/ 下,排除 docs/test 等
        "attr_hint": "@Test/@ParameterizedTest/@RepeatedTest", "fail_hint": "fail()",
        "dirs": {"pure": (["test"], []),
                 "behavioral": (["androidTest", "test"], []),
                 "state": (["androidTest", "test"], [])},
    },
    # Maestro(Android E2E):測試單位=YAML flow 檔,綁 name: 欄位(識別字安全)。
    # file_must_match=^appId: 只認真 flow,濾掉 CI 等其他 yaml(否則其 name: 被誤收)。
    "maestro": {
        "exts": {".yaml", ".yml"}, "method_re": MAESTRO_NAME_RE, "scaffold_ext": ".yaml",
        "dir_mode": "rglob", "rglob_under": None, "file_must_match": MAESTRO_FLOW_RE,
        "attr_hint": "Maestro flow name:", "fail_hint": "assertVisible(哨兵)",
        "dirs": {"pure": ([], []),
                 "behavioral": ([".maestro"], []),
                 "state": ([".maestro"], [])},
    },
    # Playwright(web E2E):test('id')/test.describe('id')。識別字 title(含空白 NO MATCH,
    # 設計上不可綁)。無 file_must_match(以 test( 為錨,不需檔案過濾)。
    "playwright": {
        "exts": {".ts", ".tsx", ".js", ".jsx"}, "method_re": PLAYWRIGHT_TEST_RE,
        "scaffold_ext": ".spec.ts", "dir_mode": "rglob", "rglob_under": None,
        "attr_hint": "test('id')/test.describe('id')", "fail_hint": "expect(哨兵).toBe(...)",
        "dirs": {"pure": ([], []),
                 "behavioral": (["tests", "e2e"], []),
                 "state": (["tests", "e2e"], [])},
    },
}


def load_test_profile(repo_root):
    """讀 <repo>/.lumos/config.json 的 test_profile(預設 csharp-xunit;向後相容)。
    支援欄位級 inline 覆蓋(exts/scaffold_ext/method_regex)當逃生口。"""
    import json
    prof = dict(TEST_PROFILES["csharp-xunit"])
    cfg_path = repo_root / ".lumos" / "config.json"
    if not cfg_path.exists():
        return prof
    try:
        cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
    except Exception as e:
        print(f"⚠ .lumos/config.json 解析失敗,用 csharp-xunit 預設: {e}", file=sys.stderr)
        return prof
    name = cfg.get("test_profile") or "csharp-xunit"   # null/空字串 → 預設(F8)
    if name in TEST_PROFILES:
        prof = dict(TEST_PROFILES[name])
    elif name != "csharp-xunit":
        print(f"⚠ 未知 test_profile '{name}'(有: {', '.join(TEST_PROFILES)}),用 csharp-xunit",
              file=sys.stderr)
    ov = cfg.get("test")
    if ov is not None and not isinstance(ov, dict):   # F1:test 非 dict → 忽略不 crash
        print(f"⚠ config.json 的 test 欄位應為物件,忽略(收到 {type(ov).__name__})", file=sys.stderr)
        ov = None
    if isinstance(ov, dict):
        if "exts" in ov:
            raw = ov["exts"]
            raw = [raw] if isinstance(raw, str) else raw   # F1:字串容錯為單元素
            if isinstance(raw, list):
                prof["exts"] = {e if e.startswith(".") else "." + e for e in raw}
            else:
                print("⚠ test.exts 應為陣列,忽略", file=sys.stderr)
        if isinstance(ov.get("scaffold_ext"), str):
            prof["scaffold_ext"] = ov["scaffold_ext"]
        if "method_regex" in ov:
            rx, err = _safe_user_regex(ov["method_regex"])   # F2:編譯 + ReDoS 探針
            if rx is not None:
                prof["method_re"] = rx
            else:
                print(f"⚠ test.method_regex 不採用({err}),沿用 profile 內建", file=sys.stderr)
    return prof


def load_platforms(repo_root):
    """讀 .lumos/config.json 的多根多 profile 設定(多平台合約測試綁定)。
    回 {multiplatform: bool, default_platform: str, platforms: {plat: {profile: dict, root: Path}}}。
    - 無 config / 無 `platforms` 鍵 → legacy:multiplatform False、單一條目(key=test_profile 或
      csharp-xunit、root=repo_root、profile 走 load_test_profile 含 inline 覆蓋)。此 multiplatform
      信號(而非「dict 是否為空」)決定 resolve_test_refs 要不要做前綴切分(審計 r4 + opus 辯方拍板)。
    - 有 `platforms` 鍵 → multiplatform True:每平台 profile 名 → profile dict、
      root=(repo_root/root_str).resolve()(不存在大聲警告、不擋);default_platform 依 D1 規則。
    設定錯誤(缺 default_platform 且平台 >1 / default 指向不存在鍵 / profile 名未知)→ raise ValueError。"""
    import json
    cfg_path = repo_root / ".lumos" / "config.json"
    cfg = {}
    if cfg_path.exists():
        try:
            cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
        except Exception as e:
            print(f"⚠ .lumos/config.json 解析失敗,退回 legacy 單 profile: {e}", file=sys.stderr)
            cfg = {}
    plats = cfg.get("platforms")
    if not isinstance(plats, dict) or not plats:
        # legacy:單一條目(root=repo_root,profile 沿用 load_test_profile 的 inline 覆蓋支援)
        name = cfg.get("test_profile") or "csharp-xunit"
        if name not in TEST_PROFILES:
            name = "csharp-xunit"
        _tcfg = cfg.get("test") if isinstance(cfg.get("test"), dict) else {}
        return {"multiplatform": False, "default_platform": name,
                "platforms": {name: {"profile": load_test_profile(repo_root), "root": repo_root,
                                     "run_cmd": _tcfg.get("run_cmd")}}}
    out = {}
    for plat, spec in plats.items():
        if not isinstance(spec, dict):
            raise ValueError(f"platforms['{plat}'] 應為物件(收到 {type(spec).__name__})")
        pname = spec.get("profile")
        if pname not in TEST_PROFILES:
            raise ValueError(f"platforms['{plat}'].profile '{pname}' 未知(有: {', '.join(TEST_PROFILES)})")
        root_str = spec.get("root", ".")
        root = (repo_root / root_str).resolve()   # 明寫基底 repo_root(非 cwd),見 D1
        if not root.exists():
            print(f"⚠ 平台 '{plat}' 的 root 不存在: {root}(該平台 discover 將掃不到測試)", file=sys.stderr)
        out[plat] = {"profile": dict(TEST_PROFILES[pname]), "root": root,
                     "run_cmd": spec.get("run_cmd")}   # guard kill 用;缺=None
    default = cfg.get("default_platform")
    if default is None:
        if len(out) == 1:
            default = next(iter(out))
        else:
            raise ValueError(f"多平台 config 有 {len(out)} 個平台但未指定 default_platform"
                             f"(無前綴 [test:X] 不知歸屬);請加 default_platform")
    elif default not in out:
        raise ValueError(f"default_platform '{default}' 不在 platforms({', '.join(out)})")
    return {"multiplatform": True, "default_platform": default, "platforms": out}


def _safe_user_regex(pattern):
    """編譯使用者提供的 regex,並用【靜態】啟發式擋常見巢狀量詞 ReDoS。
    關鍵:**絕不執行**該 regex 來探測 — 在 CPython 裡 catastrophic regex 持有 GIL,
    用 thread/probe 探測反而會把整個 process 卡死(GIL 餓死主執行緒)。故只做模式檢查。
    非窮舉(擋不到 alternation 型),擋得到 (a+)+ / (a*)+ / (a+)* 這類經典款。
    回傳 (compiled, None) 或 (None, 原因)。"""
    if not isinstance(pattern, str):
        return None, "非字串"
    # 巢狀量詞:帶量詞的群組整體又被量詞修飾(經典 catastrophic backtracking)
    if re.search(r"\([^()]*[+*][^()]*\)\s*[+*?]", pattern) or \
       re.search(r"\([^()]*\)\s*[+*]\s*[+*]", pattern):
        return None, "疑似巢狀量詞 ReDoS(如 (a+)+);請改寫或用 profile 內建"
    try:
        return re.compile(pattern, re.S), None
    except re.error as e:
        return None, f"無效: {e}"


def invariant_test_refs(inv_text):
    """從 ★INVARIANT★ 文字抽 [test:A,B] 綁定的可執行測試名(可多個,逗號分隔)。無綁定回 []。
    回**原始字串**(含任何 平台: 前綴)——供 tag 重建/顯示;平台解析走 resolve_test_refs。"""
    out = []
    for m in TEST_REF_RE.findall(inv_text):
        out.extend(t.strip() for t in m.split(",") if t.strip())
    return out


def resolve_test_refs(inv_text, platforms, default_platform):
    """把 [test:...] 解析為 [(platform, method_name)]。沿用 invariant_test_refs 的逗號切分。
    - platforms 非空(多平台):每段含 ':' → 前綴須為已定義 platform 鍵(C#/Kotlin 名不含冒號,
      故含冒號即視為 平台:名;前綴未定義 → raise ValueError,不誤當方法名);無 ':' → 歸 default_platform。
    - platforms 空(legacy,由呼叫端在 multiplatform=False 時傳 {}):**不切分**,整串(含任何冒號)
      配 default_platform → 後續走單一 method set 比對(含冒號的假想 ref 走 dangling 而非報錯)。"""
    out = []
    for seg in invariant_test_refs(inv_text):
        if platforms and ":" in seg:
            plat, name = seg.split(":", 1)
            plat, name = plat.strip(), name.strip()
            if plat not in platforms:
                raise ValueError(
                    f"[test:{seg}] 的平台前綴 '{plat}' 未定義於 platforms"
                    f"({', '.join(platforms)});不 fallback 避免誤綁")
            out.append((plat, name))
        else:
            out.append((default_platform, seg))
    return out


def invariant_audit_refs(inv_text):
    """從 ★INVARIANT★ 文字抽 [audit:模型/日期] 留痕(通常一條)。無=回 []。"""
    return [m.strip() for m in AUDIT_REF_RE.findall(inv_text) if m.strip()]


def strip_test_refs(inv_text):
    """回傳 (去掉 [test:..]/[audit:..] 標記的乾淨宣稱文字, 綁定測試名 list)。"""
    return INV_TAG_RE.sub("", inv_text).strip(), invariant_test_refs(inv_text)


# ── 可逆性軸(獨立於 ★INVARIANT★ 合約軸;走平行函式,不碰 extract_contracts/INV_TAG_RE)──
CHECKPOINT_RE = re.compile(r"^KEY:\s*(?:\([^)]*\)\s*)?★CHECKPOINT★\s*(.*)")
IRREVERSIBLE_RE = re.compile(r"^KEY:\s*(?:\([^)]*\)\s*)?★IRREVERSIBLE★\s*(.*)")
ROLLBACK_REF_RE = re.compile(r"\[rollback:\s*([^\]]+)\]")
GUARD_REF_RE = re.compile(r"\[guard:\s*([^\]]+)\]")  # 可逆性軸,平行於 ROLLBACK_REF_RE

# ── regen 重生來源軸(M1 from-scratch 守衛;Check J,獨立於合約軸/可逆性軸)──
# 設計:Projects/from-scratch重生守衛_計劃(design-loop 3 輪,golden: governance/golden/fromscratch-m1)。
# [src:路徑(:行號)]=Tier A 現 code 可驗;[git:sha]=Tier B 變更事件;推測:/佚失: 前綴=Tier C/佚失。
SRC_REF_RE = re.compile(r"\[src:\s*([^\]]+?)(?::(\d+(?:-\d+)?))?\s*\]")
GIT_REF_RE = re.compile(r"\[git:\s*([0-9a-fA-F]{7,40})\s*\]")
# 疊放釘死:緊跟 summary 前綴(KEY:推測:/DECISION:佚失:);行中出現不算標記(防歧義)。只掃 summary。
REGEN_PREFIX_RE = re.compile(r"^(?:KEY|DECISION):\s*(推測|佚失):")


def reversibility_rollback_ref(text):
    m = ROLLBACK_REF_RE.search(text)
    return m.group(1).strip() if m else None


def reversibility_guard_ref(text):
    m = GUARD_REF_RE.search(text)
    return m.group(1).strip() if m else None


IRREVERSIBLE_HINT_PATTERNS = [
    re.compile(r"\bprod[._\-/]|production\b", re.I),
    re.compile(r"smtplib|sendmail|send_mail\b|\.send_message\b", re.I),
    re.compile(r"requests\.post\b|httpx\.post\b", re.I),
    re.compile(r"boto3\.(client|resource)\s*\(", re.I),
    re.compile(r"\bstripe\.\b|\btwilio\.\b|\bsendgrid\.\b", re.I),
    re.compile(r"\bDROP\s+TABLE\b|\bDELETE\s+FROM\b", re.I),
    re.compile(r"external_api\b|ext_api\b", re.I),
]


def _scan_diff_for_irreversible_hints(cwd):
    """掃 git diff --staged(優先)或 HEAD~1..HEAD,回傳疑似不可逆 +行摘要列表。
    非 git repo 或無 diff → 回傳 []。跳過測試檔與純注解行。
    cwd=str(env.vault) 即可:git diff 無 pathspec 時範圍為全 repo,cwd 子目錄不縮小範圍。"""
    import subprocess  # lazy import,與 L339/L2298 等先例一致
    _SKIP_EXT = {".md", ".txt", ".rst"}
    _TEST_PAT = re.compile(r"(test_|_test\.|\.spec\.|/tests?/)", re.I)

    for cmd in (["git", "diff", "--staged"], ["git", "diff", "HEAD~1..HEAD"]):
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, cwd=cwd)
        except FileNotFoundError:
            return []
        if r.returncode != 0 or not r.stdout.strip():
            continue
        diff_text = r.stdout
        break
    else:
        return []

    cur_file = ""
    hits = []
    for line in diff_text.splitlines():
        if line.startswith("+++ b/"):
            cur_file = line[6:]
        if line.startswith("+++") or line.startswith("---"):
            continue
        if not line.startswith("+"):
            continue
        ext = Path(cur_file).suffix if cur_file else ""
        if ext in _SKIP_EXT:
            continue
        if cur_file and _TEST_PAT.search(cur_file):
            continue
        code_line = line[1:].strip()
        if code_line.startswith(("#", "//", "--", "/*", "*")):
            continue
        for pat in IRREVERSIBLE_HINT_PATTERNS:
            if pat.search(code_line):
                hits.append(f"{Path(cur_file).name}: {code_line[:80]}")
                break
    return hits[:8]


def extract_reversibility(note):
    """從 summary KEY 行抽 (marker, 去 [rollback:]/[guard:] 的乾淨文字, rollback_ref, guard_ref)。"""
    summ = note.fields.get("summary")
    out = []
    if isinstance(summ, str):
        for raw in summ.split("\n"):
            line = raw.strip()
            for marker, rx in (("★CHECKPOINT★", CHECKPOINT_RE), ("★IRREVERSIBLE★", IRREVERSIBLE_RE)):
                m = rx.match(line)
                if m:
                    body = m.group(1)
                    clean_body = ROLLBACK_REF_RE.sub("", GUARD_REF_RE.sub("", body)).strip()
                    out.append((marker, clean_body,
                                reversibility_rollback_ref(body), reversibility_guard_ref(body)))
    return out


def _rollback_resolved(note, ref):
    """[rollback:decisions] 視為已解析 ⟺ 本節點 decisions[] 有 ≥1 條非空 rollback。"""
    if not ref or ref.strip().lower() != "decisions":
        return False
    return any(str(d.get("rollback", "")).strip() for d in parse_decisions(note.fm_lines))


def _guard_resolved(note, ref):
    """[guard:decisions] 視為已解析 ⟺ 本節點 decisions[] 有 ≥1 條非空 guard。"""
    if not ref or ref.strip().lower() != "decisions":
        return False
    return any(str(d.get("guard", "")).strip() for d in parse_decisions(note.fm_lines))


def build_code_haystack(repo_root):
    """讀 repo 內所有 code 檔串成大字串,供 ★INVARIANT★ 綁定的測試名做存在性檢查。
    (閉環外接觸:doctor 不執行測試,只驗證『載重宣稱認領的證據真的存在於程式碼』)"""
    import os
    parts = []
    for dp, dirs, files in os.walk(repo_root):
        dirs[:] = [d for d in dirs if d not in CODE_SKIP_DIRS]
        for f in files:
            if Path(f).suffix.lower() in CODE_EXTS_T:
                try:
                    parts.append((Path(dp) / f).read_text(encoding="utf-8", errors="ignore"))
                except Exception:
                    pass
    return "\n".join(parts)


def discover_test_methods(repo_root, profile=None):
    """掃 repo 內測試檔,回傳「真實測試方法名」集合(被測試框架註解標註者)。
    測試棧 profile 決定掃哪些副檔名 + 用哪條方法 regex(預設 csharp-xunit;P5 語言可插拔)。
    Check T 用此集合驗證 ★INVARIANT★ 綁定的是『可執行證據』而非散文裡的字面巧合(B6 審計)。"""
    import os
    profile = profile or load_test_profile(repo_root)
    exts, mre = profile["exts"], profile["method_re"]
    must = profile.get("file_must_match")   # 選填:只認內容含此 marker 的檔(如 Maestro ^appId:)
    methods = set()
    for dp, dirs, files in os.walk(repo_root):
        dirs[:] = [d for d in dirs if d not in CODE_SKIP_DIRS]
        for f in files:
            if Path(f).suffix.lower() in exts:
                try:
                    txt = (Path(dp) / f).read_text(encoding="utf-8", errors="ignore")
                except Exception:
                    continue
                # file_must_match:讀檔後、去註解前先過濾(如 .yaml 一堆,只認真 Maestro flow;
                # 濾掉 CI yaml 的 name: 被誤收)。現有 profile 無此鍵→.get() 回 None→不過濾。
                if must is not None and not must.search(txt):
                    continue
                # 先去註解:行尾 // 註解(如 [InlineData(..)] // 說明 / @Test // 備註)會打斷
                # 「註解串→方法簽章」的連續比對,導致真測試被誤判偽證據。
                txt = re.sub(r"//[^\n]*", "", txt)
                txt = re.sub(r"/\*.*?\*/", "", txt, flags=re.S)
                for m in mre.finditer(txt):
                    methods.add(m.group(1).strip("`"))  # Kotlin 反引號測試名去引號
    return methods


def cmd_contracts(env, rel=None):
    """合約登記簿: ★INVARIANT★(改=breaking) / ★DEBT★(可改)。
    動某模組前先查它的硬合約 — Obsidian 做不到(子字串不在它的 graph 裡)。
    ★INVARIANT★ 顯示綁定的測試(可執行證據);未綁=⚠(doctor Check T 會擋)。"""
    targets = [rel] if rel else sorted(env.notes)
    n_inv = n_debt = 0
    for r in targets:
        inv, debt = extract_contracts(env.notes[r])
        if not inv and not debt:
            continue
        print(f"# {r}")
        for x in inv:
            clean, refs = strip_test_refs(x)
            print(f"  ★INVARIANT★ {clean}")
            print(f"      ↳ test: {', '.join(refs)}" if refs else "      ↳ ⚠ 未綁測試(無可執行證據)")
            n_inv += 1
        for x in debt:
            print(f"  ★DEBT★ {x}")
            n_debt += 1
    if n_inv == 0 and n_debt == 0:
        print("(無合約標記)" if rel else "(全 vault 無合約標記 — 用 ★INVARIANT★/★DEBT★ 前綴標 KEY 行)")
    else:
        print(f"\n合約 {n_inv} 條(改=breaking) | 技術債 {n_debt} 條(可改)")
    return 0


KNOWN_TYPES = {"system", "verification", "issue", "project", "moc"}
SYMBOL_NAMES = {"KEY", "FLOW", "DEP", "TEST", "AUTH", "FLAG", "DECISION", "VERIFY", "CORE"}
SYMBOLISH_RE = re.compile(r"^([A-Z]{2,}):")   # 像「符號宣告」的行(全大寫前綴)→ 抓 typo


def _git_commit_exists(repo_root, sha):
    """[git:sha] Tier B 驗證:git cat-file -e sha^{commit}。非 git repo/物件缺 → False。"""
    import subprocess
    try:
        r = subprocess.run(["git", "cat-file", "-e", f"{sha}^{{commit}}"], cwd=str(repo_root),
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return r.returncode == 0
    except OSError:
        return False


def _git_is_shallow(repo_root):
    import subprocess
    try:
        r = subprocess.run(["git", "rev-parse", "--is-shallow-repository"], cwd=str(repo_root),
                           capture_output=True, text=True)
        return r.returncode == 0 and r.stdout.strip() == "true"
    except OSError:
        return False


def check_regen_provenance(note, repo_root):
    """Check J(regen 重生來源守衛)共用檢查器——cmd_lint 與 run_doctor 同呼叫同一函式(防兩入口
    規則漂移)。只對 frontmatter 帶 regen 的節點生效;非 regen 節點回三空。只掃 summary 行。
    回 (errs, warns, gov_events),兩入口映射(spec 映射表,照抄不猜):
      errs → lint errs 計 rc1 / doctor warn(hard) 計 issues
      warns → lint 顯示不計 rc / doctor warn_soft(J-d 提醒與 shallow 降級兩入口皆非阻擋)
      gov_events → 僅 doctor --ci 落 _append_governance_log;lint 高頻一律不落帳(防治理帳灌水)
    註:本函式為 regen 節點對 lint「node-local 不掃 repo」原則的 opt-in 例外(檔案+git 存取)。
    設計:Projects/from-scratch重生守衛_計劃;golden: governance/golden/fromscratch-m1。"""
    errs, warns, gov = [], [], []
    regen = note.fields.get("regen")
    if not (isinstance(regen, str) and regen.strip()):
        return errs, warns, gov
    summ = note.fields.get("summary")
    summ = summ if isinstance(summ, str) else ""
    shallow = None  # 惰性判定(每節點至多一次 rev-parse)
    untagged_keys = 0
    has_git_ptr = "[git:" in summ  # presence-guard:整節點無 [git: 子串即不 spawn
    for raw in summ.split("\n"):
        line = raw.strip()
        if not line:
            continue
        has_src = SRC_REF_RE.search(line)
        has_git = GIT_REF_RE.search(line)
        prefix_m = REGEN_PREFIX_RE.match(line)
        # 不對稱接線:推測/佚失 不得承載合約/不可逆(raw 行獨立偵測——INVARIANT_RE 對此形態
        # 整行不 match,靠它=該行對 Check T/contracts 隱形,比擋下更毒;四組合皆觸發)
        if prefix_m and ("★INVARIANT★" in line or "★IRREVERSIBLE★" in line):
            errs.append(f"『{prefix_m.group(1)}:』行不得承載 ★INVARIANT★/★IRREVERSIBLE★"
                        f"(合約不能建在推測上;補 [src:]/[git:] 或走 signoff 升級):{line[:48]}")
            continue
        # J-a:regen ★INVARIANT★ 需 [src:]/[git:] 意圖證據(與 Check T 的 [test:] 疊加——
        # [test:] 只證行為現在成立,不證意圖是合約;拒絕發明合約)
        if INVARIANT_RE.match(line) and not (has_src or has_git):
            errs.append(f"regen 節點的 ★INVARIANT★ 缺 [src:]/[git:] 意圖證據"
                        f"(J-a 拒絕發明合約):{line[:48]}")
        # J-b:DECISION 行需證據指針或顯式標 推測:/佚失:(重建的 why 必須標來源或標推測)
        if line.startswith("DECISION:") and not (has_src or has_git or prefix_m):
            errs.append(f"regen 節點的 DECISION 行無證據指針且未標 推測:/佚失:(J-b):{line[:48]}")
        # J-d:無 tier 標記的 KEY 行計數(唯讀提醒,不寫回任何欄位)
        if line.startswith("KEY:") and not (has_src or has_git or prefix_m):
            untagged_keys += 1
        # J-c:[src:] substring gate(直走 _validate_repo_ref,不經 top_dirs 靜默過濾)
        for m in SRC_REF_RE.finditer(line):
            path, lno = m.group(1).strip(), (m.group(2) or "")
            status, _ = _validate_repo_ref(repo_root, path, lno)
            if status == "missing":
                errs.append(f"[src:{path}] 目標不存在(J-c dangling=幻覺證據)")
            elif status == "line_out_of_range":
                errs.append(f"[src:{path}:{lno}] 行號越界(J-c)")
        # J-c:[git:sha](presence-guard 後才 spawn;shallow 降級=顯性+僅 doctor --ci 留痕,不得靜默)
        if has_git_ptr:
            for m in GIT_REF_RE.finditer(line):
                sha = m.group(1)
                if _git_commit_exists(repo_root, sha):
                    continue
                if shallow is None:
                    shallow = _git_is_shallow(repo_root)
                if shallow:
                    warns.append(f"[git:{sha[:12]}] Tier B 驗證跳過(shallow clone,本地無該物件;"
                                 f"非擋——full clone 下會重驗)")
                    gov.append({"gate": "check-j", "kind": "shallow-skip", "hard": False,
                                "nodes": [note.stem]})
                else:
                    errs.append(f"[git:{sha[:12]}] commit 不存在(J-c dangling=幻覺證據)")
    if untagged_keys:
        warns.append(f"{untagged_keys} 條 KEY 行無 tier 標記([src:]/[git:]/推測:/佚失:)"
                     f"——J-d 提醒:prose 級誠實機械驗不了,建議補標或過對抗審")
    return errs, warns, gov


def cmd_lint(env, node):
    """單檔快檢:寫完一個節點立刻自驗標籤/格式(node-local,不掃 repo → 比 doctor 快;
    例外:regen 節點的 Check J 需檔案+git 存取,opt-in、量小)。
    抓「寫入當下」最常見的錯:type/summary 缺漏、★ 標記格式錯(漏被 contracts 抓)、
    裸合約 / 未審、symbol 行 typo、frontmatter 指紋(ghost trap…)。
    與 doctor 分工:doctor 是全圖權威(跨節點完整性 + [test:] 存在性),lint 只看這一篇、
    predicts pre-push 會不會擋(error 即 doctor --ci 會擋的同類)。"""
    rel = env.find(node)
    if rel is None:
        print(f"ERROR: 找不到節點 {node}", file=sys.stderr)
        return 2
    n = env.notes[rel]
    errs = list(n.lint)          # frontmatter 指紋(ghost trap / 重複鍵 / 日期引號…)= error
    warns = []

    t = n.fields.get("type")
    if not isinstance(t, str) or not t:
        errs.append("缺 type(frontmatter 必須有 type)")
    elif t not in KNOWN_TYPES:
        errs.append(f"未知 type『{t}』(應為 {'/'.join(sorted(KNOWN_TYPES))})")

    summ = n.fields.get("summary")
    summ = summ if isinstance(summ, str) else ""
    if t in ("system", "issue") and not summ.strip():
        errs.append(f"{t} 節點必須有 summary block(放 FLOW:/KEY:/DEP: 等符號行)")

    _regen_val = n.fields.get("regen")
    _lint_is_regen = isinstance(_regen_val, str) and bool(_regen_val.strip())

    for raw in summ.split("\n"):
        line = raw.strip()
        if not line:
            continue
        ms = SYMBOLISH_RE.match(line)
        if ms and ms.group(1) not in SYMBOL_NAMES:
            warns.append(f"非標準符號行『{ms.group(1)}:』(typo? 符號應為 {'/'.join(sorted(SYMBOL_NAMES))})")
        for mark, rx in (("★INVARIANT★", INVARIANT_RE), ("★DEBT★", DEBT_RE)):
            if mark in line and not rx.match(line):
                # 雙報消歧 predicate(Check J):regen 節點的 KEY:推測:★INVARIANT★ 由 J 專屬訊息
                # 接手,跳過 generic 位置錯誤(同一行恰一則;非 regen 節點 generic 保留=兜底)。
                # 既有迴圈只含 INVARIANT/DEBT、無 IRREVERSIBLE → 消歧只需此分支。
                if (_lint_is_regen and REGEN_PREFIX_RE.match(line)
                        and ("★INVARIANT★" in line or "★IRREVERSIBLE★" in line)):
                    continue
                errs.append(f"{mark} 必須是 KEY 行前綴(KEY:{mark} ...),否則 contracts/doctor 抓不到:{line[:48]}")

    invs, _ = extract_contracts(n)
    for inv in invs:
        clean, refs = strip_test_refs(inv)
        if not refs:
            errs.append(f"裸 ★INVARIANT★(沒綁 [test:],Check T 會擋):{first_line(clean, 48)}")
        elif not invariant_audit_refs(inv):
            errs.append(f"★INVARIANT★ 綁了測試但未獨立審計(缺 [audit:],pre-push 會擋):{first_line(clean, 48)}")

    # Check J 單檔版(regen 重生來源守衛):共用 check_regen_provenance,映射表——
    # errs→errs(rc1)/warns→warns(顯示不計 rc)/gov_events→lint 一律不落帳(高頻)。
    if _lint_is_regen:
        j_errs, j_warns, _j_gov = check_regen_provenance(n, _repo_root_from_env(env))
        errs.extend(j_errs)
        warns.extend(j_warns)

    # Check R 單檔版:可逆性回退綁定 + 標錯型別
    for marker, rclean, ref, guard_ref in extract_reversibility(n):
        if t != "system":
            errs.append(f"{marker} 只能在 Systems 節點(本節點 type={t!r}):{first_line(rclean, 40)}")
        elif marker == "★IRREVERSIBLE★":
            if not (_rollback_resolved(n, ref) or _guard_resolved(n, guard_ref)):
                errs.append(f"{marker} 缺實質回退(行尾加 [rollback:decisions] 或 [guard:decisions],decisions[] 要有非空 rollback/guard):{first_line(rclean, 40)}")
        elif not _rollback_resolved(n, ref):  # ★CHECKPOINT★;guard_ref 不讀
            warns.append(f"{marker} 建議補回退([rollback:decisions]):{first_line(rclean, 40)}")

    if not errs and not warns:
        print(f"✓ lint {rel} — 0 問題")
        return 0
    print(f"lint {rel}")
    for e in errs:
        print(f"  ✗ {e}")
    for w in warns:
        print(f"  ⚠ {w}")
    print(f"\n{len(errs)} error / {len(warns)} warning"
          + ("" if errs else "(warning 不阻擋,但建議補)"))
    return 1 if errs else 0


SPEC_CLAUSE_RE = re.compile(r"\[S(\d+)\]")


def cmd_spec_trace(env, node, as_json=False):
    """條款級追溯(RTM 輕量版):計劃 body 的 [SN] 條款 × 回指 Verification 的認領。
    rc:全認領=0;有未認領=1;計劃無 [SN] 標記=0(opt-in 未啟用)。唯讀。"""
    import json
    rel = env.find(node)
    if rel is None:
        print(f"ERROR: 找不到節點 {node}", file=sys.stderr)
        return 2
    plan_stem = env.notes[rel].stem
    try:
        text = (env.vault / rel).read_text(encoding="utf-8-sig")
    except OSError as ex:
        print(f"ERROR: {ex}", file=sys.stderr)
        return 2
    ids = sorted({int(m) for m in SPEC_CLAUSE_RE.findall(text)})
    if not ids:
        if as_json:
            print(json.dumps({"plan": rel, "clauses": {}, "unclaimed": [],
                              "opt_in": False}, ensure_ascii=False))
        else:
            print(f"(opt-in 未啟用) {rel} 無 [SN] 條款標記——要追溯就在規格 bullet 加 [S1]/[S2]…")
        return 0
    claims = {i: [] for i in ids}
    for vrel, n in env.notes.items():
        if not vrel.startswith("Verification/"):
            continue
        prs = n.fields.get("plan_refs")
        prs = prs if isinstance(prs, list) else ([prs] if prs else [])
        if not any(plan_stem in str(x) for x in prs):
            continue   # 沒回指本計劃的提及不算認領(防偶然文字)
        # 已知設計限制:多計劃 Verification 提及 [S1] 會同時記入兩計劃的 S1
        # (條款 ID 只有數字無計劃域)——一篇 Verification 盡量只回指一個計劃
        try:
            vtext = (env.vault / vrel).read_text(encoding="utf-8-sig")
        except OSError:
            continue
        for m in SPEC_CLAUSE_RE.findall(vtext):
            i = int(m)
            if i in claims:
                claims[i].append(vrel)
    unclaimed = [i for i in ids if not claims[i]]
    if as_json:
        print(json.dumps({"plan": rel, "clauses": {f"S{i}": claims[i] for i in ids},
                          "unclaimed": [f"S{i}" for i in unclaimed]}, ensure_ascii=False))
    else:
        for i in ids:
            mark = "✓" if claims[i] else "✗"
            who = ", ".join(Path(x).stem for x in claims[i]) or "(無人認領)"
            print(f"{mark} [S{i}] ← {who}")
        print(f"\n{len(ids)} 條款 / 未認領 {len(unclaimed)}")
    return 1 if unclaimed else 0


def cmd_signoff(env, node, note, by=None):
    """業務簽核留痕(validation 那半):人對業務正確性點頭 → ledger+frontmatter 戳記。
    工具只記留痕,不證明確認真的發生(同 audit/self-audit 的誠實前提)。"""
    import json
    import datetime
    import subprocess
    if not (note or "").strip():
        print("ERROR: --note 必填(確認了什麼,給未來的人看)", file=sys.stderr)
        return 2
    rel = env.find(node)
    if rel is None:
        print(f"ERROR: 找不到節點 {node}", file=sys.stderr)
        return 2
    today = datetime.date.today().isoformat()
    commit = ""
    try:
        commit = subprocess.run(["git", "-C", str(env.vault.parent), "rev-parse", "--short", "HEAD"],
                                capture_output=True, text=True).stdout.strip()
    except OSError:
        pass
    log = env.vault.parent / ".signoff-log.jsonl"
    try:
        with open(log, "a", encoding="utf-8") as fh:
            fh.write(json.dumps({"ts": datetime.datetime.now().isoformat(timespec="seconds"),
                                 "node": rel, "by": by or "", "note": note,
                                 "commit": commit}, ensure_ascii=False) + "\n")
    except OSError as ex:
        print(f"ERROR: signoff-log 寫入失敗: {ex}", file=sys.stderr)
        return 2
    rc = cmd_set(env, rel, "signed_off", today)
    if rc != 0:
        print("⚠ ledger 已記但 frontmatter 戳記失敗(見上)", file=sys.stderr)
        return rc
    print(f"✓ signoff {rel} — {today}{('(' + by + ')') if by else ''}: {note[:60]}")
    return 0


def cmd_gov(env, node=None, since_days=90):
    """唯讀彙整六帳(bypass/rot-queue/governance/canary/kill/signoff)→ 治理事件時間軸。
    本機開發可見性工具(非合規物)。L2 無 node、L3 以 Verification 為鍵 → 對 Systems 為部分視圖。"""
    import json
    import datetime
    docs = env.vault.parent
    cutoff = (datetime.date.today() - datetime.timedelta(days=since_days)).isoformat()

    def stem(s):
        return Path(str(s)).stem.lower()

    rows = []

    def load(name, mapper):
        p = docs / name
        if not p.exists():
            return
        for line in p.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                rows.append(mapper(json.loads(line)))
            except (ValueError, KeyError):
                continue

    load(".bypass-log.jsonl", lambda d: {"ts": d.get("ts", ""), "commit": d.get("commit", ""),
         "gate": "L2", "kind": "bypassed", "hard": False, "nodes": [], "detail": d.get("subject", "")})
    load(".rot-queue.jsonl", lambda d: {"ts": d.get("ts", ""), "commit": d.get("commit", ""),
         "gate": "L3", "kind": "warned", "hard": False, "nodes": [stem(d.get("verification", ""))],
         "detail": d.get("reason", "")})
    load(".governance-log.jsonl", lambda d: {"ts": d.get("ts", ""), "commit": d.get("commit", ""),
         "gate": d.get("gate", "?"), "kind": d.get("kind", "?"), "hard": bool(d.get("hard")),
         "nodes": [stem(x) for x in d.get("nodes", [])], "detail": d.get("note", "")})
    # 第 6 源:業務簽核留痕(validation:人對業務正確性點頭的日期/人/內容)。
    load(".signoff-log.jsonl", lambda d: {"ts": d.get("ts", ""), "commit": d.get("commit", ""),
         "gate": "signoff", "kind": "signed", "hard": False,
         "token": d.get("ts", ""), "nodes": [stem(d.get("node", ""))],
         "detail": (d.get("by", "") + " " + d.get("note", "")).strip()})
    # 第 5 源:kill 殺傷力驗證留痕(guard kill 的 verdict 史)。
    load(".kill-log.jsonl", lambda d: {"ts": d.get("ts", ""), "commit": d.get("commit", ""),
         "gate": "kill", "kind": d.get("verdict", "?"), "hard": False,
         "token": d.get("invariant", "") + d.get("ts", ""),   # 同節點多合約/多次不互吞(dedup 第5鑑別子)
         "nodes": [stem(d.get("node", ""))],
         "detail": f"{d.get('invariant','')[:28]} [{d.get('test','')}] {d.get('note','')}".strip()})
    # 第 4 源:canary 審計留痕(審計員可靠度史)。只此 mapper 輸出 token 鍵(供 dedup 鑑別)。
    load(".canary-log.jsonl", lambda d: {"ts": d.get("ts", ""), "commit": "",
         "gate": "canary", "kind": d.get("kind", "?"), "hard": False, "nodes": [],
         "token": d.get("token", ""), "auditor": d.get("auditor") or "?",
         "detail": ((f"loop={d['loop']} sev={d.get('severity', '?')} · " if d.get("loop") else "")
                    + (d.get("auditor", "") + " " + d.get("note", "")).strip())})

    rows = [r for r in rows if (r["ts"][:10] or "9999") >= cutoff]
    seen, ded = set(), []
    for r in sorted(rows, key=lambda r: r["ts"]):
        # canary 每筆 token 唯一 → 加 token 當第 5 鑑別子(舊三源無此鍵,.get 回 "");必須用 .get 不可 r["token"]
        k = (r["commit"], frozenset(r["nodes"]), r["gate"], r["kind"], r.get("token", ""))
        if k in seen:
            continue
        seen.add(k)
        ded.append(r)
    if node:
        q = stem(node)
        ded = [r for r in ded if q in r["nodes"]]
    for r in ded:
        mark = "硬擋" if r["hard"] else "軟"
        print(f"{r['ts'][:10]} [{r['gate']}/{r['kind']}/{mark}] {','.join(r['nodes']) or '-'}  {r['detail'][:50]}")
    if node:
        print("\n(註:L2 繞過無 node、L3 以 Verification 為鍵;對 Systems 節點為部分視圖)")
    # canary missed 分帳(2026-07-10,borrow mutation 文獻:missed 類別要分類追蹤,
    # missed-rate 是一級指標非異常事件)。per-auditor 計數 + note 的 type=X best-effort 分佈。
    can = [r for r in ded if r["gate"] == "canary"]
    if can and not node:
        import re as _re
        by_aud = {}
        by_type = {}
        for r in can:
            aud = r.get("auditor", "?")  # record 原生欄位(終審 F2:解析 detail 字串在無 --auditor 時誤歸戶)
            st = by_aud.setdefault(aud, {"caught": 0, "missed": 0})
            st[r["kind"]] = st.get(r["kind"], 0) + 1
            m = _re.search(r"type=([\w-]+)", r["detail"])
            if m:
                tt = by_type.setdefault(m.group(1), {"caught": 0, "missed": 0})
                tt[r["kind"]] = tt.get(r["kind"], 0) + 1
        print("\ncanary 分帳(missed-rate 一級指標):")
        for aud, st in sorted(by_aud.items()):
            tot = st["caught"] + st["missed"]
            if tot:
                print(f"  {aud}: caught {st['caught']} / missed {st['missed']}"
                      f" (missed-rate {st['missed']/tot:.0%})")
        if by_type:
            print("  型別分佈: " + " | ".join(
                f"{k}:{v['caught']}c/{v['missed']}m" for k, v in sorted(by_type.items())))
    print(f"\n{len(ded)} 筆(近 {since_days} 天)")
    return 0


CLUSTER_STATES = ("resolved", "accepted-minor", "disputed-major")


def _parse_clusters(raw):
    """M2 risk-cluster 寫側解析:--clusters '名=狀態,...' → (dict{名:狀態}, None) 或 (None, 錯誤訊息)。
    三態白名單;accepted-minor 需冒號內嵌理由(整筆單一 note 對多 accepted-minor 無法對應=模糊過帳);
    尾逗號空段靜默過濾,但過濾後空列表=rc2(帶旗標即須有效內容,無「空字串=未帶」特例);
    設計:Projects/design-loop提效_計劃 M2(golden: governance/golden/dloop-m2-cluster)。"""
    parts = [p.strip() for p in str(raw).split(",") if p.strip()]
    if not parts:
        return None, "帶了 --clusters 但無有效內容(空字串/全逗號)"
    out = {}
    for p in parts:
        if "=" not in p:
            return None, f"段缺 '='(格式 名=狀態): {p!r}"
        name, state = p.split("=", 1)
        name, state = name.strip(), state.strip()
        if not re.fullmatch(r"[a-z0-9][a-z0-9_-]{0,63}", name):
            return None, f"cluster 名非法(kebab 短 slug:小寫英數起頭+[-_],≤64): {name!r}"
        base = state.split(":", 1)[0]
        if base not in CLUSTER_STATES:
            return None, f"狀態 {base!r} 不在白名單 {'/'.join(CLUSTER_STATES)}"
        if base == "accepted-minor":
            if ":" not in state or not state.split(":", 1)[1].strip():
                return None, f"accepted-minor 需逐 cluster 內嵌理由(accepted-minor:理由): {p!r}"
        elif state != base:
            # resolved/disputed-major 必須精確相等——夾帶冒號後綴=未定義第四態(帳面破三態白名單)
            return None, f"狀態 {state!r} 夾帶後綴(僅 accepted-minor 可帶冒號理由)"
        if name in out:
            return None, f"同輪同名 cluster 重複: {name!r}"
        out[name] = state
    return out, None


def cmd_canary(env, kind, auditor=None, token=None, note=None, loop=None, severity=None, findings=None, round_id=None, capture_counts=None, clusters=None):
    """記一筆 canary 審計留痕(test-the-tester):某輪對抗審計有沒有抓到植入瑕疵。
    record-only、本機;漏抓(missed)= 該輪審計員放水的訊號,經 lumos gov 可查詢。
    --loop/--severity:把這輪歸進某設計 loop(供 lumos loop status 算收斂)。
    --clusters(M2):該輪 risk-cluster 三態帳(每輪至多一筆帶;讀側 loop status --panel 消費)。
    天花板:這只證明「審計員有沒有醒著讀」,不證明它抓到所有真問題(見設計 doc)。"""
    import json
    import datetime
    import secrets
    if not token:
        token = "CANARY-" + secrets.token_hex(4)   # 隨機,非時間戳(同秒不撞)
    rec = {"ts": datetime.datetime.now().astimezone().isoformat(timespec="seconds"),
           "kind": kind, "auditor": auditor or "", "token": token, "note": note or ""}
    if loop:
        rec["loop"] = loop
    if round_id:
        rec["round"] = round_id   # panel 一輪 W 筆共享 round-id(loop status --panel 分組)
    if capture_counts:
        try:
            rec["capture_counts"] = [int(x) for x in str(capture_counts).split(",") if x.strip()]
        except ValueError:
            print(f"ERROR: --capture-counts 需逗號分隔整數,收到 {capture_counts!r}", file=sys.stderr)
            return 2
    if severity:
        rec["severity"] = severity
    if findings is not None:
        rec["findings"] = findings
    if clusters is not None:   # 空字串也進解析器 → rc2(帶旗標即須有效內容,勿被 falsy 吞)
        parsed, err = _parse_clusters(clusters)
        if err:
            print(f"ERROR: --clusters {err}", file=sys.stderr)
            return 2
        rec["clusters"] = parsed   # dict{名:狀態},同 capture_counts 寫側轉型慣例
    path = env.vault.parent / ".canary-log.jsonl"
    try:
        with open(path, "a", encoding="utf-8") as f:
            f.write(json.dumps(rec, ensure_ascii=False) + "\n")
    except OSError as e:
        print(f"ERROR: 寫入 {path} 失敗: {e}", file=sys.stderr)
        return 2
    print(f"✓ canary {kind} 留痕: {token}" + (f" (auditor={auditor})" if auditor else ""))
    return 0


def _capture_counts_from_finders(finders):
    """異質 panel 接線(code-loop 三輪壓縮):把多個 finder 各自找到的 finding-key
    彙成 capture-recapture 輸入。code-loop 的 finder 是**異質**的——LLM reviewer、
    `.lumos/lint.json` SARIF linter、測試失敗、mutation 存活——各是一組 finding-key;
    確定性工具的錯誤剖面與 LLM 正交=真獨立票(直擊「9 judge 2 票」相關性天花板)。

    參數:finders = [[key,...], [key,...], ...],每個子 list = 一個 finder 找到的 key。
    回傳:各 distinct key「被幾個 finder 找到」的次數列表(降序,決定性)——
    直接餵 _estimate_remaining_defects 算殘餘。
    正規化:key strip+casefold(容忍大小寫/前後空白差異);同一 finder 內去重(重複只算一次)。"""
    from collections import Counter
    counter = Counter()
    for finder in finders:
        seen = set()
        for k in finder:
            nk = str(k).strip().casefold()
            if nk and nk not in seen:
                seen.add(nk)
                counter[nk] += 1
    return sorted(counter.values(), reverse=True)


def _estimate_remaining_defects(capture_counts):
    """capture-recapture 殘餘缺陷估計(Chao1 偏差修正版)。

    平行 panel 的收斂結構信號(loop 三輪壓縮):W 個獨立審計員讀同稿,
    `capture_counts` = 各 distinct 缺陷「被幾個審計員找到」的次數列表。
    從「只被 1 人找到(f1)」與「恰被 2 人找到(f2)」的比例估未找到的殘餘缺陷:
        remaining ≈ f1*(f1-1) / (2*(f2+1))   # 偏差修正,f2=0 不 div0
    高重疊(f1 小)→ 母體枯竭 → 殘餘≈0 → 收斂;低重疊(f1 大)→ 殘餘大 → 續跑。
    誠實天花板:小樣本估計會出極端值,當一個收斂信號、非 oracle(見設計節點)。"""
    if not capture_counts:
        return 0.0
    f1 = sum(1 for c in capture_counts if c == 1)
    f2 = sum(1 for c in capture_counts if c == 2)
    return f1 * (f1 - 1) / (2 * (f2 + 1))


def _round_valid_m2(recs):
    """M2 統一單位謂詞(有效輪):caught≥2 ∧ missed=0 ∧ 全部 kind ∈ {caught,missed}。
    gate/fold/定錨/ledger/W 歸屬五處共用——嚴禁記錄級判定(2caught+1missed 輪的
    clusters 掛 caught 記錄上也不得採納);未知 kind 使輪無效(既有 2303 謂詞對此是盲的)。"""
    kinds = [r.get("kind") for r in recs]
    if any(k not in ("caught", "missed") for k in kinds):
        return False
    return kinds.count("caught") >= 2 and kinds.count("missed") == 0


def _loop_status_panel(rounds, loop_id):
    """平行 panel 收斂謂詞(loop 三輪壓縮)。無-cluster 舊帳:三條合取(輪有效∧存活max≤minor
    ∧capture-recapture 殘餘,fail-closed)。cluster 帳(M2,設計 Projects/design-loop提效_計劃;
    golden: governance/golden/dloop-m2-cluster):首個有效輪帶 clusters 定錨 → 兩條合取
    (輪有效∧fold 後無 disputed-major),新生 cluster/capture-recapture 降 advisory,
    無效輪 clusters 忽略+警告區列帳(不蒸發)。讀側 rc2 類:round-id 非連續/型別損壞/
    有效輪 W 歸屬衝突/有效輪級混用。"""
    from collections import OrderedDict
    groups = OrderedDict()
    for r in rounds:
        rid_ = r.get("round")
        if rid_ in groups and next(reversed(groups)) != rid_:
            # M2:round-id 被其他 round 隔開後重現=帳本次序損壞(append-only 不容跳寫)
            print(f"ERROR: round-id {rid_!r} 非連續重現(被其他輪隔開;append-only 帳次序損壞)",
                  file=sys.stderr)
            return 2
        groups.setdefault(rid_, []).append(r)
    if not groups:
        print(f"⏳ 無 panel 輪記錄 ({loop_id})")
        return 1
    # ── M2 讀側型別防禦:clusters 欄必須是 dict[str,str](寫側轉型慣例;手改/損壞 → rc2 非 traceback)
    for r in rounds:
        if "clusters" in r:
            c = r["clusters"]
            if (not isinstance(c, dict)
                    or any(not isinstance(k, str) or not isinstance(v, str) for k, v in c.items())):
                print(f"ERROR: 記錄 clusters 欄非 dict{{名:狀態}} 結構(損壞/手改 JSONL?): {c!r}",
                      file=sys.stderr)
                return 2
    valid_of = {rid_: _round_valid_m2(recs) for rid_, recs in groups.items()}
    # ── M2 W 歸屬:有效輪同輪 >1 筆帶 clusters → rc2(無效輪多筆帶=豁免,列警告區)
    for rid_, recs in groups.items():
        if valid_of[rid_] and sum(1 for r in recs if "clusters" in r) > 1:
            print(f"ERROR: 輪 {rid_} 有 {sum(1 for r in recs if 'clusters' in r)} 筆記錄帶 clusters"
                  f"(每輪至多一筆;衝突不靜默取第一筆)", file=sys.stderr)
            return 2
    # ── M2 定錨:第一個有效輪定模式(無效輪不定錨——首輪全 missed 的新 loop 不得鎖死)
    anchor_rid, anchor_cluster = None, False
    for rid_, recs in groups.items():
        if valid_of[rid_]:
            anchor_rid = rid_
            anchor_cluster = any("clusters" in r for r in recs)
            break
    if anchor_rid is not None:
        # 有效輪級混用守衛(無效輪豁免:帶或不帶皆不觸發)
        for rid_, recs in groups.items():
            if not valid_of[rid_]:
                continue
            has_c = any("clusters" in r for r in recs)
            if anchor_cluster and not has_c:
                print(f"ERROR: 本 loop 已定錨 cluster 帳(定錨輪 {anchor_rid}),有效輪 {rid_} 未帶"
                      f" clusters(半帶);補該輪 cluster 記錄或開新 loop id", file=sys.stderr)
                return 2
            if not anchor_cluster and has_c:
                print(f"ERROR: 本 loop 已定錨無-cluster 模式(定錨輪 {anchor_rid}),有效輪 {rid_} 帶了"
                      f" clusters;要用 cluster 帳請開新 loop id(不升級既有 loop)", file=sys.stderr)
                return 2
    if anchor_rid is not None and anchor_cluster:
        return _loop_status_panel_clusters(groups, valid_of, loop_id)
    # ── 無-cluster 舊帳(或零有效輪=未定錨):既有三條合取,fail-closed 不變 ──
    # cluster-intent 但未定錨(零有效輪):條 1 改用 M2 嚴格謂詞(unknown-kind 盲區補;
    # 純無-cluster loop 不受影響——舊行為迴歸保證只對真 legacy 帳)
    _cluster_intent = any("clusters" in r for r in rounds)
    rid, latest = next(reversed(groups.items()))
    if _cluster_intent and not valid_of[rid]:
        print(f"[panel] 輪有效: ✗ — cluster-intent loop 判定輪 {rid} 無效(M2 謂詞:caught≥2∧missed=0∧kind 白名單)")
        for i, r in enumerate(latest, 1):
            print(f"  {rid}.{i}\t{r.get('kind','?')}\t{r.get('severity','-')}\t{r.get('auditor','')}")
        print(f"⛔ PANEL GATE FAIL ({loop_id} 輪 {rid}: 輪無效[未定錨 cluster-intent])")
        return 1
    order = {"clean": 0, "minor": 1, "major": 2, "blocker": 3}
    fails = []
    caught_recs = [r for r in latest if r.get("kind") == "caught"]
    caught = len(caught_recs)
    missed = sum(1 for r in latest if r.get("kind") == "missed")
    # near-perfect(2026-07-10,borrow mutation score 文獻:只有近滿分 caught-rate 才有強訊號,
    # 中段分數與真實審計力相關弱)→ 輪有效 = caught≥2 且該輪 0 missed(全 caught)
    if caught >= 2 and missed == 0:
        print(f"[panel] 輪有效(canary caught {caught}/{caught},near-perfect): ✓")
    elif missed > 0:
        print(f"[panel] 輪有效: ✗ — {missed} missed(near-perfect 要求全 caught;中段分數弱訊號不背書收斂)")
        fails.append("輪無效")
    else:
        print(f"[panel] 輪有效: ✗ — canary caught {caught} <2(輪無效)")
        fails.append("輪無效")
    # maxsev 只算 caught(醒著)審計員——missed 者 findings 已剔除(設計 §判定;review M1)
    maxsev = max((order.get(r.get("severity", "clean"), 1) for r in caught_recs), default=0)
    if maxsev >= 2:
        print(f"[panel] falsification+ODC(存活 max≤minor): ✗ — 存活 {'blocker' if maxsev==3 else 'major'}")
        fails.append("存活≥major")
    else:
        print("[panel] falsification+ODC(存活 max≤minor): ✓")
    cc = next((r["capture_counts"] for r in latest if r.get("capture_counts")), None)
    if cc is None:
        # fail-closed(review C1):panel 的收斂本體就是 capture-recapture 結構信號,
        # 沒 capture_counts 就無從證母體枯竭 → 不當「跳過」,當「未枯竭」擋。
        # 否則不寫 counts 即繞過殘餘檢查、退回舊「2 caught+無 major」弱信號。
        print("[panel] capture-recapture 殘餘: ✗ — 無 capture_counts(母體未證枯竭;panel 模式必帶)")
        fails.append("無capture_counts")
    else:
        remaining = _estimate_remaining_defects(cc)
        THRESH = 1.0
        if remaining < THRESH:
            print(f"[panel] capture-recapture 殘餘: ✓ — 估計 {remaining:.2f} < {THRESH}")
        else:
            print(f"[panel] capture-recapture 殘餘: ✗ — 估計 {remaining:.2f} ≥ {THRESH}(母體未枯竭)")
            fails.append("殘餘超門檻")
    for i, r in enumerate(latest, 1):
        print(f"  {rid}.{i}\t{r.get('kind','?')}\t{r.get('severity','-')}\t{r.get('capture_counts','-')}\t{r.get('auditor','')}")
    if fails:
        print(f"⛔ PANEL GATE FAIL ({loop_id} 輪 {rid}: {'/'.join(fails)})")
        return 1
    print(f"✅ PANEL GATE PASS ({loop_id} 輪 {rid}: 輪有效 ∧ 存活≤minor ∧ capture-recapture 枯竭)")
    return 0


def _loop_status_panel_clusters(groups, valid_of, loop_id):
    """M2 cluster 帳 gate:兩條合取(判定輪有效 ∧ fold 後無 disputed-major)。
    fold 只採有效輪(last-wins,同名跨輪最後狀態勝);無效輪 clusters 警告區列帳不蒸發;
    新生 cluster 與 capture-recapture 皆 advisory 不進合取。"""
    order = {"clean": 0, "minor": 1, "major": 2, "blocker": 3}
    rid, latest = next(reversed(groups.items()))
    fails = []
    # 條 1:判定輪(latest)有效——同一謂詞
    caught_recs = [r for r in latest if r.get("kind") == "caught"]
    n_caught, n_missed = len(caught_recs), sum(1 for r in latest if r.get("kind") == "missed")
    if valid_of[rid]:
        print(f"[panel/cluster] 條1 輪有效(caught {n_caught}≥2,0 missed): ✓")
    else:
        print(f"[panel/cluster] 條1 輪有效: ✗ — caught {n_caught}/missed {n_missed}"
              f"(謂詞:caught≥2∧missed=0∧kind 全白名單)")
        fails.append("輪無效")
    # fold(僅有效輪,append 序 last-wins)+ ledger(首現/末更輪僅計有效輪,與 advisory 同源)
    from collections import OrderedDict as _OD
    ledger = _OD()
    for rid_, recs in groups.items():
        if not valid_of[rid_]:
            continue
        for r in recs:
            for name, state in (r.get("clusters") or {}).items():
                if name not in ledger:
                    ledger[name] = {"state": state, "first": rid_, "last": rid_}
                else:
                    ledger[name]["state"] = state
                    ledger[name]["last"] = rid_
    disputed = [n for n, e in ledger.items() if e["state"].split(":", 1)[0] == "disputed-major"]
    if disputed:
        print(f"[panel/cluster] 條2 fold 後無 disputed-major: ✗ — {len(disputed)} 個: {','.join(disputed)}")
        fails.append("存在disputed-major")
    else:
        print("[panel/cluster] 條2 fold 後無 disputed-major: ✓")
    # advisory:新生 cluster(僅基於有效輪;判定輪無效 → 不適用)
    if valid_of[rid]:
        born = [n for n, e in ledger.items() if e["first"] == rid]
        print(f"[panel/cluster] (advisory) 新生 cluster: {len(born)} 個"
              + (f": {','.join(born)}" if born else ""))
    else:
        print("[panel/cluster] (advisory) 新生 cluster: 判定輪無效,新生統計不適用")
    # advisory:capture-recapture(照算照印,不進合取;無 counts 不 fail-closed——cluster 帳接手守門)
    cc = next((r["capture_counts"] for r in latest if r.get("capture_counts")), None)
    if cc is not None:
        remaining = _estimate_remaining_defects(cc)
        print(f"[panel/cluster] (advisory) capture-recapture 殘餘估計: {remaining:.2f}(不進合取)")
    else:
        print("[panel/cluster] (advisory) capture-recapture: 無 counts(advisory,不擋)")
    # 警告區:無效輪攜帶的 clusters(已忽略;資料本在 canary-log,顯示即留痕——status 唯讀)
    for rid_, recs in groups.items():
        if valid_of[rid_]:
            continue
        carried = []   # 全列:同名多筆逐條保留(dict.update 會靜默覆蓋掩掉爭議狀態)
        for r in recs:
            carried.extend((n, s) for n, s in (r.get("clusters") or {}).items())
        if carried:
            print(f"  ⚠ {rid_}(無效輪) clusters 已忽略: "
                  + ",".join(f"{n}={s}" for n, s in carried))
    # ledger 表
    if ledger:
        print("  ── cluster ledger(僅計有效輪)──")
        for n, e in ledger.items():
            print(f"  {n}\t{e['state']}\t首現 {e['first']}\t末更 {e['last']}")
    for i, r in enumerate(latest, 1):
        print(f"  {rid}.{i}\t{r.get('kind','?')}\t{r.get('severity','-')}\t{r.get('auditor','')}")
    if fails:
        print(f"⛔ PANEL GATE FAIL ({loop_id} 輪 {rid}: {'/'.join(fails)})")
        return 1
    print(f"✅ PANEL GATE PASS ({loop_id} 輪 {rid}: 輪有效 ∧ fold 後無 disputed-major"
          f"[cluster 帳,{len(ledger)} 個 cluster])")
    return 0


def cmd_loop_capture_counts(env, finders, from_pitfalls=None, repo=None):
    """異質 panel 接線的機械生產者(code-loop 三輪壓縮):把各 finder 的 finding-key
    彙成 capture_counts + 算殘餘估計,吐出可直接餵 `canary record --capture-counts` 的逗號串。

    為什麼要機械算:重疊計數(哪個洞被幾個 finder 找到)是 capture-recapture 的核心輸入,
    人手數易錯——正是該機械化的。異質 finder 一律先正規化 key 再跨 finder 數重疊:
    LLM reviewer 的 finding、`pitfalls --diff` 的 SARIF linter 命中、測試失敗、mutation 存活,
    每個 finder 給一個 --finder(逗號分隔它找到的 key,如 file:line 或 section:nature)。
    確定性工具與 LLM 錯誤剖面正交 → 真獨立票,重疊(同洞多 finder 中)= 更強收斂信號。

    --from-pitfalls <range>:自動收割 `pitfalls --diff` 的命中成確定性 finder(免手貼)——
    按 source 分組(每個 linter driver / pitfalls 內建各自一個 finder,錯誤剖面互不相同),
    每個 finder = 該 source 命中的 `file:line` 集合,併進手動 --finder 一起算重疊。
    這關掉「手動把 linter 命中貼成 --finder」那半破口。

    finders = [comma_str, ...](每個 --finder 一項)。空/全空 → 印 0 缺陷、殘餘 0.0。"""
    parsed = [[k for k in str(fs).split(",") if k.strip()] for fs in (finders or [])]
    harvested = []
    if from_pitfalls:
        repo_root = _anchor_repo_root(repo)
        if repo_root is None:
            return 2
        data = _pitfall_diff_collect(from_pitfalls, repo_root, no_lint=False)
        if data is None:
            return 2                              # git 錯誤(壞 range 等),collect 已印
        from collections import OrderedDict
        by_source = OrderedDict()
        for c in data.get("claims", []):
            src = c.get("source") or "pitfalls-builtin"
            by_source.setdefault(src, []).append(f"{c['file']}:{c['line']}")
        for src, keys in by_source.items():
            harvested.append((src, keys))
            parsed.append(keys)
        for src, keys in harvested:
            print(f"收割 from-pitfalls finder [{src}]: {len(keys)} 命中")
    cc = _capture_counts_from_finders(parsed)
    remaining = _estimate_remaining_defects(cc)
    n_finders = len(parsed)
    n_distinct = len(cc)
    print(f"finders={n_finders} distinct-findings={n_distinct} "
          f"capture_counts={','.join(str(c) for c in cc) if cc else '(空)'}")
    print(f"remaining-estimate={remaining:.2f}  "
          f"({'枯竭 <1.0 → 收斂側' if remaining < 1.0 else '殘餘 ≥1.0 → 續跑側'})")
    if cc:
        print(f"→ canary record ... --capture-counts {','.join(str(c) for c in cc)}")
    return 0


def cmd_loop_status(env, loop_id, need=2, gate=False, spec=None, repo=None, panel=False):
    """算某設計 loop 的收斂(收斂留痕):連 K 輪『canary caught 且 severity∈{clean,minor}』。
    --gate:升級為證據閘(K-streak 為必要條件,合取 G1 refcheck 引用座標 + G2 發現枯竭);
    findings 數的源頭仍是 LLM 裁決——gate 機械化的是算術,不是數字的正確性(見設計 doc)。
    讀 .canary-log.jsonl 的 **append 序**(不 ts-sort:ts 只到秒、同秒會並列),篩 loop==id。
    tail-K 滑動窗:前面髒輪不影響、只看最後 K 筆;missed/缺 severity 視同未收斂。
    exit 0=CONVERGED / 1=未收斂(含無記錄=還沒開始)/ 2=真錯誤。
    天花板:收斂=連 K 輪醒著的審計員沒找到 blocker/major,非完整正確;severity 自報(見設計 doc)。"""
    import json
    need = max(1, need)
    path = env.vault.parent / ".canary-log.jsonl"
    rounds = []
    try:
        if path.exists():
            for line in path.read_text(encoding="utf-8").splitlines():
                line = line.strip()
                if not line:
                    continue
                try:
                    d = json.loads(line)
                except ValueError:
                    continue
                if d.get("loop") == loop_id:
                    rounds.append(d)
    except OSError as e:
        print(f"ERROR: 讀 {path} 失敗: {e}", file=sys.stderr)
        return 2

    # 混用守衛(R2-F1 footgun):panel 記錄(有 round 欄)與 legacy 模式不可混用。
    # 用 all/any 而非單向 any:partial-mix(部分有 round、部分沒)也擋——否則 round-less
    # 記錄在 panel 模式會形成 None phantom 組、可能成「最新輪」偽過(review I1)。
    n_round = sum(1 for r in rounds if "round" in r)
    if panel and rounds and n_round != len(rounds):
        print("ERROR: --panel 要求本 loop 記錄全帶 round 欄(混用/legacy 記錄拒讀,防 None phantom 輪)",
              file=sys.stderr)
        return 2
    if not panel and n_round > 0:
        print("ERROR: canary-log 含 round 欄(panel 記錄)卻未加 --panel——拒絕靜默把一輪 W 筆當 W 輪",
              file=sys.stderr)
        return 2
    if panel:
        return _loop_status_panel(rounds, loop_id)

    def good(r):
        return r.get("kind") == "caught" and r.get("severity") in ("clean", "minor")

    converged = len(rounds) >= need and all(good(r) for r in rounds[-need:])
    streak = 0                                  # 從尾往回的連續合格數(算「還需 N」)
    for r in reversed(rounds):
        if good(r):
            streak += 1
        else:
            break
    if not gate:
        if converged:
            print(f"✅ CONVERGED ({loop_id}, 連 {need} 輪 caught+乾淨;共 {len(rounds)} 輪)")
            rc = 0
        else:
            print(f"⏳ 還需 {need - streak} 輪乾淨 ({loop_id}, 已 {len(rounds)} 輪)")
            rc = 1
        for i, r in enumerate(rounds, 1):       # 留痕:每輪一行 tab 分隔
            print(f"{i}\t{r.get('kind', '?')}\t{r.get('severity', '-')}\t{r.get('ts', '')}\t{r.get('note', '')}")
        return rc

    # ── 證據閘(--gate):K-streak(必要)∧ G1 refcheck(--spec 可選)∧ G2 發現枯竭 ──
    repo_root = _anchor_repo_root(repo)
    if repo_root is None:
        return 2
    fails = []
    if converged:
        print(f"[gate] K-streak(--need {need}): ✓")
    else:
        print(f"[gate] K-streak(--need {need}): ✗ — 還需 {need - streak} 輪 caught+乾淨(已 {len(rounds)} 輪)")
        fails.append("K-streak")
    if spec is None:
        print("[gate] G1 refcheck(引用座標): skipped(無 spec 對象,code-loop 情境)")
    else:
        try:
            text = Path(spec).read_text(encoding="utf-8-sig")
        except OSError as e:
            print(f"ERROR: 讀不到 --spec {spec}: {e}", file=sys.stderr)
            return 2
        claims, n_missing, n_oor, _n_ok = _refcheck_scan(text, repo_root)
        bad = [c for c in claims if c["status"] in ("missing", "line_out_of_range")]
        if bad:
            print(f"[gate] G1 refcheck(引用座標): ✗ — {len(bad)} 條壞宣稱")
            for c in bad:
                loc = f"{c['token']}:{c['line']}" if c["line"] else c["token"]
                print(f"    {loc}({c['status']})")
            fails.append("G1")
        else:
            print(f"[gate] G1 refcheck(引用座標): ✓ — {len(claims)} 條宣稱全 ok")
    tail = rounds[-need:]
    fs = [r.get("findings") for r in tail]
    g2_fail = ""
    if len(tail) < need:
        g2_fail = f"紀錄不足 {need} 輪"
    elif any(f is None for f in fs):
        g2_fail = "tail-K 有輪缺 findings 欄位(fail-closed:用 canary record --findings N 記錄)"
    else:
        for r in tail:
            sev, f = r.get("severity"), r.get("findings")
            if (sev == "clean" and f != 0) or (sev == "minor" and f < 1):
                g2_fail = f"欄位互證矛盾:severity={sev} 與 findings={f} 不相容"
                break
        if not g2_fail:
            if need == 1:
                drained = fs[-1] == 0
            else:
                mono = all(fs[i] >= fs[i + 1] for i in range(len(fs) - 1))
                drained = mono and fs[-1] <= 1 and (fs[-1] == 0 or fs[-1] < fs[-2])
            if not drained:
                g2_fail = f"findings={fs} 未枯竭(需單調不增、末輪 ≤1 且末輪=0 或末步嚴格下降)"
    if g2_fail:
        print(f"[gate] G2 發現枯竭: ✗ — {g2_fail}")
        fails.append("G2")
    else:
        print(f"[gate] G2 發現枯竭: ✓ — findings={fs}")
    for i, r in enumerate(rounds, 1):
        print(f"{i}\t{r.get('kind', '?')}\t{r.get('severity', '-')}\t{r.get('findings', '-')}\t{r.get('ts', '')}\t{r.get('note', '')}")
    if fails:
        print(f"⛔ GATE FAIL ({loop_id}: {'/'.join(fails)})")
        return 1
    print(f"✅ GATE PASS ({loop_id}: K-streak ∧ G1 ∧ G2)")
    return 0


# ───────────── guard: 合約守衛 scaffold(對談驅動)─────────────
# lumos 只做機械活:① 列出 ★INVARIANT★ 綁定狀態 ② 套範本產 stub(預設紅燈) ③ 把 [test:] 綁回 KEY 行(自驗)。
# 「斷言本體」由 Claude 經對談向人確認意圖後填 — claim 的真來自人確認,不來自 code 反推
# (反推=套套邏輯=Check T 在打的偽證據)。範本是技術棧專屬、放專案 .lumos/guard-templates/<type>.tmpl,
# lumos 本體維持語言無關。
GUARD_TYPES = ("pure", "behavioral", "state")
GUARD_ICON = {"real": "✅ 已綁真方法", "dangling": "❌ 懸空(找不到方法)",
              "fake": "⚠ 偽證據(非測試方法)", "naked": "❌ 裸合約(未綁)"}


def _repo_root_from_env(env):
    for p in env.vault.parents:
        if p.name == "docs":
            return p.parent
    return env.vault.parent  # standalone vault root


def _platform_test_index(repo_root):
    """依 .lumos/config 建「平台 → (method set, code haystack)」的惰性索引 + 解析參數。
    多平台 discover 呼叫點(Check T / classify_invariants / cmd_archive)共用,避免各自重寫平台迴圈。
    回 (split, default, methods_for, hay_for):
    - split = multiplatform 時的 platforms dict、legacy 時 {}(→ resolve_test_refs 不切分);
    - default = default_platform;
    - methods_for(plat)/hay_for(plat) = 惰性(一次 CLI 內快取)取該平台 root+profile 的測試方法集/haystack
      (haystack 也跨 repo,修 r4:fake vs dangling 訊息品質)。"""
    pdata = load_platforms(repo_root)
    split = pdata["platforms"] if pdata["multiplatform"] else {}
    default = pdata["default_platform"]
    mcache, hcache = {}, {}

    def methods_for(plat):
        if plat not in mcache:
            p = pdata["platforms"].get(plat)
            mcache[plat] = discover_test_methods(p["root"], p["profile"]) if p else set()
        return mcache[plat]

    def hay_for(plat):
        if plat not in hcache:
            p = pdata["platforms"].get(plat)
            hcache[plat] = build_code_haystack(p["root"]) if p else ""
        return hcache[plat]

    return pdata, split, default, methods_for, hay_for


def _classify_one(x, split, default, methods_for, hay_for):
    """單條 ★INVARIANT★ 的綁定狀態:naked/real/fake/dangling(多平台:每 ref 對其平台判、取最壞)。
    未定義平台前綴(resolve 報 ValueError)→ dangling(guard list 不 crash;doctor Check T 另明確報)。"""
    _, refs = strip_test_refs(x)
    if not refs:
        return "naked"
    try:
        resolved = resolve_test_refs(x, split, default)
    except ValueError:
        return "dangling"
    sts = []
    for plat, name in resolved:
        if name in methods_for(plat):
            sts.append("real")
        elif name in hay_for(plat):
            sts.append("fake")
        else:
            sts.append("dangling")
    return "dangling" if "dangling" in sts else ("fake" if "fake" in sts else "real")


def classify_invariants(env):
    """每條 ★INVARIANT★ 的綁定狀態:real / dangling / fake / naked(多平台感知)。"""
    repo_root = _repo_root_from_env(env)
    _, split, default, methods_for, hay_for = _platform_test_index(repo_root)
    rows = []
    for rel in sorted(env.notes):
        inv, _ = extract_contracts(env.notes[rel])
        for x in inv:
            clean, refs = strip_test_refs(x)
            status = _classify_one(x, split, default, methods_for, hay_for)
            rows.append({"node": rel, "text": clean, "refs": refs, "status": status,
                         "audited": bool(invariant_audit_refs(x)),
                         "audit": invariant_audit_refs(x),
                         "has_kill": bool(KILL_REF_RE.search(x))})   # 從原始行判(clean 已剝)
    return rows


def cmd_guard_list(env, unbound_only=False):
    rows = classify_invariants(env)
    shown = 0
    for r in rows:
        if unbound_only and r["status"] == "real":
            continue
        shown += 1
        print(f"{GUARD_ICON[r['status']]}  {r['node']}")
        print(f"    {r['text'][:96]}")
        tag = f"[test:{','.join(r['refs'])}]" if r["refs"] else "(未綁)"
        tag += f"  [audit:{','.join(r['audit'])}]" if r["audited"] else ("  ⚠ 未審" if r["refs"] else "")
        if r.get("has_kill"):
            tag += "  [kill✓]"
        print(f"    {tag}")
    from collections import Counter
    c = Counter(r["status"] for r in rows)
    unaudited = sum(1 for r in rows if r["refs"] and not r["audited"])
    print(f"\n合約 {len(rows)} 條 — 真綁 {c['real']} / 懸空 {c['dangling']} / "
          f"偽證據 {c['fake']} / 裸 {c['naked']} / 未審 {unaudited}")
    if unbound_only and shown == 0:
        print("✓ 沒有未綁合約(全綁真方法)")
    return 0


IDENT_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")


def _detect_test_dir(repo_root, gtype, profile=None):
    """偵測測試專案目錄。由 profile 決定:
    suffix 模式(C#)= 頂層目錄 endswith(pure 排除 IntegrationTests);
    rglob 模式(Kotlin/Android)= 遞迴找目錄名(巢狀 src/test、多 module)。
    多候選印警告取第一個(避免靜默寫錯)。找不到回 None → scaffold 要求 --out。"""
    profile = profile or load_test_profile(repo_root)
    inc, exc = profile["dirs"].get(gtype, ([], []))
    if profile["dir_mode"] == "suffix":
        hit = [d for d in sorted(repo_root.iterdir())
               if d.is_dir() and any(d.name.endswith(p) for p in inc)
               and not any(d.name.endswith(e) for e in exc)]
    else:  # rglob:遞迴找目錄名(取第一個 include pattern 有命中者)
        under = profile.get("rglob_under")
        hit = []
        for p in inc:
            found = sorted(d for d in repo_root.rglob(p)
                           if d.is_dir() and not (set(d.parts) & CODE_SKIP_DIRS)
                           and (under is None or under in d.parts))  # F6:限 src/ 下
            if found:
                hit = found
                break
    if not hit:
        return None
    if len(hit) > 1:
        names = [str(d.relative_to(repo_root)) for d in hit]
        print(f"⚠ 偵測到多個測試目錄 {names},取 {names[0]};要寫別處用 --out 指定",
              file=sys.stderr)
    return hit[0]


def _tautology_warn(claim, clean):
    """claim 高度重述 invariant = 套套邏輯嫌疑(防帶風向)。字元三連袋 Jaccard,中英都適用。"""
    def trigrams(s):
        s = re.sub(r"\s+", "", s)
        return {s[i:i+3] for i in range(max(0, len(s) - 2))}
    a, b = trigrams(claim), trigrams(clean)
    if not a or not b:
        return
    jac = len(a & b) / len(a | b)
    norm_claim = re.sub(r"\s+", "", claim)
    norm_clean = re.sub(r"\s+", "", clean)
    if norm_claim and (norm_claim in norm_clean or norm_clean in norm_claim or jac >= 0.85):
        print("⚠ claim 與 invariant 文字高度雷同(套套邏輯嫌疑)。claim 應是『向人確認過、"
              "可驗的具體斷言』,不是重述合約本身——確認它來自意圖而非 code/合約 reword。",
              file=sys.stderr)


def cmd_guard_scaffold(env, node, invariant_substr, method, gtype, claim,
                       out_dir=None, template=None, klass=None, platform=None):
    if gtype not in GUARD_TYPES:
        print(f"ERROR: --type 須為 {'|'.join(GUARD_TYPES)}(收到 {gtype})", file=sys.stderr)
        return 2
    if not IDENT_RE.match(method):
        print(f"ERROR: --method『{method}』非合法識別字(只允許字母/數字/底線,不可數字開頭)。"
              f"\n  (Kotlin 反引號測試名含空白 → CLI 不支援,請手動編輯 .md 的 [test:] 與測試檔)",
              file=sys.stderr)
        return 2
    if klass is not None and not IDENT_RE.match(klass):
        print(f"ERROR: --class『{klass}』非合法識別字", file=sys.stderr)
        return 2
    rel = env.find(node)
    if rel is None:
        print(f"ERROR: 找不到節點 {node}", file=sys.stderr)
        return 2
    inv, _ = extract_contracts(env.notes[rel])
    # 比對 invariant 語義本體(去掉 [test:..] 後綴),避免子字串誤命中既有測試名
    matched = [x for x in inv if invariant_substr in strip_test_refs(x)[0]]
    if not matched:
        print(f"ERROR: {rel} 沒有含『{invariant_substr}』的 ★INVARIANT★(已排除 [test:] 後綴)",
              file=sys.stderr)
        return 2
    if len(matched) > 1:
        print(f"ERROR: 『{invariant_substr}』命中 {len(matched)} 條,請給更精確子字串", file=sys.stderr)
        return 2
    clean, _ = strip_test_refs(matched[0])
    _tautology_warn(claim, clean)
    repo_root = _repo_root_from_env(env)
    # 多平台:依 --platform 選 root+profile(範本落點/scaffold_ext/測試目錄偵測都跟平台走)。
    try:
        pdata = load_platforms(repo_root)
    except ValueError as ex:
        print(f"ERROR: config platforms 設定錯誤: {ex}", file=sys.stderr)
        return 2
    if platform is None:
        if len(pdata["platforms"]) == 1:
            platform = next(iter(pdata["platforms"]))
        else:
            print(f"ERROR: 多平台 config 有 {len(pdata['platforms'])} 個平台,scaffold 請用 --platform 指定"
                  f"(可選: {', '.join(pdata['platforms'])})", file=sys.stderr)
            return 2
    elif platform not in pdata["platforms"]:
        print(f"ERROR: --platform '{platform}' 不在 config platforms({', '.join(pdata['platforms'])})",
              file=sys.stderr)
        return 2
    pentry = pdata["platforms"][platform]
    platform_root, profile = pentry["root"], pentry["profile"]
    tpl_path = Path(template) if template else \
        (platform_root / ".lumos" / "guard-templates" / f"{gtype}.tmpl")   # 範本走該平台 root(審計 r4)
    if not tpl_path.exists():
        print(f"ERROR: 找不到範本 {tpl_path}\n  範本是技術棧專屬、放專案 "
              f".lumos/guard-templates/<type>.tmpl;lumos 語言無關不內建。先建範本再 scaffold。",
              file=sys.stderr)
        return 2
    klass = klass or (method + "Tests")  # 不複用 method 當類名(避免 class==method 同名)
    prefix = "TEST" + re.sub(r"[^A-Za-z]", "", method).upper()[:7]
    text = tpl_path.read_text(encoding="utf-8")
    for k, v in {"CLASS": klass, "METHOD": method, "NODE": rel,
                 "INVARIANT": clean, "CLAIM": claim, "PREFIX": prefix}.items():
        text = text.replace("{{" + k + "}}", v)
    leftover = sorted(set(re.findall(r"\{\{[^}]+\}\}", text)))
    if leftover:
        print(f"⚠ 範本有未取代的 placeholder {leftover}(範本 typo?)— 仍寫出,請檢查產出檔",
              file=sys.stderr)
    out = Path(out_dir) if out_dir else _detect_test_dir(platform_root, gtype, profile)
    if out is None:
        print("ERROR: 偵測不到測試專案目錄,請給 --out", file=sys.stderr)
        return 2
    if not out.is_dir():
        print(f"ERROR: 輸出目錄不存在: {out}(打錯路徑?先 mkdir 或修正 --out)", file=sys.stderr)
        return 2
    target = out / f"{klass}{profile['scaffold_ext']}"
    if target.exists():
        print(f"ERROR: {target} 已存在,不覆寫(避免蓋掉既有守衛)", file=sys.stderr)
        return 2
    _write_lf(target, text)
    print(f"✓ 已產 stub: {target}")
    print(f"  類型: {gtype}  |  方法: {method}  |  守衛: {clean[:70]}")
    print("\n下一步(Claude/人):")
    print(f"  1. 開 {target.name},把 // TODO 換成『已向人確認的斷言』"
          f"(預設 {profile['fail_hint']} → 必須填到綠)")
    _pflag = f" --platform {platform}" if pdata["multiplatform"] else ""
    print(f"  2. 綁回圖譜:  lumos guard bind {rel} \"{invariant_substr}\" {method}{_pflag}")
    print(f"  3. lumos doctor 確認 Check T 通過")
    return 0


def cmd_guard_bind(env, node, invariant_substr, method, platform=None):
    if not IDENT_RE.match(method):
        print(f"ERROR: method『{method}』非合法識別字", file=sys.stderr)
        return 2
    # 多平台:平台另帶(method 維持識別字、不含冒號),寫成 [test:平台:方法]。IDENT_RE 不放寬。
    ref = f"{platform}:{method}" if platform else method
    rel = env.find(node)
    if rel is None:
        print(f"ERROR: 找不到節點 {node}", file=sys.stderr)
        return 2
    path = env.vault / rel
    try:
        lines, _, e = load_raw_for_edit(path)
    except (ValueError, RuntimeError) as ex:
        print(f"ERROR: {ex}", file=sys.stderr)
        return 2
    target_idx = None
    for i in range(1, e):
        # 比對去掉 [test:..] 後的行(子字串不誤命中既有測試名)
        if INVARIANT_RE.match(lines[i].strip()) and invariant_substr in TEST_REF_RE.sub("", lines[i]):
            if target_idx is not None:
                print(f"ERROR: 『{invariant_substr}』命中多條 KEY 行,請給更精確子字串", file=sys.stderr)
                return 2
            target_idx = i
    if target_idx is None:
        print(f"ERROR: {rel} 找不到含『{invariant_substr}』的 ★INVARIANT★ KEY 行", file=sys.stderr)
        return 2
    line = lines[target_idx]
    m = TEST_REF_RE.search(line)
    if m:
        refs = [t.strip() for t in m.group(1).split(",") if t.strip()]
        if ref in refs:   # 去重比完整 ref(platform:method),否則多平台漏判(審計 r3)
            print(f"已綁 [test:{ref}],無需重綁")
            return 0
        refs.append(ref)
        newline = line[:m.start()] + f"[test:{','.join(refs)}]" + line[m.end():]
    else:
        newline = line.rstrip() + f" [test:{ref}]"
    new_lines = lines[:target_idx] + [newline] + lines[target_idx + 1:]

    def check(fields):
        summ = fields.get("summary")
        if not isinstance(summ, str):
            return False
        for l in summ.split("\n"):
            mi = INVARIANT_RE.match(l.strip())
            if mi and invariant_substr in l:
                return ref in invariant_test_refs(mi.group(1))   # verify closure 也比完整 ref
        return False

    try:
        atomic_write_verify(path, new_lines, f"[test:{ref}]", check)
    except (ValueError, RuntimeError) as ex:
        print(f"ERROR: {ex}", file=sys.stderr)
        return 2
    print(f"✓ 綁定 [test:{ref}] → {rel} 的 ★INVARIANT★")
    print("  下一步: lumos doctor — 方法須已存在於 code,否則 Check T 顯示懸空")
    return 0


# ── guard kill:殺傷力驗證(宣告式壞法→隔離 worktree→綁定測試必須翻紅) ──
# 設計 spec:docs/lumos-toolchain-knowledge/Projects/guard殺傷力驗證_計劃.md(3 輪 panel 收斂)
# borrow-design:pytest-mutagen(宣告式)+cargo-mutants(baseline/timeout)+Stryker command-runner

_KILL_METHOD_OK_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$|^[\w .]+$")  # IDENT 或 Kotlin 反引號拆殼後白名單


def _kill_read_recipes(path):
    """讀節點的 kill_recipes frontmatter(block scalar 單行 compact JSON array)。回 (list, err)。"""
    import json
    try:
        lines, _, e = load_raw_for_edit(path)
        fields, _bk, _lint = parse_frontmatter(lines[1:e])
    except Exception as ex:
        return None, f"frontmatter 解析失敗: {ex}"
    raw = fields.get("kill_recipes")
    if raw is None:
        return [], None
    try:
        data = json.loads(raw if isinstance(raw, str) else str(raw))
        if not isinstance(data, list):
            return None, "kill_recipes 必須是 JSON array"
        return data, None
    except ValueError as ex:
        return None, f"kill_recipes JSON 解析失敗: {ex}"


def cmd_guard_kill_add(env, node, invariant_substr, file, old, new, test=None,
                       platform=None, note=""):
    """宣告一條壞法配方進 kill_recipes + KEY 行補 [kill:recipes](同檔一次 atomic 寫)。"""
    import json
    if old == new:
        print("ERROR: old 與 new 相同,配方無語意", file=sys.stderr)
        return 2
    rel = env.find(node)
    if rel is None:
        print(f"ERROR: 找不到節點 {node}", file=sys.stderr)
        return 2
    path = env.vault / rel
    try:
        lines, _, e = load_raw_for_edit(path)
    except (ValueError, RuntimeError) as ex:
        print(f"ERROR: {ex}", file=sys.stderr)
        return 2
    # 定位 KEY 行(去標記後比對,避免子字串誤中標記文字)
    target_idx = None
    for i in range(1, e):
        if INVARIANT_RE.match(lines[i].strip()) and invariant_substr in INV_TAG_RE.sub("", lines[i]):
            if target_idx is not None:
                print(f"ERROR: 『{invariant_substr}』命中多條 KEY 行,請給更精確子字串", file=sys.stderr)
                return 2
            target_idx = i
    if target_idx is None:
        print(f"ERROR: {rel} 找不到含『{invariant_substr}』的 ★INVARIANT★ KEY 行", file=sys.stderr)
        return 2
    # 解析綁定測試:--test 或 KEY 行唯一 [test:] ref;0 個 → 硬報(kill 驗的就是綁定)
    line = lines[target_idx]
    refs = invariant_test_refs(line)
    if test is None:
        if len(refs) == 0:
            print("ERROR: 該合約無 [test:] 綁定(naked)——kill 驗的是綁定測試,先 guard bind", file=sys.stderr)
            return 2
        if len(refs) > 1:
            print(f"ERROR: 該合約綁多個測試({', '.join(refs)}),--test 指明哪一個", file=sys.stderr)
            return 2
        test = refs[0]
    recipe = {"invariant": invariant_substr, "test": test, "file": file,
              "old": old, "new": new, "note": note or ""}
    if platform:
        recipe["platform"] = platform
    recipes, err = _kill_read_recipes(path)
    if recipes is None:
        print(f"ERROR: {err}", file=sys.stderr)
        return 2
    for r in recipes:
        if r.get("invariant") == invariant_substr and r.get("file") == file and r.get("old") == old:
            print("ERROR: 重複配方(同 invariant 同 file/old),先手動移除舊條", file=sys.stderr)
            return 2
    recipes.append(recipe)
    blob = json.dumps(recipes, ensure_ascii=False)
    # 重寫 frontmatter:替換或插入 kill_recipes block(單行 compact) + KEY 行補標記
    newline = line if KILL_REF_RE.search(line) else line.rstrip() + " [kill:recipes]"
    out, i, replaced = [], 0, False
    while i < e:
        l = lines[i]
        if i == target_idx:
            out.append(newline); i += 1; continue
        if l.startswith("kill_recipes:"):
            out.append("kill_recipes: |-")
            out.append("  " + blob)
            i += 1
            while i < e and (lines[i].startswith("  ") or not lines[i].strip()):
                i += 1
            replaced = True
            continue
        out.append(l); i += 1
    if not replaced:
        out.append("kill_recipes: |-")
        out.append("  " + blob)
    new_lines = out + lines[e:]
    # 若 KEY 行在 summary block 內(常態),target_idx < e 已處理;標記寫後自驗

    def check(fields):
        raw = fields.get("kill_recipes")
        if not isinstance(raw, str):
            return False
        try:
            data = json.loads(raw)
        except ValueError:
            return False
        if not any(r.get("invariant") == invariant_substr and r.get("old") == old for r in data):
            return False
        summ = fields.get("summary")
        if isinstance(summ, str):
            for sl in summ.split("\n"):
                mi = INVARIANT_RE.match(sl.strip())
                if mi and invariant_substr in INV_TAG_RE.sub("", sl):
                    return bool(KILL_REF_RE.search(sl))
        return False

    try:
        atomic_write_verify(path, new_lines, "[kill:recipes]", check)
    except (ValueError, RuntimeError) as ex:
        print(f"ERROR: {ex}", file=sys.stderr)
        return 2
    print(f"✓ kill 配方寫入 {rel}(invariant『{invariant_substr[:24]}…』, test={test})")
    print("  下一步: lumos guard kill 跑殺傷力驗證(worktree 隔離,弄壞→測試必須翻紅)")
    return 0


def _kill_run(cmd, cwd, timeout):
    """跑 run_cmd(shell,killpg 沿 lint 先例)。回 (rc, tail200, elapsed, timed_out)。"""
    import os
    import signal
    import subprocess
    import tempfile
    import time
    t0 = time.time()
    with tempfile.TemporaryFile(mode="w+", encoding="utf-8", errors="replace") as buf:
        proc = subprocess.Popen(cmd, shell=True, cwd=str(cwd), start_new_session=True,
                                stdout=buf, stderr=subprocess.STDOUT)
        try:
            proc.communicate(timeout=timeout)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(os.getpgid(proc.pid), signal.SIGKILL)
            except (ProcessLookupError, OSError, AttributeError):
                # AttributeError=Windows 無 killpg/SIGKILL → 退回殺直接子程序
                try:
                    proc.kill()
                except OSError:
                    pass
            proc.wait()
            buf.seek(0)
            txt = buf.read()
            return (None, txt[-200:], time.time() - t0, True)
        buf.seek(0)
        txt = buf.read()
    return (proc.returncode, txt[-200:], time.time() - t0, False)


def cmd_guard_kill(env, node, invariant_substr=None, platform_override=None,
                   as_json=False, keep_worktree=False):
    """跑節點的 kill 配方:worktree 隔離→baseline 綠→套壞法→綁定測試必須翻紅。
    rc:全 killed(含 timed_out)=0;任一 survived=1;有 drifted/abort/error 而無 survived=2;
    零配方/缺 run_cmd/config 壞=2。"""
    import json
    import os
    import shlex
    import shutil
    import subprocess
    import tempfile
    import datetime
    rel = env.find(node)
    if rel is None:
        print(f"ERROR: 找不到節點 {node}", file=sys.stderr)
        return 2
    path = env.vault / rel
    recipes, err = _kill_read_recipes(path)
    if recipes is None:
        print(f"ERROR: {err}", file=sys.stderr)
        return 2
    if invariant_substr:
        recipes = [r for r in recipes if invariant_substr in r.get("invariant", "")]
    if not recipes:
        print("ERROR: 無配方可跑(kill-add 先宣告;或子字串不匹配)", file=sys.stderr)
        return 2
    repo_root = _repo_root_from_env(env)
    try:
        pdata = load_platforms(repo_root)
    except ValueError as ex:
        print(f"ERROR: config 壞: {ex}", file=sys.stderr)
        return 2
    plats = pdata["platforms"]
    default_plat = pdata["default_platform"]
    if pdata.get("multiplatform") and (Path(repo_root) / ".lumos" / "config.json").exists():
        # platforms 在則 test.run_cmd 不生效(load_platforms 二分慣例)→ 有宣告時告警
        try:
            _cfg = json.loads((Path(repo_root) / ".lumos" / "config.json").read_text(encoding="utf-8"))
            if isinstance(_cfg.get("test"), dict) and _cfg["test"].get("run_cmd"):
                print("⚠ config 同時有 platforms 與 test.run_cmd——多平台模式下 test.run_cmd 不生效")
        except Exception:
            pass
    floor = 20.0
    try:
        floor = float(os.environ.get("LUMOS_KILL_TIMEOUT_FLOOR", "20"))
    except ValueError:
        pass
    results = []
    commit = ""   # 迴圈外留痕用;多平台時記最後一組的 HEAD(各 row 的 platform 欄可辨)
    ts = datetime.datetime.now().isoformat(timespec="seconds")
    # 依 platform 分組(每平台一個 worktree + baseline per test)
    groups = {}
    for r in recipes:
        groups.setdefault(r.get("platform") or platform_override or default_plat, []).append(r)
    for plat, plist in groups.items():
        pentry = plats.get(plat)
        if pentry is None:
            for r in plist:
                results.append({**r, "platform": plat, "verdict": "error",
                                "detail": f"平台 '{plat}' 不在 config"})
            continue
        run_cmd = pentry.get("run_cmd")
        if not run_cmd:
            print(f"ERROR: 平台 '{plat}' 未宣告 run_cmd(多平台=platforms.{plat}.run_cmd;"
                  f"legacy=test.run_cmd)——kill 不可用", file=sys.stderr)
            return 2
        proot = Path(pentry["root"])
        commit = ""
        try:
            commit = subprocess.run(["git", "-C", str(proot), "rev-parse", "--short", "HEAD"],
                                    capture_output=True, text=True).stdout.strip()
        except Exception:
            pass
        try:
            dirty = subprocess.run(["git", "-C", str(proot), "status", "--porcelain"],
                                   capture_output=True, text=True).stdout.strip()
        except OSError:
            dirty = ""
        if dirty:
            print(f"⚠ {plat} repo 有未提交變更——不會進沙盒(kill 以 HEAD 為基準),配方/測試需先 commit")
        flaky = pentry["profile"].get("scaffold_ext") in (".yaml", ".yml") or plat in ("maestro", "playwright")
        # per (test) baseline 快取:同測試多配方只跑一次 baseline
        tmp_parent = tempfile.mkdtemp(prefix="lumos-kill-")
        wt = os.path.join(tmp_parent, "wt")
        wt_ok = False
        try:
            r_add = subprocess.run(["git", "-C", str(proot), "worktree", "add", "--detach", wt],
                                   capture_output=True, text=True)
            if r_add.returncode != 0:
                for r in plist:
                    results.append({**r, "platform": plat, "verdict": "error",
                                    "detail": f"worktree add 失敗: {r_add.stderr.strip()[:120]}"})
                continue
            wt_ok = True
            wt_real = os.path.realpath(wt)
            baselines = {}
            for r in plist:
                method_full = r.get("test", "")
                method = method_full.split(":", 1)[1] if (":" in method_full and pdata.get("multiplatform")) else method_full
                method = method.strip("`")   # Kotlin 反引號名拆殼後進白名單
                if not _KILL_METHOD_OK_RE.fullmatch(method or ""):
                    results.append({**r, "platform": plat, "verdict": "error",
                                    "detail": f"test 名不合法(拒注入): {method!r}"})
                    continue
                cmd = run_cmd.replace("{method}", shlex.quote(method)) if "{method}" in run_cmd else run_cmd
                note_ws = "" if "{method}" in run_cmd else " whole-suite"
                if cmd not in baselines:
                    b_rc, b_tail, b_elapsed, b_to = _kill_run(cmd, wt, max(600.0, floor))
                    baselines[cmd] = (b_rc, b_tail, b_elapsed, b_to)
                b_rc, b_tail, b_elapsed, b_to = baselines[cmd]
                if b_to or b_rc != 0:
                    results.append({**r, "platform": plat, "verdict": "abort",
                                    "detail": f"baseline 非綠(rc={b_rc}){note_ws}", "tail": b_tail})
                    continue
                # 套配方(路徑圍欄:雙邊 realpath)
                target = os.path.realpath(os.path.join(wt, r.get("file", "")))
                if not target.startswith(wt_real + os.sep):
                    results.append({**r, "platform": plat, "verdict": "error",
                                    "detail": "file 路徑逃逸 worktree(圍欄擋下)"})
                    continue
                try:
                    with open(target, encoding="utf-8") as _tf:
                        src = _tf.read()
                except OSError as ex:
                    results.append({**r, "platform": plat, "verdict": "drifted",
                                    "detail": f"file 開不了: {ex}"})
                    continue
                cnt = src.count(r.get("old", ""))
                if cnt != 1:
                    results.append({**r, "platform": plat, "verdict": "drifted",
                                    "detail": f"old 命中 {cnt} 次(需恰 1——配方漂移,重寫)"})
                    continue
                with open(target, "w", encoding="utf-8") as _tf:
                    _tf.write(src.replace(r["old"], r["new"], 1))
                m_timeout = max(b_elapsed * 5, floor)
                m_rc, m_tail, _me, m_to = _kill_run(cmd, wt, m_timeout)
                rv = subprocess.run(["git", "-C", wt, "checkout", "--", r.get("file", "")],
                                    capture_output=True)
                if rv.returncode != 0:
                    results.append({**r, "platform": plat, "verdict": "error",
                                    "detail": "revert 失敗——後續同組配方作廢防污染"})
                    break   # 樹已髒,本組終止(worktree 在 finally 清)
                if m_to:
                    verdict = "timed_out"   # 歸 killed 類(PIT:變異致掛=被超時接住)
                elif m_rc != 0:
                    verdict = "killed"
                else:
                    verdict = "survived"
                res = {**r, "platform": plat, "verdict": verdict}
                if verdict == "survived":
                    res["tail"] = b_tail    # 供人查 filter 是否真的跑到測試(zero-hit 假 survived)
                if flaky:
                    res["flaky_risk"] = True
                if note_ws:
                    res["detail"] = (res.get("detail", "") + note_ws +
                                     ("(弱證據:紅燈可能來自無關測試)" if verdict in ("killed", "timed_out") else ""))
                results.append(res)
        finally:
            if keep_worktree:
                print(f"(--keep-worktree) 現場保留: {wt}")
            else:
                if wt_ok:
                    subprocess.run(["git", "-C", str(proot), "worktree", "remove", "--force", wt],
                                   capture_output=True)
                shutil.rmtree(tmp_parent, ignore_errors=True)   # add 失敗也清(無條件)
                if wt_ok:
                    subprocess.run(["git", "-C", str(proot), "worktree", "prune"],
                                   capture_output=True)          # prune 放 rmtree 後(dir 已消才修行政記錄)
    # 留痕(docs/.kill-log.jsonl,gov 第 5 支 load 撈)——迴圈外:add 失敗 continue 的 error 也要進帳
    if True:
        log = env.vault.parent / ".kill-log.jsonl"
        try:
            _fh_ok = True
            fh_cm = open(log, "a", encoding="utf-8")
        except OSError as ex:
            _fh_ok = False
            print(f"⚠ kill-log 寫入失敗(結果只印不留痕): {ex}", file=sys.stderr)
        if _fh_ok:
          with fh_cm as fh:
            for res in results:
                if res.get("_logged"):
                    continue
                res["_logged"] = True
                fh.write(json.dumps({"ts": ts, "node": rel, "commit": commit,
                                     "invariant": res.get("invariant", ""), "test": res.get("test", ""),
                                     "platform": res.get("platform", ""),
                                     "verdict": res["verdict"], "note": res.get("note", ""),
                                     "flaky_risk": res.get("flaky_risk", False),
                                     "tail": res.get("tail", "")}, ensure_ascii=False) + "\n")
    verdicts = [r["verdict"] for r in results]
    if as_json:
        print(json.dumps({"results": [{k: v for k, v in r.items() if k != "_logged"}
                                      for r in results]}, ensure_ascii=False))
    else:
        icon = {"killed": "✓", "timed_out": "✓", "survived": "✗",
                "drifted": "⚠", "abort": "⚠", "error": "⚠"}
        for r in results:
            print(f"{icon.get(r['verdict'],'?')} {r['verdict']:<9} {r.get('invariant','')[:30]}"
                  f" [{r.get('test','')}] {r.get('detail','')}")
    if "survived" in verdicts:
        print("✗ 有配方 SURVIVED——綁定測試接不住宣告的壞法(稻草人證據),補強測試", file=sys.stderr)
        return 1
    if any(v in ("drifted", "abort", "error") for v in verdicts):
        return 2
    if not as_json:
        print(f"✓ 全部 killed({len(verdicts)} 配方)——綁定測試咬得住")
    return 0


def cmd_guard_audit(env, node, invariant_substr, model="sonnet", date=None):
    """把 [audit:模型/日期] 留痕寫回 ★INVARIANT★ KEY 行(寫後自驗)。
    語意:這條鐵則的「合法性」(是不是真鐵則 / 綁的測試夠不夠格)已由一個
    *無對話脈絡的獨立 agent* 判過並通過。工具只記留痕,不證明審計真的乾淨——
    那靠 skill 的 maker/checker 誠實鐵則(別餵結論給審計者、提出者不得自評)。"""
    import datetime
    if date is None:
        date = datetime.date.today().isoformat()
    stamp = f"{model}/{date}"
    rel = env.find(node)
    if rel is None:
        print(f"ERROR: 找不到節點 {node}", file=sys.stderr)
        return 2
    path = env.vault / rel
    try:
        lines, _, e = load_raw_for_edit(path)
    except (ValueError, RuntimeError) as ex:
        print(f"ERROR: {ex}", file=sys.stderr)
        return 2
    target_idx = None
    for i in range(1, e):
        # 比對去掉 [test:]/[audit:] 後的行(子字串不誤命中既有標記內容)
        if INVARIANT_RE.match(lines[i].strip()) and invariant_substr in INV_TAG_RE.sub("", lines[i]):
            if target_idx is not None:
                print(f"ERROR: 『{invariant_substr}』命中多條 KEY 行,請給更精確子字串", file=sys.stderr)
                return 2
            target_idx = i
    if target_idx is None:
        print(f"ERROR: {rel} 找不到含『{invariant_substr}』的 ★INVARIANT★ KEY 行", file=sys.stderr)
        return 2
    line = lines[target_idx]
    m = AUDIT_REF_RE.search(line)
    if m:
        newline = line[:m.start()] + f"[audit:{stamp}]" + line[m.end():]   # 重審 → 覆蓋舊留痕(新日期生效)
    else:
        newline = line.rstrip() + f" [audit:{stamp}]"
    new_lines = lines[:target_idx] + [newline] + lines[target_idx + 1:]

    def check(fields):
        summ = fields.get("summary")
        if not isinstance(summ, str):
            return False
        for l in summ.split("\n"):
            mi = INVARIANT_RE.match(l.strip())
            if mi and invariant_substr in INV_TAG_RE.sub("", l):
                return stamp in invariant_audit_refs(mi.group(1))
        return False

    try:
        atomic_write_verify(path, new_lines, f"[audit:{stamp}]", check)
    except (ValueError, RuntimeError) as ex:
        print(f"ERROR: {ex}", file=sys.stderr)
        return 2
    print(f"✓ 留痕 [audit:{stamp}] → {rel} 的 ★INVARIANT★")
    print("  前提:這條合法性已由無脈絡的獨立 agent 判過(maker≠checker)。doctor Check T 不再報『未審』。")
    return 0


def cmd_guard_trace(env, node=None):
    """合約 → 守衛測試 → Verification 證據 的鏈(reverse lookup)。
    用途:改某模組前,看它的 ★INVARIANT★ 各綁哪個測試、哪篇 Verification 背書 →
    breaking change 的爆炸半徑可查(grep 輸出某測試名即反查)。"""
    rel = None
    if node:
        rel = env.find(node)
        if rel is None:
            print(f"ERROR: 找不到節點 {node}", file=sys.stderr)
            return 2
    # 預掃所有 Verification 全文 → 之後查「哪篇提到某測試方法名」。
    # 剝 fenced/inline code(對齊 load_vault 的 body 連結抽取慣例 — code block 內宣告不算證據)。
    verif_text = {}
    for r in env.notes:
        if r.startswith("Verification/"):
            try:
                raw = (env.vault / r).read_text(encoding="utf-8-sig")
                verif_text[r] = INLINE_CODE_RE.sub("", FENCE_RE.sub("", raw))
            except Exception:
                verif_text[r] = ""
    # 多平台:refs 帶 平台: 前綴(如 android:X),但 Verification 文字寫的是裸方法名 X →
    # 搜尋前先剝前綴(顯示仍用完整 ref)。config 壞則當 legacy(不剝)。
    try:
        _pd = load_platforms(_repo_root_from_env(env))
        _split = _pd["platforms"] if _pd["multiplatform"] else {}
    except ValueError:
        _split = {}

    def _bare(mth):
        if _split and ":" in mth:
            p, n = mth.split(":", 1)
            if p.strip() in _split:
                return n.strip()
        return mth

    targets = [rel] if rel else sorted(env.notes)
    nodes_with_inv = 0
    short_names = set()
    for r in targets:
        inv, _ = extract_contracts(env.notes[r])
        if not inv:
            continue
        nodes_with_inv += 1
        print(f"# {r}")
        for x in inv:
            clean, refs = strip_test_refs(x)
            print(f"  ★INVARIANT★ {clean[:78]}")
            if not refs:
                print("      ↳ ⚠ 未綁測試")
                continue
            for mth in refs:
                bare = _bare(mth)   # 剝平台前綴後才是 Verification 文字裡的方法名
                if len(bare) < 10:
                    short_names.add(bare)
                # re.ASCII:方法名 ASCII;否則中文緊貼方法名(無空格)時 \b 失效漏命中
                pat = re.compile(r"\b" + re.escape(bare) + r"\b", re.ASCII)
                vs = sorted(env.notes[vr].stem for vr, t in verif_text.items() if pat.search(t))
                tail = ", ".join(vs) if vs else "(無 Verification 提到此守衛)"
                print(f"      ↳ [test:{mth}]  →  {tail}")
    if nodes_with_inv == 0:
        print("(無 ★INVARIANT★ 合約)" if rel else "(全 vault 無合約)")
        return 0
    print("\n※ 「→」是 Verification 全文【字串命中】(非結構化背書):不分正/否定句,"
          "也抓不到「有驗但沒寫方法名」的篇。當證據鏈線索用,別當鐵證。")
    if short_names:
        print(f"⚠ 短方法名 {sorted(short_names)} 易誤命中(全文裡剛好出現該字),建議用長、領域專屬名。")
    return 0


def cmd_sync_verified_by(env, apply=False):
    """補 doctor Check 3 抓到的 verified_by 漏寫(Verification 連到 Systems、但 Systems.verified_by 沒列)。
    只動這一個『零判斷』項 — orphan 補掛 / plan_refs 需語意判斷,不在此自動修。
    dry-run 預設;--apply 才寫(T1 atomic append,自帶 dedup)。"""
    from collections import defaultdict
    notes, resolve = env.notes, env.resolve
    expected = defaultdict(set)
    for r, n in notes.items():
        if not r.startswith("Verification/"):
            continue
        for t in n.targets:
            dest = resolve(t)
            if dest and dest.startswith("Systems/"):
                expected[dest].add(r)
    planned = []
    for sys_rel, verif_rels in sorted(expected.items()):
        actual = {resolve(link_target(a))
                  for a in as_list(notes[sys_rel].fields.get("verified_by"))}
        actual.discard(None)
        for v in sorted(verif_rels):
            if v not in actual:
                vl = v[:-3] if v.endswith(".md") else v
                planned.append((sys_rel, f"[[{vl}]]"))
    if not planned:
        print("✓ verified_by 已全同步,無漏寫")
        return 0
    for sys_rel, vl in planned:
        print(f"  {'+' if apply else '·'} {sys_rel}  ← {vl}")
    if not apply:
        print(f"\n{len(planned)} 筆待補(dry-run)。加 --apply 真寫入。")
        print("※ 判準同 doctor Check 3:Verification 連到某 Systems 即視為驗證它。"
              "若連結是『描述性提及』(如「取代 [[Systems/舊]]」)會誤補 → 先審這份 dry-run 再 --apply。")
        return 0
    print()
    n_ok = 0
    for sys_rel, vl in planned:
        try:
            if cmd_append(env, sys_rel, "verified_by", vl) == 0:
                n_ok += 1
        except (ValueError, RuntimeError) as ex:
            print(f"  ✗ {sys_rel} {vl}: {ex}", file=sys.stderr)
    print(f"\n✓ 補了 {n_ok}/{len(planned)} 筆 verified_by")
    return 0


def _node_age_days(n):
    """節點日齡(天):Verification 用 date:、System 用 updated:。
    取不到或格式異常 → None(不參與日齡判斷)。90 天紅標的共用來源(cmd_context + doctor Check V)。"""
    import datetime
    date_str = n.fields.get("date") or n.fields.get("updated") or ""
    if not date_str:
        return None
    try:
        return (datetime.date.today() - datetime.date.fromisoformat(str(date_str))).days
    except ValueError:
        return None


# ── 相關節點推薦(BFS-decay+共引+Jaccard × BM25F 融合;spec:檢索優化_計劃 §2) ──

def _reco_adj(env):
    """無向鄰接表(全部邊型:body wikilink+frontmatter list)。"""
    adj = {}
    for rel, n in env.notes.items():
        for tgt in n.targets:
            dst = env.resolve(tgt)
            if dst and dst != rel:
                adj.setdefault(rel, set()).add(dst)
                adj.setdefault(dst, set()).add(rel)
    return adj


def _reco_scores(env, seed, depth=2):
    """回 {rel: {"hop","B","C","J","G"}}(不含 seed)。
    B=min(1, 2/2^k);C=max 共引飽和(同行×2/同節點×1,每引用者一次);J=鄰域 Jaccard。"""
    adj = _reco_adj(env)
    # BFS 最短距(每節點一次)
    hops, frontier, seen = {}, {seed}, {seed}
    for k in range(1, depth + 1):
        nxt = set()
        for u in frontier:
            for v_ in adj.get(u, ()):
                if v_ not in seen:
                    seen.add(v_)
                    hops[v_] = k
                    nxt.add(v_)
        frontier = nxt
    # 共引:掃引用 seed 的節點 u,同行/同節點的其他 wikilink
    craw = {}
    seed_stem = env.notes[seed].stem
    for u, n in env.notes.items():
        if u == seed:
            continue
        try:
            text = (env.vault / u).read_text(encoding="utf-8-sig")
        except Exception:
            continue
        if f"[[{seed_stem}" not in text and f"[[Systems/{seed_stem}" not in text \
           and not any(env.resolve(tg) == seed for tg in n.targets):
            continue
        contrib = {}
        for line in text.split("\n"):
            links = [env.resolve(m.group(1).split("|")[0].split("#")[0])
                     for m in re.finditer(r"\[\[([^\]]+)\]\]", line)]
            links = [x for x in links if x]
            if seed in links:
                for other in links:
                    if other not in (seed, u):
                        contrib[other] = max(contrib.get(other, 0), 2)   # 同行=2
        for tg in n.targets:
            dst = env.resolve(tg)
            if dst and dst not in (seed, u) and dst not in contrib \
               and any(env.resolve(t2) == seed for t2 in n.targets):
                contrib[dst] = 1   # 同節點=1
        for other, w in contrib.items():
            craw[other] = craw.get(other, 0) + w
    gs = env.notes and adj.get(seed, set())
    out = {}
    for rel, k in hops.items():
        B = min(1.0, 2.0 / (2 ** k))
        cr = craw.get(rel, 0)
        C = cr / (cr + 2.0)
        gv = adj.get(rel, set())
        inter = len(gs & gv) if gs else 0
        union = len(gs | gv) if (gs or gv) else 1
        J = inter / union if union else 0.0
        out[rel] = {"hop": k, "B": B, "C": round(C, 4), "J": round(J, 4),
                    "G": round(0.60 * B + 0.25 * C + 0.15 * J, 4)}
    # 共引但不在 BFS 深度內的節點也納入(hop 記為 depth,B 用共引者路徑近似 2 hop)
    for rel, cr in craw.items():
        if rel not in out and rel != seed and rel in env.notes:
            C = cr / (cr + 2.0)
            out[rel] = {"hop": 2, "B": 0.5, "C": round(C, 4), "J": 0.0,
                        "G": round(0.60 * 0.5 + 0.25 * C, 4)}
    return out


def _reco_fused(env, seed, top=8, min_score=0.20, depth=2):
    """G × BM25F 融合(query=seed 的 title+summary+tags)。R=0.6L+0.4G;
    hop1 只受靜態底線;hop≥2 需 L>0。回 list[dict] 依 R 降冪。"""
    gscores = _reco_scores(env, seed, depth=depth)
    if not gscores:
        return []
    sf = _rank_fields(env, seed)
    query = " ".join([sf["title"], sf["summary"], sf["tags"]])
    # 結構前綴停用(KEY:/FLOW:…是 summary 模板詞,人人都有——不算詞彙訊號)
    _STOP = {"key", "flow", "dep", "test", "verify", "auth", "decision", "flag",
             "core", "type", "status", "system", "systems"}
    q_toks = [tok for tok in _rank_tokenize(query) if tok not in _STOP]
    scored = {rel: s for rel, s, _h in _rank_score_candidates(env, " ".join(q_toks), list(gscores))}
    mx = max(scored.values()) if scored else 0.0
    out = []
    for rel, g in gscores.items():
        L = (scored.get(rel, 0.0) / mx) if mx > 0 else 0.0
        if g["hop"] >= 2 and L <= 0:
            continue   # 遠端需詞彙背書(spec §2 r1)
        R = round(0.60 * L + 0.40 * g["G"], 4)
        if R < min_score:
            continue
        out.append({"node": rel, "score": R, "L": round(L, 4), **g})
    out.sort(key=lambda x: (-x["score"], x["node"]))
    return out[:max(int(top), 1)]


def _usage_log(env, rel, cmd):
    """A2 事件帳種子(節點靜態先驗_調研):記「節點真的被查閱採用」的 append 帳。
    先累語料不進分數;未來 frecency=查詢時現算(Firefox 教訓:不存時變分數)。best-effort 靜默。"""
    try:
        import datetime as _dt
        p = env.vault.parent / ".usage-log.jsonl"
        with open(p, "a", encoding="utf-8") as fh:
            fh.write(json.dumps({"ts": _dt.datetime.now().isoformat(timespec="seconds"),
                                 "node": rel, "cmd": cmd}, ensure_ascii=False) + "\n")
    except Exception:
        pass


def cmd_context(env, rel, brief=False, recommend=False, top=8, min_score=0.20, as_json=False):
    """節點 + 鄰居 summary 壓縮索引 — MemPalace closet 具象化
    brief=True: 只給 meta + summary 首兩行 + 鄰居名單(壓 token 用)"""
    n = env.notes[rel]
    _usage_log(env, rel, "context")
    out_e, in_e = env.edges
    meta = " | ".join(f"{k}:{n.fields[k]}" for k in ("type", "status", "created", "updated")
                      if isinstance(n.fields.get(k), str) and n.fields.get(k))
    print(f"# {rel}")
    if meta:
        print(meta)
    vu = _conds(n.fields.get("valid_under"))
    if vu:
        age = _node_age_days(n)
        flag = f"[⚠ 節點已 {age} 天未更新,前提條件可能失效]" if (age is not None and age > 90) else ""
        print(f"⚠ 使用前驗證(valid_under){flag}:")
        for c in vu:
            print(f"  {c}")
    inv, debt = extract_contracts(n)
    if inv or debt:
        print("⚠ 合約(動前必讀):")
        for x in inv:
            print(f"  ★INVARIANT★ {x}")
        for x in debt:
            print(f"  ★DEBT★ {x}")
    summ = n.fields.get("summary")
    if isinstance(summ, str) and summ:
        lines = summ.split("\n")
        if brief:
            lines = lines[:2]
        print("summary:")
        for l in lines:
            print(f"  {first_line(l, 100) if brief else l}")
    for key in ("verified_by", "plan_refs", "core_refs"):
        vals = as_list(n.fields.get(key))
        if vals:
            print(f"{key}: {', '.join(vals)}")
    for label, rows in (("→ 連出", sorted(set(out_e.get(rel, [])))),
                        ("← 連入", sorted(set(in_e.get(rel, []))))):
        print(f"{label} ({len(rows)}):")
        for d in rows:
            if brief:
                print(f"  • {d} [{status_of(env, d)}]")
                continue
            nb = env.notes[d]
            s = nb.fields.get("summary")
            hint = first_line(s if isinstance(s, str) else "")
            print(f"  • {d} [{status_of(env, d)}]" + (f" — {hint}" if hint else ""))
    if recommend:
        recos = _reco_fused(env, rel, top=top, min_score=min_score)
        if as_json:
            import json as _json
            print(_json.dumps({"node": rel, "recommend": recos}, ensure_ascii=False))
        else:
            print("\n相關節點推薦(圖分×詞彙融合 top-%d):" % top)
            shown = {}
            for x in recos:
                key = re.sub(r"_[^_]+$", "", Path(x["node"]).stem)
                if key in shown:
                    shown[key] += 1
                    continue
                shown[key] = 0
                print(f"  {x['score']:5.2f}  {x['node']}  (hop{x['hop']} L={x['L']})")
            sisters = sum(v for v in shown.values() if v)
            if sisters:
                print(f"  (+姐妹 {sisters};--json 全量)")
    return 0
def parse_decisions(fm_lines):
    """從 frontmatter 原始行解析 decisions 陣列(content/decided/valid/superseded_by/ended)"""
    items = []
    i, n = 0, len(fm_lines)
    while i < n and not re.match(r"^decisions:\s*$", fm_lines[i]):
        i += 1
    if i >= n:
        return items
    i += 1
    cur = None

    def indent(s):
        return len(s) - len(s.lstrip(" "))

    while i < n:
        line = fm_lines[i]
        if line.strip() and not line.startswith(" "):
            break  # 下一個 top-level key
        m_item = re.match(r"^(\s*)-\s+([\w-]+):\s*(.*)$", line)
        m_kv = re.match(r"^(\s+)([\w-]+):\s*(.*)$", line)
        if m_item:
            cur = {}
            items.append(cur)
            key, val = m_item.group(2), m_item.group(3).strip()
            base = indent(line)
            key_col = base + 2          # dash line: key 在「- 」之後,有效欄位 = base+2
        elif m_kv and cur is not None:
            key, val = m_kv.group(2), m_kv.group(3).strip()
            base = indent(line)
            key_col = base              # 子欄位: key 欄位 = base
        else:
            i += 1
            continue
        if val in ("|", "|-", ">", ">-"):
            # block scalar 終止 = 首個縮排 <= key_col 的非空行(否則會把兄弟欄位吸進 content,Bug1)
            block = []
            i += 1
            while i < n and (not fm_lines[i].strip() or indent(fm_lines[i]) > key_col):
                if fm_lines[i].strip():
                    block.append(fm_lines[i].strip())
                i += 1
            cur[key] = "\n".join(block)
            continue
        if val == "":
            lst = []
            i += 1
            while i < n and fm_lines[i].strip() and indent(fm_lines[i]) > base \
                    and re.match(r"^\s+-\s+", fm_lines[i]):
                lst.append(strip_quotes(re.match(r"^\s+-\s+(.*)$", fm_lines[i]).group(1).strip()))
                i += 1
            cur[key] = lst
            continue
        cur[key] = strip_quotes(val)
        i += 1
    return items


def fmt_decision(d):
    mark = "✅" if str(d.get("valid", "true")).lower() != "false" else "❌"
    line = f"{mark} [{d.get('decided', '?')}] {first_line(d.get('content', ''), 100)}"
    if d.get("superseded_by"):
        line += f" → {d['superseded_by']}"
    return line


def cmd_decisions(env, rel=None, superseded=False):
    if superseded:
        found = []
        for r, n in sorted(env.notes.items()):
            for d in parse_decisions(n.fm_lines):
                if str(d.get("valid", "true")).lower() == "false":
                    found.append(f"{n.stem}: {first_line(d.get('content', ''), 80)}"
                                 f" → {d.get('superseded_by', '?')}")
        print("\n".join(found) if found else "無被推翻的決策")
        return 0
    ds = parse_decisions(env.notes[rel].fm_lines)
    if not ds:
        print(f"{rel}: 無 decisions")
        return 0
    for d in ds:
        print(fmt_decision(d))
    return 0


def _conds(val):
    """frontmatter list / 字串 / block scalar → 逐條件展開(去空行)。
    block scalar 存成含 \\n 的單一字串,split 開以免後續行被 first_line 截掉。"""
    out = []
    for c in as_list(val):
        out += [ln.strip() for ln in str(c).split("\n") if ln.strip()]
    return out


def cmd_stale(env, match=None, candidate=False):
    if match is not None and not match.strip():          # NEW-1:空 --match 會 "" in c 恆真=全掃
        print("ERROR: --match 不可為空字串", file=sys.stderr)
        return 2
    if candidate and not match:                          # Finding 6:bare --candidate ≈ 列全部=噪音
        print("ERROR: --candidate 必須配 --match <關鍵字>(例: stale --candidate --match DispatchLog)。\n"
              "  語意=『改某流程時,哪些活躍 Verification 的 revalidate_when 提到該關鍵字 → 該重驗』;\n"
              "  本圖譜每篇 Verification 都有 revalidate_when,不帶 --match = 列全部,無篩選意義。",
              file=sys.stderr)
        return 2
    if candidate:
        # 聚焦查詢:活躍(非 Archive)+ revalidate_when 提到關鍵字 = 「改 X 時該重驗的那幾篇」。
        # 與純 --match 的差別:只掃 revalidate_when(未來重驗條件,不含 valid_under 快照條件)、排 Archive。
        rows, n_hit = [], 0
        for rel, n in sorted(env.notes.items()):
            if not rel.startswith("Verification/") or "/Archive/" in rel:
                continue
            rw = [c for c in _conds(n.fields.get("revalidate_when")) if match in c]
            if not rw:
                continue
            n_hit += 1
            rows.append(f"{rel} [{status_of(env, rel) or 'no-status'}]")
            rows += [f"    ↳ {first_line(c, 90)}" for c in rw]
        if not rows:
            print(f"無 revalidate_when 提到『{match}』的活躍 Verification")
            return 0
        print("\n".join(rows))
        print(f"\n{n_hit} 篇 revalidate_when 提到『{match}』→ 逐一判斷是否需重驗"
              f"(`lumos set <篇> status stale`)。")
        return 0
    rows = []
    for rel, n in sorted(env.notes.items()):
        if not rel.startswith("Verification/"):
            continue
        arch = " [archived]" if "/Archive/" in rel else ""   # Archive 命中明確標記
        if match:
            hit = [c for c in (_conds(n.fields.get("valid_under"))
                               + _conds(n.fields.get("revalidate_when"))) if match in c]
            if hit:
                rows.append(f"{rel} [{status_of(env, rel) or 'no-status'}]{arch}")
                rows += [f"    ↳ {first_line(h, 90)}" for h in hit]
        elif status_of(env, rel) == "stale":
            rows.append(f"{rel} [stale]{arch}")               # NEW-2:格式統一加 [stale]
    if rows:
        print("\n".join(rows))
    else:
        print("無命中" if match else "無 status:stale 的驗證")
    return 0


def cmd_recent(env, days):
    cutoff = time.time() - days * 86400
    rows = sorted(((n.mtime, rel) for rel, n in env.notes.items() if n.mtime >= cutoff),
                  reverse=True)
    for mt, rel in rows:
        print(f"{time.strftime('%Y-%m-%d %H:%M', time.localtime(mt))}  {rel}")
    print(f"({len(rows)} 篇 / 最近 {days} 天)")
    return 0


def cmd_stats(env):
    folders = defaultdict(int)
    for rel in env.notes:
        folders[rel.split("/")[0] if "/" in rel else "(root)"] += 1
    width = max(len(k) for k in folders)
    for k in sorted(folders):
        print(f"{k:<{width}}  {folders[k]}")
    print(f"{'total':<{width}}  {len(env.notes)}")
    return 0


def cmd_export(env, fmt, folders):
    out_e, _ = env.edges
    include = [rel for rel in env.notes
               if rel.split("/")[0] in folders]
    ids = {rel: f"n{i}" for i, rel in enumerate(sorted(include))}
    if fmt == "dot":
        print("digraph G {")
        for rel, nid in ids.items():
            label = env.notes[rel].stem.replace("\\", "\\\\").replace('"', '\\"')
            print(f'  {nid} [label="{label}"];')
        for rel, nid in ids.items():
            for d in out_e.get(rel, []):
                if d in ids:
                    print(f"  {nid} -> {ids[d]};")
        print("}")
        return 0
    print("flowchart LR")
    for rel, nid in ids.items():
        label = env.notes[rel].stem.replace('"', "&quot;")  # mermaid quoted label 逸出
        print(f'    {nid}["{label}"]')
    for rel, nid in ids.items():
        for d in sorted(set(out_e.get(rel, []))):
            if d in ids:
                print(f"    {nid} --> {ids[d]}")
    return 0


