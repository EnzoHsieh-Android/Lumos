    p.add_argument("--why", help="why_chosen 為何選這個")

    p = sub.add_parser("install", help="symlink 到 ~/.local/bin → 全域可用")
    p.add_argument("--force", action="store_true", help="覆寫既有")
    sub.add_parser("uninstall", help="移除 ~/.local/bin/lumos symlink")
    p = sub.add_parser("archive", help="滾動歸檔老 Verification(單遍,移檔+path連結正規化)")
