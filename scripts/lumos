</html>"""


def _html_model(env):
    """蒐集語意模型給 HTML 視圖:nodes(含 type/status/合約/stale/raw)+ typed edges。"""
    out_e, in_e = env.edges
    nodes, edges, seen = [], [], set()
    for rel, n in env.notes.items():
        inv, debt = extract_contracts(n)
        summ = n.fields.get("summary")
        summ = summ if isinstance(summ, str) else ""
        status = status_of(env, rel)
        ntype = n.fields.get("type")
        ntype = ntype if isinstance(ntype, str) and ntype else rel.split("/")[0].lower()
        try:
            raw = (env.vault / rel).read_text(encoding="utf-8-sig")
        except Exception:
            raw = ""
        nodes.append({
            "id": rel, "label": n.stem, "rel": rel, "type": ntype, "status": status,
            "folder": rel.split("/")[0], "inv": inv, "debt": debt,
            "indeg": len(set(in_e.get(rel, []))),
            "summary": [l.strip() for l in summ.split("\n") if l.strip()][:6],
            "raw": raw,
        })
    # typed edges: plan_refs / verified_by / link
    for rel, n in env.notes.items():
        plan = {env.resolve(link_target(x)) for x in as_list(n.fields.get("plan_refs"))}
        verify = {env.resolve(link_target(x)) for x in as_list(n.fields.get("verified_by"))}
        plan.discard(None); verify.discard(None)
        for d in set(out_e.get(rel, [])):
            kind = "plan" if d in plan else "verify" if d in verify else "link"
            key = (rel, d, kind)
            if key not in seen:
                seen.add(key)
                edges.append({"source": rel, "target": d, "kind": kind})
    return {"nodes": nodes, "edges": edges}


_VIZ_LIBS = {
    "3d-force-graph": ("https://cdn.jsdelivr.net/npm/3d-force-graph",
                       '<script src="https://cdn.jsdelivr.net/npm/3d-force-graph"></script>'),
    "marked": ("https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js",
               '<script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>'),
}
_FONT_LINKS = ('<link rel="preconnect" href="https://fonts.googleapis.com">\n'
               '<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>\n'
               '<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">')


def _fetch_text(url, cache):
    """下載文字資源並快取(scripts/vendor/)。離線重複 export 不再抓。
    用 curl(走系統憑證;macOS python urllib 常無 cert store 致 SSL verify 失敗)。"""
    import subprocess
    if cache.exists():
        return cache.read_text(encoding="utf-8")
    cache.parent.mkdir(parents=True, exist_ok=True)
    txt = subprocess.run(["curl", "-fsSL", url], capture_output=True, text=True,
                         timeout=60, check=True).stdout
    if not txt:
        raise RuntimeError("空回應")
    cache.write_text(txt, encoding="utf-8")
    return txt


def cmd_export_html(env, out_path, standalone=False):
    import json
    import datetime
    model = _html_model(env)
    # </script> 在嵌入 JSON 裡會提早關閉 <script> 標籤破壞整頁 → 轉義 </(標準作法)
    data = json.dumps(model, ensure_ascii=False).replace("</", "<\\/")
    stamp = datetime.date.today().isoformat()
    html = _HTML_TEMPLATE.replace("__DATA__", data).replace("__STAMP__", stamp) \
                         .replace("__VAULT__", env.vault.name) \
                         .replace("__NC__", str(len(model["nodes"]))) \
                         .replace("__EC__", str(len(model["edges"])))
    if standalone:
        # inline cytoscape/marked(去 CDN,防火牆/離線可開);字體退化系統字(移除 google link)
        vendor = Path(__file__).resolve().parent / "vendor"
        for name, (url, tag) in _VIZ_LIBS.items():
            try:
                src = _fetch_text(url, vendor / f"{name}.min.js").replace("</script", "<\\/script")
            except Exception as e:
                print(f"ERROR: --standalone 需抓 {name}(此機需一次網路): {e}", file=sys.stderr)
                return 2
            html = html.replace(tag, f"<script>{src}</script>")
        html = html.replace(_FONT_LINKS, "<!-- standalone: 字體退化系統字(無外部 CDN) -->")
    Path(out_path).write_text(html, encoding="utf-8")
    mode = "standalone(自包含/離線可開)" if standalone else "CDN"
    print(f"✓ export html [{mode}]: {out_path}  ({len(model['nodes'])} 節點 / {len(model['edges'])} 邊)")
    return 0


# ═══════════════════════ 階段三: 寫側 T1(行級手術) ═══════════════════════

SCALAR_KEYS = {"status", "updated", "created", "type", "self_audit"}
LIST_KEYS = {"verified_by", "plan_refs", "related", "tags"}
DATE_KEYS = {"updated", "created", "date", "decided", "ended"}
DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")


def fm_structure(fm_lines):
    """回傳 ordered [(key, start, end, kind)]，kind ∈ scalar/list/block。
    end = 該 key 區塊最後一行的 index(含)。"""
    out = []
    i, n = 0, len(fm_lines)
    while i < n:
        m = TOP_KEY_RE.match(fm_lines[i])
        if not m:
            i += 1
            continue
        key, val = m.group(1), m.group(2).strip()
        start = i
        if val in ("|", "|-", ">", ">-"):
            i += 1
            while i < n and (fm_lines[i].startswith("  ") or not fm_lines[i].strip()):
                i += 1
            out.append((key, start, i - 1, "block"))
        elif val == "":
            # 消費所有縮排行(含 list item 的 sub-mapping,如 decisions 的 content/decided),
            # 與 parse_frontmatter 一致 → fm_structure 算出的 end 涵蓋整個區塊(BUG-5 對齊)
            i += 1
            while i < n and (fm_lines[i].startswith(" ") or not fm_lines[i].strip()):
                i += 1
            out.append((key, start, i - 1, "list"))
        else:
            out.append((key, start, start, "scalar"))
            i += 1
    return out


def fmt_scalar(key, value):
    """純量值格式化。日期 bare(不加引號避污染指紋);含 ': ' 或特殊字元才引號。"""
    v = value.strip()
    if key in DATE_KEYS:
        if not DATE_RE.match(v):
            raise ValueError(f"{key} 需 YYYY-MM-DD,得到: {v}")
        return v  # bare,絕不加引號
    # YAML 型別劫持守衛: true/false/null/yes/no/~ 與純數字當 status 會被解析成 bool/num/null
    if v.lower() in ("true", "false", "null", "yes", "no", "on", "off", "~") or \
       re.fullmatch(r"-?\d+(\.\d+)?", v):
        return '"' + v + '"'
    if re.search(r":\s|^[\[\{>|*&!#@`]|^\s|\s$", v) or v == "":
        return '"' + v.replace('"', '\\"') + '"'
    return v


def fmt_list_item(value):
    """list 項格式化。wikilink / 含特殊字元 → 引號(鐵則1 安全:一項一行)。"""
    v = value.strip()
    if v.startswith("[[") or re.search(r":\s|^[\[\{]", v):
        return '"' + v.replace('"', '\\"') + '"'
    return v


def edit_fm_scalar(fm_lines, key, value):
    fm = list(fm_lines)
    formatted = fmt_scalar(key, value)
    struct = {k: (s, e, kind) for k, s, e, kind in fm_structure(fm)}
    if key in struct:
        s, e, kind = struct[key]
        if kind != "scalar":
            raise ValueError(f"{key} 是 {kind} 型,set 只改純量(list 用 append,巢狀用 T3)")
        fm[s] = f"{key}: {formatted}"
    else:
        # 插在開頭純量區之後(第一個 list/block key 之前,否則末尾)
        ins = len(fm)
        for k, s, e, kind in fm_structure(fm):
            if kind in ("list", "block"):
                ins = s
                break
        fm.insert(ins, f"{key}: {formatted}")
    return fm


def edit_fm_append(fm_lines, key, value):
    fm = list(fm_lines)
    item = fmt_list_item(value)
    tgt = link_target(value)
    struct = {k: (s, e, kind) for k, s, e, kind in fm_structure(fm)}
    if key in struct:
        s, e, kind = struct[key]
        if kind != "list":
            raise ValueError(f"{key} 是 {kind} 型,append 只加 list 項")
        # dedup: 精確 full-target 比對(保留路徑;非子字串、非 basename-only)
        for j in range(s + 1, e + 1):
            existing = fm[j].strip()
            if existing.startswith("-") and link_target(existing[1:]) == tgt:
                return fm  # 已存在,no-op
        # 偵測現有項縮排,否則預設 2 空格
        indent = "  "
        for j in range(s + 1, e + 1):
            if fm[j].lstrip().startswith("-"):
                indent = fm[j][:len(fm[j]) - len(fm[j].lstrip())]
                break
        # 插在最後一個非空行之後(避開區塊尾部空行,免在 list 中插出空行)
        last = e
        while last > s and not fm[last].strip():
            last -= 1
        fm.insert(last + 1, f"{indent}- {item}")
    else:
        ins = len(fm)
        fm.insert(ins, key + ":")
        fm.insert(ins + 1, f"  - {item}")
    return fm


def decisions_items(fm_lines):
    """surgical 定位 decisions[] 的每個項目行範圍(不重序列化,延伸 T1 到巢狀)。
    回傳 (block_start, block_end, [(item_start, item_end)], item_indent, sub_indent)
    或 None(無 decisions)。item_end 含,已去尾部空行。處理項目內含 nested 子清單。"""
    block = None
    for k, s, e, kind in fm_structure(fm_lines):
        if k == "decisions" and kind == "list":
            block = (s, e)
            break
    if block is None:
        return None
    s, e = block
    item_indent = None
    starts = []
    for i in range(s + 1, e + 1):
        ln = fm_lines[i]
        if not ln.strip():
            continue
        m = re.match(r"^(\s*)-\s", ln)
        if m:
            ind = len(m.group(1))
            if item_indent is None:
                item_indent = ind
            if ind == item_indent:  # 只認最淺層 dash(子清單的 dash 更深,不算項目)
                starts.append(i)
    items = []
    for idx, st in enumerate(starts):
        en = (starts[idx + 1] - 1) if idx + 1 < len(starts) else e
        while en > st and not fm_lines[en].strip():
            en -= 1
        items.append((st, en))
    sub_indent = (item_indent + 2) if item_indent is not None else 4
    return s, e, items, (item_indent or 2), sub_indent


def load_raw_for_edit(path: Path):
    """讀 raw,拒 BOM/CRLF(本 vault 慣例 LF/no-BOM,異常不靜默正規化)。
    回傳 (all_lines, fm_start, fm_end_exclusive)。fm = all_lines[1:fm_end]。"""
    raw = path.read_bytes()
    if raw.startswith(b"\xef\xbb\xbf"):
        raise ValueError("T1 不寫 BOM 檔(慣例外),請用 obsidian CLI / 先正規化")
    if b"\r\n" in raw:
        raise ValueError("此檔是 CRLF(慣例要求 LF)。Windows 常見=git autocrlf;"
                         "修:確認 .gitattributes 已套用(vault 標 eol=lf)+ `git add --renormalize .`,"
                         "或單檔 `dos2unix`。lumos 不靜默改行尾。")
    lines = raw.decode("utf-8").split("\n")
    if not lines or lines[0].strip() != "---":
        raise ValueError("無 frontmatter,T1 不處理")
    fm_end = None
    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            fm_end = i
            break
    if fm_end is None:
        raise ValueError("frontmatter 未閉合")
    return lines, 1, fm_end


def _write_lf(path: Path, text: str):
    """寫 UTF-8 / LF / no-BOM,平台無關(不靠 text mode)。vault 唯一寫入原語。
    用 write_bytes:write_text(newline=) 要 Python 3.10,違反本專案 ≥3.8。"""
    path.write_bytes(text.encode("utf-8"))


def atomic_write_verify(path: Path, new_lines, key, expected_check):
    """寫 tmp → re-parse 自驗 + lint 無新指紋 → atomic rename。任一步敗:tmp 丟棄,原檔不動。"""
    orig_fm = load_raw_for_edit(path)
    orig_lint = set(parse_frontmatter(orig_fm[0][1:orig_fm[2]])[2])
    text = "\n".join(new_lines)
    new_fm_lines = new_lines[1:]
    for i in range(1, len(new_lines)):
        if new_lines[i].strip() == "---":
            new_fm_lines = new_lines[1:i]
            break
    fields, _, new_lint = parse_frontmatter(new_fm_lines)
    if not expected_check(fields):
        raise RuntimeError(f"自驗失敗:{key} 寫入後值不符預期")
    introduced = set(new_lint) - orig_lint
    if introduced:
        raise RuntimeError("自驗失敗:引入新 frontmatter 指紋:" + "; ".join(sorted(introduced)))
    import os
    tmp = path.with_suffix(path.suffix + ".lumos-tmp")
    try:
        _write_lf(tmp, text)
        os.replace(tmp, path)
    finally:
        if tmp.exists():
            tmp.unlink()


def cmd_set(env, rel, key, value):
    if key not in SCALAR_KEYS:
        print(f"ERROR: set 白名單={sorted(SCALAR_KEYS)};{key} 不在內"
              f"(list 用 append;decisions 翻盤/新增用 decision-supersede / decision-add)", file=sys.stderr)
        return 2
    path = env.vault / rel
    lines, s, e = load_raw_for_edit(path)
    new_fm = edit_fm_scalar(lines[1:e], key, value)
    new_lines = lines[:1] + new_fm + lines[e:]
    exp = fmt_scalar(key, value)
    exp_val = strip_quotes(exp)
    atomic_write_verify(path, new_lines, key,
                        lambda f: str(f.get(key, "")) == exp_val)
    print(f"✓ set {rel}: {key} = {exp}")
    return 0


def cmd_self_audit(env, rel, model="sonnet", date=None):
    """L4 自足性審計留痕:寫 self_audit: <model>/<date> 到節點 frontmatter。
    語意:這整篇節點的「自足性」(無主對話脈絡的乾淨 agent 只讀圖譜能不能還原
    專案現況)已由一個獨立 agent 審過並通過。對應 guard audit 的角色(乾淨 agent
    審後蓋戳),但程式路徑獨立——這是節點級戳記,guard audit 是行級 [audit:]。
    工具只記留痕,不證明審計真乾淨——派 agent 的乾淨脈絡/中立 prompt 靠主對話誠實。"""
    import datetime
    if date is None:
        date = datetime.date.today().isoformat()
    else:
        try:
            datetime.date.fromisoformat(date)
        except ValueError:
            print(f"ERROR: --date 須為 YYYY-MM-DD:{date!r}", file=sys.stderr)
            return 2
    return cmd_set(env, rel, "self_audit", f"{model}/{date}")


def cmd_append(env, rel, key, value):
    if key not in LIST_KEYS:
        print(f"ERROR: append 白名單={sorted(LIST_KEYS)};{key} 不在內", file=sys.stderr)
        return 2
    path = env.vault / rel
    lines, s, e = load_raw_for_edit(path)
    new_fm = edit_fm_append(lines[1:e], key, value)
    new_lines = lines[:1] + new_fm + lines[e:]
    tgt = link_target(value)
    atomic_write_verify(path, new_lines, key,
                        lambda f: any(link_target(x) == tgt for x in as_list(f.get(key))))
    print(f"✓ append {rel}: {key} += {value}")
    return 0


def _fm_of(all_lines):
    """從完整檔行抽 frontmatter 行(供 decision 自驗用 parse_decisions 重解)。"""
    for i in range(1, len(all_lines)):
        if all_lines[i].strip() == "---":
            return all_lines[1:i]
    return all_lines[1:]


def _fmt_decision_value(v):
    """decision 子欄位值格式化(含 ': ' 或特殊字元 → 引號,避鐵則 3)。"""
    v = v.strip()
    if re.search(r":\s|^[\[\{>|*&!#@`\"']|^\s|\s$", v) or v == "":
        return '"' + v.replace('"', '\\"') + '"'
    return v


def cmd_decision_supersede(env, rel, match, by, ended=None):
    """T3 巢狀手術:把 decisions[] 中 content 含 match 的決策標 valid:false + 補
    superseded_by/ended。surgical line-based(不重序列化,最小 diff;優於 ruamel reflow)。"""
    if ended and not DATE_RE.match(ended):
        raise ValueError(f"--ended 需 YYYY-MM-DD,得到: {ended}")
    path = env.vault / rel
    lines, s_fm, e_fm = load_raw_for_edit(path)
    fm = lines[1:e_fm]
    loc = decisions_items(fm)
    if loc is None:
        raise ValueError("此筆記無 decisions")
    if not loc[2]:  # block 存在但解析不到項目(Bug2:0-indent / 非標準縮排)
        raise ValueError("decisions 區塊解析不到項目(本工具要求 2-space 縮排,不支援 0-indent/tab)")
    _, _, items, _, sub = loc
    needle = nfc(match)
    target = None
    for (st, en) in items:
        if needle in nfc("\n".join(fm[st:en + 1])):
            target = (st, en)
            break
    if target is None:
        raise ValueError(f"找不到 content 含「{match}」的決策")
    st, en = target
    pad = " " * sub
    valid_line = None
    for i in range(st, en + 1):
        if re.match(rf"^{pad}valid:\s", fm[i]):   # 只認精確 sub_indent(Bug5:移除過寬 fallback,免誤命中子清單)
            valid_line = i
            break
    if valid_line is None:
        raise ValueError("該決策無 valid 欄位(或縮排非標準 2-space),T3 不自動 supersede(請手動 / 確認結構)")
    # Bug3: 已 superseded 不重插(免重複鍵)。同 sub_indent 已有 superseded_by → 拒
    for i in range(st, en + 1):
        if re.match(rf"^{pad}superseded_by:\s", fm[i]):
            raise ValueError("該決策已有 superseded_by(已翻盤過),不重複 supersede;要改取代者請手動編輯")
    fm[valid_line] = f"{pad}valid: false"
    ins = [f"{pad}superseded_by: {_fmt_decision_value(by)}"]
    if ended:
        ins.append(f"{pad}ended: {ended}")
    fm[valid_line + 1:valid_line + 1] = ins
    new_lines = lines[:1] + fm + lines[e_fm:]

    def _check(_fields):
        for d in parse_decisions(_fm_of(new_lines)):
            if needle in nfc(str(d.get("content", ""))):
                return str(d.get("valid", "")).lower() == "false" and "superseded_by" in d
        return False
    atomic_write_verify(path, new_lines, "decisions", _check)
    print(f"✓ supersede {rel}: 決策「{match[:30]}」→ valid:false + superseded_by")
    return 0


def cmd_decision_add(env, rel, content, decided, context=None, why=None):
    """T3 巢狀手術:append 一條新 ADR 決策到 decisions[](無則建)。surgical line-based。"""
    if not DATE_RE.match(decided):
        raise ValueError(f"--decided 需 YYYY-MM-DD,得到: {decided}")
    path = env.vault / rel
    lines, s_fm, e_fm = load_raw_for_edit(path)
    fm = lines[1:e_fm]
    loc = decisions_items(fm)
    if loc is None:
        # 無 decisions key → 在 fm 末尾建
        item_indent, sub = 2, 4
        block = [f'{" "*item_indent}- content: {_fmt_decision_value(content)}']
        if context:
            block.append(f'{" "*sub}context: {_fmt_decision_value(context)}')
        if why:
            block.append(f'{" "*sub}why_chosen: {_fmt_decision_value(why)}')
        block += [f"{' '*sub}decided: {decided}", f"{' '*sub}valid: true"]
        fm = fm + ["decisions:"] + block
    else:
        _, e_block, items, item_indent, sub = loc
        ip, sp = " " * item_indent, " " * sub
        block = [f"{ip}- content: {_fmt_decision_value(content)}"]
        if context:
            block.append(f"{sp}context: {_fmt_decision_value(context)}")
        if why:
            block.append(f"{sp}why_chosen: {_fmt_decision_value(why)}")
        block += [f"{sp}decided: {decided}", f"{sp}valid: true"]
        last = items[-1][1] if items else e_block
        fm[last + 1:last + 1] = block
    new_lines = lines[:1] + fm + lines[e_fm:]
    needle = nfc(content)

    def _check(_fields):
        return any(needle in nfc(str(d.get("content", "")))
                   for d in parse_decisions(_fm_of(new_lines)))
    atomic_write_verify(path, new_lines, "decisions", _check)
    print(f"✓ decision-add {rel}: 「{content[:30]}」(valid:true)")
    return 0


TEMPLATES = {
    "system": ("Systems", "type: system\nstatus: doing\ncreated: {today}\nupdated: {today}\n"
               "tags:\n  - type/system\n  - status/doing\nsummary: |-\n  FLOW:\n  KEY:\n  DEP:\n  TEST:"),
    "verification": ("Verification", "type: verification\nstatus: pass\ndate: {today}\n"
                     "valid_under:\nrevalidate_when:\ntags:\n  - type/verification\n  - status/pass"),
    "issue": ("Issues", "type: issue\nstatus: open\ncreated: {today}\nupdated: {today}\n"
              "tags:\n  - type/issue\n  - status/open\nsummary: |-\n  FLAG:\n  DECISION:\n  KEY:"),
    "project": ("Projects", "type: project\nstatus: doing\ncreated: {today}\nupdated: {today}\n"
                "tags:\n  - type/project\n  - status/doing"),
}

# new 後印出的「寫入當下教學」:符號行怎麼填 + 合約鏈,讓正確格式在執行 CLI 的此刻就在 context。
NEW_HINT = {
    "system": [
        "填 summary 符號行: FLOW:<流程 a→b→c>  KEY:<關鍵概念/欄位>  DEP:[[依賴模組]]  TEST:<測試狀態>",
        "合約用 KEY 行前綴: ★INVARIANT★=業務合約(改=breaking),必綁 [test:測試名] 再經獨立 [audit:];★DEBT★=偶然可改",
        "  └ 綁定別手寫: lumos guard bind <node> \"<KEY子字串>\" <測試名> / guard audit <node> \"<KEY子字串>\"",
        "可逆性: 不可逆動作(prod遷移/上架)標 ★IRREVERSIBLE★ + [rollback:decisions];改了難救標 ★CHECKPOINT★;外部不可逆(信已送/下游已消費)改用 [guard:decisions] 記冪等鍵/核可閘([guard:] 僅對 ★IRREVERSIBLE★ 生效;屬可逆性軸,與 lumos guard bind 的合約軸正交)",
        "組合覆蓋: 最重的鐵則(金額/權限/不可逆)在 ★INVARIANT★ 之後標 ★COMBO★ → doctor Check K 軟提醒補組合測試(別只測 happy-path)",
    ],
    "issue": [
        "填 summary 符號行: FLAG:<TECHNICAL/DECISION/ORIGIN>  DECISION:<決策簡述>  KEY:<關鍵發現>",
    ],
    "verification": [
        "填 valid_under:<此驗證在什麼前提下成立>  revalidate_when:<改到什麼時該重驗>",
        "從對應 Systems 用 verified_by 回掛本篇(或 lumos sync-verified-by 補);summary 可選 TEST:/VERIFY:",
    ],
    "project": [
        "計劃節點: 落地的 Verification 用 plan_refs 回指本節點(意圖鏈,doctor Check 4 把關)",
    ],
}


def cmd_new(env, ntype, name, today):
    if ntype not in TEMPLATES:
        print(f"ERROR: type 須為 {sorted(TEMPLATES)}", file=sys.stderr)
        return 2
    if "/" in name or "\\" in name or ".." in name or name.startswith("."):
        print(f"ERROR: name 不得含路徑分隔符 / .. / 開頭點(防路徑逃脫): {name}", file=sys.stderr)
        return 2
    folder, tmpl = TEMPLATES[ntype]
    path = env.vault / folder / f"{name}.md"
    if path.exists():
        print(f"ERROR: 已存在: {path}", file=sys.stderr)
        return 2
    path.parent.mkdir(parents=True, exist_ok=True)
    fm = tmpl.format(today=today)
    _write_lf(path, f"---\n{fm}\n---\n# {name}\n")
    print(f"✓ new {ntype}: {path.relative_to(env.vault)}")
    for line in NEW_HINT.get(ntype, []):
        print(f"  {line}")
    print(f"  寫完跑 lumos lint {name}(單檔快檢標籤/格式)→ 全圖再 lumos doctor;完整規範見 lumos-project-notes skill")
    return 0


# ═══════════════════════ 階段三: archive(lumos 自做,單遍) ═══════════════════════

ARCHIVABLE = {"pass", "done", "superseded"}


def cmd_archive(env, days, apply, today):
    import os
    import datetime
    cutoff = (datetime.date.fromisoformat(today) - datetime.timedelta(days=days)).isoformat()

    # 「活守衛護欄」:一份 Verification 若還在提到某條 ★INVARIANT★ 綁定、且該測試仍存在於 code 的守衛,
    # 它的有效性是 CI 每次真機跑出來證明的、不是日曆決定的 → 不按年齡歸檔(否則把還在跑綠的守衛證據
    # 降級進 Archive,等於歸檔規則[天數]凌駕有效性規則[CI 綠燈])。守衛若被刪(測試不在 code)則照舊可歸檔。
    repo_root = None
    for p in env.vault.parents:
        if p.name == "docs":
            repo_root = p.parent
            break
    live_guard_tests = set()
    guard_re = None
    if repo_root is not None:
        # 多平台感知:每 invariant 依平台前綴解析,對其平台 root+profile 的 method set 判存活。
        # 收「存活的裸方法名」(非帶前綴的 ref)——guard_re 要在 Verification 文字裡搜方法名。
        _, split, default, methods_for, _hay = _platform_test_index(repo_root)
        for _n in env.notes.values():
            invs, _ = extract_contracts(_n)
            for inv in invs:
                try:
                    for plat, name in resolve_test_refs(inv, split, default):
                        if name in methods_for(plat):
                            live_guard_tests.add(name)
                except ValueError:
                    continue   # 未定義平台前綴:非有效綁定,不護
        if live_guard_tests:
            # 精確度對齊 Check T:用【詞界】比對方法名,不是 raw 子字串。
            # 否則短/前綴名(live `Pay` 命中散文 "Payment"、`Foo` 命中 `FooBar`)會
            # 假性護住無關 Verification → 它們永遠不歸檔(歸檔靜默失效)。
            # re.ASCII:方法名是 ASCII 識別字;否則 Python \b 視 CJK 為 \w,
            # 「守衛Pay跑」(中文緊貼方法名無空格)→ \b 不成立 → 漏護(under-protection,更危險)。
            guard_re = re.compile(r"\b(?:" + "|".join(map(re.escape, live_guard_tests)) + r")\b",
                                  re.ASCII)
    guards_all_dead = repo_root is not None and not live_guard_tests and any(
        invariant_test_refs(inv)
        for _n in env.notes.values() for inv in extract_contracts(_n)[0])

    cands = []       # (rel, stem, ym)
    protected = []   # (rel, [backs...]):早於 cutoff 但仍背書存活守衛
    for rel, n in sorted(env.notes.items()):
        if not rel.startswith("Verification/") or "/Archive/" in rel:
            continue
        if str(n.fields.get("status", "")) not in ARCHIVABLE:
            continue
        datestr = str(n.fields.get("created") or n.fields.get("date") or "")[:10]
        if not DATE_RE.match(datestr) or datestr > cutoff:
            continue
        # 活守衛護欄:這篇是否【詞界】提到任一條「測試仍存在」的綁定名 → 是則保留不歸檔
        if guard_re is not None:
            try:
                raw = (env.vault / rel).read_text(encoding="utf-8-sig")
            except Exception:
                raw = ""
            backs = sorted(set(guard_re.findall(raw)))
            if backs:
                protected.append((rel, backs))
                continue
        cands.append((rel, n.stem, datestr[:7]))

    print(f"lumos archive — vault: {env.vault}")
    print(f"  cutoff: {cutoff} (--days {days})  mode: {'APPLY' if apply else 'DRY-RUN(--apply 真執行)'}")
    if repo_root is None:
        print("  ⚠ 無法定位 repo root → 活守衛護欄停用(本次純按年齡歸檔)")
    if guards_all_dead:
        print("  ⚠ ★INVARIANT★ 綁定的測試都不在 code(守衛已刪/裸合約)→ 活守衛護欄本次停用"
              "(0 受護 ≠ 全部都能放心歸檔)")
    if protected:
        print(f"  活守衛護欄:{len(protected)} 篇早於 cutoff 但仍背書存活守衛(綁定測試還在 code)→ 保留不歸檔")
        for rel, backs in protected:
            print(f"      • {rel}  (backs: {', '.join(backs)})")
    print()
    if not cands:
        print("  無符合條件的 Verification(status∈{pass,done,superseded} 且早於 cutoff;已扣除活守衛護欄保留者)")
        return 0

    moved_stems = {stem for _, stem, _ in cands}
    # 計算每個被移檔的 path 式入連結(body + frontmatter 字串一起,raw text 掃)
    rewrite_plan = defaultdict(list)  # rel → [stem,...] 該檔內要正規化的 path 式連結
    for rel, n in env.notes.items():
        try:
            text = (env.vault / rel).read_text(encoding="utf-8-sig")
        except Exception:
            continue
        for stem in moved_stems:
            if re.search(r"\[\[Verification/" + re.escape(stem) + r"(?=[\]|#])", text):
                rewrite_plan[rel].append(stem)

    print(f"  將歸檔 {len(cands)} 篇:")
    for rel, stem, ym in cands:
        print(f"    • {rel} → Verification/Archive/{ym}/{stem}.md")
    n_links = sum(len(v) for v in rewrite_plan.values())
    print(f"\n  path 式入連結正規化(→ basename): {n_links} 處,分佈 {len(rewrite_plan)} 檔")
    for rel, stems in sorted(rewrite_plan.items()):
        print(f"    • {rel}: {', '.join(stems)}")
    if not apply:
        print("\n  (DRY-RUN,未動檔。basename 式入連結不受影響=移檔不斷)")
        return 0

    # 1) 先正規化連結(檔案還在原位)。順序=先 rewrite 後移檔:若中途失敗,
    #    已 rewrite 未移檔的檔其 basename 連結仍解析得到(檔還在 Verification/),狀態良性;
    #    且 re-run archive 會跳過已正規化的(無 path 式可改)只補移檔 → 可重入恢復。
    rewritten = 0  # 實際改寫處數(非計畫數;CRLF 跳過時不灌水,GAP-4)
    for rel, stems in sorted(rewrite_plan.items()):
        p = env.vault / rel
        raw = p.read_bytes()
        if raw.startswith(b"\xef\xbb\xbf") or b"\r\n" in raw:
            print(f"  ⚠ 跳過 rewrite(BOM/CRLF 慣例外,不靜默正規化): {rel}", file=sys.stderr)
            continue
        text = raw.decode("utf-8")
        for stem in stems:
            text, n_sub = re.subn(r"\[\[Verification/" + re.escape(stem) + r"(?=[\]|#])",
                                  "[[" + stem, text)
            rewritten += n_sub
        tmp = p.with_suffix(p.suffix + ".lumos-tmp")
        try:
            _write_lf(tmp, text)
            os.replace(tmp, p)
        finally:
            if tmp.exists():
                tmp.unlink()
    # 2) 移檔
    moved = 0
    for rel, stem, ym in cands:
        src = env.vault / rel
        dst_dir = env.vault / "Verification" / "Archive" / ym
        dst_dir.mkdir(parents=True, exist_ok=True)
        dst = dst_dir / f"{stem}.md"
        if dst.exists():
            print(f"  ⚠ 跳過(目標已存在): {dst}", file=sys.stderr)
            continue
        os.replace(src, dst)
        moved += 1
    print(f"\n  ✓ 歸檔 {moved} 篇,正規化 {rewritten} 處連結(計畫 {n_links})")
    return 0


# ═══════════════════════ main ═══════════════════════

def cmd_install(force=False):
    """全域 lumos + user-scope skills(機器層一鍵)。Unix=symlink、Win=.cmd shim。"""
    import os
    src = Path(__file__).resolve()
    bindir = Path.home() / ".local" / "bin"
    bindir.mkdir(parents=True, exist_ok=True)
    if _IS_WIN:
        shim = bindir / "lumos.cmd"
        shim.write_text(f'@echo off\r\npython "{src}" %*\r\n', encoding="utf-8")
        print(f"✓ 安裝: {shim} → python {src}")
    else:
        dst = bindir / "lumos"
        if dst.is_symlink() and dst.resolve() == src:
            print(f"✓ 已安裝(symlink 正確): {dst} → {src}")
        elif dst.exists() or dst.is_symlink():
            if not force:
                cur = str(dst.resolve()) if dst.is_symlink() else "(一般檔案)"
                print(f"⚠ {dst} 已存在(→ {cur}),加 --force 覆寫", file=sys.stderr)
                return 2
            dst.unlink(); dst.symlink_to(src); print(f"✓ 覆寫安裝: {dst} → {src}")
        else:
            dst.symlink_to(src); print(f"✓ 安裝: {dst} → {src}")
    # 連帶裝 skills(r2-F1:機器層一鍵)
    print("裝 user-scope skills…")
    _install_skills()
    # PATH 檢查(r1-F7:用 os.pathsep,Windows 是 ;)
    if str(bindir) not in os.environ.get("PATH", "").split(os.pathsep):
        hint = (f'  Windows:把 {bindir} 加進使用者 PATH(系統環境變數)'
                if _IS_WIN else f'  export PATH="$HOME/.local/bin:$PATH"')
        print(f"⚠ {bindir} 不在當前 PATH —\n{hint}", file=sys.stderr)
    else:
        print(f"  {bindir} 已在 PATH — 任何專案打 `lumos doctor` 即可")
    return 0


def cmd_uninstall():
    """對稱移除 cmd_install 裝的東西:全域指令(Unix symlink / Win lumos.cmd)+ user-scope skills。"""
    import os, shutil
    removed = []
    bindir = Path.home() / ".local" / "bin"
    for name in ("lumos.cmd", "lumos"):          # Win shim + Unix symlink
        g = bindir / name
        if g.is_symlink():
            removed.append(f"{g}(symlink → {g.resolve()})"); g.unlink()
        elif g.exists():
            removed.append(str(g)); g.unlink()
    sk = Path.home() / ".claude" / "skills"      # 對稱 _install_skills:junction/symlink/複製夾都清
    for s in _SKILLS:
        d = sk / s
        if d.is_symlink():
            d.unlink(); removed.append(str(d))
        elif d.is_dir():
            try:
                os.rmdir(d)                       # junction/空夾:只移連結本身,不跟進 target(同 W4)
            except OSError:
                shutil.rmtree(d, ignore_errors=True)
            removed.append(str(d))
    if removed:
        print("✓ 移除:\n  " + "\n  ".join(removed))
    else:
        print("✓ 未安裝(無全域 lumos / skills)")
    return 0


def cmd_deinit(keep_graph=False, dry_run=False, yes=False, source=None):
    """專案層反安裝(對稱 cmd_init):拆本 repo 的 pre-commit 閘 / vendored 工具組 /
    CLAUDE.md 注入區塊 /(預設)圖譜 vault。不碰機器共用項(~/.claude)。不自動 commit。"""
    import subprocess
    # root 走 git toplevel;非 git 目錄中止(不 fallback cwd——deinit 會刪檔)
    try:
        root = Path(subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], text=True,
            stderr=subprocess.DEVNULL).strip())
    except Exception:
        print("ERROR: 非 git 目錄,deinit 需可靠 repo root(不 fallback cwd)", file=sys.stderr)
        return 2
    # pre-flight 守衛①:來源 repo 自我保護(對齊 cmd_update 的 root==src → return 2)
    src = _lumos_src(source)
    if root.resolve() == src.resolve():
        print("ERROR: 當前就是 Lumos 來源本身,deinit 拒絕執行", file=sys.stderr)
        return 2
    vault = _vault_in(root)
    # pre-flight 守衛②:vault == root 鐵閘(防 rmtree 整個 repo)
    if vault is not None and vault.resolve() == root.resolve() and not keep_graph:
        keep_graph = True
        print("⚠ 偵測到 standalone vault(圖譜=repo 根):強制保留圖譜,只拆其餘專案層。",
              file=sys.stderr)
    will_delete_vault = (vault is not None) and (not keep_graph)
    installed = _deinit_detect_installed(root)
    has_claude = _claude_block_present(root)
    if not installed and not will_delete_vault and not has_claude:
        print("✓ 未安裝(此 repo 無 Lumos 專案層)")
        return 0
    if dry_run:
        print("lumos deinit --dry-run(僅預演,不改動):")
        print(f"  root: {root}")
        print("  拆閘: git config --unset core.hooksPath" if installed
              else "  拆閘: (core.hooksPath 未設,略)")
        if has_claude:
            print("  剝 CLAUDE.md graph-discipline 區塊")
        if will_delete_vault:
            n = len([f for f in vault.rglob("*") if f.is_file()])
            print(f"  刪圖譜 vault: {vault}({n} 檔)")
        elif vault is not None:
            print(f"  保留圖譜 vault: {vault}")
        print("  移除 vendored 工具組(白名單:5 檔 + hooks/templates 兩夾)")
        return 0
    if will_delete_vault and not yes:
        if not sys.stdin.isatty():
            print("ERROR: 非互動環境(stdin 非 tty)且未加 --yes,拒絕刪圖譜。加 --yes 確認。",
                  file=sys.stderr)
            return 2
        files = [f for f in vault.rglob("*") if f.is_file()]
        dirty = subprocess.run(["git", "-C", str(root), "status", "--porcelain", str(vault)],
                               capture_output=True, text=True).stdout
        n_dirty = len([ln for ln in dirty.splitlines() if ln.strip()])
        print(f"將刪除圖譜 vault: {vault}({len(files)} 檔)")
        if n_dirty:
            print(f"  ⚠ 其中 {n_dirty} 個未 commit — 刪了 git 救不回!")
        try:
            ans = input("確定刪除?輸入 y 繼續、其他取消: ").strip().lower()
        except EOFError:
            # isatty() 在某些終端/Windows 回 True 但 stdin 其實 EOF → 讀不到確認。
            # 破壞性操作安全預設:拒刪(對齊上面非互動 rc2)。
            print("ERROR: 讀不到確認輸入(stdin EOF),拒絕刪圖譜。加 --yes 確認。", file=sys.stderr)
            return 2
        if ans != "y":
            print("已取消。")
            return 1
    # ── 固定順序執行(pre-flight 已過)──
    _deinit_unbar_gate(root)                 # step 1 先拆閘
    _deinit_strip_claude(root)               # step 2 剝 CLAUDE.md 區塊
    if will_delete_vault:                    # step 3 刪圖譜(pre-flight + 安全網已過)
        import shutil
        shutil.rmtree(vault)
    _deinit_remove_vendored(root)            # step 4 最後移 vendored(可能含自己)
    print("✓ deinit 完成(專案層已移除)。檢視 `git diff` 後自行 commit。")
    return 0


def _deinit_unbar_gate(root: Path) -> int:
    """拆 pre-commit 閘:git -C root config --unset core.hooksPath。
    rc 0(已 unset)/ rc 5(key 本不存在)皆成功;其他 rc 印 warning 但不中止
    (真正保險是 step 4 會把 scripts/hooks/ 整夾刪掉,缺 hook 檔 git 自會放行)。"""
    import subprocess
    r = subprocess.run(["git", "-C", str(root), "config", "--unset", "core.hooksPath"],
                       capture_output=True, text=True)
    if r.returncode not in (0, 5):
        print(f"  ⚠ git config --unset core.hooksPath rc={r.returncode}(續行)", file=sys.stderr)
    return r.returncode


def _extract_claude_block_span(text: str):
    """定位 CLAUDE.md 中的 LUMOS:GRAPH-DISCIPLINE sentinel 區塊,回傳三態。

    回傳 (state, span):
      "found"  → span 是 BlockSpan(body, body_start, body_end);
                 body = START 行結尾 \\n 之後、END 行開頭之前的子字串,strip 首尾空行;
                 保證 text[body_start:body_end] == body。
      "absent" → (START 前綴出現 0 次 且 END 出現 0 次) → ("absent", None)
                 乾淨「沒這塊」,T2 可安全附加。
      "broken" → 只 START 沒 END / 只 END 沒 START / END 在 START 前 /
                 START 前綴出現 > 1 次 → ("broken", None)
                 有殘跡但壞了,不可盲改。
    """
    start_count = 0
    idx = 0
    si = -1
    # 計算 START 前綴出現次數,同時記第一次位置
    while True:
        pos = text.find(_CLAUDE_START_PREFIX, idx)
        if pos == -1:
            break
        start_count += 1
        if start_count == 1:
            si = pos
        idx = pos + 1

    ei = text.find(_CLAUDE_END)

    has_start = start_count > 0
    has_end = ei != -1

    # absent: 兩者皆無
    if not has_start and not has_end:
        return ("absent", None)

    # broken: 只有其中一個 / 重複 START / END 在 START 前
    if start_count > 1:
        return ("broken", None)
    if has_start and not has_end:
        return ("broken", None)
    if has_end and not has_start:
        return ("broken", None)
    if ei < si:
        return ("broken", None)

    # found: si = START 行首字元;找該行結尾(含 \n)
    nl_after_start = text.find("\n", si)
    if nl_after_start == -1:
        # START 行是檔案最後一行,無換行 → 無 body
        body_raw_start = len(text)
    else:
        body_raw_start = nl_after_start + 1  # body 從 START 行下一字元開始

    # body 結束 = END 行開頭字元
    body_raw_end = ei  # text[body_raw_start:body_raw_end] 是未 strip 的 body

    raw_body = text[body_raw_start:body_raw_end]

    # strip 首尾空白行(只去掉 \n,保留內部縮排)
    stripped = raw_body.strip("\n")

    if stripped:
        # 在 raw_body 中找 stripped 的真實位移
        inner_start = raw_body.find(stripped)
        body_start = body_raw_start + inner_start
        body_end = body_start + len(stripped)
    else:
        # body 全是空白行:body 設為空字串,位移指向 body_raw_start
        body_start = body_raw_start
        body_end = body_raw_start
        stripped = ""

    return ("found", BlockSpan(body=stripped, body_start=body_start, body_end=body_end))


# Task 2 ─────────────────────────────────────────────────────────────────────
# START 行(本 task 無版本戳;T5 會在此字串中插入版本號——形式保留易替換)


def _expected_claude_body(root: Path, slug: str) -> "str | None":
    """讀 scripts/templates/graph-discipline.md,{{KG}} 替換後 strip 首尾空行 → 預期 body 字串。
    範本不存在 → None(呼叫端 skip Check D)。
    strip 用 `.strip("\\n")`(只去首尾空行、保留內縮排),與 _extract_claude_block_span 的 body
    取法一致——reinject 寫入、extract 讀回、Check D 比對三處同一算法,版本差不觸發(版本在 body 外)。"""
    tpl_path = root / "scripts" / "templates" / "graph-discipline.md"
    if not tpl_path.exists():
        return None
    return tpl_path.read_text(encoding="utf-8").replace("{{KG}}", f"docs/{slug}-knowledge/").strip("\n")



def _reinject_claude_block(root: Path, slug: str) -> "ReInjectResult":
    """讀 vendored 範本 → {{KG}} 替換 → 組 sentinel block → 依三態更新 CLAUDE.md。

    status ∈ created|updated|unchanged|appended|sentinel_broken|no_template。
    diff:僅 updated 帶 difflib.unified_diff 字串,其餘 None。
    讀入時正規化 CRLF→LF 並去 BOM;寫入一律 _write_lf(強制 LF / 無 BOM)。
    """
    import difflib

    # 1. 範本 + body(共用 _expected_claude_body 確保 Check D 比對算法一致)
    body = _expected_claude_body(root, slug)
    if body is None:
        return ReInjectResult("no_template", None)

    # 3. 組 block(START 行帶當前版本戳,機械插值——版本在 body 外,不影響 Check D 比對)
    start_line = _START_TEMPLATE.format(version=LUMOS_VERSION)
    block = start_line + "\n" + body + "\n" + _CLAUDE_END

    # 4. 讀 CLAUDE.md(去 BOM + CRLF 正規化)
    cm = root / "CLAUDE.md"
    if cm.exists():
        raw = cm.read_bytes()
        # 去 UTF-8 BOM
        if raw.startswith(b"\xef\xbb\xbf"):
            raw = raw[3:]
        claude_text = raw.decode("utf-8").replace("\r\n", "\n").replace("\r", "\n")
    else:
        claude_text = None

    # 5. 三態分派
    if claude_text is None:
        # CLAUDE.md 不存在 → created
        _write_lf(cm, "# CLAUDE.md\n\n" + block + "\n")
        return ReInjectResult("created", None)

    state, span = _extract_claude_block_span(claude_text)

    if state == "broken":
        return ReInjectResult("sentinel_broken", None)

    if state == "absent":
        # 有 CLAUDE.md 但無 sentinel → appended
        new_text = claude_text.rstrip() + "\n\n" + block + "\n"
        _write_lf(cm, new_text)
        return ReInjectResult("appended", None)

    # state == "found": splice body only (保留 sentinel 行)
    old_body = span.body
    new_body = body

    if old_body == new_body:
        return ReInjectResult("unchanged", None)

    # 有差 → 替換 body 區段
    new_text = claude_text[:span.body_start] + new_body + claude_text[span.body_end:]
    _write_lf(cm, new_text)

    diff = "".join(difflib.unified_diff(
        old_body.splitlines(keepends=True),
        new_body.splitlines(keepends=True),
        fromfile="old body",
        tofile="new body",
    ))
    return ReInjectResult("updated", diff)


def _deinit_strip_claude(root: Path) -> bool:
    """剝 CLAUDE.md 的 LUMOS:GRAPH-DISCIPLINE 區塊;其餘內容/整個檔都留。
    無檔或無 START 標記 → no-op 回 False(對稱注入端 scripts/lumos:3175 的存在性 gating)。"""
    cm = root / "CLAUDE.md"
    if not cm.exists():
        return False
    text = cm.read_text(encoding="utf-8")
    start_marker = "<!-- LUMOS:GRAPH-DISCIPLINE:START"
    end_marker = "LUMOS:GRAPH-DISCIPLINE:END -->"
    si = text.find(start_marker)
    ei = text.find(end_marker)
    if si == -1 or ei == -1 or ei < si:
        return False
    ei += len(end_marker)
    new = (text[:si].rstrip() + "\n" + text[ei:].lstrip()).strip()
    _write_lf(cm, (new + "\n") if new else "")
    return True


def _deinit_remove_vendored(root: Path) -> list:
    """白名單移除 vendored 工具組:① _VENDORED_TOOLKIT 固定 5 檔;
    ② scripts/hooks/、scripts/templates/ 整夾遞迴刪(Lumos-owned,不靠 src 列舉)。
    scripts/ 底下使用者自有檔不碰;scripts/ 空了才 rmdir。回傳已移除相對路徑列表。"""
    import shutil
    removed = []
    for rel in _VENDORED_TOOLKIT:
        p = root / rel
        if p.exists():
            p.unlink(); removed.append(rel)
    for d in ("scripts/hooks", "scripts/templates"):
        p = root / d
        if p.is_dir():
            shutil.rmtree(p); removed.append(d + "/")
    sc = root / "scripts"
    if sc.is_dir() and not any(sc.iterdir()):
        sc.rmdir(); removed.append("scripts/")
    return removed


def _deinit_detect_installed(root: Path) -> bool:
    """target repo root 是否有專案層安裝痕跡:core.hooksPath 有值 或 scripts/hooks/ 存在。
    不靠 scripts/lumos 自身存在(執行檔與'此 repo 是否裝過'無關)。"""
    import subprocess
    hp = subprocess.run(["git", "-C", str(root), "config", "core.hooksPath"],
                        capture_output=True, text=True)
    if hp.returncode == 0 and hp.stdout.strip():
        return True
    return (root / "scripts" / "hooks").is_dir()


def _claude_block_present(root: Path) -> bool:
    cm = root / "CLAUDE.md"
    return cm.exists() and "LUMOS:GRAPH-DISCIPLINE:START" in cm.read_text(encoding="utf-8")


def _lumos_src(source=None):
    """解析 Lumos 唯一源 repo 路徑:--source > $LUMOS_HOME > ~/harness/lumos-toolchain。"""
    import os
    return Path(source or os.environ.get("LUMOS_HOME")
                or (Path.home() / "harness" / "lumos-toolchain")).expanduser()


# ── Task 5: 版本 parse + nudge ───────────────────────────────────────────────

def _parse_sentinel_version(claude_text: str) -> "str | None":
    """從 CLAUDE.md 文字中找 START sentinel 行,空格切分取形如 vX.Y 的欄位。
    取不到(無 START / START 行無版本欄位) → None;不 crash。"""
    _ver_re = re.compile(r"\bv\d+\.\d+\b")
    for line in claude_text.splitlines():
        if _CLAUDE_START_PREFIX in line:
            # START 行存在,掃各 token 找 vX.Y
            for token in line.split():
                if _ver_re.fullmatch(token):
                    return token
            # START 行存在但無版本欄位 → None
            return None
    return None


def _version_nudge(root: Path) -> "str | None":
    """比對本專案 CLAUDE.md sentinel 版本 vs 來源 clone 的 LUMOS_VERSION。

    - 來源 clone 不存在/不可達 → None(靜默 skip;CI 無來源 clone 不誤報)。
    - CLAUDE 版本 < 來源版本(字串不等且 CLAUDE 較舊) → 軟提示字串。
    - 相等 / CLAUDE 較新 / 任一取不到 → None。
    """
    # 1. 讀 CLAUDE.md sentinel 版本
    cm = root / "CLAUDE.md"
    if not cm.exists():
        return None
    try:
        claude_text = cm.read_bytes()
        if claude_text.startswith(b"\xef\xbb\xbf"):
            claude_text = claude_text[3:]
        claude_text = claude_text.decode("utf-8").replace("\r\n", "\n").replace("\r", "\n")
    except OSError:
        return None
    claude_ver = _parse_sentinel_version(claude_text)
    if claude_ver is None:
        return None

    # 2. 讀來源 clone 的 LUMOS_VERSION(文字 grep,不 import 避免副作用)
    src = _lumos_src()
    src_lumos = src / "scripts" / "lumos"
    if not src_lumos.exists():
        return None  # 來源不可達 → 靜默 skip
    try:
        _ver_pat = re.compile(r'^LUMOS_VERSION\s*=\s*"(v\d+\.\d+)"', re.MULTILINE)
        src_text = src_lumos.read_text(encoding="utf-8", errors="replace")
        m = _ver_pat.search(src_text)
        if not m:
            return None
        src_ver = m.group(1)
    except OSError:
        return None

    # 3. 比對:CLAUDE 版本 < 來源版本 → nudge(簡單字串不等判準;版本是 advisory)
    if claude_ver == src_ver:
        return None
    # 嘗試 tuple 比對(vMAJOR.MINOR → (MAJOR, MINOR));取不到就用字串不等
    def _ver_tuple(s):
        try:
            parts = s.lstrip("v").split(".")
            return tuple(int(x) for x in parts)
        except (ValueError, AttributeError):
            return None
    ct = _ver_tuple(claude_ver)
    st = _ver_tuple(src_ver)
    if ct is not None and st is not None and ct >= st:
        return None  # CLAUDE 版本 ≥ 來源,不 nudge
    # CLAUDE 落後(或無法比較)→ 提示
    return (
        f"本專案紀律區塊版本 {claude_ver} 落後來源 {src_ver},"
        f" 可跑 lumos update 刷新"
    )


# vendored 工具組白名單(固定 5 檔,scripts/ 前綴;hooks/templates 兩夾另走整夾刪)。
# _vendor_toolchain 安裝端與 cmd_deinit 移除端共用,避免漂移。
_VENDORED_TOOLKIT = ("scripts/lumos", "scripts/test_lumos.py",
                     "scripts/merge-claude-settings.py", "scripts/graph-rename.sh",
                     "scripts/fetch-notesmd.sh")


def _vendor_toolchain(src, root, slug, no_pull=False):
    """從 Lumos 來源 src vendor 工具組到專案 root(python 單一源 scaffold + hooks + 結尾自癒)。
    回傳 0;來源無效回傳 None。圖譜資料受 _scaffold_project 的 skip 保護不被動。
    cmd_update / cmd_init(--with-hooks) 共用。"""
    import subprocess, shutil, filecmp
    installer = src / "scripts" / "install-graph-toolchain.sh"  # 仍作來源有效性探針(薄殼亦在)
    if not installer.exists():
        print(f"ERROR: 找不到 Lumos 來源 {src}（無 scripts/install-graph-toolchain.sh）\n"
              f"  用 --source <path> 指定、設 $LUMOS_HOME、或 clone 到 ~/harness/lumos-toolchain",
              file=sys.stderr)
        return None
    if not no_pull:
        if (src / ".git").is_dir():
            print("  git pull 來源(取最新工具組)…")
            if subprocess.run(["git", "-C", str(src), "pull", "--ff-only"]).returncode != 0:
                print("  ⚠ git pull 失敗(無 remote / 非 ff),用現有來源繼續", file=sys.stderr)
        else:
            print("  (來源非 git repo,跳過 pull)")
    # 安裝邏輯收進 python 單一源(scaffold + hooks);bash 安裝器僅留薄殼。
    _scaffold_project(root, slug)
    _install_hooks_py(root)
    rc = 0
    # 結尾 diff 自癒:python 端逐檔比對 src↔target,差異即補(可安全覆寫)。
    toolkit = list(_VENDORED_TOOLKIT)
    for sub in ("scripts/hooks", "scripts/templates"):
        base = src / sub
        if base.is_dir():
            toolkit += [str(p.relative_to(src)) for p in base.rglob("*") if p.is_file()]
    healed = []
    for rel in toolkit:
        s, t = src / rel, root / rel
        if not s.exists():
            continue
        if (not t.exists()) or not filecmp.cmp(s, t, shallow=False):
            t.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(s, t)
            if s.stat().st_mode & 0o111:
                t.chmod(t.stat().st_mode | 0o111)
            healed.append(rel)
    if healed:
        print(f"  結尾自癒:補齊 installer 漏的 {len(healed)} 檔 → {', '.join(healed)}")
    else:
        print("  ✓ 結尾自癒檢查:工具組完全對齊(無漏)")
    # 範本已是最新(copy2 迴圈完成) → reinject CLAUDE.md 紀律區塊
    ri = _reinject_claude_block(root, slug)
    if ri.status == "updated":
        print("  CLAUDE.md 紀律區塊已更新")
        if ri.diff:
            for line in ri.diff.splitlines()[:20]:  # 最多印 20 行 diff 摘要
                print(f"    {line}")
    elif ri.status in ("created", "appended"):
        print(f"  CLAUDE.md 紀律區塊已注入({ri.status})")
    elif ri.status == "sentinel_broken":
        print("  ⚠ CLAUDE.md sentinel 半壞,未自動覆蓋,請檢查", file=sys.stderr)
    # unchanged / no_template → 靜默
    return rc


def cmd_update(source=None, no_pull=False):
    """從 Lumos 唯一源 repo 更新「本專案」vendored 的工具組。
    = (git pull Lumos) + install-graph-toolchain --target <本專案> --slug <自動偵測>。
    圖譜資料受 install-graph-toolchain 的 scaffold-skip 保護,不會被動。"""
    src = _lumos_src(source)
    vault = find_vault(Path.cwd())
    if vault is None:
        print("ERROR: 當前目錄找不到 docs/*-knowledge 專案 vault", file=sys.stderr)
        return 2
    root = vault.parent.parent  # docs/<slug>-knowledge → docs → 專案 root
    slug = vault.name[:-len("-knowledge")] if vault.name.endswith("-knowledge") else vault.name
    if root.resolve() == src.resolve():
        print("ERROR: 當前就是 Lumos 來源本身,不需 update", file=sys.stderr)
        return 2
    print(f"lumos update — 來源 {src} → 本專案 {root}（slug={slug}）")
    rc = _vendor_toolchain(src, root, slug, no_pull=no_pull)
    return 2 if rc is None else rc


_SKILLS = ("lumos-project-notes", "lumos-core-knowledge", "lumos-design-loop")  # 同 install.sh:28


def _link_or_copy(src: Path, dst: Path):
    """src→dst:Unix symlink、Win 目錄 junction、失敗 fallback 複製。src 須為目錄。"""
    import os, shutil, subprocess
    # W4:Windows junction 不被 is_symlink() 認出。舊碼 rmtree(dst) 會「跟進」junction 刪掉
    # 來源 target;且重跑時 junction 殘留 → mklink 報已存在 → 不冪等。改:junction/空夾用
    # os.rmdir(只移連結本身、不碰 target),真實非空夾才 rmtree。
    if dst.is_symlink():
        dst.unlink()                                  # Unix symlink
    elif dst.is_dir():
        try:
            os.rmdir(dst)                             # junction 或空夾:只移連結/夾,不跟進 target
        except OSError:
            shutil.rmtree(dst, ignore_errors=True)    # 真實非空夾(上次 fallback 複製過)
    elif dst.exists():
        dst.unlink()
    dst.parent.mkdir(parents=True, exist_ok=True)
    try:
        if _IS_WIN:
            # W2:mklink 輸出走 OEM 碼頁(繁中=cp950),text=True 預設 UTF-8 解碼會在
            # reader thread 炸 UnicodeDecodeError。errors="replace" 防炸,returncode 仍可靠。
            r = subprocess.run(["cmd", "/c", "mklink", "/J", str(dst), str(src)],
                               capture_output=True, text=True, encoding="utf-8", errors="replace")
            if r.returncode != 0:
                raise OSError(r.stderr)
        else:
            dst.symlink_to(src)
    except OSError:
        shutil.copytree(src, dst, dirs_exist_ok=True)  # Python ≥ 3.8
        print(f"  ⚠ 連結失敗,改複製(失去 git pull 即更新): {dst}")


def _install_skills():
    repo = Path(__file__).resolve().parent.parent
    dest = Path.home() / ".claude" / "skills"
    for s in _SKILLS:
        src = repo / "skills" / s
        if src.is_dir():
            _link_or_copy(src, dest / s)
            print(f"  ✓ skill {s}")


_INIT_SUBDIRS_FULL = ("Systems", "Verification", "Projects", "Issues", "Sessions", "MOC")


def _scaffold_project(root: Path, slug: str):
    kg = root / "docs" / f"{slug}-knowledge"
    if kg.exists():
        print(f"  ✓ vault 已存在,跳過 scaffold(保護資料): {kg}")
        return
    for d in _INIT_SUBDIRS_FULL:
        (kg / d).mkdir(parents=True, exist_ok=True)
    _write_lf(kg / "MOC" / "index.md",
              f"---\ntype: moc\nstatus: doing\n---\n# {slug} 知識圖譜總索引\n")
    _write_lf(kg / ".gitignore",
              ".bypass-log.jsonl\n.rot-queue.jsonl\n.governance-log.jsonl\n.canary-log.jsonl\n")
    print(f"  ✓ scaffold {kg}")


def _install_hooks_py(root: Path):
    import subprocess, shutil
    # ① git config core.hooksPath
    subprocess.run(["git", "-C", str(root), "config", "core.hooksPath", "scripts/hooks"])
    # ② 複製 Claude hooks 到 ~/.claude/hooks/(個別 .py 一律 copy,不用 junction:mklink /J 只連目錄)
    chooks = Path.home() / ".claude" / "hooks"
    chooks.mkdir(parents=True, exist_ok=True)
    src_dir = root / "scripts" / "hooks" / "claude"
    for f in ("check-graph-sync.py", "verification-rot-check.py", "impact-hook.py", "code-loop-guard.py"):
        s = src_dir / f
        if s.exists():
            shutil.copy2(s, chooks / f)
    # ③ settings.json 註冊(Task 3 改 merge-claude-settings.py 用 resolved python)
    merge = root / "scripts" / "merge-claude-settings.py"
    if merge.exists():
        subprocess.run([sys.executable, str(merge)])
    print("  ✓ hooks:core.hooksPath + Claude hooks 複製 + settings 註冊")


def cmd_bootstrap(lumos_url=None, lumos_home=None, pull=False):
    """一鍵在專案內裝好一切:自動 clone Lumos(若缺)→ user-scope skills → 全域 lumos → repo hooks。
    給「剛 clone 專案、機器還沒設定」的同事:cd 進專案打 `python3 scripts/lumos bootstrap` 即可,
    連 Lumos 都不用先手動 clone(專案自帶 vendored lumos 來跑這個)。
    --pull:既有 Lumos clone 也 git pull 拉最新(否則已存在就沿用,拿不到 skills 更新)。"""
    import os, subprocess
    home = Path(lumos_home or os.environ.get("LUMOS_HOME")
                or (Path.home() / "harness" / "lumos-toolchain")).expanduser()
    url = lumos_url or os.environ.get("LUMOS_URL") or "https://github.com/EnzoHsieh-Android/Lumos"
    # 1) 確保 Lumos 來源在(缺則自動 clone;--pull 則既有 clone 也拉最新)
    if (home / "install.sh").exists():
        if pull:
            print(f"[1/3] Lumos 來源已在,git pull 更新: {home}")
            if subprocess.run(["git", "-C", str(home), "pull", "--ff-only"]).returncode != 0:
                print(f"WARN: git pull 失敗(來源有本機改動?),沿用現有 clone", file=sys.stderr)
        else:
            print(f"[1/3] Lumos 來源已在: {home}（--pull 可拉最新 skills）")
    else:
        print(f"[1/3] clone Lumos → {home} …")
        home.parent.mkdir(parents=True, exist_ok=True)
        if subprocess.run(["git", "clone", url, str(home)]).returncode != 0:
            print(f"ERROR: clone 失敗。手動 `git clone {url} {home}` 後重試", file=sys.stderr)
            return 2
    # 2) 全域 lumos → 指向 Lumos 來源(非 vendored copy);install --force 已連帶裝 user-scope skills
    print("[2/3] 裝全域 lumos(+ user-scope skills)…")
    subprocess.run([sys.executable, str(home / "scripts" / "lumos"), "install", "--force"])
    # 3) 本 repo hooks(git toplevel)
    try:
        root = Path(subprocess.check_output(["git", "rev-parse", "--show-toplevel"], text=True).strip())
    except Exception:
        root = Path.cwd()
    if (root / "scripts" / "merge-claude-settings.py").exists():
        print(f"[3/3] 裝 repo hooks（{root}）…")
        _install_hooks_py(root)
    else:
        print(f"[3/3] ⚠ {root} 無 vendored 工具組(找不到 scripts/merge-claude-settings.py),跳過 hooks", file=sys.stderr)
    print("\n✓ bootstrap 完成。最後一步:**重啟 Claude Code session**(L1/L3 hooks 要 session start 才載入)。")
    return 0


def _slugify_vault(name: str):
    """repo basename → vault slug:小寫、非英數轉 -、收斂連續 -、去頭尾 -、去既有 -knowledge 尾。"""
    s = re.sub(r"[^a-z0-9]+", "-", name.lower()).strip("-")
    if s.endswith("-knowledge"):
        s = s[:-len("-knowledge")]
    return s or "project"


def cmd_init(name=None, force=False, with_hooks=True, no_pull=False):
    """在當前 repo 初始化知識圖譜:建 docs/<slug>-knowledge/{6 個資料夾} + .gitignore,
    預設並 vendor 工具組 + 裝 pre-commit/pre-push 閘(--no-hooks 只建圖譜輕量版)。
    像 `openspec init`:一行開好就能 `lumos new`。
    分工:init = 專案層(圖譜 + 該 repo 的 hooks);bootstrap = 機器層(clone Lumos/skills/全域 lumos),一輩子一次。
    序列(既有 vault 非 force):只 _reinject_claude_block(讀本機已 vendor 範本,不 pull、不重裝 hooks)→ early-return。
    序列(新 vault 或 --force):_vendor_toolchain(pull + copy2 + hooks + reinject) → scaffold → 完成。
    no_hooks 路徑(不分新/既有):只 _reinject_claude_block(讀本機已 vendor 範本,無則靜默)。"""
    import subprocess
    try:
        root = Path(subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], text=True, stderr=subprocess.DEVNULL).strip())
    except Exception:
        root = Path.cwd()
    existing = _vault_in(root)
    # slug 決定順序:① --name 顯式 ② 既有 vault 的 slug ③ repo basename。
    # ②必須先於③:否則既有 vault 上跑 --force 會用 repo basename 當 slug,
    # 建錯一個空 vault + 把 CLAUDE.md {{KG}} 路徑寫錯(現場事故:basename landmarkmember
    # vs 既有 vault landmark-knowledge)。既有 vault 的資料夾名即權威 slug,不重新 slugify。
    if name:
        slug = _slugify_vault(name)
    elif existing is not None and existing.name.endswith("-knowledge"):
        slug = existing.name[:-len("-knowledge")]
    else:
        slug = _slugify_vault(root.name)

    # ── Step 1: reinject CLAUDE.md(依路徑輕/重分流)─────────────────────
    # 既有 vault 非 force:只 reinject(輕量);不 pull、不重裝 hooks。
    # 新 vault 或 --force:完整 _vendor_toolchain(pull + copy2 + hooks + reinject)。
    # no_hooks 路徑:一律只 reinject(讀本機已 vendor 範本,無則靜默)。
    def _do_reinject():
        ri = _reinject_claude_block(root, slug)
        if ri.status == "updated":
            print("  CLAUDE.md 紀律區塊已更新")
        elif ri.status in ("created", "appended"):
            print(f"  CLAUDE.md 紀律區塊已注入({ri.status})")
        elif ri.status == "sentinel_broken":
            print("  ⚠ CLAUDE.md sentinel 半壞,未自動覆蓋,請檢查", file=sys.stderr)
        # unchanged / no_template → 靜默

    if with_hooks:
        src = _lumos_src()
        if root.resolve() == src.resolve():
            print("\n  (當前就是 Lumos 來源本身,跳過 vendor/hooks)")
        elif existing is not None and not force:
            # 既有 vault 非 force:輕量路徑,只刷新 CLAUDE.md 紀律區塊
            _do_reinject()
        else:
            # 新 vault 或 --force:完整 vendor(pull + copy2 + hooks + reinject)
            print(f"lumos init — 在 {root} 建圖譜 vault: docs/{slug}-knowledge/")
            print("\n裝 hooks:vendor 工具組 + 啟用 pre-commit/pre-push 閘…")
            rc = _vendor_toolchain(src, root, slug, no_pull=no_pull)
            # _vendor_toolchain 已呼叫 _install_hooks_py + _reinject_claude_block;不重複
            if rc is None:
                print("  ⚠ 來源不可用,略過 hooks(圖譜已建好)。日後補裝:lumos update")
    else:
        # no_hooks:讀本機 vendored 範本執行 reinject(無範本 → no_template → 靜默)
        _do_reinject()

    # ── Step 2: existing/force 判定 ───────────────────────────────────
    if existing is not None and not force:
        print(f"✓ 此 repo 已有 vault: {existing.relative_to(root)}")
        print("  (要另建用 --name <slug>;要在既有 vault 上重裝/更新 hooks 與工具組用 --force,vault 內容不動)")
        return 0

    # ── Step 3: scaffold 圖譜資料(新 vault;既有 vault 內部 kg.exists() guard 保護) ──
    if not with_hooks:
        print(f"lumos init — 在 {root} 建圖譜 vault: docs/{slug}-knowledge/")
    _scaffold_project(root, slug)  # 6 夾 + .gitignore + MOC/index.md;既有 vault 自動 skip 保護資料

    print("\n✓ init 完成。開始用:")
    print(f"    cd {root}")
    print("    lumos new system <模組名>     # 建第一個系統節點")
    print("    lumos doctor                  # 健檢")
    if with_hooks:
        print("  (已裝 pre-commit/pre-push 閘:改 code 沒更新圖譜會被擋)")
    return 0


def _vault_in(d: Path):
    """d 之下是否有 vault: docs/*-knowledge 或 docs/knowledge(專案佈局),
    或 d 本身就是 vault root(standalone,如核心 repo:有 MOC/ + Verification|Systems)。"""
    docs = d / "docs"
    if docs.is_dir():
        for sub in sorted(docs.iterdir()):
            if sub.is_dir() and sub.name.endswith("-knowledge"):
                return sub
        if (docs / "knowledge").is_dir():
            return docs / "knowledge"
    # standalone vault root(核心 repo 等):MOC/ + (Verification/ 或 Systems/)
    if (d / "MOC").is_dir() and ((d / "Verification").is_dir() or (d / "Systems").is_dir()):
        return d
    return None


def find_vault(start: Path):
    """從 cwd 往上走找 vault(全域安裝後可從任何專案子目錄跑)。"""
    start = start.resolve()
    for d in [start, *start.parents]:
        v = _vault_in(d)
        if v is not None:
            return v
        if (d / ".git").exists():  # 到 repo 根還沒找到就停(別爬出專案)
            break
    return None



ANCHOR_FILES = [
    "scripts/test_lumos.py",
    "scripts/test_autonomous_loop.py",
    "scripts/hooks/pre-commit",
    "scripts/hooks/pre-push",
    "scripts/hooks/post-commit",
]
_ANCHOR_BASELINE_REL = "governance/anchor-baseline.json"


def _anchor_repo_root(repo):
    """--repo 顯式優先;省略時 cwd 逐層向上找 .git(同 refcheck 慣例)。失敗印錯回 None。"""
    if repo is not None:
        p = Path(repo)
        if not p.is_dir():
            print(f"ERROR: --repo 不是目錄: {repo}", file=sys.stderr)
            return None
        return p
    for cand in (Path.cwd(), *Path.cwd().parents):
        if (cand / ".git").exists():
            return cand
    print("ERROR: cwd 逐層向上找不到 .git repo,請用 --repo 指定", file=sys.stderr)
    return None


def cmd_anchor_verify(repo=None, as_json=False):
    """錨點完整性核對:baseline 內每個錨點檔算 sha256 比對。
    全符 rc=0;mismatch/缺檔 rc=1;baseline 不存在 rc=0+警示(漸進採用);參數錯 rc=2。
    只證「驗證器檔案沒被動過」,不證測試本身寫得對(spec 誠實天花板)。"""
    import json
    import hashlib
    repo_root = _anchor_repo_root(repo)
    if repo_root is None:
        return 2
    bp = repo_root / _ANCHOR_BASELINE_REL
    if not bp.exists():
        print("anchor: baseline 不存在(未啟用)——`lumos anchor approve --note` 建立後生效")
        return 0
    try:
        data = json.loads(bp.read_text(encoding="utf-8"))
    except (OSError, ValueError) as e:
        print(f"ERROR: baseline 讀取失敗: {e}", file=sys.stderr)
        return 2
    mismatches = []
    for rel, expected in sorted(data.get("anchors", {}).items()):
        f = repo_root / rel
        if not f.is_file():
            mismatches.append({"file": rel, "expected": expected, "actual": "(缺檔)"})
            continue
        actual = hashlib.sha256(f.read_bytes()).hexdigest()
        if actual != expected:
            mismatches.append({"file": rel, "expected": expected, "actual": actual})
    if as_json:
        print(json.dumps({"ok": not mismatches, "mismatches": mismatches}, ensure_ascii=False))
    elif mismatches:
        print("✗ anchor verify 失敗——驗證器檔案與 baseline 不符:")
        for m in mismatches:
            act = m["actual"] if m["actual"] == "(缺檔)" else m["actual"][:16] + "…"
            print(f"  {m['file']}(期望 {m['expected'][:16]}… 實際 {act})")
        print("非刻意 → git checkout 還原;刻意改錨點 → lumos anchor approve --note \"理由\"")
    else:
        print(f"✓ anchor verify — {len(data.get('anchors', {}))} 個錨點全符")
    return 1 if mismatches else 0


def cmd_anchor_approve(repo=None, note=None, vault=None):
    """重算全部錨點 sha256 寫回 baseline + governance-log 留痕(anchor-approve 事件)。
    改錨點檔的唯一合法路徑;--note 必填(空理由=無資訊留痕)。"""
    import json
    import hashlib
    import datetime
    if not note or not note.strip():
        print("ERROR: --note 必填(留痕理由)", file=sys.stderr)
        return 2
    repo_root = _anchor_repo_root(repo)
    if repo_root is None:
        return 2
    anchors, absent = {}, []
    for rel in ANCHOR_FILES:
        f = repo_root / rel
        if f.is_file():
            anchors[rel] = hashlib.sha256(f.read_bytes()).hexdigest()
        else:
            absent.append(rel)
    if absent:
        print(f"⚠ 錨點檔缺失(不入 baseline): {', '.join(absent)}")
    bp = repo_root / _ANCHOR_BASELINE_REL
    prev = {}
    if bp.exists():
        try:
            prev = json.loads(bp.read_text(encoding="utf-8")).get("anchors", {})
        except (OSError, ValueError):
            prev = {}
    changed = sorted({k for k in anchors if anchors[k] != prev.get(k)} | (set(prev) - set(anchors)))
    bp.parent.mkdir(parents=True, exist_ok=True)
    payload = {"version": 1, "anchors": anchors,
               "approved_at": datetime.datetime.now().astimezone().isoformat(timespec="seconds"),
               "note": note}
    bp.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    v = vault or find_vault(Path.cwd())
    if v is None:
        print("⚠ 無 vault:baseline 已寫,governance-log 留痕跳過")
    else:
        _append_governance_log(v, [{"gate": "anchor-approve", "kind": "approved",
                                    "hard": False, "nodes": changed, "note": note}])
    print(f"✓ anchor approve — {len(anchors)} 個錨點寫入 baseline({len(changed)} 個變更)")
    return 0


def _refcheck_scan(text, repo_root):
    """refcheck 抽取+核對核心(不列印):回 (claims, n_missing, n_oor, n_ok)。
    cmd_refcheck 與 loop status --gate(G1 錨)共用;抽取規則見 cmd_refcheck docstring。"""
    top_dirs = {p.name for p in repo_root.iterdir() if p.is_dir() and not p.name.startswith(".")}
    _suffix_re = re.compile(r":([^/]+)$")
    spans = [s.strip("`") for s in INLINE_CODE_RE.findall(FENCE_RE.sub("", text))]
    seen = set()
    claims = []
    for raw in spans:
        if "://" in raw or any(c in raw for c in "*<>?"):
            continue
        m = _suffix_re.search(raw)
        if m:
            token, sfx = raw[:m.start()], m.group(1)
            line = sfx if re.fullmatch(r"\d+(?:-\d+)?", sfx) else ""
        else:
            token, line = raw, ""
        if "/" not in token or (token, line) in seen:
            continue
        if token.split("/")[0] not in top_dirs:
            continue
        seen.add((token, line))
        target = repo_root / token
        if not target.exists():
            claims.append({"token": token, "line": line, "status": "missing", "excerpt": ""})
            continue
        if target.is_dir():
            claims.append({"token": token, "line": line, "status": "ok", "excerpt": "", "dir": True})
            continue
        if not line:
            claims.append({"token": token, "line": line, "status": "ok", "excerpt": ""})
            continue
        if "-" in line:
            lo, hi = (int(x) for x in line.split("-", 1))
        else:
            lo = hi = int(line)
        try:
            file_lines = target.read_text(encoding="utf-8-sig", errors="replace").splitlines()
        except OSError:
            file_lines = None
        if file_lines is None or lo < 1 or hi > len(file_lines):
            claims.append({"token": token, "line": line, "status": "line_out_of_range", "excerpt": ""})
            continue
        if lo == hi:
            excerpt = file_lines[lo - 1]
        else:
            excerpt = file_lines[lo - 1] + "\n…\n" + file_lines[hi - 1]
        claims.append({"token": token, "line": line, "status": "ok", "excerpt": excerpt})

    n_missing = sum(1 for c in claims if c["status"] == "missing")
    n_oor = sum(1 for c in claims if c["status"] == "line_out_of_range")
    n_ok = sum(1 for c in claims if c["status"] == "ok")
    return claims, n_missing, n_oor, n_ok


PITFALL_CLASSES = {
    "payment": [r"金流", r"payment", r"stripe", r"billing", r"退款", r"refund", r"扣款"],
    "external-send": [r"寄送", r"送出", r"\bsend\b", r"webhook", r"notify", r"LINE 推送", r"\bmail\b", r"簡訊", r"對外"],
