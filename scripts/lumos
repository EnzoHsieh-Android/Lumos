// ---- 時間軸:按節點日期回放圖譜生長 ----
const tt=document.getElementById('timetoggle');tt.classList.remove('on');tt.classList.add('off');
const tb=document.getElementById('timebar'),tr=document.getElementById('trange'),
      td=document.getElementById('tdate'),tp=document.getElementById('tplay');
const dates=[...new Set(DATA.nodes.map(n=>n.dnum).filter(d=>d>0))].sort((a,b)=>a-b);
let playTimer=null;
function fmtd(d){const s=String(d);return s.slice(0,4)+'-'+s.slice(4,6)+'-'+s.slice(6,8);}
function setCut(i){
